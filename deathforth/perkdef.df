\ Moving Arq's BTTW down here 
\ For compatibility reasons, i.e Kensai/Ranger/etc using the main_events slot 

\ Not remotely ideal. But in future, traits will be better designed to avoid this 

: run_swing_logic args( chara thing ) 
		<- chara .perk@ "Kensai" $= if 
			STAT_STRENGTH <- thing .character@ .effstat -0.05 * 1 + 0.6 1 clamp <- thing .cooldown@ * <- thing .cooldown! 
				\ weapondef{ <- thing .wielded sel cooldown@ } print 
				\ <- thing .cooldown@ print 
				\ "IT WORKS!" print 
		then 
		
		<- chara .perk@ "Ranger" $= if 
			1.5 <- thing .cooldown@ * <- thing .cooldown!
		then 
;

: run_throw_logic args( chara thing ) 
	<- chara .perk@ "Chairmaster" $= if
		<- thing .carryid@ 0 = not if 
			invisible_blowup
			<- thing .carryid@ lt .weapon_state.val! 

				<- thing .carryid@ #thing .hitpoints@ 3 + <- thing .carryid@ #thing .hitpoints!
		then
	then 
; 

: run_shoot_logic args( chara thing ) 
	
	<- chara .perk@ "Ranger" $= if 
		0.7 <- thing .cooldown@ * <- thing .cooldown! 
	then
	
	<- chara .perk@ "The Big Shot" $= if 
		weapondef{ <- thing .wielded sel projectiles@ } 2 < weapondef{ <- thing .wielded sel shell_count@ } 1 = or if 
				
		\	1 <- thing modify_bullet_bigshot ' timer_add 
		\ stomach : no longer necessary 
		
		then
			
		<- thing .cooldown@ 1.3 * <- thing .cooldown! 
	then 
;

: run_onhit_logic args( chara thing )

	<- chara .perk@ "Duelist" $= if 
		<- thing .pos <- thing .just_hit_id@ #thing .pos xysub xymag weapondef{ <- thing .wielded sel melee_range@ } - 5 - 5 - print 
			<- thing .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if
				<- thing .pos <- thing .just_hit_id@ #thing .pos xysub xymag weapondef{ <- thing .wielded sel melee_range@ } - 5 - 5 - >int 10.89 > if 
				\ First, find the distance from the hit target. subtract thinglee range, player and zomb rad. if we are left at 11 or more, we 
				\ must have hit near the tip. award extra damage 
				
				<- thing .fatigue@ 7 - 0 127 clamp <- thing .fatigue! \ Reward with stamina recovery. 
				
					\ Normal functionality, i.e non-scepter code
					<- thing .pos <- thing .just_hit_id@ #thing .pos xysub xynorm -6 xymul <- thing .just_hit_id@ #thing .vel! 
					50 %chance if 
						-3 <- thing .just_hit_id@ #thing .vel.z! 
					else
						3 <- thing .just_hit_id@ #thing .vel.z! 
					then 
					
					<- thing .just_hit_id@ #thing .pos xyblast 
					weapondef{ <- thing .wielded sel power@ } 2 / lt .hitcheck.power!
					4 lt .hitcheck.rad!
					-1 lt .hitcheck.blast! 
					\ 5 lt .hitcheck.knockback! 
					
					5 6 rnd for
					<- thing .just_hit_id@ #thing .pos
						particle{
							new pos!
							15 ticks! } 
						
						<- thing .pos <- thing .just_hit_id@ #thing .pos xysub xyangle 140 220 frnd + particle{ angle! } 
						
						particle{	
							glowy
							0.8 grow!
							11 fade_out!
							particles_base_id 0x 51 + spriteid!
							angle@ anglexy 2 3 frnd xymul vel! 
							pos@ angle@ anglexy 8.5 xymul xyadd pos!
							\ gathingticks angle!
							1 scale!
							0 1 1 rgb!
						}
					next 
					
						sfx{ zelda 0 d! 0 a! } 
					then 
				then
			then 
;

// Arq back to the wall
: backwall-main-events over .thing@ args( chara eventid thing )
	<- chara .party@ 0?;
	<- eventid MAIN_EVENT_DRIVING_START = if
		<- chara bow-perk-regen <- chara pyro-perk-regen
	then;
	<- eventid MAIN_EVENT_CYOA_END = if
		THING_EVENT_WAS_HIT <- chara MAIN_EVENT_MISSION_CHARACTER_THING_EVENT over .main_events@ execute // manually execute code to proc the event
	then;
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> ?;
	
	THING_EVENT_SWING ?(
		<- chara <- thing run_swing_logic
	);
	
	THING_EVENT_SHOOT ?( 
		<- chara <- thing run_shoot_logic
	); 
	
	THING_EVENT_THROW ?( 
		<- chara <- thing run_throw_logic
	); 
	
	THING_EVENT_DID_HIT ?( 
		<- chara <- thing run_onhit_logic
	); 
	
	THING_EVENT_WAS_HIT ?(
		<- chara .dead? ?; // skip below if dead
		<- chara .health@ 1 = 0?; // got hit, so see if health is 1
		// bonuses?
		<- chara .speed_bonus@ 0 > ?; // if the buff is already active, dont apply it again
		<- chara
			0.15 over .speed_bonus!
			1 STAT_STRENGTH 2 pick .bonus+
			1 STAT_FITNESS 2 pick .bonus+
			1 STAT_SHOOTING 2 pick .bonus+
		drop
		mission? if
			RED "MY BACK'S TO THE WALL!" .. <- thing .yellmsglong // indicator that ability was activated
			// maybe put a deck of multiple lines here?
		else
			($ ICON_UP textclr$ .. <- chara .name@ .. " feels " .. <- chara xhis .. " back against a wall!!!" .. 0 textclr$ $)
			blurbevent ICON_UP blurbicon <- chara character# road{ charid } blurb-last-to-cyoa
		then
	);
	THING_EVENT_OVERLAP ?(
		<- thing .overlap .events@ weapondef{ ' healcloud-handler v= } 0?; // if player uses heal spray, delete bonuses
		<- chara .speed_bonus@ 0 = ?; // ability wasn't active, so don't apply debuff
		<- chara
			0 over .speed_bonus!
			-1 STAT_STRENGTH 2 pick .bonus+
			-1 STAT_FITNESS 2 pick .bonus+
			-1 STAT_SHOOTING 2 pick .bonus+
		drop
		// maybe an indicator here as well?
	);
	drop
;
: backwalltrait args( chara )
	"BACK TO THE WALL APPLIED ON CHAR " type <- chara .name@ print
	// boring <- chara .wits! boring <- chara .attitude! boring <- chara .composure!
	' backwall-main-events <- chara .main_events!
	
	\ Note to self: do something about this... 
	
	WEAPON_SWITCHBLADE <- chara .trademarkwep 
	// tm wep?
;
: .backwall? .main_events@ ' backwall-main-events v= ;
: backwall-manual-check args( chara )
	// mission? 0?; // is the game in the mission?
	// <- chara .location@ LOCATION_MISSION = 0?; // is the character in the mission?
	<- chara .backwall? if // do they have the trait?
		THING_EVENT_WAS_HIT <- chara MAIN_EVENT_MISSION_CHARACTER_THING_EVENT over .main_events@ execute // manually execute code to proc the event
	then
;
: backwall-manual-check-foreach ' backwall-manual-check foreach-team-char ;





} 

// Definitions

: defperks init

	// Perks
	"Mechanic" $perk
		($ "The car is life! Note: Not necessarily a COMPETENT mechanic.
		+ Start with a wrench
		" .. mechaniclevel $) $desc
		' mechanicperk applyword
		
	"Athlete" $perk
		($ "An athletic past translates well into zombie survival.
		+ Start with a random sports weapon
		" .. athletelevel $) $desc
		' athleteperk applyword
		
	"Fighter" $perk
		($ "This person has always been a real fighter.
		+ Start with a hatchet
		" .. fighterlevel $) $desc
		' fighterperk applyword
		
	"Surgeon" $perk
		($ "Has a good intuition of anatomy and a real steady hand.
		+ Start with a scalpel
		" .. surgeonlevel $) $desc
		' surgeonperk applyword
		
	"Gungineer" $perk
		($ "Good with anything mechanical, and guns are mechanical.
		+ Start with a crowbar
		" .. gungineerlevel $) $desc
		' gungineerperk applyword
		
(*	"Pistoleer" $perk
		($ "Pistols aim fast and ammo is plentiful!
		+ Start with a pistol and 30 bullets
		" .. pistollevel $) $desc
		' pistolperk applyword
		
	"Rifle Shooter" $perk
		($ "A rifle shot can pierce a line of zombies, in the right hands!
		+ Start with a rifle and 24 ammo
		" .. riflelevel $) $desc
		' rifleperk applyword
		
	"Shotgunner" $perk
		($ "Everyone knows that shotguns are the true anti-zombie weapon!
		+ Start with a shotgun and 15 shells
		" .. shotgunlevel $) $desc
		' shotgunperk applyword *)

	"Martial Artist" $perk
		($ "No weapons? No problem!
		+ Start with a powerful two-hit unarmed attack!!
		- Refuses to use firearms, chainsaws, and some others!!
		" .. martialartistlevel $) $desc
		' martialartistperk applyword		
		
	"Big Bruiser" $perk
		($ "Moves slow, hits real hard, takes a beating!
		+ Start with a better unarmed attack! Take one more hit than normal!
		- Slower walking speed!
		" .. bruiserlevel $) $desc
		' bruiserperk applyword
	
	"Gun Collector" $perk
		($ "You knew hoarding all those guns would be useful! Eventually. You just knew it!
		" .. guncrazylevel $) $desc
		' guncrazyperk applyword
	
	"Health Care" $perk
		($ "Jerks get bit by zombies all the time. Better be prepared! 
		" .. healthcarelevel $) $desc
		' healthcareperk applyword	
		
	"Car Nut" $perk
		($ "Being a car enthusiast is practically a superpower now!
		+ Start with a nicer car
		" .. carnutlevel $) $desc
		' carnutperk applyword
				
	"Megabuff" $perk
		($ "Possibly too swole to control. Handy for picking up and throwing heavy furniture!
		+ Start with a metal pipe
		" .. megabufflevel $) $desc
		' megabuffperk applyword
		
	"Ultrafit" $perk
		($ "All that yoga really paid off!
		+ Start with some granola bars
		" .. ultrafitlevel $) $desc 
		' ultrafitperk applyword
				
	"Friend of Dog" $perk
		($ "This person loves dogs, and tends to run into them!
		+ Angry dogs may become friendly
		" .. doglevel $) $desc
		' dogfriendperk applyword

	"Explorer" $perk
		($ "Some people just have a really good sense of direction when driving!
		+ Get one extra location choice during Always Be Looting events!
		" .. explorerlevel $) $desc
		' explorerperk applyword
		
	"Ex-Wrestler" $perk
		($ "Was top dog before a tragic mishap in the ring!
		+ Pick up downed zombies, then throw or slam them!
		- Large penalty to maximum shooting skill.
		" .. exwrestlerlevel $) $desc
		' exwrestlerperk applyword
		
	"Hidden Potential" $perk
		($ "Looks unassuming, but can exceed others with training!
		+ Every 2nd increase in strength or fitness also increases the maximum for that stat by 1!
		" .. hiddenpotentiallevel $) $desc
		' hiddenpotentialperk applyword
	
	"Top Seller" $perk
		($ "Good salesmanship still has its own niche!
		+ Gets 1-8 extra food when selling to a weapons buyer, depending on original price.
		+ No morale penalty when paying bandit tolls with food!
		" .. hagglerlevel $) $desc
		' hagglerperk applyword
	
	"Pathfinder" $perk
		($ "Hiking experience helps avoid forest terrors!
		+ Removes a penalty event from the 1st walking day, every time you lose the car!
		" .. pathfinderlevel $) $desc
		' pathfinderperk applyword
	
	"Trademark Weapon" $perk
		($ "Stands out from the crowd, with a signature weapon!
		+ Starts with a special weapon, depending on trait!
		- Can not drop this weapon, even in death.
		" .. trademarklevel $) $desc
		' trademarkperk applyword
		
	"Natural Shot" $perk
		($ "A natural at shooting! Just needs more training and maybe even a gun and ammo!
		" .. naturalshotlevel $) $desc
		' naturalshotperk applyword
	
	"T*S*T*C" $perk
		($ "Definitely too swole! REFUSES to do cardio!
		+ Starts at full strength!
		+ May train strength 6 times over the maximum!!!
		" .. tstclevel $) $desc
		' tstcperk applyword
		
	"Shield of Hope" $perk
		($ "Keeps going through sheer willpower!
		+ Protects against fatal hits if morale is over :(
		- Will still die to some instant-kill events.
		" .. shieldofhopelevel $) $desc
		' shieldofhopeperk applyword
		
	"Bow and Arrows" $perk
		($ "Archery ended up being a useful hobby!
		+ Start with a silent bow, 30 arrows, 2 points in strength!
		- Can not drop this bow, even in death.
		" .. archerlevel $) $desc
		' archerperk applyword
		
	"Pyromaniac" $perk
		($ "Zombies are extremely flammable!
		+ Start with a blowtorch, and protection against fire!
		- Can't drop this blowtorch, even in death.
		" .. pyrolevel $) $desc
		' pyroperk applyword
	
	// Arq new perk descriptions
	"Fierce Hitter" $perk
		($ "This person hits hard and strong. Better watch out!
		+ Gain a " .. fierce-calc .. "% chance to instantly kill any zombie with melee!
		+ 1 strength point
		- Doesn't work with default punch or when exhausted
		" .. fiercelevel $) $desc
		' fierceperk applyword
	
	"Supporter" $perk
		($ "Always here to help in a pickle!
		- Run speed penalty
		+ " .. supportlevel $) $desc
		' supportperk applyword
	
	"Jack of All Trades" $perk
		($ "Master of none, but still pretty good at things generally.
		+ " .. jackalllevel $) $desc
		' jackallperk applyword
		
		
	"Ranger" $perk
		($ "A hunter and proficient sharpshooter.
		+ 30% faster ranged weapon cooldown 
		- 50% longer cooldown on all melee swings 
		" .. rangerlevel $) $desc
		' rangerperk applyword
	"Chairmaster" $perk
		($ "Even the ground tremors in your wake!  
		+ ANY thrown objects explode on impact, dealing extra instances of damage!
		+ Thrown objects are more resilient to breaking! 
		" .. tavernlevel $) $desc
		' tavernperk applyword
	"Kensai" $perk
		($ "The archetypal 'sword-saint', a melee expert. 
		+ Gain +5% attack speed per strength level!  
		- Can't use firearms
		" .. kensailevel $) $desc
		' kensaiperk applyword		
	"Duelist" $perk
		($ "A renaissance re-enactor, or possibly just a history nerd. 
		+ Attacks that connect at the tip of your melee range deal bonus damage!
		" .. fencerlevel $) $desc
		' fencerperk applyword		
	"The Big Shot" $perk
		($ "Ego and calibre in excess. 
		+ Each shooting point buffs your ranged damage by 17%
		- 30% extra ranged cooldown!
		" .. bigshotlevel $) $desc
		' bigshotperk applyword		
		

// TEST MAX PERKS
	
	(*
	6 for

	"TEST" i .. $perk
		($ "Archery ended up being a useful hobby!
		+ Start with a silent bow, 30 arrows, 2 points in strength!
		- Can not drop this bow, even in death.
		" .. archerlevel $) $desc
		' archerperk applyword
	next
	*)
		
	// "Barbarian"
	// "Home Run Champ"
	// "Fierce"
			
	// Traits
	"Paranoid" $trait
		"A combination of high perception and extreme pessimism lets someone brace for the worst!
		+ May identify traits in new recruits
		+ Always on the lookout for danger
		- Can be a real grumpus" $desc
		' paranoidtrait applyword
	"Oblivious" $trait
		"A great outlook on life combined with not being very perceptive allows for some magical feats of denial!
		+ May ignore despair
		- Bad rolls for perception and wits" $desc
		' oblivtrait applyword
	"Charming" $trait
		"From perception of others, a good attitude, and pure charisma, there's something about this person that opens doors!
		+ Charms way into free stuff or out of bad situations
		- Can't charm way out of everything" $desc
		' charmtrait applyword
	"Irritating" $trait
		"This person thinks they're soooooo cool. But they're not! They're just annoying!
		+ Tell people to 'Cool it'
		- Anger pretty much everybody" $desc
		' gratingtrait applyword
	"Bandit" $trait
		"Being untrustworthy can be an asset in the post-apocalypse.
		+ Rip others off
		- Rip the group off
		- Ticking time bomb" $desc
		' bandittrait applyword
	"Mysterious Past" $trait
		"This person... has a mysterious past......
		+ 3 points given to fight skills at random
		- Randomized and extreme personality!" $desc
		' mysterytrait applyword
	"Practical" $trait
		"Has a variety of useful skills, but is kind of boring.
		+ 3 points given to fight skills at random
		+ 3 points given to support skills at random
		- Boring personality" $desc
		' practicaltrait applyword
	"Warrior" $trait
		"Good start on zombie thwacking skills, with a nondescript personality.
		+ 2 points more strength!
		+ 2 points more fitness!
		- Boring personality" $desc
		' warriortrait applyword
	"Fierce Tempered" $trait
		"Someone's got a bad temper! The aggression can come in handy.
		+ 1 extra point in strength
		- Bad temper due to low composure
		+ Temper can sometimes be good
		+ Gain a 5% chance to instantly kill any zombie with melee!!!" $desc
		' fiercetrait applyword
	"Calm Under Fire" $trait
		"Calm and collected. Useful when shooting into a horde!
		+ Very calm due to high composure
		+ 1 extra point in shooting" $desc
		' calmtrait applyword
	"Nurturing" $trait
		"Always thinking of others! Somehow not zombie food yet.
		+ 2 points more medical! Great Attitude
		+ Can go one over maximum for medical skill!!
		- May be an act" $desc
		' nurturetrait applyword
	"Inventive" $trait
		"Comfortable with machinery, such as cars.
		+ 2 points more mechanical!  Great wits checks!
		+ Can go one over maximum for mechanical skill!!
		- May need more practice to repair car" $desc
		' inventtrait applyword
	"Frantic Whiner" $trait
		"Kind of a fragile sort. But really good at fleeing!
		+ Run speed bonus!
		- Takes one less hit than normal
		- Bad attitude" $desc
		' frantictrait applyword
	"Resilient Type" $trait
		"Really tough! The muscle! Not a long term planner.
		+ Resist 1 damage once per event, even from bandits!
		- Bad wits rolls" $desc
		' toughtrait applyword
	"BERSERK!" $trait
		"Destroy all zombies! Never retreat! Oh no, I got bit!
		+ 4 points to strength, fitness, and shooting!!
		+ Can go one over the maximum for the above stats!!!
		- Super low personality stats! Dies in one bite!!" $desc
		' berserktrait applyword
	"Civilized" $trait
		"Retains old values before world went crazy. This is good and bad.
		+ Super high loyalty and personality stats!
		+ 1 point to medical and mechanical skills!!
		- Permanent and significant morale penalty!!" $desc
		' civiltrait applyword
	"Hyperfixated" $trait
		"An expert on one particular subject; doesn't care otherwise.
		+ High wits! 
		+ 3 points to whatever your highest non-personality stat! Random if tied between stats.
		+ Can go 3 over the maximum for this stat! 
		- Other stats capped at 3!" $desc
		' hyperfixatedtrait applyword	
	"D.I.N.K" $trait
		"All it takes is one really bad day...
		+ 3 points to each combat stat!
		+ Can go 1 over the maximum for these stats also! 
		" "- 4 morale penalty!!!" rbold .. $desc
		' dinktrait applyword
	"Craftsman" $trait
		"A former tradesperson with a deadly skillset. 
		+ 1 point in mechanical!
		+ 1 point in strength!
		+ Held weapons never break!" $desc
		' zealoustrait applyword	
\	"Big Stick Diplomacy" $trait
\		"Speak softly and obliterate your opponent with a giant weapon.  
\		+ 1 point in strength! 
\		+ Heavy melee weapons always deal extra damage! More instakills!
\		(Heavy weapons are those with high damage and cooldowns.)" $desc
\		' gwm_trait applyword		
	"Sound Sleeper" $trait
		($ "Sleeps anytime, anywhere. #1 best at sleeping!
		+ Superhuman sleeping! Needs very little sleep.
		+ Never gets the TIRED status, ever." .. soundsleep-lock $) $desc
		' soundsleeptrait applyword
	"Gourmand" $trait
		($ "Really appreciates old canned food!
		+ Eating a full meal restores 1 extra morale to you and your team! Gets an extra point of max health!
		- Eats 3 food instead of 2. Running low on food decreases morale faster!" .. gourmand-lock $) $desc
		' gourmandtrait applyword
	"City Seeker" $trait
		($ "Blessed with an interesting life!
		+ Much greater chance of finding a weird building or character in city looting events! Normal chance: 10%  With trait: 50%
		+ Doubles the chance to find Rare Trader Camps!" .. cityseek-lock $) $desc
		' cityseektrait applyword
	"Travel Light" $trait
		($ "Carry less so you can run a little faster!
		+ Run speed bonus!
		+ 1 point more in fitness!
		- Can only carry two weapons at a time!" .. travellight-lock $) $desc
		' travellighttrait applyword
	"Hero Type" $trait
		($ "I'll protect you!...sometimes.
		+ Prevents teammate death in text events once per game.
		+ Starts with 6 loyalty!
		+ Protects nearby teammates in missions for up to 3s. Charge with zomb kills!" .. herotype-lock $) $desc
		' herotypetrait applyword
	"Tiny Eater" $trait
		($ "Eats much less than normal! Takes tiny bites!
		+ A full meal only requires 1 food!!
		- Gets a 2 point penalty to maximum strength!
		- Gets a 1 point penalty to maximum fitness." .. tinyeat-lock $) $desc
		' tinyeattrait applyword	
	"Anime Fan" $trait
		($ "This is just like my zombie animes!
		+ Weapon is replaced with an overpowered Strong Katana.
		- Katana can't be dropped, even on death.
		- WARNING: Avoid getting full morale! BEWARE ANIME!" .. animefan-lock $) $desc
		' animefantrait applyword	
	"Specialist" $trait
		($ "A little too fixated on one method of zombie splatting.
		+ 2 points to strength, fitness, and shooting
		+ Can go one over the maximum for the above stats!!
		- Can only carry ONE WEAPON at a time!!" .. specialist-lock $) $desc
		' spectrait applyword
	"Grappler" $trait
		($ "If a zombie falls down, you can pick it up!
		+ Throw or slam carried zombies!
		- Boring personality" .. grappler-lock $) $desc
		' grapplertrait applyword
	"Phoenix" $trait
		($ "Literally too spicy to die.
		+ Resurrects self on death, to full health!!
		+ Immune to fire 
		+ Has hot sauce; creates rings of fire on use!
		- Only the sauce remains after revival" .. phoenix-lock $) $desc
		' phoenixtrait applyword
	"Dingus Savant" $trait
		($ "Always destined for great things! Never bothered to work for it.
		+ 2 points to medical, mechanical, shooting! Can go 1 over the maximum for these stats also!  
		- Takes 1 less hit than normal
		- 2 point penalty to max morale" .. savant-lock $) $desc
		' savanttrait applyword
	"Fast Learner" $trait
		($ "Starts low, but learns new skills fast!
		+ Gets double the amount of shooting, mechanical, and medical skill!
		- Each growth bonus stops after its skill gets to 4 points" .. fastlearn-lock $) $desc
		' fastlearntrait applyword
	"Unpredictable" $trait
		($ "This person's got a bad mood! Well, sometimes.
		+ Personality is randomized upon each new day!
		+ 2 randomly chosen stats in fight & support skills may be trained 1 over the maximum!" .. rand-lock $) $desc
		' unpredicttrait applyword
	"BACK TO THE WALL" $trait
		($ "When things are desparate, this person goes all out!
		+ Gain a bonus to strength, fitness, shooting, and run speed when at 1 health!
		- Bonuses removed when healed above 1 health" .. backwall-lock $) $desc
		' backwalltrait applyword

		
