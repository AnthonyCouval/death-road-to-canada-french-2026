: trademarklevel
	gstats{ perk-trademark } 3 >= if
		($ "+ Arme par defaut : machette solide !!" $) 2 lvl
	then;
	gstats{ perk-trademark } 2 >= if
		($ "+ Arme par defaut : 50% chance batte alu, 50% machette" .. NEXT_LEVEL .. "100% chance machette solide !" $) 1 lvl
	then;
		($ "+ Arme par defaut : batte en aluminium !" ..
		gstats{ perk-trademark } 1 < if
			($ LOCKED $) 1 lock
		else
			($ NEXT_LEVEL .. "50% chance de machette solide !" $)
		then $)
;

