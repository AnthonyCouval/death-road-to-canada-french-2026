perkdef{

(*
0 value perk-num
0 value trait-num

32 constant PERKTRAIT_MAX

: $perk
	perk-num PERKTRAIT_MAX > if abort" OUT OF PERKS!" then;
	"Allocating PERK: " over .. print $perk
	' perk-num ++
	"PERK COUNT: " perk-num .. print
;
: $trait
	trait-num PERKTRAIT_MAX > if abort" OUT OF TRAITS!" then;
	"Allocating TRAIT:" over .. print $trait
	' trait-max ++
;
*)

: boring 2 4 rnd ;
: hilow 50 %chance if 0 1 rnd else 5 6 rnd then ;

// WEAPON_ <- chara .trademarkwep
: .trademarkwep args( weapon chara )
	<- chara .perk@ "Arme de marque" $= if
		<- weapon <- chara .weapona!
		1 <- chara .weapon_nodropa!
		
		<- chara .trait@ "Hyperfixated" $= if 
			20 <- chara .stackeda! 
		then 
		
	then
;

// Arq changes to separate the main events due to Back to the Wall also using main-events
: bow-perk-regen args( chara )
	<- chara .perk@ "Bow And Arrows" $= 0?;
	WEAPON_BOW <- chara .weaponb@ = 0?;
	// no need to put Specialist check here
	<- chara .stackedb@ gstats{ perk-archer } 3 * 1+ + 30 min <- chara .stackedb!
;

: pyro-perk-regen args( chara )
	<- chara .perk@ "Pyromaniac" $= 0?;
	WEAPON_BLOWTORCH <- chara .weaponb@ = 0?;
	// no need to put Specialist check here
	<- chara .stackedb@ gstats{ perk-pyro } 2 * 2 + + 30 min <- chara .stackedb!
;
// need these since both perks give the character a main_events, but so does the trait and the trait is applied second, overwriting the first main_events
// these are put in trait main_events

// Traits

: paranoidtrait args( chara )
	"PARANOIA APPLIQUE AU PERSO " type <- chara .name@ print
	6 <- chara .wits! 0 <- chara .attitude!
	<- chara .witsREV <- chara .attitudeREV
;

: oblivtrait args( chara )
	"INCONSCIENT APPLIQUE AU PERSO " type <- chara .name@ print
	0 <- chara .wits! 6 <- chara .attitude!
	<- chara .witsREV <- chara .attitudeREV
	WEAPON_WALLOFHAM <- chara .trademarkwep
;

: bandittrait args( chara )
	"BANDIT APPLIQUE AU PERSO " type <- chara .name@ print
	0 <- chara .composure! 0 <- chara .loyalty!
	boring <- chara .wits! boring <- chara .attitude!
	<- chara .temperREV <- chara .loyaltyREV
	
	WEAPON_SWITCHBLADE <- chara .trademarkwep \ stomach 
;

: charmtrait args( chara )
	"CHARMEUR APPLIQUE AU PERSO " type <- chara .name@ print
	6 <- chara .wits! 6 <- chara .attitude!
	<- chara .witsREV <- chara .attitudeREV
	
;

: tmgrating-main-events ( teid ) args( chara eventid )
	<- chara .party@ 0= if then;
	<- eventid MAIN_EVENT_DRIVING_START = if
		WEAPON_SPORTSHORN <- chara .weapona@ = if 
			20 <- chara .stackeda!
		then;
	then;
;

: gratingtrait args( chara )
	"AGACANT APPLIQUE AU PERSOR " type <- chara .name@ print
	0 <- chara .wits! 0 <- chara .attitude!
	<- chara .witsREV <- chara .attitudeREV
	WEAPON_SPORTSHORN <- chara .trademarkwep
	<- chara .perk@ "Arme de marque" $= if
		' tmgrating-main-events <- chara .main_events!
	then
;

// Arq adding fierce crits
: fierce-calc
	gstats{ perk-fierce } case
		3 of 20 endof
		2 of 15 endof
		otherwise 10
	endcase
;
: .fierce% // args( chara )
	0
	over .trait@ "Fierce Tempered" $= if
		5 +
	then swap .perk@ "Fierce Hitter" $= 0?; // add an extra % for Fierce Hitter + Fierce Tempered, highest possible 25%
	fierce-calc +
;
(* // see mission-events-human.df for used logic
: fierce-main-events over .thing@ 0 args( chara eventid thing justhit )
	<- chara .party@ 0?;
	<- eventid MAIN_EVENT_DRIVING_START = if
		<- chara bow-perk-regen <- chara pyro-perk-regen
	then;
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> ?;
	THING_EVENT_DID_HIT ?(
		<- thing .wielded 0= <- chara .weapon_default@ 0= and ?; // don't do the below if using the weak default punch
		<- thing .just_hit_id@ #thing -> justhit // save whatever character hit into an args for easy calling
		<- justhit .zomb? 0?; // is it a zombie? if no, don't do the below
		<- chara .fierce% %chance if // % chance of procing
			0 <- justhit .hitpoints! // CRIT, KILL IT
		then
	);
	drop
;
*)
: fiercetrait args( chara )
	"CARACTERE IMPULSIF APPLIQUE AU PERSO " type <- chara .name@ print
	0 <- chara .composure!
	1 STAT_STRENGTH <- chara .stat+
	<- chara .temperREV <- chara .strengthREV
	// ' fierce-main-events <- chara .main_events!
	WEAPON_SLEDGE <- chara .trademarkwep
;

