\ ; 

: fencer-thing-events args( me teid )

	<- teid THING_EVENT_DID_HIT = if			

		<- me .pos <- me .just_hit_id@ #thing .pos xysub xymag weapondef{ <- me .wielded sel melee_range@ } - 5 - 5 - print 
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if
			<- me .pos <- me .just_hit_id@ #thing .pos xysub xymag weapondef{ <- me .wielded sel melee_range@ } - 5 - 5 - >int 10.89 > if 
			\ First, find the distance from the hit target. subtract melee range, player and zomb rad. if we are left at 11 or more, we 
			\ must have hit near the tip. award extra damage 
			
			<- me .fatigue@ 7 - 0 127 clamp <- me .fatigue! \ Reward with stamina recovery. 
			
				\ Normal functionality, i.e non-scepter code
				<- me .pos <- me .just_hit_id@ #thing .pos xysub xynorm -6 xymul <- me .just_hit_id@ #thing .vel! 
				50 %chance if 
					-3 <- me .just_hit_id@ #thing .vel.z! 
				else
					3 <- me .just_hit_id@ #thing .vel.z! 
				then 
				
				<- me .just_hit_id@ #thing .pos xyblast 
				weapondef{ <- me .wielded sel power@ } 2 / lt .hitcheck.power!
				4 lt .hitcheck.rad!
				-1 lt .hitcheck.blast! 
				\ 5 lt .hitcheck.knockback! 
				
				5 6 rnd for
				<- me .just_hit_id@ #thing .pos
					particle{
						new pos!
						15 ticks! } 
					
					<- me .pos <- me .just_hit_id@ #thing .pos xysub xyangle 140 220 frnd + particle{ angle! } 
					
					particle{	
						glowy
						0.8 grow!
						11 fade_out!
						particles_base_id 0x 51 + spriteid!
						angle@ anglexy 2 3 frnd xymul vel! 
						pos@ angle@ anglexy 8.5 xymul xyadd pos!
						\ gameticks angle!
						1 scale!
						0 1 1 rgb!
					}
				next 
				
					sfx{ zelda 0 d! 0 a! } 
				then 
			then
		then
	

;

