: spectrait args( chara )
	"SPECIALISTE APPLIQUE AU PERSONNAGE " type <- chara .name@ print
	// boring <- chara .wits! boring <- chara .attitude! boring <- chara .composure!
	1 STAT_STRENGTH <- chara .bonus+
	1 STAT_FITNESS <- chara .bonus+
	1 STAT_SHOOTING <- chara .bonus+
	1 STAT_STRENGTH <- chara .stat+
	1 STAT_FITNESS <- chara .stat+
	1 STAT_SHOOTING <- chara .stat+
	1 <- chara .carrying.slot_count!
	<- chara .shootingREV <- chara .strengthREV <- chara .fitnessREV
	<- chara .perk@ "Arc et Fleches" $= if
		"WEAPON_WARBOW" evaluate <- chara .weapona! \ Q update: special bow specialist 
		\ BE CAREFUL WITH WEAPON ID ORDER! 
		
		1 <- chara .weapon_nodropa!
		0 <- chara .weaponb!
		60 <- chara .stackeda!
	then
	(*
	// Arq fix for getting supplies for not recruiting them
	<- chara .perk@ "Collectionneur d'armes" $= if
		gstats{ perk-guncrazy } 3 >= if 1 WEAPON_SHOTGUN trunk.weapon+ then
		gstats{ perk-guncrazy } 2 >= if 1 WEAPON_RIFLE trunk.weapon+ then
		gstats{ perk-guncrazy } 3 < if 1 WEAPON_PISTOL trunk.weapon+ then
		0 <- chara .weaponb!
		0 <- chara .weaponc!
	then
	*)
	<- chara .perk@ "Pyromane" $= if
		WEAPON_NAPALM <- chara .weapona!
		1 <- chara .weapon_nodropa!
		0 <- chara .weaponb!
		25 <- chara .stackeda!
	then
	WEAPON_KNIGHT <- chara .trademarkwep
;

: travellighttrait args( chara )
	"VOYAGE LEGER APPLIQUE AU PERSO " type <- chara .name@ print
	1 STAT_DEXTERITY <- chara .stat+ 
	1 STAT_FITNESS <- chara .stat+
	2 <- chara .carrying.slot_count!
	(*
	<- chara .perk@ "Collectionneur d\'armes" $= if
		gstats{ perk-guncrazy } 2 >= if 1 WEAPON_RIFLE trunk.weapon+ then
		0 <- chara .weaponc!
	then
	*)
	WEAPON_SCLEAVER <- chara .trademarkwep
;

: .exwrestler? .perk@ "Ex-Wrestler" $= ;
: .grappler? .trait@ "Grappler" $= ;


\ *******************************
\ sticking chairmaster stuff up here
\ for grappler bug fix
\ q update 

: blowuponlanding args( me teid ) 
	<- teid THING_EVENT_BOUNCE = if 
		 <- me .pos xyblast
		-1 lt .hitcheck.blast! 22 lt .hitcheck.rad!
		\ "I LOVE CHEESE!" print
		RED "KAPLOW!" .. <- me .report 
		<- me silentkillit
		
		<- me .pos3 
		particle{ new pos3!
		5 ticks!
		5 fade_out!
		0.75 scaley!
		0.5 scale!
		1.3 grow!
		0 vel.y!
		particles32_base_id 4 + spriteid!
		1 clr.r! 1 clr.g! 1 clr.b!
	}
	
	3 rumble
		
	then 
	
	<- teid THING_EVENT_TIMER = if
	1 <- me .timer! 
		<- me .weapon_state.val@ #thing 0 = if then; 
		<- me .weapon_state.val@ #thing .pos3 <- me .pos3! 
	then 
;	

		
: invisible_blowup 
	spawn
	100000000 lt .mass! \ frank NO 
	1 lt .invisible!
	1 lt .walkover!
	10000000 lt .hitpoints!
	1 lt .no_hit!
	1 lt .nocollide!
	3 lt .tileflags! 
	1 lt .timer! 
	' blowuponlanding lt .events! 
;
		
: tbrawler-thing-events args( me eventid )
	
	<- eventid THING_EVENT_THROW = if 
	<- me .carryid@ 0 = not if 
		invisible_blowup
		<- me .carryid@ lt .weapon_state.val! 

			<- me .carryid@ #thing .hitpoints@ 3 + <- me .carryid@ #thing .hitpoints! \ thrown objects are tankier 
			\ Potential issue for thrown zombies, maybe. But the whole point is thrown things are meant to be more resilient, so... 
			
		\ <- me .carryid@ #thing .vel 0 20 xyadd <- me .carryid@ #thing .vel!  
		then 
	then \ then 
	
;

\ ************************************

// Arq changes for Back to the Wall and for AI to use Grapple
: grappler-main-events over .thing@ 0 args( chara eventid thing temp )
	<- chara .party@ 0?;
	<- eventid MAIN_EVENT_DRIVING_START = if
		<- chara bow-perk-regen <- chara pyro-perk-regen
	then;
	<- eventid MAIN_EVENT_MISSION_START = if
		15 <- thing .ai.assess! // execute the below code more frequently
	then;
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> ?;
	
	THING_EVENT_AI_ASSESS ?(
		<- thing .carryid@ if
			<- thing .forcethrow
		then;
		<- thing .fatigue@ 55 > ?;
		orders_tactic@ 1 = ?;
		<- thing .nearest_interact_id@ 0?;
		<- thing .nearest_interact_id@ #thing -> temp
		<- temp .zomb? 0?;
		<- chara .exwrestler? <- chara .grappler? and if
			<- temp <- thing .carry
		then;
		<- temp .zombfallen? if
			<- temp <- thing .carry
		then
	);
	drop 
		
;


: grapplertrait args( chara )
	"GRAPPLER APPLIED ON CHAR " type <- chara .name@ print
	boring <- chara .wits! boring <- chara .attitude! boring <- chara .composure!
	
	<- chara .perk@ "Ex-Wrestler" $= if
		// 2 STAT_STRENGTH <- chara .stat+ 2 STAT_FITNESS <- chara .stat+
		8 <- chara .specialbody!
		<- chara statmod{ .zombiewrestler }
		<- chara statmod{ .nocanshoot }
	else
		<- chara statmod{ .zombielifter }
	then
	
	WEAPON_NIGHTSTICK <- chara .trademarkwep
	
	<- chara .perk@ "Chairmaster" $= not if
		<- chara .perk@ "Kensai" $= not if
			<- chara .perk@ "Ranger" $= not if
				<- chara .perk@ "Duelist" $= not if \ i hate thisssss. 
					<- chara .perk@ "The Big Shot" $= not if
	' grappler-main-events <- chara .main_events!
	then then then then then 
	\ apparently if you use any perk that isnt wrestler and grappler the ai wont do anything 
	\ so this is a bandaid fix for now 
	\ 
	\ RETINA: I am going to probably take a look at this next update - STOMACH
	\ There is no reason for this to use the main-events slot, it could easily be a statmod. 
	\ for modder's sake at least 
;

