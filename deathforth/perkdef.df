perkdef{ 

0 value highest 
0 value hyper_stat_pos
0 value hyper_stat

0 stack 
	STAT_MECHANICAL shove 
	STAT_MEDICAL shove 
	STAT_SHOOTING shove 
	STAT_FITNESS shove 
	STAT_STRENGTH shove 
constant STATLIST_FIXATION


: translate_hyperfixation case 
	STAT_MEDICAL of "MEDICAL" endof 
	STAT_SHOOTING of "SHOOTING" endof 
	STAT_STRENGTH of "STRENGTH" endof 
	STAT_FITNESS of "FITNESS" endof 
	STAT_MECHANICAL of "MECHANIC" endof 
	endcase
; 

\ Pain await ye, all who enter the Hyperfixated trait code. 
\ I hate it too 

: sorthighfrom5 ( n1 n2 n3 )
	\ works for N doohickeys 

	\ 0 value highest 
	0 to highest 
  
	\ .s 
	
		5 for \ n1 n2 n3 
			dup \  dup \ n1 n2 n3 n3 
			
			highest > if \ n1 n2 n3 n3 highest -> n1 n2 n3 
				to highest \ n1 n2			
				"high num found!" print
				highest print 
			else  \ n1 n2 n3 	
			drop then \ n1 n2 
		next 
		highest 
	

; 

: shuffle_things case
	1 of 4 roll endof 
	2 of rot endof 
	3 of swap endof 
	4 of -rot endof 
	5 of 5 roll endof 
	endcase
;

: the_shuffler  
	5 for 
		1 5 rnd shuffle_things
	next
; 
	
: deduce_highstat args( chara ) 
	
	STAT_MECHANICAL <- chara .effstat STAT_MEDICAL <- chara .effstat STAT_SHOOTING <- chara .effstat STAT_FITNESS <- chara .effstat STAT_STRENGTH <- chara .effstat

	0 to hyper_stat
	0 to hyper_stat_pos
	
	sorthighfrom5 \ Return biggest stat's value
	dup dup dup dup 
	
	STAT_MECHANICAL <- chara .effstat = if 
		hyper_stat_pos 0 = if 
			1 to hyper_stat_pos
		else
			50 %chance if 
				1 to hyper_stat_pos
			then 
		then 
	then 
	
	STAT_MEDICAL <- chara .effstat = if 
		hyper_stat_pos 0 = if 
			2 to hyper_stat_pos
		else
			50 %chance if 
				2 to hyper_stat_pos
			then 
		then 
	then 
	
	STAT_SHOOTING <- chara .effstat = if 
		hyper_stat_pos 0 = if 
			3 to hyper_stat_pos
		else
			50 %chance if 
				3 to hyper_stat_pos
			then 
		then 
	then 
	
	STAT_FITNESS <- chara .effstat = if 
		hyper_stat_pos 0 = if 
			4 to hyper_stat_pos
		else
			50 %chance if 
				4 to hyper_stat_pos
			then 
		then 
	then 	
	
	STAT_STRENGTH <- chara .effstat = if 
		hyper_stat_pos 0 = if 
			5 to hyper_stat_pos
		else
			50 %chance if 
				5 to hyper_stat_pos
			then 
		then 
	then 
	
	
	STATLIST_FIXATION hyper_stat_pos picks to hyper_stat
	
	STATLIST_FIXATION hyper_stat_pos picks 3 swap <- chara .bonus+  
	STATLIST_FIXATION hyper_stat_pos picks 1 swap <- chara .knownstat!
	\ "CHOSEN STAT: " print  
	\ STATLIST_FIXATION hyper_stat_pos picks swap drop translate_hyperfixation bbold print
;

: deduce_dysfunction args( chara ) 
	
	STATLIST_FIXATION depths for 
		STATLIST_FIXATION i picks hyper_stat = not if 
		
			STATLIST_FIXATION i picks -3 swap <- chara .bonus+  
			STATLIST_FIXATION i picks 3 swap <- chara .stat+
		\	 "MODIFYING..." print 
		\	STATLIST_FIXATION i picks swap drop translate_hyperfixation rbold print
		
		then 
	next 
; 

: run_hyperfixations args( chara ) 

	0 to hyper_stat
	
	<- chara deduce_highstat
	<- chara deduce_dysfunction 
	
	\ .s 
	
	6 <- chara .wits! 
	<- chara .witsREV
	
	2 4 rnd <- chara .attitude!
	2 4 rnd <- chara .composure!
	\ 2 4 rnd <- chara .loyalty!
	\ Breaks accidental combos
; 

: hyperfixatedtrait args( chara )
	"HYPERFIXATED APPLIED ON CHAR " type <- chara .name@ print
	<- chara run_hyperfixations				
	
	17 for 
		drop 
	next 
	\ Cleanup...

	WEAPON_PHASEBLADE <- chara .trademarkwep
;


