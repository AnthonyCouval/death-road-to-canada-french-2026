;

defperks

}

// Arq new perk logic for not getting supplies unless you recruit them
: someperkchecks
	perkdef{
		' healthcare-check foreach-team-char
		' guncrazy-check foreach-team-char
		' ultrafit-check foreach-team-char
	}
;

: recruitee-perkcheck
	perkdef{
		recruitee healthcare-check
		recruitee guncrazy-check
		recruitee ultrafit-check
	}
;