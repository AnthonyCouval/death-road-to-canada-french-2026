// Arq changes to guncrazy to only get the supplies if you recruit them
: guncrazy-calc
	gstats{ perk-guncrazy } case
		3 of
			1 WEAPON_SHOTGUN trunk.weapon+ 8 trunk-shotgun-shell+
			1 WEAPON_RIFLE trunk.weapon+ 12 trunk-rifle-shell+
			// 1 WEAPON_PISTOL trunk.weapon+
		endof
		2 of
			1 WEAPON_RIFLE trunk.weapon+ 12 trunk-rifle-shell+
		endof
	endcase
	1 WEAPON_PISTOL trunk.weapon+ 17 trunk-bullet+
;
: guncrazy-blurb args( chara )
	($ ICON_UP textclr$ .. <- chara .name@ .. " ajoute " .. <- chara xhis .. " collection d'armes au coffre !" .. 0 textclr$ $)
	blurbevent ICON_UP blurbicon <- chara character# road{ charid } blurb-last-to-cyoa
	guncrazy-calc
;
