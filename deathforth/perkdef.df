: tbrawler-main-events ( teid ) args( chara eventid )
	 	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
	
	\ 1 <- chara .thing@ .timer!
	<- chara .location@ 1 = if 
		<- chara .thing@ swap ( teid ) tbrawler-thing-events
	then 
	
	
;

\ TAVERN BRAWLER: THROWN THINGS EXPLODE! 

: kensai-thing-events args( me teid )

	<- teid THING_EVENT_SWING = if
		\ 1 <- me .character@ .strength@ STAT_STRENGTH <- me .character@ .bonus@ + 0.05 * - 0.6 1 clamp <- me .cooldown@ * <- me .cooldown!

		STAT_STRENGTH <- me .character@ .effstat -0.05 * 1 + 0.6 1 clamp <- me .cooldown@ * <- me .cooldown! 
		STAT_STRENGTH <- me .character@ .effstat -0.05 * 1 + print 

		weapondef{ <- me .wielded sel cooldown@ } print 
		<- me .cooldown@ print 
	then
	
;


