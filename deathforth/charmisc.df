// CO-OP JOIN MESSAGE
: temp-buddy-events args( chara hint )
	// Join
	<- hint 1 = if
		<- chara .tempify
		<- chara .thing@ .pooftemp
	then;

	// Leave
	<- hint 0 = if
		TEAM_STATUS_FAMILIAR <- chara .decruit
		<- chara .thing@ .pooftemp
		<- chara .thing@ silentkillit
	then;
;

