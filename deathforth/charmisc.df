: .johnnyfy
	123 over .specialtype! 0 over .specialmode! 0 over .female!
	"BERSERK!" over .trait! "Max Potential" over .perk!
	4 over .strength! 4 over .fitness! 0 over .shooting!
	1 STAT_STRENGTH 2 pick .bonus! 1 STAT_FITNESS 2 pick .bonus! 6 STAT_SHOOTING 2 pick .bonus!
	4 over .mechanical! 4 over .medical!
	-4 STAT_MECHANICAL 2 pick .bonus! -4 STAT_MEDICAL 2 pick .bonus!
	0 over .wits! 0 over .attitude! 0 over .composure! 0 over .loyalty!
	1 over .vitality! 1 over .health!
	"Johnny" over .name!
	"etait dans l'armee, avant que la plupart soit zombifiee." over .job!
	WEAPON_FIRE over .weapona! // 1 over .weapon_nodropa!
	WEAPON_ASSAULT over .weaponb! 1 over .weapon_nodropb!
	2 over .carrying.slot_count!
	60 LOOT_SHOTGUN_SHELL 2 pick .lootamt!
	dup .showitall
	0 STAT_DEXTERITY 2 pick .knownstat!
	1 over .ai.prefer_weapon_slot!
	drop
;

