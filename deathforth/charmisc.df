: .arqify
	124 over .specialbody! 0 over .specialmode! 0 over .female!
	1 over .headtype! 19 over .hairtype! 0 over .glassestype! 0 over .facetype! 0 over .hattype! 0 over .skincolour! 6 over .haircolour!
	4 over .strength! 0 over .fitness! 3 over .shooting!
	-2 STAT_FITNESS 2 pick .bonus!
	3 over .mechanical! 0 over .medical!
	6 over .wits! 3 over .attitude! 3 over .composure! 3 over .loyalty!
	4 over .vitality! 4 over .health!
	"Arq" over .name!
	"Gourmand" over .trait! "Programmer" over .perk!
	"est un type quelconque. Du moins c'est ce qu'il dit." over .job!
	-0.2 swap .speed_bonus!
;

