3 constant MAX_PUKEYBALL_COUNT
: pukeyball-counter args( char )
	WEAPON_PUKEYBALL <- char .weapona@ = if <- char .stackeda@ 0= if 1 else <- char .stackeda@ then + then
	WEAPON_PUKEYBALL <- char .weaponb@ = if <- char .stackedb@ 0= if 1 else <- char .stackedb@ then + then
	WEAPON_PUKEYBALL <- char .weaponc@ = if <- char .stackedc@ 0= if 1 else <- char .stackedc@ then + then
;
: team-has-pukeyballs? 0 ' pukeyball-counter foreach-team-char
	WEAPON_PUKEYBALL trunk.weapon@ +
	dup MAX_PUKEYBALL_COUNT >= if true else false then swap " pukeyballs" .. print ;

0 value THEBRCKMON
defer get-brckmon // see /events/sc/omentum.df

: brckmon-main-events over .thing@ 0 args( chara eventid thing host )
	<- eventid MAIN_EVENT_MISSION_START = if
		<- thing .thingseed@ #thing dup 0= if drop then; -> host
		<- host .typeid@ THING_HUMAN <> ?;
		<- host .character@ .dead? 0?;
		1 <- chara .charm! 1 <- chara .party!
	then;
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> ?;

	THING_EVENT_WAS_HIT
	?(
		<- chara .dead? 0?;
		0 <- thing .timer! 0 <- thing .events! // 0 <- chara .main_events!
	);

	THING_EVENT_TIMER
	?(
		<- chara .charm@ ?;
		<- thing .retrigger_timer
		2 <- chara .party! <- thing .thingseed@ <- thing .ai.followid!
		<- thing .ai.followid@ #thing .character@ .dead? if
			0 <- thing .timer!
			<- chara character# to THEBRCKMON ' get-brckmon stack-road-action
			1 <- chara .party! 0 <- thing .ai.followid!
			0 <- thing .events! // 0 <- chara .main_events!
		then
	);
	drop
;

: .brckmon-defaults
	WEAPON_BOXING over .weapon_default!
	0 over .composure! 6 over .loyalty!
	1 over .carrying.slot_count!
	-1 over .breathescale!
	1 over .ai.rush_chance! 0 over .ai.attack_level! 0 over .ai.threat_respond_chance!
	' brckmon-main-events over .main_events!
	"est un Pukeymon. La plupart ont disparu apres l'apocalypse." over .job!
	drop
;
: .geyofy 126 over .specialtype! 	4 over .strength! 4 over .fitness! 3 over .floatval! 8 over .floatheight! -1 over .headoff.y! "Geyodyde" over .name! drop ;
: .grovelfy 127 over .specialtype! 	5 over .strength! 5 over .fitness! "Groveler" over .name! drop ;
: .galemfy 128 over .specialtype! 	6 over .strength! 6 over .fitness! WEAPON_FIERCE over .weapon_default! "Galem" over .name! drop ;

126 	is-specialchar: .geyo?
127 	is-specialchar: .grovel?
128 	is-specialchar: .galem?
: .brckmon? .main_events@ ' brckmon-main-events v= ;
: stpick-brckmon team-stack ' .brckmon? stack-filter if shuffles pops nip true else drop false then ;

: brckmon-summon args( chara thing ) // use charm stat to determine evolution of brck's pkmn
	new-npc 1 lt .repeating_timer
	lt .character@ dup .default-ai-setup ( dup .party-familiar ) dup .brckmon-defaults dup .notake dup .nopickups
	10 over .ai.follow_leash! 15 over .ai.safety_leash!
	2 over .party!
	<- chara .charm@ 0= if
		.geyofy
	else
		<- chara .charm@ 2 < if
			.grovelfy
		else
			.galemfy
		then
	then
	<- thing thing# lt .ai.followid! // only follow brck
	<- thing .inside_id@ dup lt .inside_id! // if in car, spawn there
	0= if <- thing .pos lt .pos! then
	<- thing thing# lt .thingseed!
;

: brck-main-events over .thing@ args( chara eventid thing )
	<- chara .party@ 0?;
	<- eventid MAIN_EVENT_MISSION_START = if <- chara <- thing brckmon-summon then;
	<- eventid MAIN_EVENT_DRIVING_START = if
		team-has-pukeyballs? ?; // if the group has 3 or more pukeyballs, dont give another one
		1 WEAPON_PUKEYBALL trunk.weapon+
	then;
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> ?;
	drop
;

: brcknamer
	($ "Br" ..
	deck-new
		"a" ,
		"i" ,
		"u" ,
		"e" ,
		"y" ,
		"oyoe" ,
		"*" ,
		"@" ,
		"#" ,
	shuffles pops nip .. "ck" $) swap .name!
;

: .brckify
	125 over .specialtype! 0 over .specialmode! 0 over .female!
	' brck-main-events over .main_events!

	2 over .wits! 6 over .attitude! 2 4 rnd over .composure! 6 over .loyalty!
	4 over .strength! 1 over .fitness! 0 over .shooting!
	0 over .mechanical! 0 over .medical!

	dup brcknamer
	($ "doit trouver des " .. "belles nanas" fbold .. " au Canada." $) over .job!
	WEAPON_FRYING over .weapona! 1 over .ai.prefer_weapon_slot!
	WEAPON_PUKEYBALL over .weaponb! 9 over .stackedb!

	0 over .charm!
	0 over .ai.wander_chance!
	dup .thing@ dup if
		brckmon-summon
		// 2 lt .character@ .party!
	else
		2drop
	then
;

