\ Stuff for scepter mode, various powerups... 

: divine-smite args( me ) 

10 for
	<- me .pos  
		particle{ new pos! 30 ticks! 
				pos@ -15 5 frnd + swap -3 2 frnd + swap pos!
					
				particles_base_id 1+ spriteid!
				330 390 frnd anglexy 2 3 frnd xymul vel!
				
				30 fade_out! 
				1 clr.r!
				0.8 1 frnd clr.g!
				0 clr.b!
				glowy

				}
	next 
		<- me .pos3 
		particle{ 
			new
		pos3!

		0 wait!
		12 ticks!
		5 fade_out!
		0.75 scaley!
		0.5 scale!
		1.1 grow!
		0 vel.y!
		1 clr.r! 1 clr.g! 0 clr.b! 
		particles32_base_id 4 + spriteid! } 
		
	sfx{ thump 2 scale! 0.5 pitch! 350 r! 350 d! 40 a! } 
	\ YELLOW "DIVINE SMITE" .. <- me .report 

;

: izzy-event args( me eventid ) 
	
	<- eventid THING_EVENT_DID_HIT = if
		<- me .character@ .morale@ 6 * %chance if 
			\ <- me .just_hit_id@ .typeid@ THING_ZOMBIE = if 
				<- me .just_hit_id@ #thing divine-smite 
				
				weapondef{ <- me .wielded sel power@ } <- me .character@ .strength@ 0.05 + * 0.33 swap anyexpo <- me .just_hit_id@ #thing .hitpoints@ >= if 
					-5 <- me .just_hit_id@ #thing .vel.z! 
				then 
				\ BITS GO FLYING 
				
				<- me .just_hit_id@ #thing .hitpoints@ weapondef{ <- me .wielded sel power@ } <- me .character@ .strength@ 0.05 + * 0.33 swap anyexpo - <- me .just_hit_id@ #thing .hitpoints! 
				\ (STR * WEP_DMG)**0.33 
				YELLOW "SMITTEN FOR:" .. print 
				YELLOW weapondef{ <- me .wielded sel power@ } <- me .character@ .strength@ 0.05 + * 0.33 swap anyexpo .. print 
				
				
				\ fragment when using 0 base for expo 
				
			then 
		then 

	
;

\ I dedicate this to my partner, Isabelle
\ Bless you, girl, ilysm <3 

: izzy-main-events args( chara eventid ) 
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then; 
	
	<- chara .location@ 1 = if 
		1 <- chara .thing@ .timer!
		<- chara .thing@ swap izzy-event
	then 
; 
	
	
: lienne-thing-events args( me teid )
	
		<- teid THING_EVENT_SWING = if
		<- me .character@ .mod_flags2@ 2 = if 

			<- me .character@ .user.special_counter@ -1 * 10 + 10 / 0.37 1 clamp <- me .cooldown@ * <- me .cooldown!
			\ <- me .fatigue@ 5 + 0 127 clamp <- me .fatigue!
			<- me .character@ .user.special_counter@ -1 * 10 + 10 / print 
			<- me .cooldown@ print 
			
			<- me .fatigue@ -5 + 0 127 clamp <- me .fatigue! 
			then 
			
		then
		
	\	<- teid THING_EVENT_SHOOT = if
	\		<- me .character@ .user.special_counter@ -1 * 10 + 10 / <- me .cooldown@ * <- me .cooldown!

	\	then
		
		<- teid THING_EVENT_DID_HIT = if
			\ 320 <- me .timer!
		<- me .character@ .user.special_counter@ 1 + 0 10 clamp <- me .character@ .user.special_counter!
			
		then 
	
		<- teid THING_EVENT_TIMER = if 
			1 <- me .timer!
			player 0 = if then; 
			player .isswap? if 
				0 <- me .character@ .user.special_counter!
			then 
		 then

	
;


