	<- chara .location@ 1 = if 
		1 <- chara .thing@ .timer!
		<- chara .thing@ swap ( teid ) lienne-thing-events
	then 
;



: falcorebullet 
	
	lt .typeid@ THING_PROJECTILE = if 
		\ lt .id@ lt .report
		
		lt .vel xymag print  
		lt .hitcheck.power@ print 
		
		\ 1 lt .anim.info!
		\ weapons_base_id 699 + lt .spriteid! 
		
		lt .hitcheck.power@ 1.5 * lt .hitcheck.power!  \ 150% dmg 
		8 lt .hitcheck.power_max! \ increased max power...why not? for bosses 
		4 lt .anim.substate! 
		lt .anim.counter@ 1.25 * lt .anim.counter! \ 125% range 
		lt .vel 1.25 xymul lt .vel! \ 150% speed 
		lt .anim.extra@ 0.3 + lt .anim.extra! \ 0.3+ bounce  
		
		 lt .vel xymag print  
		 lt .hitcheck.power@ print 
		
	
		then 
;


: falcore-thing-events args( me teid )
	
	<- teid THING_EVENT_SHOOT = if 

		weapondef{ <- me .wielded sel ammo_type@ } 4 = weapondef{ <- me .wielded sel projectiles@ } 2 < weapondef{ <- me .wielded sel shell_count@ } 1 = or or if 

			1 ' falcorebullet timer_add

		then 
		
	then 
;


: falcore-main-events ( teid ) args( chara eventid )
	 	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
	
	<- chara .location@ 1 = if 
		1 <- chara .thing@ .timer!
		<- chara .thing@ swap ( teid ) falcore-thing-events
	then 
	
;

: lobotomise args( chara )
	0 <- chara .ai.loot_chance!
	0.1 <- chara .ai.attack_dist!
	0 <- chara .ai.attack_chance!
	125 <- chara .ai.safety_threshold!
	0 <- chara .ai.flee_dist!
	0 <- chara .ai.loot_chance!
	0 <- chara .ai.wander_chance! // Don't look around
	0	<- chara .ai.rush_chance!
	4	<- chara .ai.attack_level!
	\ -1   <- chara .ai.pickup_gun_max!
	\ -1  <- chara .ai.pickup_melee_max!
	0 <- chara .ai.threat_respond_chance! 
	
	
; 

: echoattack args( me teid )
	<- teid THING_EVENT_TIMER = if 
		1 <- me .timer!
		
		<- me .cooldown@ 0 = if 
			<- me .attack
		then; 
		
		<- me .cooldown@ 1 = if
			sfx{ glass 0.25 scale! } 
			5 <- me .smashybits
			<- me silentkillit
		then;	
	then 
	
	<- teid THING_EVENT_SWING <> if 
		<- me .timer@ 29 = if 
			\ This is stupid beyond words
				<- me .character@ .user.special_counter@ #thing .aim_angle@ <- me .aim_angle!
				<- me .character@ .user.special_counter@ #thing .move_angle@ <- me .move_angle!
			then 
		then 
	
;

0 value turntowardhack 

: spawn-lasija-echo args( me ) 
	dummy-npc 
	lt .character@ lobotomise
	
	0.66 lt .clr.a!
	0 lt .clr.r! 
	
	<- me .character@ .specialtype@ lt .character@ .specialtype! 
	
	1 lt .character@ .carrying.slot_count!  
	<- me  .wielded lt .character@ .weapona! 
	
	<- me .id@ lt .character@ .user.special_counter! 

	1 lt .character@ .weapon_nodropa!
	1 lt .character@ .weapon_nodropb!
	1 lt .character@ .weapon_nodropc!
	0 lt .rad.x! 0 lt .rad.y! 0 lt .rad.z! 0 lt .mass!
	1 lt .unseen! 
	
	<- me .pos <- me .aim_angle@ anglexy -3 xymul xyadd lt .pos!
	
	<- me lt .turn-toward
	
	0 lt .cooldown!
	0 lt .action_cooldown!
	0 lt .stun! 
	
	<- me .aim_angle@ lt .aim_angle!
	<- me .move_angle@ lt .move_angle!
	\ <- me .angle@ lt .angle!
	\ <- me lt .turn-toward 

	1 lt .unseen!
	3 lt .tileflags!
	1 lt .nocollide!
	1 lt .nopush! 
	' echoattack lt .events! 
	30 lt .timer!
	
	lt .move_angle@ anglexy 2 xymul lt .vel! 

	
;

: chronomancer-thing-events args( me teid )
	
	<- teid THING_EVENT_SWING = if 
		<- me spawn-lasija-echo
	then 

;

: chronomancer-main-events ( teid ) args( chara eventid )

	 <- eventid MAIN_EVENT_MISSION_START = if 
		0 <- chara .user.special_counter! 
	 then 
	 	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
	
	<- chara .location@ 1 = if 
		<- chara .thing@ swap ( teid ) chronomancer-thing-events
		1 <- chara .thing@ .timer!
	then 
	
;


: echosenior-thing-events args( me teid )
	
	<- teid THING_EVENT_DID_HIT = if
		35 %chance if
			<- me .just_hit_id@ #thing dup .pos xyblast
			-1 lt .hitcheck.blast! 7 lt .hitcheck.rad!
			RED "CRIT!" .. <- me .report
			weapondef{ <- me .wielded sel power@ } 1.5 * lt .hitcheck.power!
		then
	then			
;

: echosenior-main-events ( teid ) args( chara eventid )
	 	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
	
	<- chara .location@ 1 = if 
		<- chara .thing@ swap ( teid ) echosenior-thing-events
	then 
	
;


: erosetta-thing-events args( me teid )

	<- teid THING_EVENT_TIMER = if 
		1 <- me .timer!
		
			<- me .character@ .user.special_counter@ 0 > if 
				1 <- me .invincible_counter! 
			then
			
		
			<- me .anim.extra@ 0 > if 
				<- me .character@ .user.special_counter@ -200 250 / + 0 200 clamp <- me .character@ .user.special_counter!
			then
		
		<- me .pos
		 particle{ new pos!
		 special_objects32_base_id 213 + spriteid!
			1 ticks!
			0 fade_in!
			0 fade_out!
			1 scalex!
			1 scaley!
			1 layer!
			
		\	15 360 frnd rotate! // variable rotation rate
			<- me .character@ .user.special_counter@ 400 / 0 0.5 clamp particle{ clr.a! }
			<- me .vel vel!
		 }
		 
		0 0.3 1 particle{ rgb! } 
	then
	
	<- teid THING_EVENT_DID_HIT = if
		weapondef{ <- me .wielded sel power@ } 15 * <- me .character@ .user.special_counter@ + 0 200 clamp <- me .character@ .user.special_counter!

	then
				
;

: erosetta-main-events ( teid ) args( chara eventid )
	 	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
	
	<- chara .location@ 1 = if
		1 <- chara .thing@ .timer!
		 <- chara .thing@ swap ( teid ) erosetta-thing-events
	then	 
	
;

: bomber-recharge args( chara eventid )
	<- eventid MAIN_EVENT_DRIVING_START = if

		
		12 for
			1 "WEAPON_BOMBERCLASSTWO" evaluate trunk.weapon+
		next
	then
;

: grenadier-recharge args( chara eventid )
	<- eventid MAIN_EVENT_DRIVING_START = if
		5 for
			1 WEAPON_GRENADE trunk.weapon+
		next
	then
;

: archer-recharge args( chara eventid )
	<- eventid MAIN_EVENT_DRIVING_START = if
		50 <- chara .stackeda!
	then
;	

