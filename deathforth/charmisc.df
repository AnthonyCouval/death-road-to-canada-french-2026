: rat-thing-events args( thing eventid )

	<- eventid

		THING_EVENT_SWING ?(
			sfx{ pip 0.05 duty! 500 100 rnd dup freq! 500 swap - 100 + freq2! 5.5 6.5 frnd pitch!
				25 a! 0.9 q! 25 50 rnd d! 0.1 s! 50 r!
				0.125 scale!
				<- thing .adjust-vol
			}
		);

	drop
;


