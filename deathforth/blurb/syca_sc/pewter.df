	constant PEWTER-ONELINERS
	PEWTER-ONELINERS var PEWTER-oneliners
	PEWTER-ONELINERS shuffles to PEWTER-oneliners

: PEWTER-oneliner
	PEWTER-oneliners depths 0= if PEWTER-ONELINERS shuffles to PEWTER-oneliners then
	blurbslot 0= if
		drawcard blurbsay
	then
;

	deck-new
	21 cards: PEWTER-oneliner

	constant BLURB-PEWTER-DECK
	BLURB-PEWTER-DECK var blurb-PEWTER-deck
	BLURB-PEWTER-DECK shuffles to blurb-PEWTER-deck
