	constant MERENJA-ONELINERS
	MERENJA-ONELINERS var MERENJA-oneliners
	MERENJA-ONELINERS shuffles to MERENJA-oneliners

: MERENJA-oneliner
	MERENJA-oneliners depths 0= if MERENJA-ONELINERS shuffles to MERENJA-oneliners then
	blurbslot 0= if
		drawcard blurbsay
	then
;

	deck-new
	21 cards: MERENJA-oneliner

	constant BLURB-MERENJA-DECK
	BLURB-MERENJA-DECK var blurb-MERENJA-deck
	BLURB-MERENJA-DECK shuffles to blurb-MERENJA-deck
