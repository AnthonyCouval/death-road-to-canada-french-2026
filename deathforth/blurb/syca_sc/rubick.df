	constant RUBICK-ONELINERS
	RUBICK-ONELINERS var RUBICK-oneliners
	RUBICK-ONELINERS shuffles to RUBICK-oneliners

: RUBICK-oneliner
	RUBICK-oneliners depths 0= if RUBICK-ONELINERS shuffles to RUBICK-oneliners then
	blurbslot 0= if
		drawcard blurbsay
	then
;

	deck-new
	21 cards: RUBICK-oneliner

	constant BLURB-RUBICK-DECK
	BLURB-RUBICK-DECK var blurb-RUBICK-deck
	BLURB-RUBICK-DECK shuffles to blurb-RUBICK-deck
