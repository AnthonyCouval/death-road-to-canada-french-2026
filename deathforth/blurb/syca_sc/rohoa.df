	constant ROHOA-ONELINERS
	ROHOA-ONELINERS var ROHOA-oneliners
	ROHOA-ONELINERS shuffles to ROHOA-oneliners

: ROHOA-oneliner
	ROHOA-oneliners depths 0= if ROHOA-ONELINERS shuffles to ROHOA-oneliners then
	blurbslot 0= if
		drawcard blurbsay
	then
;

	deck-new
	21 cards: ROHOA-oneliner

	constant BLURB-ROHOA-DECK
	BLURB-ROHOA-DECK var blurb-ROHOA-deck
	BLURB-ROHOA-DECK shuffles to blurb-ROHOA-deck
