	constant ZEUS-ONELINERS
	ZEUS-ONELINERS var ZEUS-oneliners
	ZEUS-ONELINERS shuffles to ZEUS-oneliners

: ZEUS-oneliner
	ZEUS-oneliners depths 0= if ZEUS-ONELINERS shuffles to ZEUS-oneliners then
	blurbslot 0= if
		drawcard blurbsay
	then
;

	deck-new
	21 cards: ZEUS-oneliner

	constant BLURB-ZEUS-DECK
	BLURB-ZEUS-DECK var blurb-ZEUS-deck
	BLURB-ZEUS-DECK shuffles to blurb-ZEUS-deck
