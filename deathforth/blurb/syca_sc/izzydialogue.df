	constant IZZY-ONELINERS
	IZZY-ONELINERS var IZZY-oneliners
	IZZY-ONELINERS shuffles to IZZY-oneliners

: IZZY-oneliner
	IZZY-oneliners depths 0= if IZZY-ONELINERS shuffles to IZZY-oneliners then
	blurbslot 0= if
		drawcard blurbsay
	then
;

	deck-new
	21 cards: IZZY-oneliner

	constant BLURB-IZZY-DECK
	BLURB-IZZY-DECK var blurb-IZZY-deck
	BLURB-IZZY-DECK shuffles to blurb-IZZY-deck
