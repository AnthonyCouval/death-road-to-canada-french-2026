	constant BAYONET-ONELINERS
	BAYONET-ONELINERS var BAYONET-oneliners
	BAYONET-ONELINERS shuffles to BAYONET-oneliners

: BAYONET-oneliner
	BAYONET-oneliners depths 0= if BAYONET-ONELINERS shuffles to BAYONET-oneliners then
	blurbslot 0= if
		drawcard blurbsay
	then
;

	deck-new
	21 cards: BAYONET-oneliner

	constant BLURB-BAYONET-DECK
	BLURB-BAYONET-DECK var blurb-BAYONET-deck
	BLURB-BAYONET-DECK shuffles to blurb-BAYONET-deck
