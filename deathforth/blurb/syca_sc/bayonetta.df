		card: BAYONET-oneline4
		card: BAYONET-oneline5
		card: BAYONET-oneline6
		card: BAYONET-oneline7
		card: BAYONET-oneline8
		card: BAYONET-oneline9
		card: BAYONET-oneline10
		card: BAYONET-oneline11
		card: BAYONET-oneline12
		card: BAYONET-oneline13
		card: BAYONET-oneline14
		card: BAYONET-oneline15
		card: BAYONET-oneline16
		card: BAYONET-oneline17
		card: BAYONET-oneline18
