	constant CONDOR-ONELINERS
	CONDOR-ONELINERS var CONDOR-oneliners
	CONDOR-ONELINERS shuffles to CONDOR-oneliners

: CONDOR-oneliner
	CONDOR-oneliners depths 0= if CONDOR-ONELINERS shuffles to CONDOR-oneliners then
	blurbslot 0= if
		drawcard blurbsay
	then
;

	deck-new
	21 cards: CONDOR-oneliner

	constant BLURB-CONDOR-DECK
	BLURB-CONDOR-DECK var blurb-CONDOR-deck
	BLURB-CONDOR-DECK shuffles to blurb-CONDOR-deck
