	constant CLOCKKING-ONELINERS
	CLOCKKING-ONELINERS var CLOCKKING-oneliners
	CLOCKKING-ONELINERS shuffles to CLOCKKING-oneliners

: CLOCKKING-oneliner
	CLOCKKING-oneliners depths 0= if CLOCKKING-ONELINERS shuffles to CLOCKKING-oneliners then
	blurbslot 0= if
		drawcard blurbsay
	then
;

	deck-new
	21 cards: CLOCKKING-oneliner

	constant BLURB-CLOCKKING-DECK
	BLURB-CLOCKKING-DECK var blurb-CLOCKKING-deck
	BLURB-CLOCKKING-DECK shuffles to blurb-CLOCKKING-deck
