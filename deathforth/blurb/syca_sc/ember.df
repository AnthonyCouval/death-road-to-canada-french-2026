	constant EMBER-ONELINERS
	EMBER-ONELINERS var EMBER-oneliners
	EMBER-ONELINERS shuffles to EMBER-oneliners

: EMBER-oneliner
	EMBER-oneliners depths 0= if EMBER-ONELINERS shuffles to EMBER-oneliners then
	blurbslot 0= if
		drawcard blurbsay
	then
;

	deck-new
	21 cards: EMBER-oneliner

