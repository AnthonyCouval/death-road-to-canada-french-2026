\ Beefy yet extremely short range sidegrade 
custom: Flechette Shotgun
	weapon: flet
	spriteid: 294
	gun_muzzle_height: 3
	cock_sound: 2
	ammo_type: LOOT_SHOTGUN_SHELL
	boom_factor: 1.5
	spread_factor: 0
	shot_power: 0
	revolver: 0
	cooldown: 0.8
	projectiles: 0
	power: 0.8
	knockback: 0.5
	shoot_thru: 0.33
	shot_knockback: 1
	func: WEAPON_FUNC_SHOOT
	skill_angle_range: 0
	ammo_max: 30
	melee_break_scale: 0
	targeting: 1
	pointblank_near
	Crangedtier
	reload: 1 \ no effective change 
	
	\ Again, custom bullet system... 
	
	\ Stomach resprite 
	spriteid: GUNS_ANIM_SPRITE 18 + 
	
	
	: fire-pellet args( me )
	
			12 for
				bullet
				
		-1 lt .anim.info!
		weapons_base_id 295 + lt .spriteid!
		<- me thing# lt .throwerid!
		<- me .aim_angle@ lt .angle!
		lt .angle@ 17 -17 rnd + lt .angle!
		<- me .pos lt .angle@ anglexy 8 xymul xyadd lt .pos!


		6 lt .anim.counter!
		\ Extremely short range 

		0.55 lt .hitcheck.power! // Power (exponential)
		0 lt .hitcheck.shoot_thru!

//		lt .hitcheck.power@ print

		lt .angle@ anglexy 7 xymul lt .vel! // Speed

		-3 <- me .breath - lt .pos.z!
		lt .pos lt .pos.z@ +

		\ 56 <- me .action_cooldown!
		60 <- me .cooldown!
		
		next 
	;

: always_anim args( me eventid ) 

	<- eventid THING_EVENT_ANIMATE = if
		<- me .anim.state@ if then;
			GUN_ANIMS 1 = if
				<- me .anim.counter@ 1 = if 
					0 <- me .weapon_state.frame!			
				then 
			then 
		then 

	<- eventid THING_EVENT_SHOOT = if	
		
		GUN_ANIMS 1 = if 
			1 <- me .weapon_state.frame!

			<- me .character@ .perk@ "Ranger" $= if 
				<- me .cooldown@ 2 / <- me .anim.counter! 
			else 
				<- me .character@ .perk@ "The Big Shot" $= if 
					<- me .cooldown@ 0.825 / <- me .anim.counter! 
				else 
					<- me .cooldown@ 1.2 / <- me .anim.counter!
				then 
			then 
			<- me fire-pellet
		then 
	then 
;

	wielder_handler: last
	
	
	\ See regular bow (weapondef.df) for formal explanation of bow rework 
	\ Longbow is for specialist + bow 
	\ Main perk is 5 pwr at max draw for infinite pen 
	
	custom: Longbow
	weapon: warbow
	spriteid: 296
	chargename: Arrows
	func: WEAPON_FUNC_CUSTOM_AIMING
	melee_weapon_angle: 90
	melee_windup_angle: -270
	melee_start_angle: -180
	melee_end_angle: -45
	stack_max: 65
	stack_as_charges: 1
	melee_aiming: 0
	power: 0.4
	cooldown: 0
//	reload: 0.25
	reload: 0
	targeting: 0
	lock_drift: 0.025
	melee_range_hint: 100
	melee_range_min_hint: 40
	Ctier 
	
: .zombie? .typeid@ THING_ZOMBIE = ;

: restore_ammo_longbow args( me eventid ) 
	<- eventid THING_EVENT_OVERLAP = if
	<- me .overlap_id@ #thing .character@ .weapona@ WEAPON_WARBOW = if
			<- me .overlap_id@ #thing .character@ .stackeda@ 65 < if 
				<- me .overlap_id@ #thing .character@ .stackeda@ 1 + <- me .overlap_id@ #thing .character@ .stackeda!
				<- me silentkillit
				sfx{ goodfx } 
				<- me .reportammo
		then then;
		
		<- me .overlap_id@ #thing .character@ .weaponb@ WEAPON_WARBOW = if
			<- me .overlap_id@ #thing .character@ .stackedb@ 65 < if 
				<- me .overlap_id@ #thing .character@ .stackedb@ 1 + <- me .overlap_id@ #thing .character@ .stackedb!
				<- me silentkillit
				sfx{ goodfx } 
				<- me .reportammo
		then then;
		
		<- me .overlap_id@ #thing .character@ .weaponc@ WEAPON_WARBOW = if
			<- me .overlap_id@ #thing .character@ .stackedc@ 65 < if 
				<- me .overlap_id@ #thing .character@ .stackedc@ 1 + <- me .overlap_id@ #thing .character@ .stackedc!
				<- me silentkillit
				sfx{ goodfx } 
				<- me .reportammo
		then then;
		
	then 
; 

: spare_arrow_long
	spawn 
	1 lt .walkover!
	3 lt .hitpoints!
	weapons_base_id 298 + lt .spriteid!
	1 lt .nopush!
	' restore_ammo_longbow lt .events!
	\ 1 lt .no_hit!
	5 lt .rad.x! 5 lt .rad.y! 
	\ "MICHAEL" lt .report 
; 
	
: arrow-stuck2 args( me eventid )
	<- eventid THING_EVENT_TIMER = if
	
	1 <- me .timer!
		<- me .pos particle{ 
			new pos!
			1 ticks!
			75 angle!
			weapons_base_id 299 + spriteid!
			1 scale!
		}
	then
;
	
	
	\ ----------------------------------------------
\ RECTUM BOW REWORK LOGIC : 
\ ----------------------------------------------


defer penshotLongBow
	
	: fire-penshot-longbow args( me )
		
					bullet


			<- me .aim_angle@ lt .angle!


			<- me .pos lt .angle@ anglexy 11 xymul xyadd lt .pos!
		
			1 lt .timer! 
			' penshotLongBow lt .events! 
			 
			
			0 lt .anim.extra! \ No ricochets. 
			
	;
	

	
	: continue_pen_longbow args( me eventid )
	
	\ <- me .anim.counter@ 1 = if 
	
	<- me .weapon_state.val@ 0 = if <- me silentkillit then; 
	
	<- eventid THING_EVENT_FREE = if
			
			"NUM 1" print 
			
				<- me .anim.counter@ 1 > if
					<- me .weapon_state.val@ 1 = if 
					"NUM 2" print 

					<- me .hitcheck.lasthit_id@ 0 = not if 
						<- me .hitcheck.lasthit_id@ #thing .typeid@ THING_ZOMBIE = if 
							' arrow-stuck2 <- me .hitcheck.lasthit_id@ #thing .events!
							0.6 <- me .hitcheck.lasthit_id@ #thing .friction!
							100 <- me .hitcheck.lasthit_id@ #thing .stun! 
							<- me .spriteid@ <- me .hitcheck.lasthit_id@ #thing .weapon_state.val! 
							1 <- me .hitcheck.lasthit_id@ #thing .timer! 
						then 
					then 
				then 
					
				else
					spare_arrow_long
					<- me .pos lt .pos!
					<- me .angle@ lt .angle!
					<- me .spriteid@ lt .spriteid! 
					' restore_ammo_longbow lt .events! 
					<- me silentkillit
				then 
			
			
			map{ <- me .pos pos>tile tile@ 0 } = not if \ This entire conditional segment basically says "don't penetrate wall or blocked tiles, unless the tile is a shelf" 
				map{ <- me .pos pos>tile tile@ .id@ TILE_BLOCK } = map{ <- me .pos pos>tile tile@ .id@ TILE_LINK_DOOR } = map{ <- me .pos pos>tile tile@ .id@ TILE_BLOCK_FLOOR } = map{ <- me .pos pos>tile tile@ .id@ TILE_WRECKAGE } = map{ <- me .pos pos>tile tile@ .id@ TILE_WALLTOP } = or or or or if 
					0 <- me .anim.counter! 
				then 
			then 
			
					<- me .anim.counter@ 0 = not if 
						<- me .angle@ <- me .aim_angle!
						<- me fire-penshot-longbow \ create new bullet, ensure old bullet properties are transient...
						<- me .weapon_state.val@ 1 - lt .weapon_state.val! \ Penetration counter 
						<- me .hitcheck.power@ 0.82 * lt .hitcheck.power! \ 18% stat loss per penetration 
						<- me .hitcheck.knockback@ 0.82 * lt .hitcheck.knockback! 
						<- me .hitcheck.shoot_thru@ 0.82 * lt .hitcheck.shoot_thru! 
						<- me .vel lt .vel! \ No velocity reduction yet...unnecessary? 
						<- me .anim.counter@ lt .anim.counter! \ No duration reduction yet, either 
						<- me .anim.extra@ lt .anim.extra! 
						-1 lt .anim.info!
						<- me .spriteid@ lt .spriteid!
						1 lt .timer! 
						' penshotLongBow lt .events! 
					\ 	<- me .weapon_state.hint@ lt .weapon_state.hint! 
						\ <- me .spriteid@ ": " .. lt .spriteid@ .. <- me .report  

						"PIERCED!" print 
						"Power:" lt .hitcheck.power@ .. print 
						"KB: " lt .hitcheck.knockback@ .. print 
						"SHOOT-THRU: " lt .hitcheck.shoot_thru@ .. print 

			
				then
		then
	
		<- eventid THING_EVENT_TIMER = if 
			1 <- me .timer! 
			
				<- me .vel xymag 3.5 > if 
						
						<- me .pos -4 4 rnd -4 4 rnd xyadd <- me .angle@ anglexy -10 xymul xyadd 
						particle{
							new pos!
							2 ticks!
							
							particles_base_id 70 + spriteid!
							1 scale!
						}
						<- me .pos.z@ particle{ pos.z! }
						<- me .angle@ particle{ angle! } 
						
				 then
		
		then 

	
	;
	
	last to penshotLongBow \ cursed recursion logic 


\ ----------------------------------------------
\ RECTUM BOW REWORK LOGIC
\ ----------------------------------------------


\ 29-10-25
\ Fix this shit-ass longbow. 
	
	90 BOW_FRESH_DRAW * 1.6 * constant WARBOW_DRAW_TIME

	: fire-longarrow args( me )
		sfx{ pip 0 duty! freq@ 0.6 * freq2! 0.9 0.8 frnd 0.75 *  pitch! <- me .adjust-vol
			2 a! 35 d! 0.2 s! 200 r!
			scale@ 0.5 * scale!
		}

		bullet

		-1 lt .anim.info!
		<- me thing# lt .throwerid!
		<- me .wielded_spriteid 2 + lt .spriteid!
		-5 <- me .weapon_state.reach!
		<- me .aim_angle@ lt .angle!
		<- me .pos lt .angle@ anglexy 7 xymul xyadd lt .pos!
		\ Arrow should leave from the mid of bow, not edge 

		<- me .weapon_state.user@ WARBOW_DRAW_TIME / 15 * 5 + lt .anim.counter!

		<- me .weapon_state.user@ WARBOW_DRAW_TIME / dup * 4 * 1 + 5 clamp lt .hitcheck.power! 
		"POWER:" print 
		lt .hitcheck.power@ print 
		
		<- me .character@ .strength@ STAT_STRENGTH <- me .character@ .bonus@ + <- me .weapon_state.user@ BOW_DRAW_TIME / * >int 1 + 0 11 clamp lt .weapon_state.val! 
		\ May make longbow scaling more effective yet, idk 

		1 lt .timer! 
		' continue_pen_longbow lt .events! 

		lt .angle@ anglexy <- me .weapon_state.user@ BOW_DRAW_TIME / 4 * 2 + xymul lt .vel! // Speed
		0.05 lt .hitcheck.shoot_thru! // Pierce (exponential)
		\ 0.5 lt .hitcheck.shoot_thru!

		-2 <- me .breath - lt .pos.z!
		lt .pos lt .pos.z@ +

		0 <- me .weapon_state.user!

		<- me .bow-cooldown-time 20 + <- me .action_cooldown!
		<- me .useanammo
	;

	: animate-longbow args( me )

		<- me .weapon_state.user@ 0 > abs <- me .weapon_state.frame!
		2 <- me .weapon_state.user@ BOW_DRAW_TIME / 5 * + <- me .weapon_state.off.x!

		<- me .weapon_state.user@ 0= if then;

		<- me .isattack? not if <- me fire-longarrow then;

		<- me .fatigued? <- me .weapon_state.user@ WARBOW_DRAW_TIME >= or if
			gameticks 80 * sin 0.5 * <- me .weapon_state.off.x@ + <- me .weapon_state.off.x!
		then
	;

	: draw-longarrow args( me )
		<- me .weapon_state.user@ 0= if 5 <- me .fatigue+ else // Just starting to draw incurs 5 fatigue
			gameticks 5 % dup print 0= if 1 <- me .fatigue+ then
		then

		<- me .weapon_state.user@ WARBOW_DRAW_TIME >= if
//			<- me .fatigued? if
//				<- me .vel 0.75 xymul <- me .vel! // Slow walking
//			then
		then;

		<- me .fatigued? if BOW_FRESH_DRAW 2 / else BOW_FRESH_DRAW <- me .character@ STAT_STRENGTH swap .effstat dup * + then // Strength draws faster
			<- me .weapon_state.user@ + <- me .weapon_state.user!

		<- me .weapon_state.user@ WARBOW_DRAW_TIME >= if
			<- me dup .fatigued? if .ugh else .hup then
			-2 <- me .shudder! 
		then;
	;

	:noname args( me eventid )
		<- me .carryid@ if then;
		<- me .anim.state@ if then;

		<- eventid THING_EVENT_ANIMATE = if 
			<- me animate-longbow
		then 
		
		<- eventid THING_EVENT_SWING <> if 
			<- me .isattack? not if
				<- me .flip@ 1 = if
					-45 <- me .weapon_state.angle_add!
				else
				45 <- me .weapon_state.angle_add!
				then
			else
				0 <- me .weapon_state.angle_add!
			then
		then 
		
		<- me .action_cooldown@ if then;

		<- eventid THING_EVENT_SHOOT = if 
			<- me draw-longarrow
		then 
		
	;

	wielder_handler: last

	

} 


weapondef{ 

custom: Diesel
	weapon: lfdfuel
	chargename: Gallons
	spriteid: 300
	power: 0
	cooldown: 0
	knockback: 3.5
	melee_extra_hits: 2
	stack_max: 60
	stack_as_charges: 1
	melee_fatigue_scale: 0
	wepscorebonus
	melee_start_angle: -420
	melee_windup_angle: -420
	melee_end_angle: -420
	melee_shift.x: 1.4
	melee_shift.y: -3.6

	
: breach args( me event )
	<- event THING_EVENT_SWING = if	
	then
;

wielder_handler: last

: #lfdfuel lfdfuel .item.charges! ;
root{ : lfdfuel 30 45 rnd #lfdfuel ; }





	\ Stuff for the RPG mode classes... 
	
	custom: Dynamite
	weapon: bomberclasstwo
	spriteid: 304
	power: 0
	melee_thrown: 1
	melee_thrown_lob: 2
	stack_max: 12
	wepscorebonus
	1 no_discard!
	

		mission{

		thing-event: grenade-events 
			eventid THING_EVENT_THROW = if
				me .anim.counter@ 0= if
					40 me .timer!
				then
				1 me .mass!
				15 me .hitpoints!
				1 me .lob_mode!
				0.1 me .mass!
				1 me .no_hit!
				90 me .flipx * me .rot!
				1 me .item.locked!
				me .vel xynorm 1.5 ( <- change this number for shorter/longer throw ) xymul me .vel!
				me .vel.z@ 0.75 - me .vel.z! // A bit extra lob
			then

			eventid THING_EVENT_BOUNCE = if
				me .angle@ me .rot@ + me .angle!
			then

			eventid THING_EVENT_TIMER = if
				me .pos 2 xypowboom -1 lt .hitcheck.blast! 30 lt .hitcheck.rad!
				2 me .shudder!
				1 rumble
				
				me silentkillit
				then
		;

			melee_thrown_handler: last
		}


	\ Spellblade sword 
	custom: Hexblade 
	weapon: elongsword
	spriteid: 305
	knockback: 2
	power: 3.33
	cooldown: 0.75
	melee_break_scale: 0
	melee_extra_hits: 2
	melee_start_angle: 60
	melee_end_angle: -180
	0 melee_off.y!
	7 melee_off.x!
	melee_reach: 20
	melee_range: 16
	wepscorebonus
	
: enchanting args( me eventid )
	<- eventid THING_EVENT_SWING = if
	
	33 %chance if
		1 <- me .weapon_state.frame!
	then;
	
	33 %chance if
		2 <- me .weapon_state.frame!
	then;
	
	33 %chance if
		3 <- me .weapon_state.frame!
	then;
	
		then
		
	<- eventid THING_EVENT_DID_HIT = if
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if
		
			<- me .weapon_state.frame@ 1 = if 

			<- me .just_hit_id@ #thing 1 swap .burning!
			<- me .just_hit_id@ #thing 0 swap .spreadability!		
					then
				then
			
			
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if

			<- me .weapon_state.frame@ 2 = if 
			<- me .just_hit_id@ #thing 120 swap .stun!
					
					then
				then
			
			
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if

			<- me .weapon_state.frame@ 3 = if 
			<- me .just_hit_id@ #thing 0.56 swap .friction!
					
					then
				then
			
		then
	
		
;

	wielder_handler: last


	\ Melee alt subclass weapon 

	WEAPON_SLEDGE clone-to: Earthquaker
		spriteid: 309
		weapon: meleealt
		knockback: 3.5
		power: 4
		melee_extra_hits: 1
		cooldown: 1
		wepscorebonus
		
		: quake args( me eventid )
		
		<- eventid THING_EVENT_DID_HIT = if
			<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if
				<- me .just_hit_id@ #thing dup .pos xyblast
				-1 lt .hitcheck.blast! 25 lt .hitcheck.rad!
			then
		then
		
		;
		
		wielder_handler: last
		
	
	\ mage primary 
	\ i NEED to reference BG3 
	
	custom: Scorching Ray 
	spriteid: 312
	no_held_sprite: 1 
	weapon: mageclassone 
	laser_type: 2
	func: WEAPON_FUNC_CUSTOM_AIMING
	stack_as_charges: 1
	stack_max: 375
	reload: 0 
	projectiles: 0
	stack_no_show: 1
	lock_drift: 0.1
	

	\ RED "Eldritch Blast" .. WHITE .. name!
	
	: ^2 dup * ; 
	
		: repeatparticle args( me eventid )
		
		
			<- eventid THING_EVENT_FREE = if
				<- me .pos xyblast
				-1 lt .hitcheck.blast! 
				14 21 rnd lt .hitcheck.rad! 
				1 lt .hitcheck.power! 
				<- me .weapon_state.val@ 40 / lt .hitcheck.knockback!
			then 
		
		
			<- eventid THING_EVENT_TIMER = if 
				1 <- me .timer!
				
				<- me .pos 
				particle{ new pos! 
				\	pos@ -5 5 frnd + swap -5 5 frnd + swap pos!
					
				weapons_base_id 311 + spriteid!
				\ angle@ -1 * 10 -10 frnd + anglexy 1 2 frnd xymul vel!
				
				8 ticks! 
				4 fade_out! 
				\ 1 clr.r!
				
				\ 0.8 1 frnd clr.g!
				\ 0 clr.b!
				\ glowy

				}
				
				<- me .angle@ particle{ angle! } 
				
			
			<- me .pos 	
			particle{
                new pos!
                20 ticks!
                0 360 frnd angle!
				glowy
				
                5 fade_out!
                particles_base_id 149 + spriteid!
                // angle@ anglexy 0.04 0.08 frnd xymul vel!
                pos@ -10 10 frnd + swap -10 10 frnd + swap pos!
                0.25 0.4 frnd scale!
                1 0 0 rgb!
				\ pos@ 
            }
				
				
			then 
		; 
				
				
				
	
		: fire-arrow args( me )
		
				1 for
			
					bullet

			<- me thing# lt .throwerid!
			<- me .aim_angle@ lt .angle!
			<- me .pos lt .angle@ anglexy 18 xymul xyadd lt .pos!
			
			\ ' aoe-damage lt .events!
			
			' repeatparticle lt .events! 

			1 lt .anim.info! // activate bullet sprite option
			 weapons_base_id 311 + lt .spriteid!

			0 lt .hitcheck.shoot_thru!
			1.3 <- me .weapon_state.val@ 40 / + lt .hitcheck.power!  
			0 lt .anim.extra!
			
			1 lt .timer! 
			
			<- me .weapon_state.val@ lt .weapon_state.val! 
			
			2 lt .anim.substate!

			lt .angle@ anglexy 7 xymul lt .vel! // Speed
	
			\ 80 %chance if
			\ <- me .useanammo
			\ then

			-1.6 <- me .breath - lt .pos.z!
			lt .pos lt .pos.z@ +

			15 <- me .action_cooldown!
			15 <- me .cooldown!
			\ 0 <- me .anim.weapon_counter!
			
			next 
	;
	
	: setup-fx args( me eventid )
	
		<- eventid THING_EVENT_ANIMATE = if
			<- me .anim.state@ if then;
			\ <- me .weapon_state.val@ 39 > if 
				<- me .anim.counter@ 1 = if
				
				\ 	<- me .weapon_state.val@ 40 / for 
						<- me fire-arrow
							sfx{ noise 300 d! 0.5 1 frnd pitch! } 
											
				
				5 6 rnd for
					<- me .pos
					particle{
						new pos!
						15 ticks!
						<- me .aim_angle@ angle!
						\ glowy
						0.8 grow!
						3 fade_out!
						particles_base_id 0x 51 + spriteid!
						i 20 40 rnd * 90 - angle@ + anglexy 2 3 frnd xymul vel! 
						pos@ angle@ anglexy 8.5 xymul xyadd pos!
						gameticks angle!
						1 scale!
						0 0 0 rgb!
					}
				next 
						
						<- me .weapon_state.val@ lt .weapon_state.val! 
						
						0 <- me .weapon_state.val!
						
									10 %chance if 
										RED "ARDE!" .. <- me .yellmsg
									then 
								
				\ 	next 
				
				
				
				10 <- me .shudder!
				
				
				\ then
			then 
		then

		<- eventid THING_EVENT_SHOOT = if
		
			\ <- me .action_cooldown@ 0 > if then;
			<- me .weapon_state.val@ 121 = if 7 <- me .cooldown! then;
		
				7 <- me .anim.counter! // works like a timer otherwise????
				<- me .weapon_state.val@ 1 + 0 121 clamp <- me .weapon_state.val!
				
			
		  <- me .pos <- me .aim_angle@ anglexy 6 xymul xyadd 
		   particle{
                new pos!
                10 ticks!
                0 360 frnd angle!
                glowy
				
                5 fade_out!
                particles_base_id 149 + spriteid!
                // angle@ anglexy 0.04 0.08 frnd xymul vel!
                
                0.25 0.4 frnd scale!
                0.3 0.8 frnd 0 0.1 frnd 0 rgb!
				\ pos@ 
            }
			<- me .weapon_state.val@ 90 / 0.05 + 0.4 + 0 1.1 clamp particle{ grow! } 
			
			<- me .move_angle@ ^2 bi_root 360 % 271.1 > <- me .move_angle@ ^2 bi_root 360 % 89 < or if
				particle{ 1 layer! }
			else 
				particle{ 0 layer! } 
			then 
			
			
			10 %chance if 
			sfx{ crunch 30 a! 30 d! 30 r! 30 s! 0.1 scale! } 
			then 
			
			<- me .pos <- me .aim_angle@ anglexy 6 xymul xyadd
		   particle{
                new pos!
                10 ticks!
                0 360 frnd angle!
               \  glowy
				
                5 fade_out!
                particles_base_id 149 + spriteid!
                // angle@ anglexy 0.04 0.08 frnd xymul vel!
                
                0.25 0.4 frnd scale!
                0 0 0 rgb!
				1 layer! 
				\ pos@ 
            }
			<- me .weapon_state.val@ 90 / 0.05 + 0.4 + 0 1.1 clamp particle{ grow! } 
			
			<- me .move_angle@ ^2 bi_root 360 % 271.1 > <- me .move_angle@ ^2 bi_root 360 % 89 < or if \ YESSSS!!!!!! 
				particle{ 1 layer! }
			else 
				particle{ 0 layer! } 
			then 
		then
		
		
	;

wielder_handler: last


\ maybe replace with chain lightning one day 
custom: Arcane Flame 
	weapon: mageclasstwo
	spriteid: 302
	melee_fatigue_scale: 1
	melee_fatigue_cooldown_scale: 3
	cooldown: 1.25
	
	: glowy-events args( me eventid )
	
		1 <- me .flipx * <- me .rot!
	
		<- eventid THING_EVENT_TIMER = if
			1 <- me .timer!
				0.5 1 1 45 <- me .pos d-light
				<- me .anim.info@ 0= if 1 <- me .timer! then
		<- me .angle@ abs 360 %
		<- me .angle@ <- me .rot@ + <- me .angle!
			then
	;

	
	: fire-fire args( me )
		
						bullet
						-1 lt .anim.info! // Can the bullet be sprited?
						1 lt .timer!
						180 lt .anim.counter! // How long should the bullet last?
						weapons_base_id 310 + lt .spriteid! // Spriteid
						
						0 lt .glow! // Transparent bullets?
						1 lt .anim.extra! // for bounce chance
						' glowy-events lt .events!
						1000 lt .hitpoints!
						100 lt .flammability!
						1 lt .burning!
						1 lt .clr.r!
						0 lt .clr.b!
						0 lt .clr.g!
						
						4 lt .rad.x!
						4 lt .rad.y!
						


		<- me thing# lt .throwerid!
		<- me .aim_angle@ lt .angle!
		<- me .pos lt .angle@ anglexy 7 xymul xyadd lt .pos!


		6 lt .hitcheck.power! // Power (exponential)
		0.8 lt .hitcheck.shoot_thru!
		4 lt .scale.x! // These don't appear to actually work.
		4 lt .scale.y! // same here.
		1 lt .glow!	
		1 lt .tileflags!
		15 lt .hitcheck.hits_allowed!
			
//		lt .hitcheck.power@ print

		lt .angle@ anglexy 2 xymul lt .vel! // SLOW

		-3 <- me .breath - lt .pos.z!
		lt .pos lt .pos.z@ +

		10 <- me .fatigue+ 

	;

	:noname args( me eventid )
		<- me .carryid@ if then;

		<- eventid THING_EVENT_SWING = if
			sfx{ fm 0.2 pitch! }

				sfx{ pwm 300 a! 100 freq! 0.8 1.2 frnd pitch!  }
			<- me fire-fire
			
			0 <- me .anim.weapon_counter!
			
		then
		
		
	;

	wielder_handler: last	




} 



