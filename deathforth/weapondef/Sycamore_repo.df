custom: Arc Lightning
	weapon: zeusfire
	no_held_sprite: 0
	spriteid: 348
	3 melee_off.x!
	melee_start_angle: 0
	melee_windup_angle: 0
	melee_end_angle: 0
	melee_aiming: 1
	stack_as_charges: 1
	stack_max: 100
	melee_fatigue_scale: 0
	melee_start_angle: 0
	melee_windup_angle: 0
	melee_end_angle: melee_start_angle@
	power: 0 
	
	Arangedtier
	
	\ defer fire-arrowzomb
	defer aoe-damage3a
	
			: fire-reboundlight args( me )
		
			\ 2 for 
					bullet

			<- me .aim_angle@ gameticks 35 * sin 3 * + lt .angle! // i really like this effect

			1 lt .anim.info!
			weapons_base_id 351 + lt .spriteid!
			\ // weapons16_base_id 21 + lt .spriteid!
			<- me .pos lt .angle@ anglexy 20 xymul xyadd lt .pos!
			
			1 lt .clr.b!
			0 lt .clr.r!
			0.1 lt .clr.g!
			
			' aoe-damage3a lt .events! 
			 
			0 lt .hitcheck.shoot_thru!

			0.5 lt .hitcheck.knockback!
			
			0 lt .anim.extra!
			
			30 lt .anim.counter!
			
			5 lt .anim.substate!

			lt .angle@ anglexy 2 xymul lt .vel! // Speed

	;
	
	: triangulate args( me )
		<- me .pos 66 things-in-xyrad
				depths for -1 picks .zombie? if
					<- me .pos
					"1" print 
					-1 picks silentkillit
					"2" print 
					xysub xyangle 
					"3" print 
					<- me .aim_angle! 
				then
			next drop 
	
	
	;
	
	: aoe-damage3 args( me eventid )
	
	<- me .weapon_state.val@ 0 = if <- me silentkillit then; 
	
	
	<- eventid THING_EVENT_FREE = if
			
				<- me .pos 66 things-in-xyrad
				depths for i picks .zombie? if
					i picks .pos <- me .pos xysub xyangle <- me .aim_angle!
					<- me fire-reboundlight
					<- me .weapon_state.val@ 1 - lt .weapon_state.val! 
					<- me .hitcheck.power@ 3 / lt .hitcheck.power! 
					break 
					
				then
			next drop 
			
			
		6 for
			<- me .pos
            particle{
                new pos!
                10 ticks!
                0 360 frnd angle!
                glowy
                0.99 grow!
                5 fade_out!
                particles_base_id 149 + spriteid!
                // angle@ anglexy 0.04 0.08 frnd xymul vel!
                pos@ -25 25 frnd + swap -20 20 frnd + swap pos!
                0.25 0.4 frnd scale!
                0 1 1 rgb!
            }

			next
			
		then
			
	<- eventid THING_EVENT_TIMER = if
		4 <- me .timer! // reduces cpu usage and moreso the amount of unsightly mega-deviations from initial beam
			<- me .angle@ 4 -4 rnd + <- me .angle!
			<- me .angle@ anglexy 2 xymul <- me .vel!


           <- me .pos
            particle{
                new pos!
                10 ticks!
                0 360 frnd angle!
                glowy
                0.99 grow!
                5 fade_out!
                particles_base_id 149 + spriteid!
                // angle@ anglexy 0.04 0.08 frnd xymul vel!
                pos@ -15 5 frnd + swap -3 2 frnd + swap pos!
                0.25 0.4 frnd scale!
                0 0.4 1 rgb!
            }
			
		then
	
	;
	
	last to aoe-damage3a
	

		: fire-lbolt args( me )
		
				2 for
			
					bullet

			<- me thing# lt .throwerid!
			<- me .aim_angle@ gameticks 35 * sin 3 * + lt .angle! 

			1 lt .anim.info!
			weapons_base_id 351 + lt .spriteid!

			<- me .pos lt .angle@ anglexy 20 xymul xyadd lt .pos!
			
			1 lt .clr.b!
			0 lt .clr.r!
			0.1 lt .clr.g!
			
				' aoe-damage3 lt .events! 
			 
			0 lt .hitcheck.shoot_thru!
			0.5 lt .hitcheck.knockback!
			<- me .character@ .strength@ 0.04 * 0.3 + lt .hitcheck.power! 	
			
			0 lt .anim.extra!
			
			30 lt .anim.counter!
			
			5 lt .anim.substate!

			lt .angle@ anglexy 2 xymul lt .vel! // Speed
			1 lt .timer!

			-1.6 <- me .breath - lt .pos.z!
			lt .pos lt .pos.z@ +

			5 <- me .action_cooldown! // 2 bolts at 12x per second
			5 <- me .cooldown! // 24 bolts per second total
			
			4 lt .weapon_state.val! 
			\ "jumps:" print 
			\ lt .weapon_state.val@ print 
			
			next 
	;

	: draw-zap args( me )
	
	<- me .wielded-stack 0 = if 
	
	0 <- me .anim.weapon_counter! 	
	
	3 4 rnd for
			<- me .pos
			particle{
				new pos!
				15 ticks!
				<- me .aim_angle@ angle!
				glowy
				0.8 grow!
				3 fade_out!
				particles_base_id 0x 51 + spriteid!
				i 20 40 rnd * 90 - angle@ + anglexy 2 3 frnd xymul vel! // # I saw sparks #
				pos@ angle@ anglexy 8.5 xymul xyadd pos!
				gameticks angle!
				1 scale!
				0 0.7 1 rgb!
			}
			next 
			
			then;
	
	 <- me fire-lbolt
	 
	 
	 1 3 rnd for 
	 	<- me .useanammo
	next 
	
	\ increased ammo consumption 
	\  13-04-25 
		
	;

	:noname args( me eventid )

	<- me .action_cooldown@ if 0 <- me .anim.weapon_counter!  then;
	
		<- eventid
			
			THING_EVENT_SWING ?( <- me draw-zap <- me animate-bow sfx{ dutypulse 0.9 pitch! 120 300 frnd d! } 0 <- me .vel.x! 0 <- me .vel.y! 1 <- me .weapon_state.frame! 0 <- me .anim.weapon_counter! 
			
			3 <- me .weapon_state.reach!
			
			<- me .weapon_state.info@ 0 = if
				<- me .aim_angle@ <- me .weapon_state.val! // has to stop and channel the spell
			then
			
			\ 6 <- me .stun!
			
			);
			
		drop
		
		<- eventid THING_EVENT_DID_BURN <> if 
		
		<- me .cooldown@ not if 
		<- me .isattack? if
			\ <- me .weapon_state.val@ <- me .aim_angle!
			1 <- me .weapon_state.info!
		else
			0 <- me .weapon_state.val!
			0 <- me .weapon_state.info!
		then
		then
		
		
		gameticks 10 % if then; // slows down the animation to not play at 30 FUCKING FRAMES PER SECOND
			
			<- me .weapon_state.frame@ 0 = if
				1 <- me .weapon_state.frame!
			then;
			
			<- me .weapon_state.frame@ 1 = if
				2 <- me .weapon_state.frame!
			then;
			
			<- me .weapon_state.frame@ 2 = if
			0 <- me .weapon_state.frame!
			then;
			
			
			
		then
		
		<- eventid THING_EVENT_WIELD = if
		0 <- me .cooldown!
		0 <- me .action_cooldown!
		then
			
	;

	wielder_handler: last
	
	
	
	
: sunder_strike args( me eventid )
	
	<- eventid THING_EVENT_TIMER = if
		1 <- me .timer!
		
		<- me .pos.z@ -40 > if 
		
		5 <- me .smashybits
		0 <- me .spriteid! 
		0 <- me .hitpoints!
	
		then
	then

;	

: sunderbolt
		spawn special_objects96_base_id 5 + lt .spriteid! 1 health! 2000 lt .mass! 0 lt .rad.x! 0 lt .rad.y! 0 lt .rad.z! 
		3 lt .tileflags!
		1 lt .anim.info!
		sfx{ thump 3 scale! 2.5 3.5 frnd pitch! 100 a! 700 d! 120 r! }
		-450 lt .pos.z!
		173 185 rnd lt .angle!
		5 lt .anim.substate!
		1 lt .timer!
		' sunder_strike lt .events!
		21 lt .vel.z! 
;

