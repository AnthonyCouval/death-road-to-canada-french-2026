custom: Phaseblade
	weapon: phaseblade 
	spriteid: 340
	power: 0.25 \ instakills whilst charged 
	knockback: 0
	cooldown: 0.6
	melee_break_scale: 0
	melee_extra_hits: 0
	stack_as_charges: 1
	0 melee_off.y!
	4 melee_off.x!
	melee_reach: 9
	melee_range: 6
	leaning: 1.1
	wepscorebonus
	melee_start_angle: -45
	melee_end_angle: -135
	melee_shift.x: -3
	stack_max: 40
	glow: 1
	Btier 
	half-fatigue
	stack_no_show: 1 
	\ doublehit would be too good...probably? 

: phaseblade_trans args( me eventid ) 

	<- eventid THING_EVENT_WIELD = if 
		20 <- me .anim.counter! 
		21 <- me .cooldown!  
	then 
	
	<- eventid THING_EVENT_SWING = if 
		<- me .weapon_state.val@ 1 = if 
			sfx{ creepy 1 duty! 1 k! 300 450 rnd d! 1.3 1.45 frnd pitch! }
		then
	then 
	
	<- eventid THING_EVENT_DID_HIT = if 
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if 
			<- me .wielded-stack 0 > if 
				10 <- me .just_hit_id@ #thing .burning!
				0 <- me .just_hit_id@ #thing .hitpoints!
				-1 <- me .wielded-stack+
			then 
		then 
	then 

	<- eventid THING_EVENT_ANIMATE = if
		\ <- me .anim.state@ if then;
		
		<- me .wielded-stack 0 > if 
		
				<- me .weapon_state.val@ 1 = if 
					1 2 rnd <- me .weapon_state.frame!
					0 0.8 1 45 <- me .pos d-light
				then 
		
			<- me .anim.counter@ 1 = if
					
				1 <- me .weapon_state.frame!
				sfx{ pulse 400 d! 200 freq! 600 freq2! 0.30 0.36 frnd pitch! 0.95 0.96 frnd q! } \ ignition sound
				\ should improve sfx sometime...
				1 <- me .weapon_state.val!
			then 
		else 
			0 <- me .weapon_state.frame!
			0 <- me .weapon_state.val!
		then 
	then

; 	
wielder_handler: last 


custom: Megaphone
	weapon: DINKphone
	\ theres a CALL at the DINKphone
	\ its for YOU
	spriteid16x32: 52
	melee_start_angle: 0
	melee_windup_angle: -15
	melee_end_angle: 15
	melee_aiming: 1
	melee_fatigue_scale: 0
	cooldown: 0.5
	leaning: 0.5
	power: 0.25
	knockback: 4
	melee_aiming: 1
	melee_reach: 5
	melee_retract: 0.75
	melee_range: 30
	melee_extra_hits: 5
	melee_extra_chance: 1
	melee_aiming_offset: 4
	swoosh_abs_particle1: 0
	swoosh_abs_particle2: 0
	thrust_range: 4

	: DINK_lines 1 20 rnd case 
			1 of "EAT WHOLE MINTS" endof 
			2 of "EAT BRICKS" endof 
			3 of "ALSO TRY TERRARIA" endof
			4 of "LONG SOCKS OR DEATH" endof 
			5 of "SHEEP ARE EVIL" endof 
			6 of "MY WIFE LEFT ME" endof 
			7 of "...AND THEN HE..." endof 
			8 of "HAIRSPRAY IS YUMMY" endof 
			9 of "I LOVE MR ROGERS" endof 
			10 of "ROAD WORK AHEAD?" endof 
			11 of "GUWAH" endof 
			12 of "AWAWAWA" endof 
			13 of "WUFF" endof 
			14 of "GARLICCCC BREADDD!" endof 
			15 of "IS THIS THING ON?" endof 
			16 of "CHECK THIS OUT!" endof 
			17 of "GO TO WWW.COM" endof 
			18 of "WHERE'S KEPA?" endof 
			19 of "THE GOV'T LOVES POOP" endof 
			20 of "TESTING TESTING 1-2-3" endof 
		endcase
	;

	: megaphone-commands args( me )
		<- me .isattack? not if then;
		<- me .carryid@ if then;

		<- me .pos particle{
			new pos!
			<- me .aim_angle@ angle!
			particles32_base_id 0x 1a + spriteid!
			angle@ anglexy 2 xymul vel!
			vel@ 4 xymul pos@ xyadd pos!
			1.025 grow!
			20 ticks!
			5 fade_out!
		}

		sfx{ <- me .character@ charbabble 2 scale! } \ LOUD 
		5 <- me .fatigue+ 

		1 1 <- me .pos alertlcxy
		DINK_lines <- me .yellmsg

	;

	:noname args( me eventid )
		<- eventid THING_EVENT_SWING = if <- me megaphone-commands then;
	;

	wielder_handler: last


