: debuff_display3 args( me )	

	<- me .pos 		-2 2 rnd -5 xyadd 
	particle{ new pos!
		40 ticks!
		\ 1 0 0 rgb!
		15 fade_out!
		weapons_base_id 293 + spriteid!
