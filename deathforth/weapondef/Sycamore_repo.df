	\ defer spawn-fracture
	


: link_listen args( me teid ) 

	<- teid THING_EVENT_DIED = if 
		-1 <- me .character@ .user.special_counter@ #thing .character@ .health! 
	then \ kill your creator 

; 	
	
: legionsplit args( chara )

	146 <- chara .specialtype!
	WEAPON_RAHJL <- chara .weapona!
	1 <- chara .weapon_nodropa!
	1 <- chara .carrying.slot_count!
	0 <- chara .ai.loot_chance!
	500 <- chara .ai.attack_dist!
	1 <- chara .ai.attack_chance!
	1 <- chara .ai.rush_chance!
	-1 <- chara .ai.attack_level!
	0 <- chara .strength!
	0 <- chara .fitness!
	1 <- chara .health!
	1 <- chara .vitality! 
	"Fracture" <- chara .name! 

;

: new_self_fracture new-npc lt .character@ legionsplit ; 
	
: fracture args( me eventid )	
			
		
	<- eventid THING_EVENT_DID_HIT = if
				<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if

						<- me .character@ .strength@ STAT_STRENGTH <- me .character@ .bonus@ + 4 * 15 + %chance if \ ~40% chance max
						clones-created <- me .character@ .strength@ STAT_STRENGTH <- me .character@ .bonus@ + 3 / 1 + >= if then;
						
						new_self_fracture \ fracture into many! 
						' link_listen lt .events! 
						
					<- me .character@ .specialtype@ lt .character@ .specialtype! 
						' clones-created ++
						<- me .pos lt .pos!	
						<- me lt .follow 
						0 lt .character@ .ai.loot_chance!
						0.01 lt .character@ .ai.wander_chance!
						15 lt .character@ .ai.follow_leash!  
						20 lt .character@ .ai.safety_leash!
						0.5 lt .clr.a!
						
						<- me .character@ .strength@ lt .character@ .strength!
						STAT_STRENGTH <- me .character@ .bonus@ STAT_STRENGTH lt .character@ .bonus! 
						\ Inherit STR for endless funnies 
					
						1 lt .character@ .party!
						TEAM_STATUS_FAMILIAR lt .character@ .team_status!
						
						<- me .id@ lt .character@ .user.special_counter! \ keep track of creator 
						
						sfx{ creepy }
						FLASHY "We are infinite." .. <- me .yellmsg
					then
				then
			then
	
	
	<- eventid THING_EVENT_SWING = if 
	
		50 %chance if 
			weapondef{ <- me .wielded sel -100 melee_end_angle! }
			
			else
			weapondef{ <- me .wielded sel 35 360 + melee_end_angle! }
		then
			
		<- me .character@ .seed@ 101 = not if 
			10 %chance if 
				defectchatter
			then \ LSW rancor fx  
		then 
		
	then 
		
;

wielder_handler: last 

60 constant STUN_DUR 

custom: Leather Whip
	weapon: midwhip 
	spriteid16x32: 26
	power: 0.2
	melee_extra_hits: 2
	knockback: 3.5
	cooldown: 0.9
	melee_break_scale: 0
	-4 melee_off.y!
	9 melee_off.x!
