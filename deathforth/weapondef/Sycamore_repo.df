\ CONCEPTUALLY inspired by BG2-EE where Time Stop was a 9th level spell 

0 value DID_STOP

weapondef{ 

custom: TIME STOP
	spriteid: 321
	weapon: timestop
	power: 0
	cooldown: 0
	melee_fatigue_scale: 0
	wepscorebonus
	melee_start_angle: -420
	melee_windup_angle: -420
	melee_end_angle: -420
	melee_shift.x: 1.4
	melee_shift.y: -3.6
	no_ai_use: 1 
	no_discard: 1 
	

0 value TIMESTOP_TIME
\ 0 value TIMESTOP_ACTIVE moved to globals 
0 value TIMESTOP_CLOCK 
: o'clock@ hour minute 60 / + ;	

: timestopspell args( me ) 

<- me .teammate? not if 
		<- me .character@ .specialtype@ 145 = not if 
		
		\ "zombietype??" "rot???"
		\ Yes, these are two unused variables I use to temporarily store data 
		\ That data is then restored when timestop ends 
		
		<- me .typeid@ THING_PROJECTILE = if 
			<- me .item.hint@ 0 = if 
				<- me .anim.counter@ <- me .item.hint! \ Preserve bullet lifetime during timestop 
				<- me .vel.x@ <- me .zombietype!
				<- me .vel.y@ <- me .rot! 
			else
				<- me .item.hint@ <- me .anim.counter!
							0 0 <- me .vel! 
			then 
			
			TIMESTOP_TIME 1 = if 
				<- me .zombietype@ <- me .vel.x!
				<- me .rot@ <- me .vel.y! 
			then 
		then; 
	
			2 <- me .stun!
			\ 0 0 <- me .vel! 
			2 <- me .pause! \ freezes objects 

			\ <- me .timer@ 0 > if 
			\	<- me .timer@ 1 + <- me .timer!
			\ then 
		
	then 
then 

; 

: initiate_timestop 

	TIMESTOP_ACTIVE 1 = if 
		TIMESTOP_TIME 0 > if
			mission{ ' timestopspell foreach-active-thing } \ stop EVERYTHING! I hope this doesn't break anything 
			timer_retrigger 
			
				1 1 0 tint_near!
				1 1 0 tint_far!
				1 light_mode!
				12 tint_trigger
			
			TIMESTOP_TIME 1 = if 
				0 to TIMESTOP_ACTIVE
				1 light_mode!
				1 1 1 tint_near!
				1 1 1 tint_far!
				12 tint_trigger
			then 
			
			TIMESTOP_CLOCK o'clock
			
			TIMESTOP_TIME -1 + 0 400 clamp to TIMESTOP_TIME
		then 
	then 
;
	
	
: stopplayertime args( me event )
	<- event THING_EVENT_SWING = if
	
	<- me .character@ .specialtype@ 145 = not if \ Lasija... 
		"I CAN'T CONTROL TIME!" <- me .yellmsglong
		0 <- me .anim.weapon_counter!
		30 <- me .cooldown!
	then; 

	DID_STOP 0 <> TIMESTOP_ACTIVE 0 = and if 
		"I NEED TO RECHARGE." <- me .yellmsglong
		0 <- me .anim.weapon_counter!
		30 <- me .cooldown!
	then; 
	
		TIMESTOP_ACTIVE 0 = if 
			o'clock@ to TIMESTOP_CLOCK
			
			sfx{ noise 5000 d! 150 filt! 45 delay! } 
			
			12 for 
				sfx{ noise 2 scale! 500 freq! 0.7 scale! }
				-0.08 i * 1 + 0.1 1 clamp sfx{ pitch! }  
				i ^2 1.5 / 20 + sfx{ delay! }
				i 15 * sfx{ d@ + d! } 
				
			next 
			
			1 to DID_STOP
			 
		then 
		

		TIMESTOP_ACTIVE 0 = if 
			1 to TIMESTOP_ACTIVE
			400 to TIMESTOP_TIME \ also counts the stopping phase 
		else
			\ 0 to TIMESTOP_ACTIVE
			1 to TIMESTOP_TIME 
			sfx{ noise 30 a! } 
			1 "PRAETERLABOR!" <- me .yellmsglong
		then 

		60 <- me .cooldown!
		60 <- me .action_cooldown! 
		1 <- me .anim.weapon_counter!	
	then
	
	<- event THING_EVENT_SWING <> if 
	\ "that friggin timer that i hate" 
	TIMESTOP_ACTIVE 1 = if 	
			<- me .action_cooldown@ 50 = if 
				1 "TEMPUS..." <- me .yellmsglong \ "Time..."
				\ too much? 
			then 
			
			<- me .action_cooldown@ 20 = if 
				1 "CESSARE!" <- me .yellmsglong \ "HALT!" 	
				
				\ The incantation for Time Stop was originally in Xerian language (so not really readable)
				\ Let me know if you prefer Latin or Xerian 

				<- me .pos 
					particle{ 
						new
					pos!

					0 wait!
					5 ticks!
					5 fade_out!
					0.75 scaley!
					2 scale!
					1.15 grow!
					0 vel.y!
					1 clr.r! 1 clr.g! 1 clr.b!
					0.5 clr.a! 
					1 layer!
					particles32_base_id 4 + spriteid! } 
				
				
				1 ' initiate_timestop timer_add \ Start the timestop 
				\ Todo - music stops, too? 
			then 
		then 
	then 
;

wielder_handler: last 

} 


0 value clones-created

: kill_all_defects args( chara ) 
	<- chara .specialtype@ 146 = if 
		<- chara .health@ 0 > if 
			-1 <- chara .health!
		then 
	then 
; 

