custom: Hawke's Homebrew
	weapon: hawkejuice
	spriteid: 289
	knockback: 1.5
	power: 0.2
	melee_off.y: 7
	melee_shift.x: 4
	melee_weapon_angle: 90
	melee_windup_angle: 45
	melee_start_angle: 180
	melee_end_angle: 360
	melee_off.x: 6
	melee_range: 0
	melee_retract: 0.95
	cooldown: 0.75
	melee_reach: 5
	\ melee_break_scale: 0.005
	melee_extra_hits: 1
	lightcooldown
	stack_as_charges: 1
	0 melee_fatigue_scale!
	stack_max: 80 \ Rohoa starts with 70 charges in DRTS. This is enough for 1.2ish full revives. 
	targeting: 0 

	ai_mule
	
	defer spawn-a-xeresgoop 
	
	: .humane? .typeid@ THING_HUMAN = ;
	
	: am-user? args( me )
		<- me .id@ 
	; 
	
: spawngoop args( me eventid ) 
	
	<- eventid THING_EVENT_SWING = if
	
	<- me .character@ .specialtype@ 132 <> if then; 
	
		<- me .wielded-stack 0 > if 
		<- me .useanammo
		4 <- me .cooldown! 
		
		0 <- me .weapon_state.val! 
		
		<- me .pos 55 things-in-xyrad 
			depths for i picks .humane? if
					\ -1 picks .fullheal? if then;
					\ -1 picks .id@ <- me .id@ = not if   
					i picks .character@ .health@ 1 < if
					\ "SEX2" <- me .report
					i picks .character@ .recruit
					i picks dup .character@ .health@ 1 + swap .character@ .health!
					\ -1 picks .report-health
					i picks heartz
					\ i picks .recruit
					<- me .weapon_state.val@ 1 + <- me .weapon_state.val! 
					   
					   
				sfx{ fm }
				then
					\ pawn-a-xeresgoop 
				then  
			next drop
			
		<- me .weapon_state.val@ 0 = if 
			\ If you didn't find anybody to pour liquid on, 
			 spawn-a-xeresgoop <- me lt-to-thing
			 0 360 rnd lt .angle!
			 -1 lt .pos.z!
		then 
			
		
		6 8 rnd for
			
		<- me .pos
			particle{ new pos! 15 ticks! 
			pos@ 0 2 3 frnd xyadd pos!
			
			particles_base_id 1+ spriteid!
			160 200 frnd anglexy 0.5 1.2 frnd xymul vel!
			
			1 clr.r!
			0.1 clr.g!
			0.5 1 rnd clr.b!
			glowy

		}
		next
		
		0 <- me .anim.weapon_counter! 
		
		then 
	then 
	

;

wielder_handler: last 

}

: growgoop args( me eventid )
	<- eventid THING_EVENT_TIMER = if 
		<- me .scale.x@ 1 180 / + 0 1.8 clamp <- me .scale.x! 
		<- me .scale.y@ 1 180 / + 0 1.8 clamp <- me .scale.y! 
		1 <- me .timer!
		
		
		
	then 
; 
\ Goop splats and grows on the floor! 

: xeres-goop 
	spawn weapons_base_id 290 + lt .spriteid! 25 lt .hitpoints! 10000000000 lt .mass! 1.2 lt .scale.x! 1.2 lt .scale.y! 1 lt .nocollide!
	1 lt .nocollide! 1 lt .walkover! 1 lt .no_hit! 100 lt .flammability! 100 lt .spreadability! ' growgoop lt .events! 1 lt .timer! 1 lt .layer! 
	0.5 lt .scale.x! 0.25 lt .scale.y! 0.5 lt .clr.a! 
	0.4 1 rnd lt .clr.r! 
; weapondef{ last to spawn-a-xeresgoop }
\ Ignite-able goop object for revivals 


540 constant REFILL_AMOUNT  \ Roughly about 6% total fuel capacity. Adjust as it pleases you 

weapondef{ 


custom: Sledgeslammer
	weapon: sledgeslammer
	spriteid: 287
	power: 2
	knockback: 2
	cooldown: 0.9
	melee_off.x: 0
	melee_shift.x: -3
	melee_reach: 5
	melee_range: 2

	melee_start_angle: 120
	melee_end_angle: -135
	melee_shift.x: -3
	melee_reach: -7

	melee_break_scale: 0
	melee_extra_hits: 1
	melee_extra_chance: 1
	Atier

	\ Hatchet but really good :3 
	
	
	
custom: REFUEL
	weapon: robofuel 
	spriteid16x32: 23 
	leaning: 0
	cooldown: 0
	melee_fatigue_scale: 0
	melee_windup_angle: 0
	melee_start_angle: 0 
	melee_end_angle: 0
	skill_angle_range: 0
	melee_break_scale: 0
	no_held_sprite: 1
	ammo_type: LOOT_GAS
	ammo_max: 50 
	projectiles: 0
	shell_count: 0 
	func: WEAPON_FUNC_CUSTOM_AIMING 
	boom_factor: 0 
	stack_no_show: 1 
	pointblank_near
	targeting: 0 
	ai_mule
	no_ai_use: 1 

	
	: fuel-some-bitches args( me eventid ) \ teehee 
	
		<- eventid THING_EVENT_SWING = if 
			0 <- me .anim.weapon_counter! \ stop swing anim 
		then 
	
		<- eventid THING_EVENT_SHOOT = if
		<- me .character@ .specialtype@ 133 = if	
				\ "[Invalid]" <- me .report
				sfx{ goodfx } sfx{ noise }  
				30 <- me .cooldown!
				30 <- me .action_cooldown!
				0 <- me .anim.weapon_counter!
				
			<- me .character@ .mod_flags2@ 0 = if 
				<- me .character@ .user.special_counter@ REFILL_AMOUNT  + 0 8100 clamp <- me .character@ .user.special_counter!  
			else 
				<- me .character@ .user.special_counter@ REFILL_AMOUNT  + 0 10800 clamp <- me .character@ .user.special_counter!  
			then \ LOWCHARGE, MAXCHARGE, respectively 	
				
				0.5 <- me .character@ .user.special_counter@ 8100 / 100 * ~ ~ " %" .. <- me .reportdurnow
				
				<- me .useanammo
				
			 then
		then
		
		<- eventid THING_EVENT_WIELD = if
			"REFUEL" <- me .report
		then
	
	;
	
	
	
	wielder_handler: last


} 


