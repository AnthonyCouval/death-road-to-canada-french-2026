custom: Battle Rifle
	weapon: fn_fal 
	spriteid: 329
	gun_muzzle_height: 3
	cock_sound: 2
	ammo_type: LOOT_RIFLE_SHELL
	boom_factor: 2.8
	spread_factor: 1
	reload: 0.8
	cooldown: 0.5
	power: 0.60
	knockback: 0.5
	func: WEAPON_FUNC_SHOOT
	auto_eject: 1 
	ammo_max: 60
	melee_break_scale: 0
	skill_angle_range: 10 
	projectiles: 0
	pointblank_mid
	Brangedtier


: fire-battlebolt args( me )
		
			bullet
			
			\ sfx{ growl } 
			
			<- me thing# lt .throwerid!
			<- me thing# lt .shooterid!
			<- me .aim_angle@ lt .angle!

			map{ <- me .pos <- me .angle@ anglexy 17 xymul xyadd pos>tile tile@ 0 } <> <- me .mapid@ 0 <> and not if 
				<- me .pos lt .angle@ anglexy 7 xymul xyadd lt .pos!
			else
				<- me .pos lt .pos!
				\ no shooting out the map!
			then 

			' continue_pen lt .events! 
			 
			0.05 lt .hitcheck.shoot_thru!
			2 lt .hitcheck.knockback!
			2.5 lt .hitcheck.power! 		

			40 lt .anim.counter!

			lt .angle@ anglexy 8.5 xymul lt .vel! // Speed
			1 lt .timer!
			-3 <- me .breath - lt .pos.z!
			<- me .character@ .shooting@ STAT_SHOOTING <- me .character@ .bonus@ + 3 / >int 1 + 0 3 clamp lt .weapon_state.val! 


;
	
mission{
thing-event: fnfal-events

	eventid THING_EVENT_ANIMATE = if
		me .anim.state@ if then;
		
		me .anim.counter@ 1 = if 
			0 me .weapon_state.frame!			
		then 
	then 

	eventid THING_EVENT_SHOOT = if
		me .ammocount 0 > if
			me fire-battlebolt
		\	me .ammocount 20 % 1 = if
		\		me .cooldown@ 65 + me .cooldown!
		\		2 me .weapon_state.frame!
		\		1 me .weapon_state.val!
		\		me .cooldown@ 10 - me .anim.counter!
		\		sfx{ noise } 
		\	then;
		then
		
		1 me .weapon_state.frame!
		0 me .weapon_state.val! 
	then
	
	eventid THING_EVENT_SHOOT <> if 
		1 me .weapon_state.off.x! 
	
		me .anim.weapon_counter@ 5 = if
			me .weapon_state.val@ 0 = if 
				0 me .weapon_state.frame!
			then
		then 
	then 
;
}
wielder_handler: last




