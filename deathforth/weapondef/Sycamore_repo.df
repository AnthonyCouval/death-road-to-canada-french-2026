	swoosh_particle2: 0x 46
	swoosh_range: 12
	thrust_range: 12
	melee_range: 31
	melee_reach: 28
	swoosh_vel: 2 
	\ melee_fatigue_cooldown_scale: 1.5
	Btier
	
	melee_break_scale: 0.005
	
	\ Kind of similar to Johannes whip 


: debuff_apply_whip1 args( me )	
	<- me .stun@ STUN_DUR + <- me .stun! 
	\ "stunned! 1" print 
;

: debuff_apply_whip2 args( me )	
	<- me .stun@ STUN_DUR 2 * + <- me .stun! 
	\ "stunned! 2" print 
;

: debuff_apply_whip3 args( me )	
	<- me .stun@ STUN_DUR 3 * + <- me .stun! 
	\ 	"stunned! 3" print 
;

\ 1. set anim counter to use as a timer of sorts.
\ 2. extract "real" cd; necessary due to ranger, kensai
\ 3. set weapon_state.val as "real" cd 
\ 4. use "real cd" as measure for sprite states 

: crack args( me eventid )
	<- eventid THING_EVENT_WIELD = if 
		8 <- me .weapon_state.off.x! 
	then 
	
	<- eventid THING_EVENT_ANIMATE = if
		<- me .anim.state@ if then;
		<- me .anim.counter@ 1 = if
			<- me .cooldown@ <- me .weapon_state.val! 
			\ "winner!" print 
		then
	then 
	
	<- eventid THING_EVENT_TIMER <> if 
	
		<- me .weapon_state.val@ 0 = if
			0 <- me .weapon_state.frame!
		else
		
		<- me .cooldown@ <- me .weapon_state.val@ 0.4 * < if 
			0 <- me .weapon_state.frame!
		else
			2 <- me .weapon_state.frame! 
			
			<- me .cooldown@ <- me .weapon_state.val@ 0.9 * > if 
				1 <- me .weapon_state.frame!
			then 
			
		then then
	then
	
	<- eventid THING_EVENT_SWING = if
		sfx{ noise 1000 freq! 10 a! 0.5 pitch! }
		2 <- me .anim.counter! 
		0 <- me .weapon_state.val! 

	then 

	<- eventid THING_EVENT_DID_HIT = if
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if
		
			<- me .just_hit_id@ #thing .mass@ 90 > if then;
				<- me .just_hit_id@ #thing debuff_display3 
				<- me .just_hit_id@ #thing debuff_apply_whip2
		then
	then
			
;

wielder_handler: last

	
