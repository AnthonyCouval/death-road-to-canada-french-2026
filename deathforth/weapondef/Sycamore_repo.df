							1 grow!
							\ 450 fade_out!
							particles_base_id 149 + spriteid!
							\ pos@ -5 5 frnd + swap -5 5 frnd + swap pos!
							0.4 scale!
							0 1 0 rgb!
						}
						<- me .pos <- me .aim_angle@ particle{ anglexy 2 i * 5 - xymul xyadd pos! }  
						\ why define the sfx if you arent going to use it? coz i want to re-use it for rubick later.
						\ I also wanted to experiment with delay 
					next 
					sfx{ thump 600 d! 500 freq! 400 filt! 0 20 rnd delay! 1 i 10 / + 0.4 1.4 clamp pitch! }
					
					<- me fire-reboundfadereal
					<- me .weapon_state.val@ 1 - lt .weapon_state.val! 
					<- me .hitcheck.power@ 1.25 / lt .hitcheck.power! 
					<- me .aim_angle@ anglexy 2 xymul lt .vel! 
					<- me .anim.info@ lt .anim.info!
					<- me .spriteid@ lt .spriteid! 
					1 lt .timer! 
					break 
					
				then
			next drop 
		
			
		4 for
			<- me .pos
            particle{
                new pos!
                10 ticks!
                0 360 frnd angle!
                glowy
                0.99 grow!
                5 fade_out!
                particles_base_id 149 + spriteid!
                pos@ -5 5 frnd + swap -5 5 frnd + swap pos!
                0.25 0.4 frnd scale!
                0 1 0 rgb!
            }

			next
			
		then
			
	<- eventid THING_EVENT_TIMER = if
		1 <- me .timer!

           <- me .pos
            particle{
                new pos!
                45 ticks!
				\ 3 fade_out!
                0 360 frnd angle!
                glowy
             \   0.99 grow!
                particles_base_id 149 + spriteid!
				pos@ -3 3 frnd -3 3 frnd xyadd 
                0.4 scale!
               0 1 0 rgb!
				-1 layer!
            }
			
		then
		
		\ TODO: FIX THIS I GUESS 
		\ FIGURE OUT WAY TO UNSCREW MAGE 
	
	;
	
	last to fade-damage4a
	

		: fire-fadebolt args( me )
		
		
			spawn 
			<- me .pos lt .pos!
			0 lt .clr.r! 
			1 lt .clr.g!
			0 lt .clr.b!
			2 4 rnd lt .smashybits
			1 lt .invisible!
			lt silentkillit
			0 <- me .pos.z! 
		
			<- me .pos3 
			particle{ new pos3!
				5 ticks!
				5 fade_out!
				0.75 scaley!
				0.5 scale!
				1.3 grow!
				0 vel.y!
				particles32_base_id 4 + spriteid!
				0 clr.r! 1 clr.g! 0 clr.b!
			}
				
			
			bullet

			<- me thing# lt .throwerid!
			<- me .aim_angle@ lt .angle! 

			1 lt .anim.info!
			weapons_base_id 358 20 + + lt .spriteid!

			<- me .pos lt .angle@ anglexy 20 xymul xyadd lt .pos!
			
			1 lt .clr.b!
			0 lt .clr.r!
			0.1 lt .clr.g!
			
				' aoe-damage3 lt .events! 
			 
			0.0001 lt .hitcheck.shoot_thru!
			0.5 lt .hitcheck.knockback!
			<- me .character@ .strength@ 0.2 * 1.51 + lt .hitcheck.power!		
			
			0.5 lt .anim.extra!
			
			30 lt .anim.counter!
			
			\ 3 lt .anim.substate!  

			lt .angle@ anglexy 5 xymul lt .vel! // Speed
			1 lt .timer!

			-1.6 <- me .breath - lt .pos.z!
			lt .pos lt .pos.z@ +
			
			4 STAT_STRENGTH <- me .character@ .effstat + lt .weapon_state.val! 
			fade_sfx

	;



: up_and_down args( me eventid ) 
	<- eventid THING_EVENT_ANIMATE = if 
	
	gameticks 10 % 0 = if 
		<- me .weapon_state.val@ 1 + <- me .weapon_state.val!
		<- me .weapon_state.val@ 3 > if 
			0 <- me .weapon_state.val! 
		then 
		<- me .weapon_state.val@ <- me .weapon_state.frame!
	then 
	
		<- me .anim.weapon_counter@ 6 = if 
			<- me fire-fadebolt
		then 
		
	then 
	
	<- eventid THING_EVENT_SWING = if 
		\ 0 <- me .anim.weapon_counter! 
	then 
; 

wielder_handler: last 


custom: Copy Weapon
	GREEN "Copy Weapon" .. name!
	weapon: copycopy 
	spriteid: 383
	power: 0
	stack_as_charges: 1
	stack_max: 0
	stack_no_show: 1
	func: WEAPON_FUNC_CUSTOM_AIMING
	lock_drift: 0.02
	lowestmelee
	targeting: 0
	
	lightcooldown
	ai_mule
	
	0 value stolenweapon
	
	defer WEAPON_LIST_FORBIDDEN
	
	: .am-me? .character@ .specialtype@ 151 = ; \ am I rubick? 
	: .friend? .typeid@ THING_HUMAN = ;		
	
	: .is-weapon-type?
    depths for
        pops 2 pick = if -1 break then
        i 1 = if 0 then
    next
    -rot 2drop 
	;
	
	: weapon-match?
		depths for 
			WEAPON_LIST_FORBIDDEN i picks = if -1 break then 
		next
	;
			

: stealings args( me ) 
	<- me .wielded dup
;

: stealingstack args( me ) 
	<- me .wielded-stack dup
;

: forbiddenwepcheck args( me ) 
	\	depths 0 = if then;
		WEAPON_LIST_FORBIDDEN depths for 
		\ i picks print 
	\	 i print 
			i picks <- me .character@ .weaponb@ = if -1 then; 
		next 0
;
\ : forbiddenwepcheck args( me )
\	<- me .wielded dup WEAPON_LIST_FORBIDDEN .is-weapon-type? = if then;
\ ;

: somesaying 1 10 rnd case
	1 of GREEN "My turn now!" .. endof
	2 of GREEN "Now let me try!" .. endof
	3 of GREEN "Mind if I borrow that?" .. endof
	4 of GREEN "How curious!" .. endof
	5 of GREEN "This seems handy!" .. endof
	6 of GREEN "How peculiar!" .. endof
	7 of GREEN "Oh, that never gets old." .. endof
	8 of GREEN "How about this?" .. endof
	9 of GREEN "How does this one work?" .. endof
	10 of GREEN "YOINK!" .. endof
	endcase
;

: spellerror 1 3 rnd case
	1 of GREEN "Whoops, it shattered in my hands." .. endof
	2 of GREEN "I can't steal that!" .. endof
	3 of GREEN "I can't copy that weapon." .. endof

	endcase
;

: spellsteal args( me eventid )
	<- eventid THING_EVENT_SHOOT = if
			0 <- me .weapon_state.frame!
							
		<- me .character@ .weaponb@ <- me .character@ .user.special_counter!
							
		<- me .pos <- me .aim_angle@ sin 28 * <- me .aim_angle@ cos -28 * xyadd 18 things-in-xyrad
			depths for i picks .friend? if
				depths 0 = if then; 
				i picks .am-me? not if
				 i picks stealings <- me .character@ .weaponb! drop
				 
				 <- me forbiddenwepcheck 0 = if 
				 drop 
				 i picks stealingstack <- me .character@ .stackedb! drop
					\ sfx{ haha 2 pitch! } // success steal laughs @ you
					1 <- me .weapon_slot_using!
					0 <- me .weapon_state.frame!
					
					82 %chance if
						somesaying <- me .yellmsg
					then
					
					
				else 
					drop 
					spellerror <- me .report
					<- me .character@ .user.special_counter@ <- me .character@ .weaponb!
					sfx{ glass 2 scale! }
				then 
						\ then
							then
						then
					break
				next drop // only steal one guy's weapon 
				
				15 <- me .cooldown!
				0 <- me .anim.weapon_counter!
				
	then
	
	<- eventid THING_EVENT_SWING <> if 
		<- me .pos
			particle{
				new pos!
				1 ticks!
				0 angle!
				glowy
				0.8 grow!
				0 fade_out!
				weapons_base_id 386 + spriteid!
				pos@ <- me .aim_angle@ anglexy 28 xymul xyadd pos!
				gameticks sin abs 1 + scale!
			}
	then 
		
	<- eventid THING_EVENT_ANIMATE = if
			
			<- me .isswap? if
				0 <- me .weapon_state.frame!
			then
			
			3 <- me .weapon_state.off.x! 
	
		gameticks 10 % if then; 
			
			<- me .weapon_state.frame@ 0 = if
				1 <- me .weapon_state.frame!
			then;
			
			<- me .weapon_state.frame@ 1 = if
				2 <- me .weapon_state.frame!
			then;
			
			<- me .weapon_state.frame@ 2 = if
			0 <- me .weapon_state.frame!
			then;
		then
			
;

wielder_handler: last


WEAPON_SHOTGUN clone-to: Pewter's Shotgun
	weapon: pewshotgun
	spriteid: MELEE6 0x 3f +
	projectiles: 9 ( per shell )
	shell_count: 2
	cock_sound: 2
	boom_factor: 5
	shot_power: 0.6
	shot_knockback: 5
	spread_factor: 4
	cooldown: 0.6
	shoot_thru: 0.2
	reload: 1.3
	power: 0.30
	ammo_max: 60
	Brangedtier
	
	\ stomach : 
	\ switching to this spritesheet 
	\ for the reload anim 
	spriteid16x32: 64
	
: always_anim args( me eventid ) 

	<- eventid THING_EVENT_ANIMATE = if
	\ 1 <- me .weapon_state.val@ <- me .reportdurnow
		<- me .anim.state@ if then;
			GUN_ANIMS 1 = if
				<- me .anim.counter@ 1 = if 
					<- me .weapon_state.val@ 0 = if 
						1 <- me .weapon_state.frame!
						1 <- me .weapon_state.val! 
						30 <- me .anim.counter! 
					else 
						0 <- me .weapon_state.frame! 
					then 
				then 
			then 
		then 

	<- eventid THING_EVENT_SHOOT = if	
		
		GUN_ANIMS 1 = if 
			0 <- me .weapon_state.frame!
			0 <- me .weapon_state.val! 
			<- me .character@ .perk@ "Ranger" $= if 
				18 <- me .anim.counter! 
			else 
				<- me .character@ .perk@ "The Big Shot" $= if 
					34 <- me .anim.counter! 
				else 
					23 <- me .anim.counter!
				then 
			then 
		then 
	then 

;

