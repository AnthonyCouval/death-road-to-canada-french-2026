\ Merenja's harpoon gun 	
\ Thank you basement for suggesting that i add her 
	
custom: Harpoon Gun
	spriteid: 352
	gun_muzzle_height: 3
	ammo_type: LOOT_SHOTGUN_SHELL
	\ YES IT USES SHOTGUN SHELLS
	weapon: merenjaharp
	cock_sound: 2
	boom_factor: 5
	cooldown: 0.75
	reload: 1.4
	power: 0.40
	knockback: 1
	func: WEAPON_FUNC_SHOOT
	melee_windup_angle: 0
	melee_end_angle: 225
	melee_reach: -16
	ammo_max: 50
	melee_break_scale: 0
	skill_angle_range: 25
	badmelee
	pointblank_far
	Brangedtier
	projectiles: 0 
	
: fire-harpbolt args( me )
		
			bullet
			
			<- me thing# lt .throwerid!
			<- me thing# lt .shooterid!
			<- me .aim_angle@ lt .angle!

			map{ <- me .pos <- me .angle@ anglexy 17 xymul xyadd pos>tile tile@ 0 } <> <- me .mapid@ 0 <> and not if 
				<- me .pos lt .angle@ anglexy 7 xymul xyadd lt .pos!
			else
				<- me .pos lt .pos!
				\ no shooting out the map!
			then 

			' continue_pen lt .events! 
			 
			0.1 lt .hitcheck.shoot_thru!
			6 lt .hitcheck.knockback!
			6 lt .hitcheck.power! 		

			60 lt .anim.counter!
			
			1 lt .anim.info! 
			weapons_base_id 354 + lt .spriteid!

			lt .angle@ anglexy 7 xymul lt .vel! // Speed
			1 lt .timer!
			-3 <- me .breath - lt .pos.z!
			<- me .character@ .shooting@ STAT_SHOOTING <- me .character@ .bonus@ + 1.25 / >int 2 + 4 15 clamp lt .weapon_state.val! 


;


: always_pen6 args( me eventid ) 
	
	<- eventid THING_EVENT_SHOOT = if	
		1 <- me .weapon_state.frame!
		0 <- me .weapon_state.val! 
		<- me fire-harpbolt
		52 <- me .anim.counter!
		15 <- me .shudder!
	then
	
	<- eventid THING_EVENT_ANIMATE = if
		<- me .anim.state@ if then;
		
		<- me .anim.counter@ 1 = if 
			0 <- me .weapon_state.frame!			
		then 
	then 
	
	<- eventid THING_EVENT_SHOOT <> if 
		6 <- me .weapon_state.off.x! 
	
	 then 

;

wielder_handler: last		


custom: Supply Drop 
	spriteid: 355
	weapon: supplydrop
	func: WEAPON_FUNC_SHOOT
	ammo_type: LOOT_FOOD
	ammo_max: 4
	projectiles: 0
	boom_factor: 2 
	shell_count: 4 
	1 no_discard! 
	no_ai_use: 1 
	
	\ Calls supply drop 
	\ Also provides mapwide light 
	
	defer request-a-supplies
	
	: do_flarelight_fade args( me eventid )
		<- eventid THING_EVENT_TIMER = if
			1 <- me .timer! 
			1 <- me .pos ticklight 1 0.1 0 lt .clr! <- me .weapon_state.val@ lt .rad.x! 
			
			<- me .weapon_state.val@ 0.999 * <- me .weapon_state.val! 
			
			\ 1 <- me .weapon_state.val@ <- me .reportdurnow  
			
			<- me .weapon_state.val@ 11 < if
				0 <- me .timer! 
				<- me silentkillit
			then 
		then 
	;

	: calldown args( me eventid )
		<- eventid

			THING_EVENT_ANIMATE ?(
				1 gameticks & if <- me .dust then
				1 0.5 0 25 75 rnd <- me .pos d-light
			);
			
		THING_EVENT_BREAK ?(
			request-a-supplies <- me lt-to-thing
			
			spawn 
			<- me .pos lt .pos! 
			0 lt .clr.a! 2000 lt .mass! 
			1 lt .walkover! 1 lt .no_hit! 
			1 lt .nocollide! 
			' do_flarelight_fade lt .events!
			1 lt .timer! 
			600 lt .weapon_state.val! 
			
					12 for
						<- me .pos3
						particle{
							new pos3!
							15 ticks!
							<- me .aim_angle@ angle!
							glowy
							0.8 grow!
							3 fade_out!
							particles_base_id 0x 59 + spriteid!
							i 22 * 90 - angle@ + anglexy 2 3 frnd xymul vel!
							gameticks angle!
							2 scale!
							1 0.4 1 frnd 0.4 0.6 frnd rgb!
						}
					next
					
					sfx{ noise 200 a! 4000 d! } 
					\ 900 <- me .pos ticklight 1 0.1 0 lt .clr! 300 lt .rad.x! 
			);
			

		THING_EVENT_BOUNCE ?(
			<- me .smack <- me killit
		);
			
		THING_EVENT_TIMER ?(
			1 <- me .timer!
			-3 <- me .vel.z! 
		
			<- me .pos.z@ -80 < if 
				0 <- me .hitpoints!
			then 
			
		);

		drop
	;


	: requestsupplies args( me )
		spawn <- me lt-to-thing
		weapons_base_id 356 + lt .spriteid! bcircle 7 lt .rad.x!
		<- me .aim_angle@ lt .angle!
		1 lt .walkover!
		<- me thing# lt .throwerid!
		1 lt .mass!
		1 lt .no_hit!
		1 lt .nopush!
		6 lt .hitpoints!
		1 lt .anim.counter!
		1 lt .burning!
		100 lt .flammability!
		<- me .aim_angle@ anglexy 3 xymul lt .vel!
		-4 lt .pos.z!
		<- me .aim_angle@ anglexy 7 xymul lt .pos xyadd lt .pos!
		\ lt .gravity@ 0.15 * lt .gravity!
		-3 lt .vel.z!
		0 lt .friction!
		1 lt .timer! 
		0 lt .bounce_friction!
		' calldown lt .events!

		<- me .dust
		<- me .dust
		<- me .dust

		3 for
			lt .pos
			particle{
				new pos!
				15 ticks!
				<- me .aim_angle@ angle!
				glowy
				0.8 grow!
				3 fade_out!
				particles_base_id 0x 59 + spriteid!
				i 45 * 90 - angle@ + anglexy 2 3 frnd xymul vel!
				gameticks angle!
				2 scale!
				1 0 0 rgb!
			}
		next

		5 lt .pos ticklight 1 0.5 0 lt .clr!
		sfx{ noise 400 freq! 150 a! 1000 d! 0.7 q! 2 scale! }
		5 rumble
		-25 <- me .shudder!
		-15 <- me .weapon_state.reach!
	;


	:noname args( me eventid )

		<- me .action_cooldown@ if then;

		<- eventid THING_EVENT_SHOOT = if
			<- me requestsupplies
			80 <- me .action_cooldown!
			80 <- me .cooldown! 
		then;
		
		<- eventid THING_EVENT_WIELD = if 
			5 <- me .weapon_state.off.x! 
		then 
	;

	wielder_handler: last
	
	
custom: Zatoichi
	weapon: samurai_sword
	spriteid: 357
	power: 2.5
	knockback: 0
