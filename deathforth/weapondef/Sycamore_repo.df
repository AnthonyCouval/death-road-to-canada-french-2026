	lightcooldown
	Btier

: jag_always_crits args( me eventid ) 
	<- eventid THING_EVENT_DID_HIT = if 
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if 
			<- me .fatigued? not if 
				15 %chance if \ THE JAG ALWAYS CRITS. 
					0 <- me .just_hit_id@ #thing .hitpoints!
					RED "CRIT!" .. <- me .just_hit_id@ #thing .report 
				then 
			then 
		then 
	then 
; 
wielder_handler: last 	



custom: Shield 
	weapon: warriorshield   
	spriteid16x32: 53
	cooldown: 0.5
	power: 1
	knockback: 2
	melee_extra_hits: 1 
	melee_start_angle: 270
	melee_windup_angle: 270
	melee_end_angle: melee_start_angle@
	melee_reach: 15
	melee_range: 12
	thrust_range: 12
	-2.5 melee_off.y!
	3.5 melee_off.x!
	wepscorebonus	
	melee_reach: 20
	melee_retract: 0.75
	melee_range: 8
	melee_aiming_offset: 4
	swoosh_particle1: 0x 45
	swoosh_particle2: 0x 46
	swoosh_range: 0
	swoosh_vel: 0.55
	leaning: 0	
	\ no_held_sprite: 1
	
	\ Credit to Paco Paca for the shield idea
	\ Whilst this is a my own written implementation,
	\ it uses their knowledge that an obj must be around for ~3 ticks
	\ before a zombie attempts to eat it 
	
	\ For future Sycamore... findable shields? 

: reset_soon args( me eventid ) 
	<- eventid THING_EVENT_TIMER = if 
		1 <- me .timer! 
		<- me .weapon_state.val@ -1 + <- me .weapon_state.val! 
		<- me .weapon_state.val@ 0 = if 
	
			<- me silentkillit
		then 
	then 
	
	<- eventid THING_EVENT_OVERLAP = if 
		<- me .overlapper .typeid@ THING_ZOMBIE = if 
			<- me .pos <- me .overlapper .pos xysub xynorm -0.7 xymul <- me .overlapper .vel!
	then then 
	
; 

47 constant DEG_COVERAGE
DEG_COVERAGE 2 / constant DEG_OFFSET 

: shieldpiece args( me ) 
	6 for 
		spawn 
		10 lt .hitpoints!
		' reset_soon lt .events!
		1 lt .timer!
		
		<- me .pos <- me .aim_angle@ i DEG_COVERAGE * + DEG_OFFSET 6 * - anglexy 7 xymul xyadd lt .pos!   
		\ lt .pos!
		
		24 lt .mass!
		1 lt .nopush! 
		2 lt .weapon_state.val! 
		\ -1 lt .layer!
		1 lt .no_hit! 
		1 lt .nocollide! 
		1 lt .walkover!
		3 lt .tileflags!
		<- me .vel 2 xymul lt .vel! 
		9 dup lt .rad.x! lt .rad.y! 
		
		0.25 dup lt .scale.x! lt .scale.y! 
		
		<- me .flip@ 1 = if 
			0 lt .flip! 
		else 
			1 lt .flip! 
		then 
		<- me .pos.z@ lt .pos.z! 
		
		\ 220, 110 
		
		\ i 2 = if 
		<- me .aim_angle@ ^2 bi_root 360 % 275.1 > <- me .aim_angle@ ^2 bi_root 360 % 85 < or if 
				1 <- me .weapon_state.frame! 
			else
				0 <- me .weapon_state.frame! 
		then
		\ else
			0 lt .clr.a!
		\ then 
		
	next 
; 

: antiriot args( me eventid )	

	<- eventid THING_EVENT_ANIMATE = if
		
		<- me shieldpiece
		\ 1 <- me .report
		\ 2 <- me .cooldown!
		\ 0 <- me .anim.weapon_counter!
		
		<- me .anim.extra@ 0 > if 
			gameticks 2 % 0 = if 
				1 <- me .stun!
			then 
		then \ Anti-cheese 
		

	then
	

;

wielder_handler: last

\ THIS WEAPON REQUIRES A BLANK SPRITE SLOT.
\ MODDERS: BE AWARE.

\ If this looks and works nice then rubick will get a green copy 
custom: Scorching Ray II 
	weapon: fadebolt_exp  
	spriteid: 303
	cooldown: 1
	melee_extra_hits: 0
	melee_start_angle: 0
	melee_windup_angle: 0
	melee_end_angle: melee_start_angle@
	melee_reach: 0
	melee_range: 0
	thrust_range: 0
	-2.5 melee_off.y!
	3.5 melee_off.x!
	wepscorebonus	
	melee_reach: 20
	melee_retract: 0.75
	melee_range: 8
	melee_aiming_offset: 4
	swoosh_particle1: 0x 45
	swoosh_particle2: 0x 46
	swoosh_range: 0
	swoosh_vel: 0.55
	leaning: 0	
	heavycooldown 

	: fade_sfx sfx{ thump 600 d! 500 freq! 400 filt! } ; 

	defer fade-damage3a
	
		: fire-reboundfade args( me )
	
			bullet

			<- me .aim_angle@ gameticks 35 * sin 3 * + lt .angle!

			1 lt .anim.info!
			weapons_base_id 358 20 + + lt .spriteid! \ Guess which idiot didn't pay attention initially to their comment above?

			<- me .pos lt .angle@ anglexy 20 xymul xyadd lt .pos!
			
			1 lt .clr.b!
			0 lt .clr.r!
			0.1 lt .clr.g!
			
			' fade-damage3a lt .events! 
			 
			0.00001 lt .hitcheck.shoot_thru!

			0.5 lt .hitcheck.knockback!
			
			0.5 lt .anim.extra!
			
			30 lt .anim.counter!
			
			\ 3 lt .anim.substate! 

			lt .angle@ anglexy 2 xymul lt .vel! // Speed

		;
	
	
	: aoe-damage3 args( me eventid )
	
	<- me .weapon_state.val@ 0 = if <- me silentkillit then; 
	
	
	<- eventid THING_EVENT_FREE = if
			
				<- me .pos 41 things-in-xyrad
				depths for i picks .zombie? if
					i picks .pos <- me .pos xysub xyangle <- me .aim_angle!
					
					i picks .pos <- me .pos xysub xymag 4 / 2 + for  
						<- me .pos 
						particle{
							new pos!
							45 ticks!
							0 360 frnd angle!
							glowy
							1 grow!
							\ 450 fade_out!
							particles_base_id 149 + spriteid!
							\ pos@ -5 5 frnd + swap -5 5 frnd + swap pos!
							0.4 scale!
							1 0 0.2 frnd 0 rgb!
						}
						<- me .pos <- me .aim_angle@ particle{ anglexy 2 i * 5 - xymul xyadd pos! }  
						\ why define the sfx if you arent going to use it? coz i want to re-use it for rubick later.
						\ I also wanted to experiment with delay 
					next 
					sfx{ thump 600 d! 500 freq! 400 filt! 0 20 rnd delay! 1 i 10 / + 0.4 1.4 clamp pitch! }
					
					<- me fire-reboundfade
					<- me .weapon_state.val@ 1 - lt .weapon_state.val! 
					<- me .hitcheck.power@ 1.25 / lt .hitcheck.power! 
					<- me .aim_angle@ anglexy 2 xymul lt .vel! 
					<- me .anim.info@ lt .anim.info!
					<- me .spriteid@ lt .spriteid! 
					1 lt .timer! 
					break 
					
				then
			next drop 
		
			
		4 for
			<- me .pos
            particle{
                new pos!
                10 ticks!
                0 360 frnd angle!
                glowy
                0.99 grow!
                5 fade_out!
                particles_base_id 149 + spriteid!
                pos@ -5 5 frnd + swap -5 5 frnd + swap pos!
                0.25 0.4 frnd scale!
                1 0 0.2 frnd 0 rgb!
            }

			next
			
		then
			
	<- eventid THING_EVENT_TIMER = if
		1 <- me .timer!

           <- me .pos
            particle{
                new pos!
                45 ticks!
				\ 3 fade_out!
                0 360 frnd angle!
                glowy
             \   0.99 grow!
                particles_base_id 149 + spriteid!
				pos@ -3 3 frnd -3 3 frnd xyadd 
                0.4 scale!
               1 0 0.2 frnd 0 rgb!
				-1 layer!
            }
			
		then
		
		\ TODO: FIX THIS I GUESS 
		\ FIGURE OUT WAY TO UNSCREW MAGE 
	
	;
	
	last to fade-damage3a
	

		: fire-fadebolt args( me )
		
		
			spawn 
			<- me .pos lt .pos!
			1 lt .clr.r! 
			0 lt .clr.g!
			0 lt .clr.b!
			2 4 rnd lt .smashybits
			1 lt .invisible!
			lt silentkillit
			0 <- me .pos.z! 
		
			<- me .pos3 
			particle{ new pos3!
				5 ticks!
				5 fade_out!
				0.75 scaley!
				0.5 scale!
				1.3 grow!
				0 vel.y!
				particles32_base_id 4 + spriteid!
				1 clr.r! 0 clr.g! 0 clr.b!
			}
				
			
			bullet

			<- me thing# lt .throwerid!
			<- me .aim_angle@ lt .angle! 

			1 lt .anim.info!
			weapons_base_id 358 20 + + lt .spriteid!

			<- me .pos lt .angle@ anglexy 20 xymul xyadd lt .pos!
			
			1 lt .clr.b!
			0 lt .clr.r!
			0.1 lt .clr.g!
			
				' aoe-damage3 lt .events! 
			 
			0.0001 lt .hitcheck.shoot_thru!
			0.5 lt .hitcheck.knockback!
			<- me .character@ .strength@ 0.2 * 1.4 + lt .hitcheck.power!		
			
			0.5 lt .anim.extra!
			
			30 lt .anim.counter!
			
			\ 3 lt .anim.substate!  

			lt .angle@ anglexy 5 xymul lt .vel! // Speed
			1 lt .timer!

			-1.6 <- me .breath - lt .pos.z!
			lt .pos lt .pos.z@ +
			
			4 STAT_STRENGTH <- me .character@ .effstat + lt .weapon_state.val! 
			fade_sfx

	;



: up_and_down args( me eventid ) 
	<- eventid THING_EVENT_ANIMATE = if 
	
		<- me .anim.weapon_counter@ 6 = if 
			<- me fire-fadebolt
		then 
		
	then 
	
	<- eventid THING_EVENT_SWING = if 
		\ 0 <- me .anim.weapon_counter! 
	then 
; 

wielder_handler: last 


