\ Swiss Guard weapons, porting arkhalis mechanic from DRTS 
WEAPON_DEVILFORK clone-to: Swiss Halberd
	weapon: swissthrust 
	glow: 0
	wielder_handler: 0
	spriteid48: 88
	knockback: 1.5
	power: 1.25
	cooldown: 1
	melee_extra_hits: 0
	melee_aiming_offset: 6
	melee_reach: 25
	melee_range: 18
	thrust_range: 12
	melee_off.x: 3
	wepscorebonus
	half-fatigue
	Atier
	
	\ Knock em down... 
: breach args( me event )
	<- event THING_EVENT_WIELD = if
		0 <- me .cooldown!
	then
 
	<- event THING_EVENT_DID_HIT = if
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if
			<- me .just_hit_id@ #thing dup .anim.state@ 1 = if then;
				<- me .just_hit_id@ #thing .pos 28 things-in-xyrad
					depths for i picks .zombie? if
						i picks 1 swap .anim.state!
						i picks -1 swap .vel.z!
							then
						next drop
					then
				then
;			

wielder_handler: last	
	

WEAPON_BARDICHE clone-to: Swiss Halberd
	weapon: swissslash
	spriteid48: 88
	cooldown: 1.6
	power: 2.5
	melee_extra_hits: 3
	knockback: 1 
	Atier	
	wielder_handler: 0 
	7 melee_off.x! 
	melee_fatigue_scale: 1.5 
	\ Slightly penalised, coz stamina bonus on every executed target 
	\ KNOCK EM DOWN...SMASH EM UP. 
	
	\ Execute em 
: breach args( me event )
	<- event THING_EVENT_WIELD = if
		0 <- me .cooldown!
	then
	
	<- event THING_EVENT_DID_HIT = if
		<- me .just_hit_id@ mission.vehicle@ = if then;
			<- me .just_hit_id@ #thing dup .anim.state@ 1 = if 
				<- me .just_hit_id@ #thing dup .mass@ 500 < if 
			-5 swap .vel.z! 
			
			0 swap .hitpoints! 
			
			<- me .fatigue@ -14 + <- me .fatigue!
			<- me .cooldown@ -10 + <- me .cooldown!
			sfx{ ruffle }
			then
			else drop then 
		then
;

wielder_handler: last	





custom: nunchucks 2
	spriteid: GUNS_ANIM_SPRITE 36 + 
	weapon: nunchucks2 
	cooldown: 0.7
	reload: 0
	power: 0.3
	melee_reach: 0
	melee_shift.y: YSHIFT neg
	melee_aiming: 0
	melee_start_angle: 15
	lock_drift: 0.03 // Formerly 0.03
	targeting: 0
	\ stack_max: 250
	\ stack_as_charges: 1
	0.8 custom_retract!
	0 melee_fatigue_scale! 
	Atier
	
	\ Kinda like a melee chainsaw; uses different formula for stamina 
	
	\ Strictly experimental 
	
	: anim-nunchucks args( me ) 

		<- me .isattack? if 
			1 <- me .weapon_state.frame! 
			
			gameticks 4 % not if 
				1 <- me .fatigue+
			
			then 
			
				else 
			0 <- me .weapon_state.frame!
		then 	
	; 
	
	: run-nunchucks args( me ) 
		
		0 <- me .cooldown! 
		
		<- me .pos <- me .aim_angle@ anglexy 9 xymul xyadd
			particle{ new pos! 
				weapons_base_id GUNS_ANIM_SPRITE 38 + + spriteid!
				1 ticks! 
				360 0 rnd rotate! 
			} 
		<- me .aim_angle@ ^2 bi_root 360 % 271.1 > <- me .aim_angle@ ^2 bi_root 360 % 89 < or if 
				particle{ 1 layer! }
			else 
				particle{ 0 layer! } 
			then 	
			
		0 <- me .anim.weapon_counter!
		
			gameticks 8 % not if 						
				<- me .pos xyblast 
				<- me .fatigued? if 	
					0.2 lt .hitcheck.power!		
					0.5 lt .hitcheck.knockback!
				else 
					1 3 / lt .hitcheck.power!
					1 lt .hitcheck.knockback!
				then 
	
				1 lt .hitcheck.mode!						
				6 lt .rad.x!
				<- me .pos <- me .aim_angle@ anglexy 9 xymul xyadd lt .pos!
				-1 lt .anim.substate! // Melee coloured blast
			then
		
	; 

	:noname args( me eventid )
		<- me .carryid@ if then;
		\ <- me .anim.state@ if then;

		<- eventid

			\ <- me .action_cooldown@ if then;
			
			THING_EVENT_ANIMATE ?( <- me anim-nunchucks ); 

			THING_EVENT_SWING ?( <- me run-nunchucks );
		drop
	;

	wielder_handler: last



} 


