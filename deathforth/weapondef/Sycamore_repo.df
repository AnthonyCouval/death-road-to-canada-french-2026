0 value headshot_combo


weapondef{

	custom: Marbelle
		weapon: marbelle
		spriteid16x32: 22
		gun_muzzle_height: 1
		ammo_type: LOOT_RIFLE_SHELL
		spread_factor: 0.3
		reload: 0
		power: 1.5
		cock_sound: 2
		boom_factor: 2
		cooldown: 1
		shot_knockback: 1.0
		shot_power: 2
		shoot_thru: 0.2
		func: WEAPON_FUNC_CUSTOM_AIMING
		revolver: 1
		ammo_max: 45
		projectiles: 0
		targeting: 0 
		skill_angle_range: 5
		melee_break_scale: 0
		melee_start_angle: 0
		melee_windup_angle: 0
		melee_end_angle: melee_start_angle@
		melee_aiming: 1
		melee_reach: 20
		melee_retract: 0.75
		melee_range: 8
		-2 melee_off.y!
		6 melee_off.x!
		swoosh_particle1: 0x 45
		swoosh_particle2: 0x 46
		swoosh_range: 0
		thrust_range: 8
		swoosh_vel: 1
		leaning: 0
		lock_drift: 0.008
		
		lightcooldown
		pointblank_mid
		
	: headshot args( me eventid ) 
		
		<- eventid THING_EVENT_TIMER = if 
			<- me silentkillit
		then
	;

	0 value time_elapsed

	: headshot-radbonus
		headshot_combo 39 > if headshot_combo 8 / 3 + then; 
		headshot_combo 29 > if 7 then;
		headshot_combo 19 > if 6 then;
		headshot_combo 11 > if 5 then;
		headshot_combo 7 > if 4 then;
		headshot_combo 3 > if 3.4 then;
		2
	;
	\ stomach number tweak 

	: headshot? args( me eventid )
		<- eventid THING_EVENT_FREE = if 
		
		\ <- me .weapon_state.val@ print
			
			<- me .weapon_state.val@ 0 > if 
			
			spawn
			
			1 lt .walkover!
			1 lt .nocollide!
			1 lt .no_hit!
			1 lt .tileflags!
			100 lt .hitpoints!
			1 lt .nopush!
			1000000000 lt .mass! \ frank NO
			lt .invisible
			6 lt .rad.x!
			3 lt .rad.y!
			 ' headshot lt .events!
			
			5 lt .timer!
			
			<- me .weapon_state.val@ #thing .pos 0 -5.55 xyadd lt .pos!
			
			\ " -- / -- " print
			\ "bullet xpos, ypos:" print
			\ <- me .pos.x@ print <- me .pos.y@ print
			\ "thing pos:" print
			\ <- me .weapon_state.val@ #thing .pos.x@ print <- me .weapon_state.val@ #thing .pos.y@ print
			\ "--" print
			
			\ "abs diff:" print
			\ <- me .pos.y@ <- me .weapon_state.val@ #thing .pos.y@ 5.55 - - abs print
			\ <- me .pos.y@ lt .pos.y@ - abs print
			\ "--" print

			
			\ <- me .angle@ abs 360 % -180 + abs print
			\ <- me .angle@ abs 360 % 180 swap rot swap % print
			
			<- me .pos.y@ <- me .weapon_state.val@ #thing .pos.y@ 6.5 - - abs ~ ~ 13.1 < <- me .angle@ abs 360 % -180 + abs 105 < or if \ headshot logic 
			
				<- me .weapon_state.val@ #thing .typeid@ THING_ZOMBIE = if
					<- me .weapon_state.val@ #thing 0 swap .hitpoints! sfx{ pip 2 pitch! 2 scale! } \ instakill 
					\ RED "HEADSHOT!" .. <- me .report
		
					' headshot_combo ++
					
					<- me .pos <- me .angle@ sin 10 * <- me .angle@ cos -10 * xyadd xyblast
					-1 lt .hitcheck.blast! 
					<- me .hitcheck.rad@ headshot-radbonus * 4 + 4 25 clamp lt .hitcheck.rad! \ Requires DRTS mathematics library 
					<- me .hitcheck.power@ 2 / lt .hitcheck.power!
						\ aoe damage
					
					headshot_combo 29 > if
					($ DEATH "Headshot Combo: " .. .. headshot_combo $) <- me .report
					then;
					
					headshot_combo 19 > if
					($ RAINBOW "Headshot Combo: " .. .. headshot_combo $) <- me .report
					then;
					
					headshot_combo 11 > if
					($ RED "Headshot Combo: " .. .. headshot_combo $) <- me .report
					then;
					
					headshot_combo 7 > if
					($ GREEN "Headshot Combo: " .. .. headshot_combo $) <- me .report
					then;
					
					headshot_combo 3 > if
					($ BLUE "Headshot Combo: " .. .. headshot_combo $) <- me .report
					then;
					
					headshot_combo -1 > if
					RED "HEADSHOT! " .. <- me .report
					then;
					
				then
			else
				\ "throwerid@:" print
				\ <- me .throwerid@ print
				
				<- me .throwerid@ #thing .character@ .mod_flags2@ 2 = if \ ammo back once combo ends, scepter 
				
				<- me .throwerid@ #thing .wielded sel ammo_type@ <- me .throwerid@ #thing .character@ .lootamt@ headshot_combo + <- me .throwerid@ #thing .wielded sel ammo_type@ <- me .throwerid@ #thing .character@ .lootamt!
				
				headshot_combo 0 = not if 
				($ RAINBOW "Ammo Recovered: " .. .. headshot_combo $)  120 view_w 0.8 * 175 msgtickxy
				then
				
				then
				
				0 to headshot_combo
			then	

			then
			
		then
		
		<- eventid THING_EVENT_TIMER = if
		
		\ <- me .weapon_state.val@ print
		
			1 <- me .timer!
			
			\ <- me .weapon_state.info@ 0 = if
			
				<- me .pos <- me .angle@ sin 8 * <- me .angle@ cos -8 * xyadd 17 things-in-xyrad \ I hate this method, with a passion.
					depths for i picks .zombie? if
						i picks .id@ <- me .weapon_state.val! \ get zombie i am destined to hit 
						\ i picks drop
						\ 0 <- me .timer!
						\ Bullet pen is a big problem.
						\ 1 <- me .weapon_state.info!
					then
				next 
				
			
				
				\ ' time_elapsed ++
				\ time_elapsed print
				
				<- me .hitcheck.power@ 0.15 + headshot_combo 5 / + <- me .hitcheck.power!
				\ Min 5 power ish if you hit near screen edge, at least on my monitor 
				<- me .hitcheck.rad@ 6 24 / + <- me .hitcheck.rad!
				
				
				"pp:" print
				<- me .hitcheck.power@ print
				 "st:" print
				 <- me .hitcheck.rad@ print
				
		then
	;
			
		
	: sniper_shot args( me ) 
	
			bullet

			0 to time_elapsed
		<- me thing# lt .throwerid!
		<- me .aim_angle@ lt .angle!
		<- me .pos lt .angle@ anglexy 8 xymul xyadd lt .pos!
		0 lt .hitcheck.knockback!
		
				0.5 lt .hitcheck.power! \ Grows quickly with distance 
		\		0.2 lt .hitcheck.shoot_thru!
				0 lt .hitcheck.shoot_thru! \ Grows quickly with distance  
				1 lt .anim.extra!
				1 lt .hitcheck.rad!

//		lt .hitcheck.power@ print

		lt .angle@ anglexy 6.5 xymul lt .vel! // Speed
		1 lt .timer!

		-3 <- me .breath - lt .pos.z!
		lt .pos lt .pos.z@ +
		' headshot? lt .events!
		
				-15 <- me .weapon_state.reach! // -15
		<- me .aim_angle@ anglexy -1.5 xymul <- me .vel!
		15 <- me .shudder!
		
	;
	
	

	: trained-aim args( me eventid )
	
		<- eventid THING_EVENT_ANIMATE = if
			
			<- me .anim.state@ if then;
				<- me .anim.counter@ 1 = if
				
				" / / /  " print
				
				<- me .useanammo
				<- me sniper_shot
				sfx{ thump 0.5 duty! 3 scale! 0.8 q! 140 freq! }
				
				83 <- me .character@ .shooting@ 7 * - <- me .action_cooldown!
				83 <- me .character@ .shooting@ 7 * - <- me .cooldown!
			then
			
		then
	
		<- eventid THING_EVENT_SHOOT = if 
		
		<- me .action_cooldown@ 0 > if then;
		
		
			<- me .vel 0.3 xymul <- me .vel!
			 
									<- me .pos
									particle{
										new pos!
										1 ticks!
										0 angle!
										1 grow!
										glowy
										0 fade_out!
											<- me .aim_angle@ 90 + angle!
										special_objects32_base_id 193 + spriteid!
										pos@ <- me .aim_angle@ anglexy 45 xymul xyadd pos!
										-0.2 pos.z!
									}
			
			3 <- me .anim.counter!
	
		then
		
	
		<- eventid THING_EVENT_SWING <> if 
		
		<- me .ammocount 0 = if
			<- me .character@ .mod_flags2@ 2 = if \ Scepter powerup....
				
				<- me .wielded sel ammo_type@ <- me .character@ .lootamt@ headshot_combo + <- me .wielded sel ammo_type@ <- me .character@ .lootamt!
				\ get ammo back after combo ends 
				
				\ ($ RAINBOW "Ammo Recovered: " .. .. headshot_combo $)  120 view_w 0.8 * 175 msgtickxy

				0 to headshot_combo
				then
			then
		
		

						\ weapons16_base_id 70 + spriteid!
					<- me .isattack? if
											
						9.25 <- me .weapon_state.off.x!
						-0.6 <- me .weapon_state.off.y! \ Aim down sights 
							else
						7 <- me .weapon_state.off.x!
						-2.5 <- me .weapon_state.off.y!
					then
									
					
		then
		
		
	\ <- eventid THING_EVENT_WIELD = if
	\	7 <- me .weapon_state.off.x!
	\	-2.5 <- me .weapon_state.off.y!
	\ then
	
	;
	
	wielder_handler: last

}

\ .................................................................
\ Special Gimmick weapons: flipari, sixshooter, slamfire
\ .................................................................

weapondef{

custom: Lever-Action
		weapon: flipari
		spriteid: MELEE7 76 +
		gun_muzzle_height: 1
		ammo_type: LOOT_RIFLE_SHELL
		spread_factor: 0.3
		reload: 0
		power: 1.5
		cock_sound: 2
		boom_factor: 2
		cooldown: 1
		shot_knockback: 1.0
		shot_power: 2
		shoot_thru: 0.2
		func: WEAPON_FUNC_CUSTOM_AIMING
		revolver: 0
		ammo_max: 70
		projectiles: 0
		targeting: 1 
		skill_angle_range: 5
		melee_break_scale: 0
		melee_start_angle: 0
		melee_windup_angle: 0
		melee_end_angle: melee_start_angle@
		melee_aiming: 1
		melee_reach: 20
		melee_retract: 0.75
		melee_range: 8
		-2 melee_off.y!
		6 melee_off.x!
		swoosh_particle1: 0x 45
		swoosh_particle2: 0x 46
		swoosh_range: 0
		thrust_range: 8
		swoosh_vel: 1
		leaning: 0
		lock_drift: 0.008
		
		lightcooldown
		pointblank_mid
		
	: lever_shot args( me ) 
	
			bullet

		\	0 to time_elapsed
		<- me thing# lt .throwerid!
		<- me .aim_angle@ lt .angle!
		<- me .pos lt .angle@ anglexy 8 xymul xyadd lt .pos!
		2 lt .hitcheck.knockback!
		
				4 lt .hitcheck.power!
				0.3 <- me .character@ .shooting@ 15 / + lt .hitcheck.shoot_thru! \ Necessary coz custom bullets dont interact with shooting scaling
				lt .hitcheck.shoot_thru@ print 
				0 1 rnd lt .anim.extra!


		lt .angle@ anglexy 7 xymul lt .vel! // Speed
		1 lt .timer!

		-3 <- me .breath - lt .pos.z!
		lt .pos lt .pos.z@ +
		
		
				-15 <- me .weapon_state.reach! // -15
		<- me .aim_angle@ anglexy -0.4 xymul <- me .vel!
		15 <- me .shudder!
		
	;
	
	

	: trained-aim args( me eventid )
	
		
		<- eventid THING_EVENT_SHOOT = if 
		
		<- me .action_cooldown@ 0 > if 
			<- me .action_cooldown@ 70 < if 
			<- me .action_cooldown@ 34 <- me .character@ .shooting@ - > <- me .action_cooldown@ 47 <- me .character@ .shooting@ + < and if 
						
				\ This is the timed reload mechanic.
				\ The window is longer if you're a better shooter. 
				
				0 <- me .cooldown! 
				0 <- me .action_cooldown!
				
				
			else
				<- me .deny 
				<- me .action_cooldown@ <- me .cooldown!
			then then 
		then;
		
			<- me .vel 0.3 xymul <- me .vel!
		
			
			
			\ 3 <- me .anim.counter!
			<- me .useanammo
				<- me lever_shot
				
				sfx{ thump 0.1 duty! 3 scale! 0.5 q! }
				
				\ These are my equivalents to your boom_factor effects and gunshot sounds
				\ Due to this weapon's design, I can't use either of those...
				
				3 4 rnd for
					<- me .pos
					particle{
						new pos!
						15 ticks!
						<- me .aim_angle@ angle!
						glowy
						0.8 grow!
						3 fade_out!
						particles_base_id 0x 51 + spriteid!
						i 20 40 rnd * 90 - angle@ + anglexy 2 3 frnd xymul vel! 
						pos@ angle@ anglexy 15 xymul xyadd pos!
						gameticks angle!
						1 scale!
						1 0.1 0.1 rgb!
					}
					next 
				
				83 <- me .action_cooldown!
				0 <- me .cooldown!
				0 <- me .weapon_state.angle_add! 
		
	
		then
		
		<- eventid THING_EVENT_DID_BURN <> if \ YES YES I KNOW I know i know. I hate it too, but lots of DRTS chars already have timers.
		
		\ This is my horrible awful "timer without a timer" tech and yes I hate it as much as you do. 
		
			<- me .action_cooldown@ 34 <- me .character@ .shooting@ - > <- me .action_cooldown@ 47 <- me .character@ .shooting@ + 3 + < and if 
						
						particle{ new <- me .pos pos! glowy weapons_base_id 271 + spriteid! pos.y@ -28 + pos.y! 1 ticks! 0 fade_in! 0 fade_out! 1 clr.a! }
					else
						particle{ new <- me .pos pos! glowy weapons_base_id 271 + spriteid! pos.y@ -28 + pos.y! 1 ticks! 0 fade_in! 0 fade_out! 0.3 clr.a! }
						\ in DRTS, I use two arrows in a circle pointing to one another to signify the reload.
						\ The particle above your head turns opaque for the reload window. 
					then 
					
					\ Controls the visual window for perfect reload 
				
			then 
	
	
		<- eventid THING_EVENT_SWING <> if 
		
				5 <- me .weapon_state.off.x!
				-0.5 <- me .weapon_state.off.y! \ I makes it look not weird when held. 
			
						\ weapons16_base_id 70 + spriteid!
					<- me .action_cooldown@ 5 > <- me .action_cooldown@ 60 < and if 
						
							1 <- me .weapon_state.frame! 
							\ Operate the Napkikari's lever action. 
					
							else
							
							0 <- me .weapon_state.frame! 
						
					then
					
					<- me .action_cooldown@ 60 = if 
						sfx{ noise } 
					then 
				
					
					
		then
		
		
	\ <- eventid THING_EVENT_WIELD = if
	\	7 <- me .weapon_state.off.x!
	\	-2.5 <- me .weapon_state.off.y!
	\ then
	
	;
	
	
	wielder_handler: last






custom: Dolt Big Iron
	weapon: sixshooter
	spriteid: MELEE7 78 +
	gun_muzzle_height: 3
	cock_sound: 1
	ammo_type: LOOT_BULLET	
	boom_factor: 2.75
	spread_factor: 1.2
	shot_power: 2.5
	reload: 0.16
	cooldown: 0.5
	power: 0.40
	knockback: 0.5
	shoot_thru: 0.25
	shot_knockback: 1
	func: WEAPON_FUNC_SHOOT
	revolver: 6
	ammo_max: 54
	melee_break_scale: 0
	skill_angle_range: 20
	pointblank_mid
	wepscorebonus
	
mission{
thing-event: wessonspeen-events
	eventid THING_EVENT_ANIMATE = if
		
		me .anim.state@ if then;
		me .anim.counter@ 1 = if 
			30 me .cooldown! \ Fan the hammer! 
		then 
	
		
	then

	eventid THING_EVENT_WIELD = if
		\ me .character@ .shooting@ -10 > if
			me .ammocount 0 > if
			\ 48 me .weapon_state.user!
			
			
			11 me .cooldown! \ Pretty sure this is some kinda anti-cheese 
			\ then
		then
	then
	
	
	eventid THING_EVENT_SHOOT = if 
		
		me .weapon_state.val@ 1 + me .weapon_state.val!
		90 me .action_cooldown! \ Single shots take longer 
		
		me .weapon_state.val@ 2 = if 
			me .cooldown@ 48 + me .cooldown! \ reload  penalty 
		then 
		
		20 me .anim.counter! 
		
	then 
	
	eventid THING_EVENT_DID_BURN <> if 
		\ here we are again with "i need a timer, but i cant use timer!" syndrome. 
		me .ammocount 0 > if
		
		\ me .action_cooldown@ 0 = me .weapon_state.val@ 6 = and if 
			me .ammocount 6 % me .weapon_state.val! 
		me .action_cooldown@ 0 > me .weapon_state.val@ 0 = and if 
			6 me .weapon_state.val! 
			\ 1 me .cooldown! 
		then 
		
			particle{ new me .pos pos! pos.y@ -28 + pos.y! 1 ticks! 0 fade_in! 0 fade_out! 1 clr.a! 0 global_colour! }
			
			weapons_base_id 272 + me .weapon_state.val@ + particle{ spriteid! } 
			
			\ "Bullets left in the chamber" logic, displayed above user's head 
			
			\ then 
		then 
	then 
	
	
;
}
wielder_handler: last



custom: Duckhunter
	weapon: slamfire
	spriteid: MELEE7 72 +
	gun_muzzle_height: 3
	cock_sound: 2
	ammo_type: LOOT_SHOTGUN_SHELL
	boom_factor: 4
	spread_factor: 3
	shot_power: 0.8
	projectiles: 0
	reload: 0.9
	cooldown: 0.5
	power: 0.40
	knockback: 0.5
	\ shoot_thru: 0.25
	shot_knockback: 1
	func: WEAPON_FUNC_SHOOT
	\ revolver: 1
	ammo_max: 42
	melee_break_scale: 0
	skill_angle_range: 20
	pointblank_mid
	wepscorebonus
	stack_no_show: 1
	

defer ricochetA
\ Self referential magic BS 
	
		: fire-ricochet args( me )
		
			\ 4 for 
					bullet

			\ pchar .seed@ 1 + pchar .seed! 

			\ <- me thing# lt .throwerid!
			<- me .aim_angle@ gameticks 35 * sin 3 * + lt .angle! // i really like this effect

			\ 1 lt .anim.info!
			\ orientcase2 + lt .spriteid!
			\ // weapons16_base_id 21 + lt .spriteid!
			<- me .pos lt .angle@ anglexy 20 xymul xyadd lt .pos!
			
			1 lt .clr.b!
			0 lt .clr.r!
			0.1 lt .clr.g!
			
			' ricochetA lt .events! 
			 
			0 lt .hitcheck.shoot_thru!
			\ 0.3 lt .hitcheck.power!
			0.5 lt .hitcheck.knockback!

			
			0 lt .anim.extra!
			
			6 lt .anim.counter!
			
			\ <- me .character@ .mod_flags2@ 2 = if 
			
			\  30 lt .anim.counter!
			
			\ then
			
			\ 5 lt .anim.substate!

			lt .angle@ anglexy 4 xymul lt .vel! // Speed

	;
	

	
	: aoe-damage3 args( me eventid )
	
	\ <- me .anim.counter@ 1 = if 
	
	<- me .weapon_state.val@ 0 = if <- me silentkillit then; 
	
	
	<- eventid THING_EVENT_FREE = if
			
				<- me .pos 66 things-in-xyrad
				depths for i picks .zombie? if
					i picks .pos <- me .pos xysub xyangle <- me .aim_angle!
					<- me fire-ricochet
					<- me .weapon_state.val@ 1 - lt .weapon_state.val! \ decrease ricochet counter 
					<- me .hitcheck.power@ 0.66 * lt .hitcheck.power! \ splice damage by one third 
					<- me .shooterid@ lt .shooterid! \ and owner stats 
					<- me .clr.r@ lt .clr.r! \ big shot stuff... 
					<- me .anim.substate@ lt .anim.substate! \ colour... 
					break 
					
				else
					<- me silentkillit
				then 
			next drop 
			
		then
			
	
	
	;
	
	last to ricochetA

		: fire-rbolt args( me )
		
			4 for 	
			
					bullet

			<- me thing# lt .throwerid!
			<- me thing# lt .shooterid!
			<- me .aim_angle@ 15 -15 rnd + lt .angle! 
			\ Custom aiming so, spread is totally random 
			

			\ 1 lt .anim.info!
			\ orientcase + lt .spriteid!
			// weapons16_base_id 21 + lt .spriteid!
			<- me .pos lt .angle@ anglexy 20 xymul xyadd lt .pos!

				' aoe-damage3 lt .events! 
			 
			0 0.25 frnd lt .hitcheck.shoot_thru!
			1.5 lt .hitcheck.knockback!
			1 lt .hitcheck.power! 		

			12 lt .anim.counter!
		
			
			0 0.9 frnd lt .anim.extra!
			
			
			\ 5 lt .anim.substate!

			lt .angle@ anglexy 7 xymul lt .vel! // Speed
			1 lt .timer!
			
			<- me .character@ .shooting@ 2 + 2 6 clamp lt .weapon_state.val! \ More shooting = more richochet 
			
			\ Could set anim.info to be 1 
			\ And then also set a spriteid if you wanted
			\ Special pellets or tracers or smth 
	
			next 
			
	;



	
mission{
thing-event: wessonspeen-events

	eventid THING_EVENT_WIELD = if
		\ me .character@ .shooting@ -10 > if
				6.5 me .weapon_state.off.x!
				-0.5 me .weapon_state.off.y!
				
			me .ammocount 6 > if 	
				7 me .weapon_state.val! \ Weapon_state.val determines the shots left in clip 
			else
				me .ammocount me .weapon_state.val!
			then 
			\ then
		
	then
	
	
	eventid THING_EVENT_SHOOT = if 
		
		me .weapon_state.val@ 1 - 0 7 clamp me .weapon_state.val!
		\ weapondef{ me .wielded sel 100 revolver! } 
		
		72 me .anim.counter! \ Time to begin reload 
		me .cooldown@ me .action_cooldown!
		
		me fire-rbolt
		
	then 
	
	eventid THING_EVENT_DID_BURN <> if 
		\ here we are again with "i need a timer, but i cant use timer!" syndrome. 
		
		6.5 me .weapon_state.off.x!
				-0.5 me .weapon_state.off.y!
		
		me .ammocount 0 > if
		
			me .anim.counter@ 24 > me .anim.counter@ 56 < and if 
				1 me .weapon_state.frame!
			else
				0 me .weapon_state.frame!
			then \ Operate the slide of the shotgun! 
			
			me .anim.counter@ 55 = if 
				sfx{ noise } 
			then 
			
			\ Various reloading noises 
			
			me .action_cooldown@ 33 = me .anim.counter@ 0 = me .ammocount 6 > and and if 
				sfx{ pip  } 
			then 
		
			me .anim.counter@ 0 = if
				me .weapon_state.val@ 7 < if 
					me .action_cooldown@ 0 = if 
					
				me .ammocount 6 > if 
					me .weapon_state.val@ 1 + 0 7 clamp me .weapon_state.val! 
				else
					me .weapon_state.val@ 1 + 0 me .ammocount clamp me .weapon_state.val!
				then 
						

						35 me .action_cooldown!
					me .weapon_state.val@ 1 = if 
						70 me .action_cooldown!
					\ first shell is longest to load
					\ stops spamfire, encourages full reload 
					then 
					
					
				\	weapondef{ me .wielded sel 1 revolver! } 
					then 
				then 
			then 
			
			me .weapon_state.val@ 0 = if 
				1 me .cooldown!
				
			then 
		
			\ me .weapon_state.val@ me .report 
			\ particle{ new me .pos pos! pos.y@ -21 + pos.y! 1 ticks! 0 fade_in! 0 fade_out! 1 clr.a! }
			
			\ weapons_base_id 655 + particle{ spriteid! } 
			
			
			\ then 
			
			me .weapon_state.val@ for 
				i 2 % 0 = if 
					particle{ new me .pos pos! pos.y@ -28 + pos.y! pos.x@ i 3 * + pos.x! 1 ticks! 0 fade_in! 0 fade_out! 1 clr.a! 0 global_colour! }
					weapons_base_id 279 + particle{ spriteid! } 
				else 
					particle{ new me .pos pos! pos.y@ -28 + pos.y! pos.x@ i -3 * + 3 + pos.x! 1 ticks! 0 fade_in! 0 fade_out! 1 clr.a! 0 global_colour! }
					weapons_base_id 279 + particle{ spriteid! } 
				
				\ Visually indicate how many shots are left in mag, generated from char's x position 
				
				then 
			next 
			\ me .weapon_state.val@ 7 / particle{ clr.a! } 
			
		then 
	then 
	
;
}
wielder_handler: last	

}


: heartz args( me ) 
		1 2 rnd for
		    <- me .pos -5 5 rnd 5 -5 rnd xyadd 
			particle{ new pos! glowy
				1 0 0 rgb!
				-0.5 vel.z!
				char + spriteid!
				30 ticks!
			}
		next
; 
\ This is for the ++ heart effect on successful heals. 

: .teammate? dup .character@ args( me chara ) <- me .charid@ 0= if 0 then;
	<- chara .team_status@ TEAM_STATUS_RECRUITED =
;
		
: .fullheal? dup .character@ args( me chara ) 
	<- chara .health@ <- chara .vitality@ =
;
		
: .longgone? dup .character@ args( me chara ) 
	<- chara .health@ 1 <
;

