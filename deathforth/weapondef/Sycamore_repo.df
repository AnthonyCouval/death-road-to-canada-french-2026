\ WIKI PEOPLE FOR THE LOVE OF ALL THINGS GOOD
\ THE ACTUAL BULLET STATS ARE SET BELOW IN FIRE-FIFTYBOLT
\ NOT ABOVE.
	
: fire-fiftybolt args( me )
		
			bullet
			
			\ sfx{ growl } 
			
			<- me thing# lt .throwerid!
			<- me thing# lt .shooterid!
			<- me .aim_angle@ lt .angle!

			map{ <- me .pos <- me .angle@ anglexy 17 xymul xyadd pos>tile tile@ 0 } <> <- me .mapid@ 0 <> and not if 
				<- me .pos lt .angle@ anglexy 7 xymul xyadd lt .pos!
			else
				<- me .pos lt .pos!
				\ no shooting out the map!
			then 

			' continue_pen lt .events! 
			 
			0.05 lt .hitcheck.shoot_thru!
			5 lt .hitcheck.knockback!
			6.5 lt .hitcheck.power! 
			
			80 lt .anim.counter!

			lt .angle@ anglexy 9.5 xymul lt .vel! // Speed
			1 lt .timer!
			-3 <- me .breath - lt .pos.z!
			<- me .character@ .shooting@ STAT_SHOOTING <- me .character@ .bonus@ + >int 4 + 4 11 clamp lt .weapon_state.val! 
			\ shooting translates directly to pen count 

;


: do_fifty_bolt args( me eventid ) 

	<- eventid THING_EVENT_SHOOT = if	
		1 <- me .weapon_state.frame!
		0 <- me .weapon_state.val! 
		<- me fire-fiftybolt
		52 <- me .anim.counter!
		15 <- me .shudder!
	then
	
	<- eventid THING_EVENT_ANIMATE = if
		<- me .anim.state@ if then;
		
		<- me .anim.counter@ 1 = if 
			0 <- me .weapon_state.frame!			
		then 
	then 
	
	<- eventid THING_EVENT_SHOOT <> if 
		6 <- me .weapon_state.off.x! 
	
	 then 

;

wielder_handler: last		



custom: SPICY SWIG
	weapon: hotsauce
	spriteid: 325
	power: 0
	cooldown: 0
	melee_fatigue_scale: 0
	melee_start_angle: -420
	melee_windup_angle: -420
	melee_end_angle: -360
	melee_shift.x: 1.4
	melee_shift.y: -3.6
	stack_max: 3
	stack_as_charges: 1 

: ignite_things args( me ) 
	1 <- me .try2burn 
; 

: hotsauce_yell 1 6 rnd case 
	1 of "I'M FEELIN' HOT" endof 
	2 of "HOTTTT HOTTTTT" endof 
	3 of "TEQUILAAAAA" endof 
	4 of "LIKE A DRAGONNN" endof 
	5 of "10000 SCOVILLES!" endof 
	6 of "BURN BABY BURRNNNN" endof 
	endcase
; 
	
: hotsauce args( me event )
	<- event THING_EVENT_SWING = if
	
		<- me .character@ .trait@ "Phoenix" $= <- me .character@ .trait@ "Phoenix Arisen!" $= or if 
			<- me .ammocount 0 > if 
				
				sfx{ pwm 100 freq! 1000 d! } 
				
				<- me .useanammo
				
				<- me .pos 40 things-in-xyrad
					depths for i picks .zombie? if
						i picks ignite_things
					then 
				next drop 
				
				hotsauce_yell <- me .yellmsg
				
				10 for
					<- me .pos
					particle{
						new pos!
						15 ticks!
						i 36 * angle!
						glowy
						0.8 grow!
						3 fade_out!
						particles_base_id 0x 51 + spriteid!
						i 20 40 rnd * 90 - angle@ + anglexy 2 3 frnd xymul vel! // # I saw sparks #
						pos@ angle@ anglexy 8.5 xymul xyadd pos!
						gameticks angle!
						1 scale!
						1 0.3 0 rgb!
					}
				next 
				
					<- me .pos3 
						particle{ 
							new
							pos3!

							0 wait!
							10 ticks!
							15 fade_out!
							0.85 scaley!
							0.55 scale!
							1.2 grow!
							0 vel.y!
							1 clr.r! 0.4 clr.g! 0 clr.b! 
						particles32_base_id 4 + spriteid! } 
				
					30 <- me .cooldown!
					0 <- me .anim.weapon_counter!
			else
				"EMPTY!" <- me .yellmsglong
				30 <- me .cooldown!
				0 <- me .anim.weapon_counter!
			
			then 
		else
			"TOO HOT!" <- me .yellmsglong
			30 <- me .cooldown!
			0 <- me .anim.weapon_counter!
		then 
	then
;

wielder_handler: last 


 custom: Banner
	weapon: buffbanner
	spriteid: 326
	cooldown: 1
	0 melee_off.y!
	8 melee_off.x!
	melee_fatigue_scale: 0.5
	melee_start_angle: -100
	melee_windup_angle: 0
	\ melee_end_angle: -100
	stack_max: 1800
	power: 0.5
	knockback: 2
	stack_as_charges: 1 
	
	: .zombie? .typeid@ THING_ZOMBIE = ;
	
	
\ External buff logic is handled in boot_end.df 
\ I know somebody is going to break it >~< 
	
:noname args( me eventid )
	
	<- eventid THING_EVENT_ANIMATE = if 
		
		<- me .wielded-stack 0 > if 
			
			<- me .inside_id@ 0 = if 
			
				gameticks 9 % 0 = if 
					-1 <- me .wielded-stack+
				then 
				
				gameticks 8 % 0 = if 
					\ 1 <- me .fatigue+ 
					0.66 ($ BOUNCY .. RAINBOW .. 0x df $chr .. BOUNCY_OFF .. " " ..
						BOUNCY .. 0x de $chr .. BOUNCY_OFF ..
						" " .. BOUNCY .. 0x df $chr .. " " .. BOUNCY_OFF ..
						BOUNCY .. 0x dd $chr $) <- me .reportdurnow
					\ sfx{ pulse 0.5 pitch! 500 freq! 600 filt_high! 200 filt! 5 scale! 200 d! 0 a! 0 s! 60 sync_wait! } 
				then 
				
				gameticks 60 % 0 = if 
					sfx{ <- me .character@ charbabble } 
				then 
				
				<- me .pos 3 -11 xyadd
					particle{ 
						new pos!
							0 wait!
							1 ticks!
							\ 1 fade_out!
							1 scaley!
							1 scale!
							0 vel.y!
					weapons_base_id 327 + spriteid! } 
					\ <- me .flip@ particle{ flipx! } 
					<- me .pos.z@ particle{ pos.z! } 
					<- me .turnframe@ 180 * cos 0 1 clamp particle{ layer! } 
			then 
		then 
	then
	
	<- eventid THING_EVENT_SWING <> if 
		-3 <- me .weapon_state.off.x! 
		1 <- me .weapon_state.off.y! 
	then
	
	<- eventid THING_EVENT_WIELD = if 
		11 <- me .cooldown! \ No charge dodge swap bs! 
	then 
	
	

;

 wielder_handler: last
 
