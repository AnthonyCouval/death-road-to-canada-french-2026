	}
;

: crack args( me eventid )
	<- eventid THING_EVENT_WIELD = if 
		8 <- me .weapon_state.off.x! 
	then 

	<- eventid THING_EVENT_DID_HIT = if 
		2 <- me .weapon_state.frame!
	then 

	<- eventid THING_EVENT_TIMER <> if 
		<- me .cooldown@ 21 < if 
			0 <- me .weapon_state.frame!
		else
			2 <- me .weapon_state.frame! 
			
			<- me .cooldown@ 47 > if 
				1 <- me .weapon_state.frame!
			then 
			
		then
	then
	
	<- eventid THING_EVENT_SWING = if
	sfx{ noise 1000 freq! 10 a! 0.5 pitch! }
	
	<- me .character@ .specialtype@ 134 = if 
		21 %chance if 
			1 30 rnd <- me econdorsayings <- me .yellmsglong
		then 
	then 
	
	then 

	<- eventid THING_EVENT_DID_HIT = if
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if
		
		<- me .character@ .specialtype@ 134 = if 
			<- me .just_hit_id@ <- me .character@ .user.special_counter@ #thing .character@ .voice.duty! 
			170 <- me .character@ .user.special_counter@ #thing .weapon_state.val! \ aggro timer 
		then \ econdor only!!! 
		
		\ 1.5 "YES MASTER" <- me .character@ .user.special_counter@ #thing .reportdurnow
		
			<- me .just_hit_id@ #thing .mass@ 90 > if then;
				<- me .just_hit_id@ #thing 200 swap .stun!
				<- me .just_hit_id@ #thing debuff_display3 
					then
				then
			


;

wielder_handler: last



