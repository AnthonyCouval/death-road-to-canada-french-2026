weapondef{ 

\ I decided to make the sprite LESS big compared to DRTS... it's huge!!! 
custom: Mamba
	weapon: blackmamba  
	spriteid16x32: 32
	gun_muzzle_height: 4
	cock_sound: 1
	ammo_type: LOOT_BULLET	
	boom_factor: 3.5
	spread_factor: 0
	shot_power: 4 \ 2x pistol 
	reload: 1.2
	cooldown: 0.5
	power: 0.40
	knockback: 0.5
	shoot_thru: 0.25 
	shot_knockback: 5
	func: WEAPON_FUNC_SHOOT
	revolver: 5
	projectiles: 0 
	ammo_max: 30
	melee_break_scale: 0
	skill_angle_range: 22
	pointblank_mid
	Arangedtier
	
	\ Hello wiki curators!
	\ This gun fires a custom projectile!
	\ Therefore the above stats are NOT what you are looking for :) 
	\ see below
	\ there have been many such examples of this since PANCREAS! 
	\ duckhunter, flip rifle, rifle rework rifles, mamba, flechette shotgun 
	
	
	\ Not really sure where to put this in the loot table...
	\ What do you think? 

: fire-500bolt args( me )
		
					bullet

			<- me thing# lt .throwerid!
			<- me thing# lt .shooterid!
			<- me .aim_angle@ lt .angle!

			<- me .pos lt .angle@ anglexy 20 xymul xyadd lt .pos!

			' continue_pen lt .events! 
			 
			0.10 lt .hitcheck.shoot_thru!
			5 lt .hitcheck.knockback! \ ya feel lucky punk 
			3 lt .hitcheck.power! 		

			30 lt .anim.counter!
		

			\ 3 lt .anim.substate! \ Yellow tracer from DRTS 
			
			
			\ 5 lt .anim.substate!

			lt .angle@ anglexy 10 xymul lt .vel! // Speed
			1 lt .timer!
			-5 <- me .breath - lt .pos.z!
			<- me .character@ .shooting@ STAT_SHOOTING <- me .character@ .bonus@ + 1.5 / >int 1 + 1 4 clamp lt .weapon_state.val! 
			15 <- me .shudder!

			
;

: always_pen args( me eventid ) 

	<- eventid THING_EVENT_SHOOT = if	
		1 <- me .weapon_state.frame!
		0 <- me .weapon_state.val! 
		<- me fire-500bolt
		\ 24 <- me .anim.weapon_counter!
		15 <- me .shudder!
		44 <- me .anim.counter!
	\	-15 <- me .weapon_state.reach! 
	
	
	then
	
	<- eventid THING_EVENT_ANIMATE = if
		<- me .anim.state@ if then;
		
		<- me .anim.counter@ 43 = if 
			<- me .ammocount 5 % 0 = if 
				<- me .ammocount 0 > if 
					1 <- me .weapon_state.val!
					2 <- me .weapon_state.frame! 
				then 
			then 
		then 
		
		<- me .anim.counter@ 1 = if 
			0 <- me .weapon_state.frame!			
		then 
	then 
	
	<- eventid THING_EVENT_SHOOT <> if 
		6 <- me .weapon_state.off.x! 
	
	\	<- me .anim.weapon_counter@ 3 = if
	\		<- me .weapon_state.val@ 0 = if 
	\			0 <- me .weapon_state.frame!
	\		then
	\	then 
	 then 
;

wielder_handler: last	



