0 value carkey

mission{ cyoa{

0 value thecar

: thething dup .subtypeid@ ITEM_VEHICLE =
	if to thecar else drop then ;
: getcar ' thething foreach-active-thing ; 

: lift-car interactee player .carry ($ DEATH .. "RAUUUGH!!!" $) me .say sfx{ pip 10 fx .freq! 250 fx .freq2! 0.01 fx .duty! 500 fx .d! } ;

// Also tried : lift-car me .interact_id@ #thing me .carry ;

: get-into-car
	interactee .as-current-car
	interactee .car-cyoa-default
	interactee player .enter
;

: cyoa-outside-car
	cyoa-start

	getcar
	"HORS DE LA VOITURE" cyoa-title!
	"On a une caisse. ET MAINTENANT ?" cyoa-text!

	cyoa-add-choice
		"Entrer dedans." cyoa-choice-text!
		' get-into-car cyoa-choice-handler!
	
	// Change this from soloer later
	cyoa-add-choice
		"Prendre la voiture." cyoa-choice-text!
		' lift-car cyoa-choice-handler!
	
	cyoa-add-choice
		"Laisse tomber." cyoa-choice-text!

	cyoa-show
;


cyoa: locked-car-hotwire
	"Fils branches !" cyoa-title!
	($ "Ca ne prend pas longtemps a " .. pname .. " pour forcer la voiture et la faire demarrer. Pas besoin de cles !" $) cyoa-text!
		2 to carkey goodfx get-into-car
	o'clock@ 1 + o'clock
;

cyoa: cyoa-locked-car
	carkey 1 > if cyoa-car then;

	carkey 0 > if
	"Let's Roll!" cyoa-title!
		($ "Les cles rentrent parfaitement !
		" .. pname .. " deverouiller les portieres." $) cyoa-text!
			2 to carkey goodfx
			choice( "Monter dans la voiture" )choice: get-into-car
			choice( "Laisser ca pour l'instant" )choice
			interactee .car-cyoa-default
	else
	"Locked Car" cyoa-title!
		"Cette voiture a l'air en tres bon etat.
		Mais ou sont les cles ?" cyoa-text!
		choice( "Laisser ca pour l'instant" )choice
		pchar .cmechanic+ if
			pchar charchoice( " demarre la voiture aux fils !" )choice: locked-car-hotwire
		then
	then
	STAT_STRENGTH cyoachar .effstat 99 > if
		choice( "Prendre la voiture" )choice: lift-car
	then

;

cyoa: carkeyz
	"Car Keys" cyoa-title!
	($ "C'est un trousseau de cles dans lequel il y a des cles de voiture.
	" .. pname .. " les prend." $) cyoa-text! goodfx
	1 to carkey deleteme
;

} }

: spawn-locked-car-noloot
	1 17 rnd spawncar mission{ cyoa{ ' cyoa-locked-car cyoa! } }
	0 lt .action_icon!
;

: spawn-locked-car 
	50 %chance if
		tireiron 50 %chance if -8 else 8 then movex .drift
	then
	10 30 rnd LOOT_GAS spawnloot 6 8 rnd movey 50 %chance if 2 else 10 then movex 
	spawn-locked-car-noloot
;

: carkeys keychain scatter mission{ cyoa{ ' carkeyz cyoa! } } delete-covering 1 lt .no_hit! 1 lt .weapon_state.val! ;
\ STOMACH : STOP BLOWING UP MY DAMN KEYS.

: resetcarkeys mission{ 0 to carkey } ;

: car-map-posy args( ypos car ) <- ypos <- car .destpos.y! <- ypos <- car .pos.y!
	<- car player .insideof? not if then;
	// Put the camera on the moved car if the player is in it
	<- car .pos.y@ camera.pos.y!
;

: bag-me dufflebag ;
: bag-me-out bag-me map{ pixelw 2 / lt .pos.x! pixelh lt .pos.y! } ;

: scale-car-up args( pct car ) map{ pixelh dup <- pct * - } <- car car-map-posy ;
: %mv-up 0 100 clamp 100 / mv@ dup 0= if 
		drop bag-me-out lt 
	then scale-car-up ;
