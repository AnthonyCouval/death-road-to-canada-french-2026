


\ Just load this file after the PANCREAS file, like last time. 

\ Note: after using any of the "ify" words, use the "to-mission" command. 
\ Some events take one mission to kick in, so to speak. (Technical hitch.) 

\ Btw - rare trader camp saturation aside - this is why the new chars will be road events.
\ I will modify the decks at a later date ^W^ 

\ ------------------------------------------------
\ ------------------------------------------------
\ ROHOA ("DR. HAWKE") HAWKE CHARACTER STUFF BELOW
\ ------------------------------------------------
\ ------------------------------------------------

: rohoalines 1 16 rnd case 
	1 of BLUE "Soyez plus prudent la prochaine fois !" .. endof
	2 of BLUE "Laisse-moi te retaper, mon chou." .. endof
	3 of BLUE "Du grand art ! Par un veritable expert." .. endof
	4 of BLUE "Viens ici 5 minutes." .. endof
	5 of BLUE "Qu'est-ce que tu as foutu cette fois ?" .. endof
	6 of BLUE "Ca avait l'air violent." .. endof
	7 of BLUE "Bouge pas, je m'en occupe..." .. endof
	8 of BLUE "Non, il n'y a pas de whisky dedans." .. endof
	9 of BLUE "Bouge pas, je vais t'aider..." .. endof
	10 of BLUE "Comme sur des roulettes !" .. endof
	11 of BLUE "Doucement, reste tranquille." .. endof
	12 of BLUE "J'ai pile ce qu'il faut pour ca." .. endof
	13 of BLUE "Tu peux arreter de crever, s'il te plait ?" .. endof
	14 of BLUE "Laisse moi te retaper." .. endof
	15 of BLUE "Reste tranquille un instant..." .. endof
	16 of BLUE "Attends, je peux donner un coup de main." .. endof
	endcase
;	
\ Flavour dialogue. 


: rohoa-thing-events args( me teid )

	<- teid THING_EVENT_DIED = if 
		"Non, non, attends ! Si je peux juste attraper ce qu'il y a dans-" <- me .yellmsg
	then 

	<- teid THING_EVENT_SWING = if
		<- me .cooldown@ 1.5 * <- me .cooldown! \ Melee CD penalty 
	then
	
	<- teid THING_EVENT_SHOOT = if
		<- me .cooldown@ 1.5 * <- me .cooldown! \ Ranged CD penalty 
	then
	
	<- teid THING_EVENT_TIMER = if 
		1 <- me .timer!

		<- me .character@ .mod_flags2@ 2 = if \ Scepter powerup 
			LOOT_MEDICAL <- me .character@ .lootamt@ 10 * 0 50 clamp %chance if \ Scepter powerup...

				2 <- me .invincible_counter! \ Makes character harder to grapple based on medicine loot count 
			then 
		then 	
		
		\ Don't worry too much about the scepter; mod_flags2 is never set in gameplay, so. 
		
		<- me .character@ .health@ 1 < if then; \ If i'm not dead ,
		\ "NUMBER 1" print \ debug 
		<- me .wielded dup WEAPON_MEDICBAG = if \ And I have my bag held ,  
		<- me .ammocount 0 > if \ And there's medicine in the bag, 
		\ "NUMBER 2" print 
		
		<- me .action_cooldown@ 0 = if \ and i've not healed in 30 ticks 
			<- me .pos 70 things-in-xyrad 
				depths for i picks .teammate? if \ and there's friends nearby, 
			\		"NUMBER 2.1" print 
					i picks .fullheal? not if \ and they're not fully healed, 
			\		"NUMBER 2.2" print 
					i picks .longgone? not if  \ but also not dead, 
			\		"NUMBER 2.3" print 
					gameticks print
					\ <- me .action_cooldown@ 0 > if then; 
					i picks dup .character@ .health@ 1 + swap .character@ .health! \ heal said friend! 
					i picks .report-health \ the healing is working guys i promise 
					i picks heartz \ <3 effect 
					i picks 50 swap .invincible_counter! \ temporary invulnerability!
 					30 <- me .action_cooldown! \ short cooldown, can help chars tank damage! 
					<- me .useanammo \ use some medical.. 
					
					50 %chance if 
						rohoalines <- me .yellmsg \ yell at the patient 
					then 
			\		"NUMBER 3" print 
					\ "ewwweeew" <- me .report 
					\ me silentkillit
					sfx{ fm } \ auditory confirmation 
					break 
					then then then 
				next drop
			then 
		then  
	then 
		\ <- me .interact_id@ #thing .wielded dup <- me .character@ .weapona!
		
	then
	

;

: rohoa-main-events ( teid ) args( chara eventid )
	 	
		<- eventid MAIN_EVENT_MISSION_START = if 
			<- chara .location@ 0 = if then; \ resting 
			1 <- chara .thing@ .timer! \ basic timer stuff 
		then 
		
		<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
		\ <- chara .thing@ .timer@ 0 = if 
		\ 	1 <- chara .thing@ .timer!
		\ then 
		 <- chara .thing@ swap ( teid ) rohoa-thing-events
		\ "WOWA" print 
;


\ ------------------------------------------------
\ ------------------------------------------------
\ EMBER THE GASGUZZLER ROBOT EXTRAORDINAIRE BELOW 
\ ------------------------------------------------
\ ------------------------------------------------



45 constant CHARGEINTERVAL \ Duration of one charge segment in seconds 
6 CHARGEINTERVAL * 10 * constant LOWCHARGE \ Lowest charge threshold
12 CHARGEINTERVAL * 10 * constant MODCHARGE  \ Med charge threshold 
18 CHARGEINTERVAL * 10 * constant HIGHCHARGE \ High charge threshold 
24 CHARGEINTERVAL * 10 * constant MAXCHARGE \ Max charge threshold 
-39 constant CHARGE_OFFSET \ Position of charge meter over head 

\ Change these if you want. 


: lichtsmash args( me )   \ Bonus damage + stun from high charge! 
	<- me .hitpoints@ 2 - <- me .hitpoints! 
	<- me .stun@ 75 + <- me .stun! 
	8 <- me .vel.z! 
	sfx{ thump 0.96 q! 0.66 scale! pitch@ 0.8 1.2 frnd * pitch! 150 1500 frnd filt!  } \ THUNK 
; 

: licht-thing-events args( me eventid )
	
	<- eventid THING_EVENT_DIED = if 
	
		RED "WHERE DID THE LIGHTS GO" .. <- me .yellmsg \ just coz it doesnt play through mission-events-human sometimes 
	
	then 

	<- eventid THING_EVENT_AI_ASSESS = if \ This entire eventid basically handles getting the AI to fuel itself.
		
		<- me .character@ .weaponc@ WEAPON_ROBOFUEL = if 
		
		orders_tactic@ 2 = not if \ How aggressively the AI fuels itself is based on FIGHTING or not. 
		
			<- me .character@ .user.special_counter@ LOWCHARGE <= if 
				LOOT_GAS <- me .character@ .lootamt@ 0 > if 
					
		weapondef{ <- me .character@ .weaponc@ sel ammo_type@ } <- me .character@ .lootamt@ -1 + 0 999 clamp weapondef{ <- me .character@ .weaponc@ sel ammo_type@ } <- me .character@ .lootamt!
		
		<- me .character@ .user.special_counter@ REFILL_AMOUNT  + <- me .character@ .user.special_counter! 
		\ sfx{ goodfx } 
			then then 
		
		else 
		
		<- me .character@ .user.special_counter@ MODCHARGE <= if 
				LOOT_GAS <- me .character@ .lootamt@ 0 > if 
					
		weapondef{ <- me .character@ .weaponc@ sel ammo_type@ } <- me .character@ .lootamt@ -1 + 0 999 clamp weapondef{ <- me .character@ .weaponc@ sel ammo_type@ } <- me .character@ .lootamt!
		
		<- me .character@ .user.special_counter@ REFILL_AMOUNT  + <- me .character@ .user.special_counter! 
		
			then then 
		
	then then then 


	<- eventid THING_EVENT_DID_HIT = if 
	
	
		\ Overcharge code used to go here. If you want it back, let me know. I have disabled it for now. 
		
		<- me .character@ .user.special_counter@ MODCHARGE > if  
			<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if
				<- me .just_hit_id@ #thing lichtsmash \ Award bonus damage @ high charge 
				then 
			then 
		then 
	\ then 
	
	<- me .character@ .user.special_counter@ LOWCHARGE < if 
		<- me .anim.extra@ 0 > if 
			gameticks 2 % 0 = if 
				1 <- me .stun! \ Harder to escape at low charge 
			then 
		then 
	then 
	
	<- eventid THING_EVENT_TIMER = if 
		1 <- me .timer! 
		
		5 <- me .flammability! \ Basically as-metal but for the robot..he is metal after all 
		
		<- me .inside_id@ 0 = if 
			<- me .character@ .user.special_counter@ 1 - 0 10800 clamp <- me .character@ .user.special_counter! \ Don't drain inside the car 
			
			\ Other scepter code used to be here. Again, LMK. 
			
			<- me .character@ .user.special_counter@ MODCHARGE > if  
				<- me .character@ statmod{ dup MOD_COFFEE swap .setmod } \ High charge also applies bonuses to SHT, FIT, STR 
				<- me .character@ statmod{ dup MOD_TIRED swap .clrmod }
				particle{ new <- me .pos pos! weapons_base_id 285 + spriteid! pos.y@ CHARGE_OFFSET  + pos.y! 1 ticks! 0 fade_in! 0 fade_out! 0 global_colour! }
				0.10 <- me .character@ .speed_bonus!
				
				16 %chance if 
				 <- me .pos
					particle{
						new pos!
						10 ticks!
						0 360 frnd angle!
						glowy
						0.99 grow!
						5 fade_out!
						particles_base_id 149 + spriteid!
						// angle@ anglexy 0.04 0.08 frnd xymul vel!
						pos@ -20 10 frnd + swap -6 5 frnd + swap pos!
						0.25 0.4 frnd scale!
						1 0 1 rgb!
					}
				then 
			then; 
			
			<- me .character@ .user.special_counter@ LOWCHARGE > if 
				<- me .character@ statmod{ dup MOD_COFFEE swap .clrmod }
				<- me .character@ statmod{ dup MOD_TIRED swap .clrmod }
				particle{ new <- me .pos pos! weapons_base_id 284 + spriteid! pos.y@ CHARGE_OFFSET  + pos.y! 1 ticks! 0 fade_in! 0 fade_out! 0 global_colour! }
				0 <- me .character@ .speed_bonus! \ Do literally nothing of merit when med charge 
			then; 
			
			<- me .character@ .user.special_counter@ 0 > if 
				<- me .character@ statmod{ dup MOD_COFFEE swap .clrmod }
				<- me .character@ statmod{ dup MOD_TIRED swap .setmod }
				particle{ new <- me .pos pos! weapons_base_id 283 + spriteid! pos.y@ CHARGE_OFFSET  + pos.y! 1 ticks! 0 fade_in! 0 fade_out! 0 global_colour! }
				-0.10 <- me .character@ .speed_bonus! \ Lose all speed at low charge 
			then; 
			
			<- me .character@ .user.special_counter@ 100 = if 
				1 RED "THE END DRAWS NEAR" .. <- me .character@ .reportdurnow \ # Am I really going to die? # 
			then 
			
			<- me .character@ .user.special_counter@ 0 = if 
				0 <- me .character@ .health! 
			\	0 <- me .character@ .main_events! 
			then; 
		then 

	then 
;

: licht-main-events args( chara eventid ) 

	
<- eventid MAIN_EVENT_MISSION_START = if 
		\ 1 <- chara .thing@ .timer!
		\ 1 to ihateyou
	\	HIGHCHARGE <- chara .user.special_counter!
	
		<- chara .location@ 1 = if 
			1 <- chara .thing@ .timer!
			' licht-thing-events <- chara .thing@ .events! 
		then 	
		\ used to do this the old way 
		
		\ Personality is always hidden!
		\ Ember has mood swings. 
		0 6 rnd <- chara .wits!
		0 6 rnd <- chara .attitude!
		0 6 rnd <- chara .composure!
		0 6 rnd <- chara .loyalty! 
		
		0 STAT_WITS <- chara .knownstat!
		0 STAT_COMPOSURE <- chara .knownstat!
		0 STAT_ATTITUDE <- chara .knownstat!
		0 STAT_LOYALTY <- chara .knownstat! 
		
	then 

;


: .rohoaify args( chara )
	132 <- chara .specialtype!
	"Dr. Hawke" <- chara .name!
	"insiste agressivement aupres des passants qu'elle a invente le gel lavant." <- chara .job!
	' rohoa-main-events <- chara .main_events!
	3 <- chara .carrying.slot_count!
	WEAPON_MEDICBAG <- chara .weapona!
	WEAPON_HAWKEJUICE <- chara .weaponb!
	70 <- chara .stackedb!
	5 <- chara .attitude!
	3 <- chara .wits!
	6 <- chara .loyalty!
	5 <- chara .medical!
	<- chara .nocanshoot
	1 <- chara .female!
	2 <- chara .vitality!
	2 <- chara .health!
	3 LOOT_MEDICAL <- chara .lootamt!
;

\ Note: after using either of this "ify" words, use the "to-mission" command.
\ Some events take one mission to kick in, so to speak. (Technical hitch.)

: .emberify args( chara )
	133 <- chara .specialtype!
	"Ember" <- chara .name!
	"jette des regards flirtatifs au reservoir de carburant de la voiture." <- chara .job!
	' licht-main-events <- chara .main_events! \ ember was originally going to be called "Licht".
	3 <- chara .carrying.slot_count!
	WEAPON_ROBOFUEL <- chara .weaponc!
	WEAPON_SLEDGESLAMMER <- chara .weapona!
	1 <- chara .weapon_nodropc!
	70 <- chara .stackedb!
	5 <- chara .attitude!
	3 <- chara .wits!
	6 <- chara .loyalty!
	1 <- chara .female!
	1 <- chara .health!
	1 <- chara .vitality!
	2 <- chara .strength!
	2 <- chara .shooting!
	HIGHCHARGE <- chara .user.special_counter!
	20 LOOT_GAS <- chara .lootamt!
;

cyoa{ road{

cyoa: rohoa-scget
	"LA DROGUE MEDICINALE" cyoa-title! \ current cultural reference xd
	char-gen to recruitee ricon 5 recruitee .morale! recruitee .rohoaify
	($ rname .. " goute un liquide violet etrange sur le bout de son doigt quand elle remarque le groupe a proximite." $) cyoa-text! basic-tone
	($ "
	Tu as l'air en mauvais etat. Si tu me laisses te rejoindre, je peux te retaper." bbold $) +text
	($ "
	Le Dr. Hawke peut soigner d'autres personnages avec sa sacoche, si celle-ci est chargee de materiel MEDICAL et tenue en main !"  $) +text
	($ "
	Elle peut meme reanimer des personnages morts en versant sa propre mixture speciale sur eux ! Elle ne porte cependant aucune arme." $) +text
	// team-count 4 < if recruited then
		choice( "Demander a " .. rname .. " de vous rejoindre" )choice: recruit-yes
		choice( "LA BIOLOGIE C'EST POUR LES INTELLOS" )choice
;

\ road{ cyoa{ rohoa-scget } }

cyoa: ember-scget
	"CE MOIS DE JUILLET...UNE HISTOIRE D'AMOUR AU DIESEL" cyoa-title!
	char-gen to recruitee ricon 5 recruitee .morale! recruitee .emberify
	($ rname .. " frappe a repetition avec un marteau sur un boitier electrique quand le groupe la trouve." $) cyoa-text! basic-tone
	($ "
	BONJOUR, AUTOMATES DEBUTANTS. VOUS DEVRIEZ M'EMBAUCHER. J'AI BATTU UN ARBRE CONSCIENT EN VENANT ICI." rbold $) +text
	($ "
    Quel argument convaincant."  $) +text
	($ "
	Ember consomme du carburant ! Tu peux la ravitailler manuellement ou laisser l'IA s'en charger. La tactique FIGHTIN' l'amenera a se ravitailler plus souvent."  $) +text
	($ "
	La puissance de combat d'Ember depend de sa jauge de charge." $) +text
	// team-count 4 < if recruited then
		choice( "Demander a " .. rname .. " de vous rejoindre" )choice: recruit-yes
		choice( "Laisser ce fou accro a l'essence" )choice
;

} }

