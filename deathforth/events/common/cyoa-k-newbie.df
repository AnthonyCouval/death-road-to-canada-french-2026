// BEGIN temporary beta start message

cyoa: knoobstartB
	"The Death Road to Canada 8/26 Alpha" cyoa-title!
	choice( "EN ROUTE !" )choice
		soloer choosechar cicon

	($ "Welcome to the Death Road to Canada Alpha!
	Currently Testing: Special Characters
	You can find a full list of recent changes and instructions to help us test the game by clicking the NEWS link on the Death Road to Canada Steam page.
	Send us feedback via Kickstarter messages!" $) cyoa-text!
		8 LOOT_FOOD trunk.loot+ 1 WEAPON_BASEBALL trunk.weapon+ 30 WEAPON_GRENADE trunk.weapon+ 30 WEAPON_PIPEBOMB trunk.weapon+ 1 WEAPON_FLAMETHROWER trunk.weapon+ 500 LOOT_GAS trunk.loot+
;

// END temporary beta start message

cyoa-choice: kn1recruit
	recruitee character# cyoa-char-icon!
	WEAPON_WRENCH recruitee .weapona!
	($ rname .. " fait maintenant partie de l'equipe !
	" .. cname .. " grogne discretement un peu a ce sujet.
	En avant vers le Canada !" $) cyoa-text! 2 300 tone
	morale-- recruitee .recruit
;
cyoa-choice: kn1nope
	($ cname .. " degage de la.
	" .. "A PLUS IMBECILE." pbold .. "
	Ca semble un bon debut." $) cyoa-text! morale2+ goodfx
;

cyoa: knoobevent1
	"Allies Puissants" cyoa-title!
	char-gen to recruitee
	recruitee character# cyoa-char-icon!
	soloer choosechar
	choice( "Recruit " .. rname )choice: kn1recruit
	cchar charchoice( " PEELS OUT" )choice: kn1nope

	($ "Alors que " .. cname .. " commence le voyage vers le Canada, il rencontre son voisin, " .. rname .. ".
	" .. cname .. " a toujours deteste cette personne, mais pourrait utiliser l'aide et/ou le leurre." $) cyoa-text! basic-tone
;

: 4food2med 4 LOOT_FOOD trunk.loot+ 2 LOOT_MEDICAL trunk.loot+ ;
cyoa-choice: kn2-shotty
	($ soloname .. " a nomme ce fusil BIG DAWG. Il est capable d'exploser les zombies, de pres comme de loin. Pour un novice, c'est peut-etre le meilleur choix d'arme a feu.
	" .. Thegroup .. " acquiert " .. RED .. "BIG DAWG" .. WHITE .. "." $)
	cyoa-text! goodfx 1 WEAPON_SHOTGUN trunk.weapon+ 8 LOOT_SHOTGUN_SHELL trunk.loot+ 4food2med
;
cyoa-choice: kn2-rifle
	($ "Les fusils peuvent traverser plusieurs cranes de zombies, entre les mains d'un excellent tireur ! " .. soloname .. " n'est pas necessairement un grand tireur, mais c'est en forgeant qu'on devient forgeron.
	" .. Thegroup .. " acquiert le fusil !" $)
	cyoa-text! goodfx 1 WEAPON_RIFLE trunk.weapon+ 12 LOOT_RIFLE_SHELL trunk.loot+ 4food2med
;
cyoa-choice: kn2-pistol
	($ "Le modeste pistolet n'a peut-etre pas la puissance des grandes armes, mais il fait le travail. Et les balles de pistolet sont encore assez abondantes. Ouvrez n'importe quel tiroir et il en sortira probablement !
	" .. Thegroup .. " acquiert le pistolet !" $)
	cyoa-text! goodfx 1 WEAPON_PISTOL trunk.weapon+ 20 LOOT_BULLET trunk.loot+ 4food2med
;
cyoa-choice: kn2-gas
	"Les armes : qui en a besoin ? La voiture est une arme. Plus ce gros bloc de metal peut rouler avant de tomber en panne d'essence, plus le voyage est sur.
	Aussi, vous trouverez peut-etre une tronconneuse." cyoa-text! goodfx 150 LOOT_GAS trunk.loot+ 4food2med
;
cyoa: knoobevent2
	"En Armes et Prets" cyoa-title! 0 to cyoaicon cyoaicon
	soloer choosechar
	($ Thegroup .. " fait un petit detour vers une cache de provisions laissee la avant.
 En plus d'un peu de nourriture et de medecine, la cache contenait : " $) cyoa-text! 2 500 tone

		choice( "Fusil a pompe et 8 cartouches" )choice: kn2-shotty
		choice( "Fusil et 12 munitions" )choice: kn2-rifle
		choice( "Pistolet et 20 balles" )choice: kn2-pistol
		choice( "150 d'essence supplementaire" )choice: kn2-gas
;

cyoa-choice: kn3recruit
	recruitee character# cyoa-char-icon!
	($ rname .. " fait maintenant partie de l'equipe !
	" .. cname .. " grimace en voyant la nouvelle recrue engloutir les deux boites de conserve longuement thesaurisees.
	En avant vers le Canada !" $) cyoa-text! 2 300 tone
	-2 LOOT_FOOD trunk.loot+ recruitee .recruit
;
cyoa-choice: kn3nope
	($ cname .. " degage de la.
	" .. "PERSONNE NE TOUCHE MES BOITES DE CONSERVE." pbold .. "
	C'etait probablement le bon choix." $) cyoa-text! goodfx morale++
;

cyoa: knoobevent3
	"Recrutement d'un Vaurien" cyoa-title!
	soloer choosechar
	char-gen to recruitee
	WEAPON_SLEDGE recruitee .weapona!
	recruitee character# cyoa-char-icon!
	($ "Pas loin de la planque de " .. cname .. ", " .. thegroup .. " tombe sur quelqu'un qui erre sur la route, masse sur l'epaule.
	" .. rname .. " se presente et propose de rejoindre la mission vers le Canada en echange d'un peu de nourriture." $) cyoa-text! basic-tone
		choice( "Recruter " .. rname .. " pour 2 Nourriture" )choice: kn3recruit
		cchar charchoice( ": C'EST MA NOURRITURE" )choice: kn3nope
;

: knoob4text ($ "Quelle incroyable sagesse.
" .. cname .. " est enrichi de ce savoir. " .. cHe .. " n'oubliera jamais ces mots." $) cyoa-text! goodfx morale++
;
cyoa-choice: kn4-eyes knoob4text wits++ ;
cyoa-choice: kn4-hitit knoob4text mechanic++ ;
cyoa-choice: kn4-sick knoob4text medical++ ;
cyoa-choice: kn4-sayit knoob4text attitude++ loyalty++ cool-it++ ;
cyoa: knoobevent4
	"Sage Mentor" cyoa-title! 0 to cyoaicon cyoaicon
	soloer choosechar
	($ cname .. " decide de rendre visite a son vieux mentor une derniere fois avant de partir vers le nord.
	Le mentor de " .. cname .. " se souvient avec " .. chim .. " et offre quelques derniers conseils avant le depart :" $) cyoa-text! 2 500 tone

	choice( "NE JAMAIS FAIRE CONFIANCE A PERSONNE NI A RIEN" )choice: kn4-eyes
	choice( "SI QUELQUE CHOSE CASSE, FRAPPE-LE" )choice: kn4-hitit
	choice( "LES MALADES FONT SEMBLANT" )choice: kn4-sick
	choice( "DIS-LE NE LE CRACHE PAS" )choice: kn4-sayit
;

cyoa: knoobstart1
	"The Death Road to Canada 5/27 Alpha" cyoa-title!
	choice( "EN ROUTE !" )choice
		soloer choosechar cicon

	($ cname .. " hears rumors that Canada is a safe place, free of the threat of zombies.
	With nothing to gain from waiting around Florida, " .. che .. " decides to gather up some hoarded supplies and head north.
	" .. cname .. " brings along a trusty baseball bat!" $) cyoa-text!
		100 LOOT_GAS trunk.loot+ 2 LOOT_MEDICAL trunk.loot+ 8 LOOT_FOOD trunk.loot+ 1 WEAPON_BASEBALL trunk.weapon+
;

