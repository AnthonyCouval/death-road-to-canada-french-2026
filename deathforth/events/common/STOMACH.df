\ The Jimventory

: diff-up-jim "road{ road-difficulty 0.1 + to road-difficulty }" evaluate ;
: mega-diff-up-jim "road{ road-difficulty 0.3 + to road-difficulty }" evaluate ;

: jim1 1 STAT_STRENGTH cchar .bonus+ ;
: jim2 1 STAT_FITNESS cchar .bonus+ ;
: jim3 1 STAT_SHOOTING cchar .bonus+ ;
: jim4 1 STAT_MEDICAL cchar .bonus+ ;
: jim5 1 STAT_MECHANICAL cchar .bonus+ ;

: jim6 2 STAT_STRENGTH cchar .bonus+ diff-up-jim ;
: jim7 2 STAT_FITNESS cchar .bonus+ diff-up-jim ;
: jim8 2 STAT_SHOOTING cchar .bonus+ diff-up-jim ;
: jim9 2 STAT_MEDICAL cchar .bonus+ diff-up-jim ;
: jim10 2 STAT_MECHANICAL cchar .bonus+ diff-up-jim ;

: jim11 cchar .carrying.slot_count@ 1 + 1 3 clamp cchar .carrying.slot_count! ;

: jim12 cchar .vitality@ 1 + 1 6 clamp cchar .vitality! ;
: jim13 cchar .vitality@ 2 + 1 6 clamp cchar .vitality! diff-up-jim ;

: jim14 1 6 rnd cchar .wits! 1 6 rnd cchar .attitude! 1 6 rnd cchar .composure! 1 6 rnd cchar .loyalty! ;

: jim1choice choice( "+1 Strength" bbold )choice: jim1 ;
: jim2choice choice( "+1 Fitness" bbold )choice: jim2 ;
: jim3choice choice( "+1 Shooting" bbold )choice: jim3 ;
: jim4choice choice( "+1 Medical" bbold )choice: jim4 ;
: jim5choice choice( "+1 Mechanical" bbold )choice: jim5 ;
: jim6choice choice( "+2 Strength" bbold " +0.1x zombs" rbold .. )choice: jim6 ;
: jim7choice choice( "+2 Fitness" bbold " +0.1x zombs" rbold .. )choice: jim7 ;
: jim8choice choice( "+2 Shooting" bbold " +0.1x zombs" rbold .. )choice: jim8 ;
: jim9choice choice( "+2 Medical" bbold " +0.1x zombs" rbold .. )choice: jim9 ;
: jim10choice choice( "+2 Mech" bbold " +0.1x zombs" rbold .. )choice: jim10 ;

: jim11choice choice( "+1 Carry Slot" bbold )choice: jim11 ;

: jim12choice choice( "+1 Max HP" bbold )choice: jim12 ;
: jim13choice choice( "+2 Max HP" bbold " +0.1x zombs" rbold .. )choice: jim13 ;

: jim14choice choice( "Reroll Personality" bbold )choice: jim14 ;

	deck-new
		card: jim1choice
		card: jim2choice
		card: jim3choice
		card: jim4choice
		card: jim5choice
		card: jim6choice
		card: jim7choice
		card: jim8choice
		card: jim9choice
		card: jim10choice
		card: jim11choice
		card: jim12choice
		card: jim13choice
		card: jim14choice
	constant JIM-DECK
	JIM-DECK var jim-deck

: drawjim
	jim-deck depths 0= if
		regiondef{ JIM-DECK shuffles to jim-deck }
	then
	drawcard
	jim-deck depths 0= if
		choice( "ALL OUTTA UPGRADES!" fbold )choice
	else
		drawcard
	then
;


\ A la demande de Kepa, cette tech est reutilisee pour un rework de Nimbus.
cyoa: jumbo-getjoker
    "NIVEAU SUPERIEUR !" cyoa-title!
    93 stpick if choosechar cicon else ($ "Nimbus" pbold .. " est absent. Tant pis. " Thegroup .. " n'allait de toute facon jamais atteindre " .. "la fin de cette campagne" rainbold .. "." .. $) text! exit then
    ($ "Avec chaque jour qui passe," " Nimbus Ordeal " pbold .. "accumule de plus en plus de puissance." .. $) cyoa-text!
    ($ "Il devra accumuler encore plus de puissance s'il veut terminer sa" " quete legendaire" rainbold .. " et gagner." .. $) +crtext
    ($ "Choisissez une amelioration pour lui :" $) +crtext
       3 for drawjim next
;

\ Ca devrait etre relativement trivial pour tout moddeur potentiel de restaurer Jimbo, s'il le souhaite.
\ Remplacez juste le "93" ici et dans road.df par "153" et appelez l'evenement de recrutement via console
\ SAUVEZ-MOI DE LA PLANTE

cyoa: recruit-jumbo-yes

    ($ rname .. " accepte un as de coeur de rechange. En passant dans sa main, il devient soudainement " "comme de l'acier" rbold .. " et un " .. "sceau rouge" rainbold .. " apparait de nulle part." .. $) cyoa-text!
    ($ "Des que " rname .. " pose la carte sur la table, le pot de fleurs explose !" .. $) +crtext
    ($ "T'ES UN VRAI JOKER ! MERCI. JE VOUS SUIVRAI, AU MOINS JUSQU'A LA FIN DE CETTE ANTE." fbold $) +crtext

    team-full? if
       ($ "Le groupe est complet.
       Qui voulez-vous remplacer pour faire de la place pour " .. rname .. " ?" $) +crtext
       recruit-replace?
    then;
    ricon
    ($ Thegroup .. " accepte " .. rname .. " dans l'equipe !" $) +crtext 2 300 tone
       recruited
    recruitee .showitall
;

cyoa: jumbo-scget
    "DECK CANADIEN COLD STAKE" cyoa-title!
    char-gen to recruitee ricon 2 recruitee .morale! recruitee .jimboify
    ($ "Le groupe se promene dans un parc quand il tombe sur un bouffon." $) cyoa-text! basic-tone
    ($ rname .. " semble plonge dans une partie de poker completement dingue. En face de lui est assis une plante en pot." $) +crtext
    ($ "LA MAUVAISE PLANTE DOIT PAYER. LA MAUVAISE PLANTE DOIT PAYER." pbold  $) +crtext
    ($ WHITE "Etrangement, malgre le fait de jouer contre un objet inanime, il semble perdre." .. $) +crtext

       choice( "Le soudoyer avec une carte" )choice: recruit-jumbo-yes
       choice( "Le laisser derriere" )choice
;

