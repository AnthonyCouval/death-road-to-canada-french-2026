: .pewterify args( chara )
	152 <- chara .specialtype!
	0 <- chara .female!

	3 <- chara .strength!

	6 <- chara .fitness!
	-6 STAT_FITNESS <- chara .bonus!

	WEAPON_ROUNDHOUSE <- chara .weapon_default!
	' familyguy-main-events <- chara .main_events!
	WEAPON_PEWSHOTGUN <- chara .weapona!

	1 <- chara .wits!
	2 <- chara .attitude!

	6 <- chara .vitality!
	6 <- chara .health!

	0 <- chara .loyalty!
	2 <- chara .composure!

	-3 STAT_MORALE <- chara .bonus!
	6 <- chara .morale!

    "Electric Man" <- chara .perk!
    "Gourmand" <- chara .trait!
    "se demande ou sont passees les bonnes vieilles valeurs d'autrefois. Nyehehehe." <- chara .job!
    "Pewter" <- chara .name!
;

\ ----------------------------------------------
\ ----------------------------------------------
\ 			JIMBO "JON BALATRO" BELOW
\ ----------------------------------------------
\ ----------------------------------------------

: .jimboify args( chara )
	153 <- chara .specialtype!
	0 <- chara .female!

	-6 6 rnd STAT_STRENGTH <- chara .bonus!
	-6 6 rnd STAT_FITNESS <- chara .bonus!
	-6 6 rnd STAT_SHOOTING <- chara .bonus!
	-6 6 rnd STAT_MEDICAL <- chara .bonus!
	-6 6 rnd STAT_MECHANICAL <- chara .bonus!
	\ meet potential man

	0 6 rnd <- chara .wits!
	0 6 rnd <- chara .attitude!
	0 6 rnd <- chara .loyalty!
	0 6 rnd <- chara .composure!

	3 dup <- chara .vitality! <- chara .health!

	0 <- chara .female!

	6 <- chara .morale!

    "Blind" <- chara .perk!
    "Joker" <- chara .trait!
    "chuchote continuellement que" " LA PLANTE MALEFIQUE DOIT PAYER." fbold .. <- chara .job!
    "Jumbo" <- chara .name!

	1 <- chara .carrying.slot_count!
;

cyoa{ road{
cyoa-choice: magic-tips
    ($ GREEN "EH BIEN, IL VOUS FAUDRAIT QUELQUES MILLIERS D'ANNEES POUR APPRENDRE CE QUE J'AI APPRIS..." .. $) cyoa-text!
    ($ PURPLE "ok, pas la peine d'etre un abruti avec ca." .. $) +crtext
    morale--all
    ($ GREEN "HMM... J'AVAIS ACHETE CES OBJETS DE SOIN POUR LA BATAILLE A VENIR. ILS NE ME SERONT PLUS D'UNE GRANDE UTILITE MAINTENANT. VOUS POUVEZ LES PRENDRE A LA PLACE." .. $) +crtext
    ($ WHITE "Magus donne au groupe 2 sprays de soin !" .. $) +crtext
    ($ "Ensuite, il effectue un mouvement circulaire de la main. Un cercle de rituel apparait a ses pieds. En une seconde, il disparait dans les airs ! Magique." $) +crtext
    morale++all
    2 WEAPON_HEALSPRAY trunk.weapon+
;

cyoa: rubick-scget
    "CHIENS DE LA RUCHE 2... ATTENDS, NON" cyoa-title!
    char-gen to recruitee ricon 3 recruitee .morale! recruitee .rubick_ify
    ($ "Quand le groupe sort de la voiture pour une pause, une musique celeste retentit. Des flashs blancs dans leurs yeux. Devant eux, une sorte de truc magique ressemblant a un gobelin vert se materialise." $) cyoa-text! basic-tone
    ($ rname .. " regarde autour de lui, confus, jetant un oeil a ses mains puis vers " thegroup .. ". Il a une sorte de baton." .. $) +crtext
    ($ GREEN "SOOOOO, C'ETAIT LA MORT. IN-TE-RES-SANT. Oh, bonjour les amis !" .. $) +crtext
    ($ WHITE "C'est pas tous les jours que quelqu'un sur la route respawn devant vous." .. $) +crtext
    ($ RED "Magus peut copier les armes des autres et utiliser de la magie." .. $) +crtext
       choice( "Demander a " .. rname .. " de rejoindre" )choice: recruit-yes
       choice( "Demander a " .. rname .. " des conseils magiques" )choice: magic-tips
       choice( "Oublier cet abruti" )choice
;


cyoa: recruit-peter-yes
    team-full? if
       ($ "Le groupe est complet.
       Qui voulez-vous remplacer pour faire de la place pour " .. rname .. " ?" $) cyoa-text!
       recruit-replace?
    then;
    ricon
    ($ Thegroup .. " accepte " .. rname .. " dans l'equipe !" $) cyoa-text! 2 300 tone
       recruited
    ($ rname .. " manque presque de s'etouffer avec les galettes de riz !" $) +crtext
    -5 trunk-food+
    3 5 rnd for
       recruitee .ouch--
    next badfx
;

cyoa: peter-scget
    "MALE HUMANOIDE DE LA VARIETE FAMILIALE" cyoa-title!
    char-gen to recruitee ricon 3 recruitee .morale! recruitee .pewterify
    ($ "NYEHEHEHEHEHE. NYEHEHEHEHEHE..." fbold $) cyoa-text! basic-tone
    ($ "EH...EH " pname .. " EH, " .. pname .. "!" .. $) +crtext
    ($ pname .. " regarde autour de lui, terrifie. Qui a dit ca ?" $) +crtext
    ($ WHITE "Il y a un grand homme avec des lunettes de dessin anime devant." .. $) +crtext
    ($ "Entre deux rires, il dit qu'il vous rejoindra, pour des" " galettes de riz." rbold ..  $) +crtext

       trunk-food 4 > if
          choice( "Offrir a " .. rname .. " 5 nourriture de galettes de riz" )choice: recruit-peter-yes
       then
          choice( "Le rejeter" )choice

;

