\ 			RUBICK SPELLSTEALER BELOW 
\ ----------------------------------------------
\ ----------------------------------------------

: rubick-thing-events args( me eventid ) 
	<- eventid THING_EVENT_SWING <> if 
		1 <- me .character@ .weapon_nodropb! 
	then 
	
	<- eventid THING_EVENT_DIED = if 
		GREEN "i lost?" .. <- me .yellmsg 
	then 
; 
	

: never_drop_things args( chara eventid ) 
	\ 1 <- me .character@ .weapon_nodropc! 
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
		<- chara .thing@ swap ( teid ) rubick-thing-events
		
; 

: .rubick_ify args( chara ) 
	151 <- chara .specialtype! 
	0 <- chara .female!  
	
	WEAPON_FADEBOLT_REAL <- chara .weapona! 
	WEAPON_SHOVEL <- chara .weaponb! \ Need to put something here or the AI tries to pick up stuff that it cant  
	
	\ Think of it as like that old shovel neutral item that dug up consumables 
	
	WEAPON_COPYCOPY <- chara .weaponc! 
	1 <- chara .stackedc! 
	\ Copy weapon does not need charges
	\ It has charges because it enables the weapon to "aim" nicely 
	\ they will never be used or run out 
	
	1 <- chara .weapon_nodropc!
	1 <- chara .weapon_nodropb!
	1 <- chara .weapon_nodropa! 
	
	0 <- chara .female! 
	
	2 <- chara .strength! 
	1 <- chara .fitness! 
	6 <- chara .wits!
	3 <- chara .attitude! 
	
	2 <- chara .vitality! 
	2 <- chara .health! 
	
	0 <- chara .loyalty! 
	0 <- chara .composure! 
	
	' never_drop_things <- chara .main_events! 
	
	"Level 30" <- chara .perk! 
	"Spellstealer" <- chara .trait! 
	"will also steal your partner, children and house if unattended. A thief through and through!" <- chara .job! 
	"Magus" <- chara .name! 
; 

\ "MYYYYYYY TURN NOW"
\ my most played dota char by far 

: pewt_laugh 1 19 rnd case 
	1 of "NYEHEHEHEHEH" endof 
	2 of "Nyheheheheh" endof 
	3 of "hehehehehh" endof 
	4 of "HEHEHEHEH" endof 
	5 of "HEY LEWIS" endof 
	6 of "hey lewis" endof 
	7 of "NYEHEHEH HEHEHEH" endof 
	8 of "nyehehehehh" endof 
	9 of "I am...ELECTRIC MAN" endof 
	10 of "pewter...the zombies are here." endof 
	11 of "this is worse than the time when..." endof 
	12 of "SHUT UP MEG." endof 
	13 of "INSERT CUTAWAY GAG" endof 
	14 of "at least I'm not drinking." endof 
	15 of "I just wanna talk to him." endof 
	16 of "Buttscratcher." endof 
	17 of "Life is a terrible thing!" endof 
	18 of "IT INSISTS UPON ITSELF." endof 
	19 of "OOOH! A DOLLAR." endof 
	endcase
; 

: familyguy-thing-events args( me eventid ) 
	<- eventid THING_EVENT_SWING = if 
		
		player 0 = not if 
			16 %chance if 
				<- me .id@ pchar .thing@ .id@ = if 
					pewt_laugh <- me .yellmsg
				else
					50 %chance if 
						"hey, hey " pchar .name@ .. "..." .. <- me .yellmsg
							else 
						"hey " pchar .name@ .. <- me .yellmsg
					then 
				then 
			then 
		then 	
	then 
	
	<- eventid THING_EVENT_DIED = if 
		RED "*gasp*...aaaaaah...*gasp*...ahhhh..." .. <- me .yellmsg 
	then 
; 
	

: familyguy-main-events args( chara eventid ) 
	\ 1 <- me .character@ .weapon_nodropc! 
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
		<- chara .thing@ swap ( teid ) familyguy-thing-events
		
; 

\ ----------------------------------------------
\ ----------------------------------------------
\ 	PETER "I JUST WANNA TALK TO HIM" GRIFFIN BELOW 
\ ----------------------------------------------
\ ----------------------------------------------

: .pewterify args( chara ) 
	152 <- chara .specialtype! 
	0 <- chara .female!  
	
	3 <- chara .strength!
	
	6 <- chara .fitness! 
	-6 STAT_FITNESS <- chara .bonus! 

	WEAPON_ROUNDHOUSE <- chara .weapon_default! 
	' familyguy-main-events <- chara .main_events! 
	WEAPON_PEWSHOTGUN <- chara .weapona! 
	
	1 <- chara .wits!
	2 <- chara .attitude! 
	
	6 <- chara .vitality! 
	6 <- chara .health! 
	
	0 <- chara .loyalty! 
	2 <- chara .composure! 
	
	-3 STAT_MORALE <- chara .bonus! 
	6 <- chara .morale! 
	
	"Electric Man" <- chara .perk! 
	"Gourmand" <- chara .trait! 
	"is wondering where all those good old-fashioned values have gone. Nyehehehe." <- chara .job! 
	"Pewter" <- chara .name! 
; 

\ ----------------------------------------------
\ ----------------------------------------------
\ 			JIMBO "JON BALATRO" BELOW 
\ ----------------------------------------------
\ ----------------------------------------------

: .jimboify args( chara ) 
	153 <- chara .specialtype! 
	0 <- chara .female!  
	
	-6 6 rnd STAT_STRENGTH <- chara .bonus! 
	-6 6 rnd STAT_FITNESS <- chara .bonus! 
	-6 6 rnd STAT_SHOOTING <- chara .bonus! 
	-6 6 rnd STAT_MEDICAL <- chara .bonus! 
	-6 6 rnd STAT_MECHANICAL <- chara .bonus! 
	\ meet potential man 
	
	0 6 rnd <- chara .wits!
	0 6 rnd <- chara .attitude! 
	0 6 rnd <- chara .loyalty! 
	0 6 rnd <- chara .composure! 
	
	3 dup <- chara .vitality! <- chara .health! 
	
	0 <- chara .female! 

	6 <- chara .morale! 
	
	"Blind" <- chara .perk! 
	"Joker" <- chara .trait! 
	"continuously whispers that" " THE EVIL PLANT MUST PAY." fbold .. <- chara .job! 
	"Jumbo" <- chara .name! 
	
	1 <- chara .carrying.slot_count! 
; 

cyoa{ road{ 
cyoa-choice: magic-tips
	($ GREEN "WELL, IT WOULD TAKE YOU A FEW THOUSAND YEARS TO LEARN WHAT I HAVE LEARNED..." .. $) cyoa-text!
	($ PURPLE "ok, no need to be a dink about it." .. $) +crtext
	morale--all 
	($ GREEN "HMM...I DID BUY THESE HEALING ITEMS FOR THE UPCOMING BATTLE. THEY WON'T BE OF MUCH USE TO ME NOW. YOU CAN HAVE THEM INSTEAD." .. $) +crtext
	($ WHITE "Magus gives the group 2 healing sprays!" .. $) +crtext
	($ "Afterwards, he performs a circular hand motion. A ritual circle appears at his feet. In a second, he vanishes into thin air! Magical." $) +crtext
	morale++all 
	2 WEAPON_HEALSPRAY trunk.weapon+ 
; 	

cyoa: rubick-scget
	"DOGS OF THE APIARY 2...WAIT, NO" cyoa-title! 
	char-gen to recruitee ricon 3 recruitee .morale! recruitee .rubick_ify 
	($ "When the group exits their car for a break, heavenly music plays. White flashes in their eyes. In front of them, some sort of green-goblin looking magic thing materialises." $) cyoa-text! basic-tone
	($ rname .. " looks around, confused, glancing at his hands and then back towards " thegroup .. ". He has some kind of staff." .. $) +crtext 
	($ GREEN "SOOOOO, THAT WAS DEATH. INTER-EST-ING. Oh, hello friends!" .. $) +crtext 
	($ WHITE "It's not everyday somebody on the road respawns in front of you." .. $) +crtext
	($ RED "Magus can copy other weapons for himself and also can use magic." .. $) +crtext 	
		choice( "Ask " .. rname .. " to join" )choice: recruit-yes
		choice( "Ask " .. rname .. " for some magic tips" )choice: magic-tips 
		choice( "Forget this jerk" )choice
;


cyoa: recruit-peter-yes
	team-full? if
		($ "The group is full.
		Who would you like to replace to make room for " .. rname .. "?" $) cyoa-text!
		recruit-replace?
	then;
	ricon
	($ Thegroup .. " accepts " .. rname .. " to the team!" $) cyoa-text! 2 300 tone
		recruited
	($ rname .. " almost chokes to death on the rice cakes!" $) +crtext
	-5 trunk-food+ 
	3 5 rnd for 
		recruitee .ouch--
	next badfx
;

cyoa: peter-scget
	"HUMANOID MALE OF THE FAMILIAL VARIETY" cyoa-title! 
	char-gen to recruitee ricon 3 recruitee .morale! recruitee .pewterify
	($ "NYEHEHEHEHEHE. NYEHEHEHEHEHE..." fbold $) cyoa-text! basic-tone
	($ "HEY...HEY " pname .. " HEY, " .. pname .. "!" .. $) +crtext 
	($ pname .. " looks around, terrified. Who said that?" $) +crtext 
	($ WHITE "There's a large man with cartoon-like glasses ahead." .. $) +crtext
	($ "Between laughs, he says he'll join you, for some" " rice cakes." rbold ..  $) +crtext 	
	
		trunk-food 4 > if 
			choice( "Offer " .. rname .. " 5 food of rice cakes" )choice:  recruit-peter-yes
		then 
			choice( "Reject him" )choice

;

