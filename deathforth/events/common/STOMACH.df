: aoe-damage args( me eventid )
	
	<- eventid THING_EVENT_TIMER = if
		1 <- me .timer!
		
		<- me .pos.z@ -40 > if 
		
				14 for
			<- me .pos
				particle{
					new pos!
					10 ticks!
					0 360 frnd angle!
					glowy
					0.99 grow!
					5 fade_out!
					particles_base_id 149 + spriteid!
					// angle@ anglexy 0.04 0.08 frnd xymul vel!
					pos@ -15 15 frnd + swap -15 15 frnd + swap pos!
					0.25 0.4 frnd scale!
					0 0.4 1 rgb!
					}
			next
		
		15 <- me .smashybits
		0 <- me .spriteid!
		0 <- me .hitpoints!
		<- me silentkillit

	
		then
	then
	
	
	<- eventid THING_EVENT_BREAK = if
			15 for
			<- me .pos
				particle{
					new pos!
					10 ticks!
					0 360 frnd angle!
					glowy
					0.99 grow!
					5 fade_out!
					particles_base_id 149 + spriteid!
					// angle@ anglexy 0.04 0.08 frnd xymul vel!
					pos@ -20 20 frnd + swap -15 15 frnd + swap pos!
					0.25 0.4 frnd scale!
					0 0.4 1 rgb!
					}
			next
	
	
		0 <- me .spriteid! 
		0 <- me .hitpoints!
		<- me silentkillit
	
	then
;

: initiate_lightning args( me ) 


		spawn special_objects96_base_id 5 + lt .spriteid! 100 health! 2000 lt .mass! 0 lt .rad.x! 0 lt .rad.y! 0 lt .rad.z! 
		
		 1 lt .timer!
		 1 lt .tileflags!
		 1 lt .anim.info!
		 1 lt .nocollide! 
		 0 lt .rad.x! 0 lt .rad.y! 
		 -350 lt .pos.z!
		 13 lt .vel.z!
		 173 185 rnd lt .angle!	
		' aoe-damage lt .events!
		<- me .vel lt .vel xyadd lt .vel! 
	
		<- me .pos lt .pos!
		sfx{ thump 2 scale! 2.7 3.3 frnd pitch! 30 180 rnd a! 700 d! 120 r! }

		<- me .pos xyblast
			-1 lt .hitcheck.blast! 13 lt .hitcheck.rad!
			1.5 lt .hitcheck.power! 6 lt .hitcheck.knockback!


;


: zeus-thing-events args( me teid )

	<- teid THING_EVENT_DIED = if 
		"OHHHH, TRAGIC DAYYYY!" <- me .yellmsglong 
	then 

	<- teid THING_EVENT_DID_HIT = if			

	<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if
	
			6 7 rnd for
			<- me .just_hit_id@ #thing dup .pos
			particle{
				new pos!
				15 ticks!
				<- me .aim_angle@ angle!
				glowy
				0.8 grow!
				3 fade_out!
				particles_base_id 0x 51 + spriteid!
				i 20 40 rnd * 90 - angle@ + anglexy 2 3 frnd xymul vel!
				pos@ angle@ anglexy 8.5 xymul xyadd pos!
				gameticks angle!
				1 scale!
				0 0.7 1 rgb!
			}
			next
			
			20 %chance if 
				FLASHY zeus_yells .. <- me .yellmsg
			then 
			
			33 %chance if 
			<- me .pos 600 things-in-xyrad
				depths for i picks .zombie? if
					\ i picks .pos <- me .pos xysub xymag print
					i picks .pos <- me .pos xysub xymag 21 > if 
					i picks initiate_lightning 	
						break 
					then then 
				next drop
			then 
			
			<- me .character@ .stackedc@ 101 < if
			
			weapondef{ <- me .wielded sel power@ } 2 * <- me .character@ .stackedc@ + <- me .character@ .stackedc!
			
			then
			
		then
	then
	

;

: zeus-main-events ( teid ) args( chara eventid )
	 	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
	
	 <- chara .thing@ swap ( teid ) zeus-thing-events
	 
	
;

: .zeusify args( chara ) 
	
	"Zeus" <- chara .name!
	14 STAT_STRENGTH <- chara .bonus!
	6 <- chara .strength! 
	
	' zeus-main-events <- chara .main_events! 
	
	-6 STAT_FITNESS <- chara .bonus! 
	6 <- chara .fitness! 
	
	4 <- chara .health! 
	4 <- chara .vitality! 
	"was banished to the USA after an unsightly incident involving a moose and his wife." <- chara .job! 
	0 <- chara .wits! 
	0 <- chara .loyalty!

	1 <- chara .weapon_nodropc! 
	WEAPON_ZEUSFIRE <- chara .weaponc! 
	WEAPON_SUNDER <- chara .weapon_default! 
	
	0 <- chara .female! 
	
	
	3 <- chara .carrying.slot_count!

	0 <- chara .attitude!
	0 <- chara .composure! 
	
	149 <- chara .specialtype! 

	6 <- chara .morale! 
	"Electric" <- chara .perk!
	"Chiselled" <- chara .trait! 
	
; 




\ -----------------------------------------------
\ ----------------------------------------------
\ CAPTAIN "RUNS AROUND IN THE RAIN" MERENJA RAVEN STUFF BELOW 
\ -----------------------------------------------
\ -----------------------------------------------

0 value HAS_YAPPED

: merenja-thing-events args( me teid )

	<- teid THING_EVENT_DIED = if 
		"BURY ME...IN A PLUGHOLE..." <- me .yellmsglong 
		\ Would have preferred a reference to Hanna, but oh well. 
		2 weather! 
		2 wind_force! 
	then 
	
	<- teid THING_EVENT_SWING = <- teid THING_EVENT_SHOOT = or if 
	
		weather@ 0.1 > if
			<- me .cooldown@ 0.6 * <- me .cooldown! 
		then; 
		
	map{ <- me .pos pos>tile tile@ } 0 = not if 
		map{ <- me .pos pos>tile tile@ .wet@ } 1 = if 
			
			<- me .cooldown@ 0.6 * <- me .cooldown! 
		
		then then;
	
	then 

	<- teid THING_EVENT_TIMER = if
	
		1 <- me .timer! 
	<- me .character@ .health@ 1 < if then; 
	
	weather@ 0 > if 
		HAS_YAPPED 0 = if 
			<- me .inside_id@ 0 = if 
				"Ah, it's like being at sea again!" <- me .yellmsglong
				1 to HAS_YAPPED
			then 
		then 
	then 
	
	weather@ 0.1 > if
		<- me .fatigue@ -1 + 0 127 clamp <- me .fatigue! \ stamina regen ++ 
		0.25 <- me .character@ .speed_bonus! 
	then; 
	
	map{ <- me .pos pos>tile tile@ } 0 = not if 
		map{ <- me .pos pos>tile tile@ .wet@ } 1 = if 
			
			<- me .fatigue@ -1 + 0 127 clamp <- me .fatigue! \ stamina regen ++ 
			0.25 <- me .character@ .speed_bonus! 
		
			else
		
			0.05 <- me .character@ .speed_bonus! 

			then 
		then;		
	then 

;


: merenja-main-events ( teid ) args( chara eventid )

	<- eventid MAIN_EVENT_MISSION_START = if 
		0 to HAS_YAPPED
	then 
	 	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
	
	<- chara .location@ 1 = if 
		1 <- chara .thing@ .timer!
		<- chara .thing@ swap ( teid ) merenja-thing-events
	then 
	 \ I can't forego a timer here ... sorry modders.
	
;

