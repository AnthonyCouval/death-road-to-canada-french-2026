	"Admiral" <- chara .name!

	5 <- chara .shooting!
	5 <- chara .mechanical!

	' merenja-main-events <- chara .main_events!

	"se demande si ce sentiment d'angoisse en se regardant dans le miroir disparaitra un jour." <- chara .job!
	6 <- chara .wits!
	6 <- chara .loyalty!
	6 <- chara .composure!
	0 <- chara .attitude!
	1 <- chara .female!

	3 <- chara .carrying.slot_count!

	150 <- chara .specialtype!

	WEAPON_JAG <- chara .weapona!
	WEAPON_MERENJAHARP <- chara .weaponb!
	WEAPON_SUPPLYDROP <- chara .weaponc!
	20 LOOT_SHOTGUN_SHELL <- chara .lootamt!
	\ IM LOCKED AND LOADEDDDDDDDDD

	6 <- chara .morale!
	"Alert" <- chara .perk!
	"Waterborne" <- chara .trait!

	1 weather! \ Rain follows Merenja wherever she goes
;



cyoa{

\ Admiral Raven

cyoa-bridge: camp-admiral-recruit
    ricon 4 recruitee .morale! clear-cyoa
    15 recruit-yes-food
    "Le monde entier est une baignoire, et nous ne sommes que ses marins." bbold +crtext
    recruitee .shootingREV recruitee .mechanicREV
;

cyoa: camp-rec-admiral
    "Commandante des Mers et de Votre Baignoire" cyoa-title!
    nearest .character@ choosechar cchar to recruitee ricon
    ($ "Au debut, cette personne en uniforme est juste en train de barboter dans une flaque d'eau. Quel que soit ce rituel, elle s'amuse comme une folle.
    Elle ressemble a un membre important d'une force navale, ou peut-etre a une pecheuse tres excentrique." $) cyoa-text! basic-tone
    "Ce personnage peut echanger de la nourriture contre des ravitaillement d'essence. Elle est tres puissante par temps pluvieux ou dans les environnements aquatiques." rbold +crtext
    trunk-food 14 > if
       choice( "La laisser pour l'instant" )choice
       choice( "L'embaucher - 15 nourriture" )choice: camp-admiral-recruit
    else
       "Vous avez besoin de 15 nourriture pour recruter l'Amiral Raven dans l'equipe." +crtext
       choice( "Pas de marine de baignoire pour vous !" )choice
    then
;
\ Zeus
\ for TRACHEA, we are definitely making Rubick
\ "IM COMING FRIENDS. WAIT FOR MEEEEEEE"

cyoa-bridge: camp-zeus-recruit
    ricon 4 recruitee .morale! clear-cyoa
    25 recruit-yes-food
    "CET HOMMAGE EST...SUFFISANT. DE PLUS, SAVOUREUX. CES CHIPS SONT-ELLES PARFUMEES A LA FOUDRE ?" fbold +crtext
    "Peut-etre que le groupe ARRIVERA au Canada, apres tout !" +crtext
;

cyoa-choice: camp-zeus-rude
    ($ ". . ." $) cyoa-text!
    "TOI, CHER MORTEL. TOI, MORTEL QUI EST CHETIF, MINUSCULE, PATHETIQUE, FAIBLE, DANS TA FORME DE CHAIR TOUTE FRAGILE..." fbold +crtext
    ". . . " +crtext
    "Tu oserais ME demander - A MOI ? - ZEUS DU MONT OLYMPE...DE ME CALMER ?" fbold +crtext
    ($ "Avec le recul, c'etait une idee aussi foireuse que de crever un pneu sur l'autoroute. D'un claquement de doigts, Zeus transforme les organes de " cname .. " en pur Zombie Points. Il n'en reste plus rien." .. $) +crtext
    "Zeus, au moins, a l'air content de lui." +crtext
    cchar .kill
    cool-it++
    20 zombop!
;

cyoa: camp-rec-zeus
    "TRUE SIGHT" cyoa-title!
    nearest .character@ choosechar cchar to recruitee ricon
    ($ "C'est litteralement Zeus. Le DIEU. Le mythe. La legende. Ici et maintenant, juste en face de vous, arpentant la Terre sous forme humaine !" $) cyoa-text! basic-tone
    "MORTELS... QUEL HOMMAGE AVEZ-VOUS POUR VOTRE DIEU ?" fbold +crtext
    "Le tonnerre gronde au loin entre chacun de ses mots." rbold "... cela pourrait aussi juste etre un paquet de chips qu'on ouvre." .. +crtext
    "Ce personnage manie la foudre avec une grande efficacite, mais elle doit etre chargee par des attaques au corps a corps." rbold +crtext
    trunk-food 24 > if
       choice( "Le laisser pour l'instant" )choice
       choice( "L'embaucher - 25 nourriture" )choice: camp-zeus-recruit

    else
       "Vous avez besoin de 25 nourriture pour le recruter dans l'equipe." +crtext
       choice( "Impossible de sacrifier la nourriture" )choice
    then
       most-grating if
          charchoice( " dit a Zeus de 'Se Calmer'" )choice: camp-zeus-rude
          \ Il n'y a pas d'issue positive quand on dit a Dieu de se calmer. Surtout si ce dieu est ZEUS.
       then

;
\ Bayonetta
