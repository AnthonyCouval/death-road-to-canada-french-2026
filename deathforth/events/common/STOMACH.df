: new_bay_wep_heavy 1 6 rnd case 
	1 of WEAPON_MEGAMAUL endof 
	2 of WEAPON_CLAYMORE endof
	3 of WEAPON_HALBERD endof 
	4 of WEAPON_ZWEI endof
	5 of WEAPON_SLEDGE endof 
	6 of WEAPON_METAL endof 
	endcase
; 

: new_bay_wep_light 1 6 rnd case 
	1 of WEAPON_TRUEKATANA endof 
	2 of WEAPON_ALUMINUM endof 
	3 of WEAPON_SICKLE endof 
	4 of WEAPON_DAGGER endof 
	5 of WEAPON_HATCHET endof 
	6 of WEAPON_MACHETE2 endof 
endcase
; 


: fire_bayonettabolts args( me )
		
		2 for \ red 
		
			bullet
			
			1 lt .anim.info! 
			
			weapons_base_id 346 + lt .spriteid! 
			
			<- me thing# lt .throwerid!
			45 i 90 * + lt .angle!
			<- me .pos lt .pos! 
			 
			0.1 lt .hitcheck.shoot_thru!
			2 lt .hitcheck.knockback!
			2.5 lt .hitcheck.power! 		

			40 lt .anim.counter!
			
			1 lt .anim.extra! 
			
			lt .angle@ anglexy 3 xymul lt .vel! // Speed
			1 lt .timer!
			-3 <- me .breath - lt .pos.z!
		
		next 
		
		2 for \ blu 
		
			bullet
			
			1 lt .anim.info! 
			
			weapons_base_id 347 + lt .spriteid! 
			
			<- me thing# lt .throwerid!
			180 45 + i 90 * + lt .angle!
			<- me .pos lt .pos! 
			 
			0.1 lt .hitcheck.shoot_thru!
			2 lt .hitcheck.knockback!
			2.5 lt .hitcheck.power! 		

			40 lt .anim.counter!
			
			1 lt .anim.extra! 
			
			lt .angle@ anglexy 3 xymul lt .vel! // Speed
			1 lt .timer!
			-3 <- me .breath - lt .pos.z!
		
		next 
		sfx{ noise 100 freq! 1.05 0.95 frnd pitch! 2 scale!  } 
		sfx{ thump 0.96 q! 0.66 scale! pitch@ 0.8 1.2 frnd * pitch! 150 1500 frnd filt!  }
		
		4 for
			<- me .pos
				particle{
					new pos!
					15 ticks! 
					90 i * 15 - 45 + angle! 
					glowy
					0.9 grow!
					11 fade_out!
					particles_base_id 0x 51 + spriteid!
					angle@ anglexy 2 3 frnd xymul vel! 
					pos@ angle@ anglexy 1 xymul xyadd pos!
					\ gameticks angle!
					1 scale!
					1 0.4 0.4 rgb!
				}
			next 
			
		4 for
			<- me .pos
				particle{
					new pos!
					15 ticks! 
					90 i * 15 + 45 + angle! 
					glowy
					0.9 grow!
					11 fade_out!
					particles_base_id 0x 51 + spriteid!
					angle@ anglexy 2 3 frnd xymul vel! 
					pos@ angle@ anglexy 1 xymul xyadd pos!
					\ gameticks angle!
					1 scale!
					0.4 0.4 1 rgb!
				}
			next 	
		
		
;

: bayonet_lines 1 20 rnd case  
	1 of "TRY TO KEEP UP~" endof 
	2 of "WHAT'S WRONG?~" endof 
	3 of "TOO FAST?~" endof 
	4 of "I'M OUTPACING YOU!~" endof 
	5 of "TRY HARDER!~" endof 
	6 of "COME ON NOW~" endof 
	7 of "HOLY SMOKES~" endof 
	8 of "DAMN I'M GOOD~" endof 
	9 of "TRY AGAIN!~" endof 
	10 of "TOO QUICK!~" endof 
	11 of "WATCH ME GO!~" endof 
	12 of "Oopsie!" endof 
	13 of "Hehe, woopsie!~" endof 
	14 of "GOTTA BE FASTER THAN THAT!" endof 
	15 of "KEEP UP NOW!~" endof 
	16 of "SMASH!~" endof 
	17 of "BASH!~" endof 
	18 of "I'M SO GOOD~" endof 
	19 of "YOU WISH YOU COULD BE SO FAST!~" endof 
	20 of "BAY-OH-NETTI!~" endof 
	endcase
; 

: bayonet-thing-events args( me eventid ) 

	<- eventid THING_EVENT_DIED = if 
		"BAYONETTI...BAYO-DEAD-TTI..." <- me .yellmsglong
	then 

	<- eventid THING_EVENT_DID_HIT = if \ if i hit 
		<- me .weapon_slot_using@ 2 = if \ and am using the combo slot 
			<- me .character@ .weapon_nodropc@ 1 = if \ and still have a combo slot, even 
				<- me .action_cooldown@ 0 = if \ and havent changed recently 
					<- me .just_hit_id@ #thing .hitpoints@ 1 < if \ and killed the target 
						<- me .anim.weapon_counter@ <- me .action_cooldown! \ GIVE ME A NEW WEAPON!!!!
						50 %chance if new_bay_wep_heavy <- me .character@ .weaponc! else new_bay_wep_light <- me .character@ .weaponc! then 
						<- me fire_bayonettabolts
						33 %chance if 
							50 %chance if 
								RED bayonet_lines .. <- me .yellmsg 
							else
								BLUE bayonet_lines .. <- me .yellmsg
							then 
						
						then 
					then 
				then 
			then 
		then 
	then 
; 	


: bayonet-main-events args( chara eventid ) 
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
		<- chara .location@ 1 = if
			<- chara .thing@ swap ( teid ) bayonet-thing-events
	then 
; 

: .bayonetta_ify args( chara ) 
	
	"Bayonetti" <- chara .name!
	6 <- chara .strength!
\	4 <- chara .shooting!
	6 <- chara .fitness!
	2 <- chara .health! 
	2 <- chara .vitality! 
	3 <- chara .carrying.slot_count! 
	"would probably take off like a rocket if she kept clicking her heels together." <- chara .job! 
	6 <- chara .loyalty!
	1 <- chara .dexterity! 
	WEAPON_MEGAMAUL <- chara .weaponc! 
	' bayonet-main-events <- chara .main_events! 
	
	WEAPON_THE1911 <- chara .weapona! 
	WEAPON_THE1911 <- chara .weaponb! 
	
	1 <- chara .weapon_nodropc! 
	
	0.5 <- chara .bounceval! \ skip & saunter about 
	
	2 <- chara .wits! 
	4 <- chara .attitude!
	2 <- chara .composure! 
	
	148 <- chara .specialtype! 
	1 <- chara .female!
	6 <- chara .morale! 
	"Pugnala" <- chara .perk!
	"Vampire Survivor" <- chara .trait! 
	
; 

