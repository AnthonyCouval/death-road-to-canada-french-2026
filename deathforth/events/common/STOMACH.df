\ Oh well.

cyoa-bridge: camp-bayonetta-recruit
    ricon 6 recruitee .morale! clear-cyoa
    15 recruit-yes-food
    "OUIOUIOUIOUIOUI ! CA VA ETRE CARREMENT GENIAL ! ;3" fbold +crtext
    recruitee .showitall
;
\ She starts with 6 morale because she extracted 2 morale from me.

cyoa: camp-rec-bayonetta
    "SURVIVORS OF THE VAMPIRIC VARIETY" cyoa-title!
    nearest .character@ choosechar cchar to recruitee ricon
    ($ "Cette femme n'arrete pas de parler. C'est un assaut implacable de confiance en soi qui agresse les sens. Neanmoins, elle semble trimballer une grande variete de bonnes armes, ainsi que deux pistolets." $) cyoa-text! basic-tone
    "OOH OOH ENGAGE-MOI ! ENGAGE-MOI ! JE VAIS ETRE SI RAPIDE QUE TU NE POURRAS PAS SUIVRE, CHERI~" fbold +crtext
    "Je suis assis dans ce cyoa et meme moi je la trouve deja agacante." +crtext
    "Ce personnage possede un systeme de combo. En tuant avec votre arme a emplacement verrouille, vous debloquerez une nouvelle arme juste apres." rbold +crtext
    trunk-food 14 > if
       choice( "Epargner vos oreilles" )choice
       choice( "L'engager - 15 nourriture" )choice: camp-bayonetta-recruit
    else
       "Vous avez besoin de 15 nourriture pour la recruter dans l'equipe." +crtext
       choice( "Impossible de sacrifier la nourriture" )choice
    then
;

}


