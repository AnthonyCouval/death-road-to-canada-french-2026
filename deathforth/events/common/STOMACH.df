	0 <- chara .female!
	0 <- chara .hairtype!
	0 <- chara .bodytype!
	6 <- chara .headtype!
	0 <- chara .torsotype!
	2 <- chara .legstype!
	0 <- chara .facetype!
	1 <- chara .hairtype!
	0 <- chara .hattype!
	0 <- chara .glassestype!
	0 <- chara .specialtype!
	0 <- chara .speed_bonus!
	0 <- chara .skincolour!
	15 <- chara .haircolour!
	1234512345 <- chara .seed!
	"IS KEPA" <- chara .trait!
	($ "is trapped in this dimension as punishment for the roomgen system." $) <- chara .job!
	"GAME DESIGNER" <- chara .perk!
	WEAPON_CARDBOARD <- chara .weapona!
	5 <- chara .shooting! 5 <- chara .strength! 3 <- chara .fitness!	2 <- chara .morale!
	0 <- chara .wits! 0 <- chara .attitude! 0 <- chara .composure! 0 <- chara .loyalty!
	<- chara .fitnessREV <- chara .strengthREV <- chara .shootingREV
	<- chara .witsREV <- chara .attitudeREV <- chara .temperREV <- chara .loyaltyREV
	1 <- chara .vitality! 1 <- chara .health!
;

