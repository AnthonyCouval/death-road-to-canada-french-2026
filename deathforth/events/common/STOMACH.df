\ The Jimventory 

: diff-up-jim "road{ road-difficulty 0.1 + to road-difficulty }" evaluate ;  
: mega-diff-up-jim "road{ road-difficulty 0.3 + to road-difficulty }" evaluate ;

: jim1 1 STAT_STRENGTH cchar .bonus+ ; 
: jim2 1 STAT_FITNESS cchar .bonus+ ; 
: jim3 1 STAT_SHOOTING cchar .bonus+ ; 
: jim4 1 STAT_MEDICAL cchar .bonus+ ; 
: jim5 1 STAT_MECHANICAL cchar .bonus+ ; 

: jim6 2 STAT_STRENGTH cchar .bonus+ diff-up-jim ; 
: jim7 2 STAT_FITNESS cchar .bonus+ diff-up-jim ; 
: jim8 2 STAT_SHOOTING cchar .bonus+ diff-up-jim ; 
: jim9 2 STAT_MEDICAL cchar .bonus+ diff-up-jim ; 
: jim10 2 STAT_MECHANICAL cchar .bonus+ diff-up-jim ; 

: jim11 cchar .carrying.slot_count@ 1 + 1 3 clamp cchar .carrying.slot_count! ; 

: jim12 cchar .vitality@ 1 + 1 6 clamp cchar .vitality! ; 
: jim13 cchar .vitality@ 2 + 1 6 clamp cchar .vitality! diff-up-jim ; 

: jim14 1 6 rnd cchar .wits! 1 6 rnd cchar .attitude! 1 6 rnd cchar .composure! 1 6 rnd cchar .loyalty! ;    

: jim1choice choice( "+1 Strength" bbold )choice: jim1 ; 
: jim2choice choice( "+1 Fitness" bbold )choice: jim2 ;
: jim3choice choice( "+1 Shooting" bbold )choice: jim3 ; 
: jim4choice choice( "+1 Medical" bbold )choice: jim4 ;
: jim5choice choice( "+1 Mechanical" bbold )choice: jim5 ; 
: jim6choice choice( "+2 Strength" bbold " +0.1x zombs" rbold .. )choice: jim6 ; 
: jim7choice choice( "+2 Fitness" bbold " +0.1x zombs" rbold .. )choice: jim7 ;
: jim8choice choice( "+2 Shooting" bbold " +0.1x zombs" rbold .. )choice: jim8 ; 
: jim9choice choice( "+2 Medical" bbold " +0.1x zombs" rbold .. )choice: jim9 ;
: jim10choice choice( "+2 Mech" bbold " +0.1x zombs" rbold .. )choice: jim10 ;
 
: jim11choice choice( "+1 Carry Slot" bbold )choice: jim11 ;

: jim12choice choice( "+1 Max HP" bbold )choice: jim12 ; 
: jim13choice choice( "+2 Max HP" bbold " +0.1x zombs" rbold .. )choice: jim13 ;

: jim14choice choice( "Reroll Personality" bbold )choice: jim14 ;

	deck-new
		card: jim1choice
		card: jim2choice
		card: jim3choice
		card: jim4choice
		card: jim5choice
		card: jim6choice
		card: jim7choice
		card: jim8choice
		card: jim9choice
		card: jim10choice
		card: jim11choice
		card: jim12choice
		card: jim13choice
		card: jim14choice
	constant JIM-DECK
	JIM-DECK var jim-deck
	
: drawjim 
	jim-deck depths 0= if 
		regiondef{ JIM-DECK shuffles to jim-deck }
	then
	drawcard
	jim-deck depths 0= if
		choice( "ALL OUTTA UPGRADES!" fbold )choice
	else
		drawcard
	then
;


\ At Kepa's request, this tech is being repurposed for a Nimbus rework. 
cyoa: jumbo-getjoker 
	"LEVEL UP!" cyoa-title! 
	93 stpick if choosechar cicon else ($ "Nimbus" pbold .. " is missing. Oh well. " Thegroup .. " was never going to reach " .. "this campaign's end" rainbold .. " anyway." .. $) text! exit then
	($ "With every passing day," " Nimbus Ordeal " pbold .. "gains more and more power." .. $) cyoa-text!
	($ "He'll need to accumulate even more power if he wants to finish his" " legendary quest" rainbold .. " and win." .. $) +crtext
	($ "Pick an upgrade for him:" $) +crtext 
		3 for drawjim next 
;

\ It should be relatively trivial for any prospective modders to restore Jimbo, if they so wish to. 
\ Just replace the "93" here and in road.df with "153" and call the recruiting event via console 
\ SAVE ME FROM THE PLANT  

cyoa: recruit-jumbo-yes

	($ rname .. " accepts a spare ace of hearts card. As it transitions into his hand, it suddenly becomes " "steel-like" rbold .. " and a " .. "red seal" rainbold .. " appears out of nowhere." .. $) cyoa-text! 
	($ "As soon as " rname .. " puts the card on the table, the plant pot explodes!" .. $) +crtext
	($ "YOU'RE A REAL JOKER! THANKS. I'LL FOLLOW YOU, AT LEAST TO THE END OF THIS ANTE." fbold $) +crtext 
	
	team-full? if
		($ "The group is full.
		Who would you like to replace to make room for " .. rname .. "?" $) +crtext
		recruit-replace?
	then;
	ricon
	($ Thegroup .. " accepts " .. rname .. " to the team!" $) +crtext 2 300 tone
		recruited
	recruitee .showitall 
;

cyoa: jumbo-scget
	"COLD STAKE CANADIAN DECK" cyoa-title! 
	char-gen to recruitee ricon 2 recruitee .morale! recruitee .jimboify
	($ "The group is walking through a park when they come across a jester." $) cyoa-text! basic-tone
	($ rname .. " seems to be deep into some kind of insane poker game. Across from him sits a plant in a pot." $) +crtext 
	($ "THE EVIL PLANT MUST PAY. THE EVIL PLANT MUST PAY." pbold  $) +crtext 
	($ WHITE "Somehow, despite playing against an inanimate object, he seems to be losing." .. $) +crtext
	
		choice( "Bribe him with a card" )choice: recruit-jumbo-yes
		choice( "Leave him behind" )choice 
;

} } 

