cyoa{ 

\ Admiral Raven 

cyoa-bridge: camp-admiral-recruit
	ricon 4 recruitee .morale! clear-cyoa
	15 recruit-yes-food 
	"All the world's a bathtub, and us merely the sailors." bbold +crtext
	recruitee .shootingREV recruitee .mechanicREV
;

cyoa: camp-rec-admiral
	"Commander Of The Seas And Your Bathtub" cyoa-title!
	nearest .character@ choosechar cchar to recruitee ricon
	($ "At first, this uniformed person is just splashing about in a puddle. Whatever kind of ritual this is, she's having a great time.  
	She looks like an important member of some naval force, or possibly a very eccentric fisherwoman." $) cyoa-text! basic-tone
	"This character can exchange food for gas supply drops. She's very powerful in wet weather or environments." rbold +crtext
	trunk-food 14 > if
		choice( "Leave her for now" )choice
		choice( "Hire her - 15 food" )choice: camp-admiral-recruit
	else
		"You need 15 food to recruit Admiral Raven to the party." +crtext
		choice( "No bathtub navy for you!" )choice
	then		
;

\ Zeus 
\ for TRACHEA, we are definitely making Rubick
\ "IM COMING FRIENDS. WAIT FOR MEEEEEEE" 

cyoa-bridge: camp-zeus-recruit
	ricon 4 recruitee .morale! clear-cyoa
	25 recruit-yes-food 
	"THIS TRIBUTE IS...SUFFICIENT. ALSO, TASTY. ARE THESE CHIPS LIGHTNING FLAVOURED?" fbold +crtext
	"Perhaps the group WILL make it to Canada, after all!" +crtext
;

cyoa-choice: camp-zeus-rude
	($ ". . ." $) cyoa-text!
	"YOU, DEAR MORTAL. YOU, MORTAL WHO IS PUNY, TINY, PATHETIC, WEAK, IN YOUR FRAIL FLESH FORM..." fbold +crtext
	". . . " +crtext
	"Would ask ME - ME? - ZEUS OF MOUNT OLYMPUS...TO COOL IT?" fbold +crtext
	($ "In retrospect, this was a popping-a-tire-on-the-freeway level bad idea. With a flick of his fingers, Zeus turns " cname .. "'s organs into pure ZP. Nothing remains." .. $) +crtext
	"Zeus, at least, looks pleased with himself." +crtext
	cchar .kill 
	cool-it++
	20 zombop!
;

cyoa: camp-rec-zeus
	"TRUE SIGHT" cyoa-title!
	nearest .character@ choosechar cchar to recruitee ricon
	($ "It's literally Zeus. The DINK. The myth. The legend. Here and now, right in front of you, wandering Earth in human form!" $) cyoa-text! basic-tone
	"MORTALS...WHAT TRIBUTE DO YOU HAVE FOR YOUR SUPERIOR?" fbold +crtext
	"Thunder quakes between his words in the far distance." rbold "...it could also just be a chips packet opening." .. +crtext
	"This character wields lightning with great effectiveness, but it must be charged through melee attacks." rbold +crtext
	trunk-food 24 > if
		choice( "Leave him for now" )choice
		choice( "Hire him - 25 food" )choice: camp-zeus-recruit
		
	else
		"You need 25 food to recruit him to the party." +crtext
		choice( "Can't spare the food" )choice
	then	
		most-grating if
			charchoice( " tells Zeus to 'Cool It'" )choice: camp-zeus-rude
			\ There is no positive outcome in telling God to cool it. Especially if that god is ZEUS.
		then
	
;

