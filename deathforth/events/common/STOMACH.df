\ ----------------------------------------------

: rubick-thing-events args( me eventid )
	<- eventid THING_EVENT_SWING <> if
		1 <- me .character@ .weapon_nodropb!
	then

	<- eventid THING_EVENT_DIED = if
		GREEN "i lost?" .. <- me .yellmsg
	then
;


: never_drop_things args( chara eventid )
	\ 1 <- me .character@ .weapon_nodropc!
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
		<- chara .thing@ swap ( teid ) rubick-thing-events

;

: .rubick_ify args( chara )
	151 <- chara .specialtype!
	0 <- chara .female!

	WEAPON_FADEBOLT_REAL <- chara .weapona!
	WEAPON_SHOVEL <- chara .weaponb! \ Need to put something here or the AI tries to pick up stuff that it cant

	\ Think of it as like that old shovel neutral item that dug up consumables

	WEAPON_COPYCOPY <- chara .weaponc!
	1 <- chara .stackedc!
	\ Copy weapon does not need charges
	\ It has charges because it enables the weapon to "aim" nicely
	\ they will never be used or run out

	1 <- chara .weapon_nodropc!
	1 <- chara .weapon_nodropb!
	1 <- chara .weapon_nodropa!

	0 <- chara .female!

	2 <- chara .strength!
	1 <- chara .fitness!
	6 <- chara .wits!
	3 <- chara .attitude!

	2 <- chara .vitality!
	2 <- chara .health!

	0 <- chara .loyalty!
	0 <- chara .composure!

	' never_drop_things <- chara .main_events!

	"Level 30" <- chara .perk!
	"Spellstealer" <- chara .trait!
	"volera aussi votre partenaire, vos enfants et votre maison si vous ne surveillez rien. Un voleur jusqu'au bout des doigts !" <- chara .job!
	"Magus" <- chara .name!
;

\ "MOOOON TOUR MAINTENANT"
\ my most played dota char by far

: pewt_laugh 1 19 rnd case
	1 of "NYEHEHEHEHEH" endof
	2 of "Nyheheheheh" endof
	3 of "hehehehehh" endof
	4 of "HEHEHEHEH" endof
	5 of "HEY LEWIS" endof
	6 of "hey lewis" endof
	7 of "NYEHEHEH HEHEHEH" endof
	8 of "nyehehehehh" endof
	9 of "Je suis... ELECTRIC MAN" endof
    10 of "pewter... les zombies sont la." endof
    11 of "c'est encore pire que la fois ou..." endof
    12 of "FERME LA MEG." endof
    13 of "INSERER UN GAG EN FLASHBACK" endof
    14 of "au moins je ne bois pas." endof
    15 of "je veux juste lui parler." endof
    16 of "Gratte-cul." endof
    17 of "La vie est une chose terrible !" endof
    18 of "IL SE PREND TRES AU SERIEUX." endof
    19 of "OOOH ! UN DOLLAR." endof
	endcase
;

: familyguy-thing-events args( me eventid )
	<- eventid THING_EVENT_SWING = if

		player 0 = not if
			16 %chance if
				<- me .id@ pchar .thing@ .id@ = if
					pewt_laugh <- me .yellmsg
				else
					50 %chance if
						"hey, hey " pchar .name@ .. "..." .. <- me .yellmsg
							else
						"hey " pchar .name@ .. <- me .yellmsg
					then
				then
			then
		then
	then

	<- eventid THING_EVENT_DIED = if
		RED "*gasp*...aaaaaah...*gasp*...ahhhh..." .. <- me .yellmsg
	then
;


: familyguy-main-events args( chara eventid )
	\ 1 <- me .character@ .weapon_nodropc!
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
		<- chara .thing@ swap ( teid ) familyguy-thing-events

;

