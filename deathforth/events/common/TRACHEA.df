: godfather_lines 1 21 rnd case 

	1 of "Combien de trahisons de plus je peux endurer ?" endof 
	2 of "T'as vu la tete de ce nul ?" endof 
	3 of "Je suis le grand patron." endof 
	4 of "J'ai jamais eu l'etoffe d'un champion." endof 
	5 of "20 ans dans une boite de sardines." endof 
	6 of "Les zombies n'achetent pas a boire." endof 
	7 of "Liquide." endof 
	8 of "Capisce ?" endof 
	9 of "Tu me comprends ?" endof 
	10 of "Tu viens me voir...le jour de mon 4eme calcul renal..." endof 
	11 of "Ca sera pas cinematographique." endof 
	12 of "Fais juste ce qu'on te dit." endof 
	13 of "Plus de genoux ? On negocie." endof 
	14 of "La famille c'est tout. La mienne ce sont des zombies." endof 
	15 of "Heyyyyyy comment t'vas ?" endof 
	16 of "C'est la schmoutz." endof 
	17 of "C'est ou le gabagoul ?" endof 
	18 of "20 000 sur mon bureau avant la nuit." endof 
	19 of "Chopez-les les gars !" endof 
	20 of "Tu ferais mieux de faire gaffe !" endof 
	21 of "T'as une abeille sur le chapeau !" endof 
	endcase
; 

: mobster-thing-events args( me teid )
	
	<- teid THING_EVENT_SHOOT = if
			weapondef{ <- me .wielded sel ammo_type@ } LOOT_BULLET = weapondef{ <- me .wielded sel ammo_type@ } LOOT_SHOTGUN_SHELL = weapondef{ <- me .wielded sel ammo_type@ } LOOT_RIFLE_SHELL = or or if 
				\ Any basic firearm, not doing bows or explosives 
				40 %chance if 
					<- me .ammocount 0 > if
						4 <- me .cooldown!
						0 <- me .action_cooldown!
						YELLOW "2x!" .. <- me .report \ Multishot 
						weapondef{ <- me .wielded sel ammo_type@ } <- me .character@ .lootamt@ 1 + weapondef{ <- me .wielded sel ammo_type@ } <- me .character@ .lootamt!
						<- me .attack
					then
			then
		then
	then
	
	<- teid THING_EVENT_DID_HIT = if 
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if 
			
			<- me .just_hit_id@ #thing .vel.z@ -1 + <- me .just_hit_id@ #thing .vel.z! 
			\ Kneecapping mechanic 
			20 %chance if 
				godfather_lines <- me .yellmsg 
			then 
		then 
	then 
			
;


: mobster-main-events args( chara eventid )
	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
		<- chara .location@ 1 = if 
			<- chara .thing@ swap ( teid ) mobster-thing-events
		then 
;

: .mobsterify args( chara ) 
	"Mafioso" <- chara .name! 
	"a fait 20 ans en taule a manger du gabagoul sur le radiateur a fromage grille." <- chara .job! 
	4 <- chara .shooting! 
	4 <- chara .strength! 
	6 <- chara .wits! 
	6 <- chara .attitude! 
	0 <- chara .loyalty! 
	0 <- chara .composure!
	0 <- chara .female! 
	\ as every mobster : a charming a-hole 
	WEAPON_ALUMINUM <- chara .weapona! 
	WEAPON_TYPEWRITER <- chara .weaponb! 
	WEAPON_DOLT <- chara .weaponc! 
	50 LOOT_BULLET <- chara .lootamt! 
	154 <- chara .specialtype! 
	"Cabrone" <- chara .perk! 
	"Homme de Main" <- chara .trait! 
	' mobster-main-events <- chara .main_events! 
; 


