	"n'est meme plus paye, il aime juste son boulot." <- chara .job! 
	4 <- chara .strength!
	4 <- chara .fitness! 
	4 <- chara .wits! 
	4 <- chara .attitude! 
	4 <- chara .composure! 
	6 <- chara .loyalty!
	-10 STAT_SHOOTING <- chara .bonus! 
	WEAPON_SWISSSLASH <- chara .weapona! 
	WEAPON_SWISSTHRUST <- chara .weaponb!
	"Hallebardier" <- chara .perk! 
	"Mercenaire" <- chara .trait! 
	<- chara .nocanshoot 
	0 <- chara .female! 
	1 <- chara .weapon_nodropa! 
	1 <- chara .weapon_nodropb! 
	6 <- chara .headoff.y! 
	156 <- chara .specialtype! 
	\ Halberd combo + some aura or something... 
; 
	
	
