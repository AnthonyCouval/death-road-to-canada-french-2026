0 stack 
	" a modifie le moteur pour encore plus d'efficacite." shove
	" a bidouille le calage des pistons." shove
	" a regle le melange air-carburant." shove
	" a remplace une piece obsolete du moteur." shove
	" essaie une formule de carburant plus legere." shove
	" conduit la voiture a une vitesse absurde." shove
	" conduit comme un fou." shove
	" a le pied presque collee chirurgicalement a l'accelerateur." shove
var stig-fix-stack
: stig-fix-phrase stig-fix-stack rndpicks nip ;


: stig-main-events args( chara eventid )
	
	<- eventid MAIN_EVENT_MISSION_START = if		
		mission.vehicle@ if
			mission.vehicle@ .mpg@ 0.3 < not if
				mission.vehicle@ .mpg@ -0.1 + mission.vehicle@ .mpg!
				then
			then			
		then
		
	<- eventid MAIN_EVENT_DRIVING_START = if
		mission.vehicle@ if
		
		car-speed 1 + 1 4 clamp to car-speed
		
		mission.vehicle@ .mpg@ 0.3 < car-speed 4 < and if then;
			road{ qmsg ($ <- chara .name@ .. stig-fix-phrase $) txt }
			road{ qmsg ($ GREEN "Consommation de la voiture amelioree !" .. $) txt }
			road{ qmsg ($ GREEN "Vitesse de la voiture augmentee !" .. $) txt }
		then
	then
		
;

	
: .stigify args( chara ) 
	155 <- chara .specialtype! 
	0 <- chara .female! 
	"Le Stug" <- chara .name! 
	"Pilote de Rallye" <- chara .perk! 
	"Non-Verbal" <- chara .trait! 
	"est quelqu'un dont on ne sait que deux choses : il sait conduire, et il s'appelle Le Stug." <- chara .job! 
	WEAPON_JAG <- chara .weapona! 
	1 <- chara .dexterity! 
	4 <- chara .mechanical! 
	1 STAT_MECHANICAL <- chara .bonus! 
	0 <- chara .composure! 
	3 <- chara .loyalty! 
	3 <- chara .wits! 
	' stig-main-events <- chara .main_events! 
	
; 
	

\ Ragdoll physics experiment; crash test dummy character? 

: ragdoll-phys-events args( me teid )
	
	<- teid THING_EVENT_WAS_HIT = if 

		-5 <- me .vel.z! 
		
		7 50 %chance if -1 * then <- me .vel.x! 
		7 50 %chance if -1 * then <- me .vel.y! 

		0 <- me .angle! 
		0 <- me .shudder! 
	then 
	
	<- teid THING_EVENT_TIMER = if 
		1 <- me .timer! 
		
			<- me .pos.z@ -3 < if 
				1 <- me .stun! 
		
				6 <- me .rot@ + <- me .rot! 
				<- me .rot@ <- me .angle!
				
				1 <- me .unseen! 
				1 <- me .nocollide! 
				
			else 
			
				0 <- me .unseen! 
				0 <- me .rot! 
				0 <- me .nocollide! 
			then 
			
		then 
; 

: ragdoll-main-events args( chara eventid )
	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
		<- chara .location@ 1 = if 
			<- chara .thing@ swap ( teid ) ragdoll-phys-events
			1 <- chara .thing@ .timer! 
		then 
; 