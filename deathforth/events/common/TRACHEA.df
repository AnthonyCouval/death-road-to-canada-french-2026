: godfather_lines 1 21 rnd case 

	1 of "How much more betrayal can I take?" endof 
	2 of "How bout that dink's face?" endof 
	3 of "I'm the kingpin." endof 
	4 of "Never had the makings of a varsity athlete." endof 
	5 of "20 years in a sardine can." endof 
	6 of "Zombies don't buy drink." endof 
	7 of "Capped." endof 
	8 of "Capiche?" endof 
	9 of "Ya understand me?" endof 
	10 of "You come to me...on the day of my 4th kidney stone..." endof 
	11 of "It won't be cinematic." endof 
	12 of "Just do as you're told." endof 
	13 of "No knees? Just compromise." endof 
	14 of "Family is everything. Mine are zombies." endof 
	15 of "Heyyyyyy how ya doinnnn?" endof 
	16 of "This is the schmutz." endof 
	17 of "Where's the gabagool?" endof 
	18 of "20 Gs on my desk by sundown." endof 
	19 of "Get 'em boys!" endof 
	20 of "You better watch yourself!" endof 
	21 of "You got-a bee on-a your hat!" endof 
	endcase
; 

: mobster-thing-events args( me teid )
	
	<- teid THING_EVENT_SHOOT = if
			weapondef{ <- me .wielded sel ammo_type@ } LOOT_BULLET = weapondef{ <- me .wielded sel ammo_type@ } LOOT_SHOTGUN_SHELL = weapondef{ <- me .wielded sel ammo_type@ } LOOT_RIFLE_SHELL = or or if 
				\ Any basic firearm, not doing bows or explosives 
				40 %chance if 
					<- me .ammocount 0 > if
						4 <- me .cooldown!
						0 <- me .action_cooldown!
						YELLOW "2x!" .. <- me .report \ Multishot 
						weapondef{ <- me .wielded sel ammo_type@ } <- me .character@ .lootamt@ 1 + weapondef{ <- me .wielded sel ammo_type@ } <- me .character@ .lootamt!
						<- me .attack
					then
			then
		then
	then
	
	<- teid THING_EVENT_DID_HIT = if 
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if 
			
			<- me .just_hit_id@ #thing .vel.z@ -1 + <- me .just_hit_id@ #thing .vel.z! 
			\ Kneecapping mechanic 
			20 %chance if 
				godfather_lines <- me .yellmsg 
			then 
		then 
	then 
			
;


: mobster-main-events args( chara eventid )
	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
		<- chara .location@ 1 = if 
			<- chara .thing@ swap ( teid ) mobster-thing-events
		then 
;

: .mobsterify args( chara ) 
	"Mobster" <- chara .name! 
	"did 20 years in the can eating gabagool off the grilled cheese radiator." <- chara .job! 
	4 <- chara .shooting! 
	4 <- chara .strength! 
	6 <- chara .wits! 
	6 <- chara .attitude! 
	0 <- chara .loyalty! 
	0 <- chara .composure!
	0 <- chara .female! 
	\ as every mobster : a charming a-hole 
	WEAPON_ALUMINUM <- chara .weapona! 
	WEAPON_TYPEWRITER <- chara .weaponb! 
	WEAPON_DOLT <- chara .weaponc! 
	50 LOOT_BULLET <- chara .lootamt! 
	154 <- chara .specialtype! 
	"Cabrone" <- chara .perk! 
	"Made Man" <- chara .trait! 
	' mobster-main-events <- chara .main_events! 
; 


