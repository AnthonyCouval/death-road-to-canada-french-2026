: defectivenamescase 1 8 rnd case 
	1 of "Defective" endof 
	2 of "D3fect1ve" endof 
	3 of "D#fe-t!ve" endof 
	4 of "D3f*ct1ve" endof 
	5 of "Defec*!ve" endof 
	6 of "D-f3ct1ve" endof 
	7 of "Defe-t*ve" endof 
	8 of "D#fec*ive" endof 
	endcase
; 

: defectivejobcase 1 6 rnd case 
	1 of "is the planeswalker, a defect; forever a lost broken soul." endof 
	2 of "can simply phase through the car door to leave the car." endof 
	3 of "responds only in jumbled, incoherent sounds, as if through TV static." endof 
	4 of "is all that remains of somebody who time forgot." endof 
	5 of "teleports behind you. Nothing personell, kid." endof 
	6 of "doesn't know anything about the origin of the split down their face." endof 
	endcase
; 




: xerespoof args( me )  
	\ intended for AI defective. 
		player if 
		player .mapid@ <- me .mapid@ = if 
		<- me .action_cooldown@ 0 > if then; 
		45 3 * <- me .action_cooldown! \ ~ 4s 
			<- me .pos <- me .pos <- me .targetpos.x@ <- me .targetpos.y@ xysub xyangle anglexy 30 xymul xyadd <- me .pos! \ defensive poof! 
			1 rumble 
			sfx{ growl 1000 r! 100 ramp_start! 1500 ramp_end! } \ weeeeawwwww 
			
			12 for 
			<- me .pos
            particle{
                new pos!
                30 ticks!
                0 360 frnd angle!
                glowy
                0.99 grow!
                25 fade_out!
                particles_base_id 149 + spriteid!
                // angle@ anglexy 0.04 0.08 frnd xymul vel!
                pos@ -21 10 frnd + swap -8 8 frnd + swap pos!
                0.25 0.4 frnd scale!
                1 0.1 0 rgb!
            }
			next 
		then then 
;

: exeres-thing-events args( me teid )
	<- teid THING_EVENT_TIMER = if
		2 <- me .timer!
		<- me .inside_id@ 0 > if then;
		    <- me .pos
            particle{
                new pos!
                10 ticks!
                0 360 frnd angle!
                glowy
                0.99 grow!
                5 fade_out!
                particles_base_id 149 + spriteid!
                // angle@ anglexy 0.04 0.08 frnd xymul vel!
                pos@ -20 10 frnd + swap -6 5 frnd + swap pos!
                0.25 0.4 frnd scale!
                1 0 0 rgb!
            }
			
			gameticks 0.1 * sin abs 0.8 1 clamp <- me .clr.a!
		then
		
	<- teid THING_EVENT_AI_ASSESS = if 
		<- me .anim.extra@ 0 > if 
			<- me xerespoof
		then 
	then 
	
	<- teid THING_EVENT_DIED = if 
		"h0me?..." <- me .yellmsglong
		' kill_all_defects foreach-char
		sfx{ creepy 0.995 q! } 
	then 
		
		
;

: echoxeres-events args( chara eventid )

	<- eventid MAIN_EVENT_MISSION_START <> if 
		defectivenamescase <- chara .name! 
	then 
	
	<- eventid MAIN_EVENT_MISSION_START = if
	
		0 to clones-created
		15 <- chara .thing@ .ai.assess!
		
		defectivejobcase <- chara .job! 
		
		then
	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
		<- chara .location@ 1 = if
			2 <- chara .thing@ .timer!
			<- chara .thing@ swap ( teid ) exeres-thing-events
		then 

;

: .ruined_soulify args( chara ) 
	146 <- chara .specialtype! 
	6 <- chara .fitness! 
	\ 1 <- chara .dexterity!
	
	\ No throwing objects for your silly ethereal arms. 
	0 <- chara .strength!
	\ -6 STAT_STRENGTH <- chara .bonus! 
	
	0 <- chara .shooting! 
	1 <- chara .vitality!
	1 <- chara .health! 
	1 <- chara .weapon_nodropa!
	
	' echoxeres-events <- chara .main_events!
	
	1 <- chara .carrying.slot_count!
	
	-1 <- chara .breathescale! 
	
	0 <- chara .composure! 
	0 <- chara .wits! 
	2 <- chara .attitude!
	2 <- chara .loyalty! 
	
	"Eldritch" <- chara .perk! 
	"Planeswalker" <- chara .trait! 
	
	"Defective" <- chara .name! 
	"appears to fade in and out of existence, as if at will." <- chara .job! 
	
	WEAPON_RAHJL <- chara .weapona! 
	
	statmod{ MOD_SWAPACTION <- chara .setmod } <- chara .swapspecial 
	

; 

cyoa{ road{ 

cyoa: defective-scget
	"H.P LOVECRAFT'S WIFE" cyoa-title! 
	char-gen to recruitee ricon 2 recruitee .morale! recruitee .ruined_soulify
	($ Thegroup .. " approaches some kind of eldritch entity clenching its wounds. When beckoned, it momentarily splits into two, but does not respond." $) cyoa-text! basic-tone
	($ "
	Reughhh...*whine*...reuuughhh..." rbold $) +text 
	($ "
	What a friendly looking face!"  $) +text
	($ "
	This extraplanar creature can blink with the SWAP button every so often." $) +text 	
	($ "
	The creature locks eyes with them suddenly. It tilts its head, as if curious, almost." rbold $) +text 
		choice( "Tentatively ask " .. rname .. " to join" )choice: recruit-yes
		choice( "NOPE. NO. THANK YOU" )choice
;

cyoa: isabelle-scget
	"ROLLING A NATURAL 20 IN EVERY STAT" cyoa-title! 
	char-gen to recruitee ricon 6 recruitee .morale! recruitee .paladinify 
	($ rname .. " rushes up to the group, silver sword in hand. A blinding flash of yellow light follows, as she brings her sword down upon a wandering zombie!" $) cyoa-text! basic-tone
	
	-20 fade_to 1 1 0 fade_clr 20 fade_count!
	sfx{ thump 2 scale! 0.5 pitch! 350 r! 600 d! 40 a! } 
	
	($ YELLOW "
	Oh, hello hun. Can I help you? I'm Isabelle. It's my job to protect people like you. Let me join, I can get you out of here." .. $) +text 
	($ WHITE "
	At a first glance, it's impossible to tell whether she's merely a cosplayer or an actual paladin from the old world." .. $) +text
	($ "
	Isabelle can smite enemies on melee hits for extra damage." $) +text 	
		choice( "Allow " .. rname .. " to join" )choice: recruit-yes
		choice( "Leave this phony behind" )choice
;

cyoa: lasija-scget
	"A RACE AGAINST THE CLOCK...CLOCK(S)?" cyoa-title! 
	char-gen to recruitee ricon 3 recruitee .morale! recruitee .chronomancerify 
	($ "Time seems to slow to a halt. Sound grows dull. Color seems to unsaturate. Suddenly, out of nowhere, a stranger appears.
	" $) cyoa-text! basic-tone
	($ 
	rname .. " turns towards the group, pocketwatch in hand. A short time later, his silhouette seems to do the same thing." $) +text 
	($ "
	...drat. I've must've set my machine wrong again...I'd better join you, or I'm toast. And you'd better let me, or else YOU'RE toast." pbold $) +text 
	($ "
	This must be some kind of traveller from the future! Or possibly just someone who COOL'D IT successfully."  $) +text
	($ "
	Once per mission, Clock King can stop time itself." $) +text 	
		choice( "Let " .. rname .. " join" )choice: recruit-yes
		choice( "GO BACK TO THE FUTURE NERD" )choice
;
\ "Why does he have a hunting rifle"? CLOCK KING KILLED JFK 

} } 

