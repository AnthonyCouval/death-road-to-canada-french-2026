// HERE WE GO AGAIN

cyoa{ road{ 

// camping event

: OMENT-gymcamp-buff
	50 %chance if .fitness++ else .strength++ then
;

cyoa-choice: OMENT-gymcamp-A
	($ Thegroup .. " fait une bonne seance sur les anciens appareils de sport bizarres. Les resultats semblent un peu aleatoires." $) text!
	numpets 0 > if "Meme les animaux font du sport !" +crtext then
	chow_calc_anytime -2 * trunk-food+ 2 calendar-day+ goodfx
	' OMENT-gymcamp-buff foreach-team-char
;

cyoa: OMENT-gymcamp
	"La Grande Salle Couverte" cyoa-title!
	($ Thegroup .. " camps out in a small gym." $) text! +cr fullcamp someicon
		choice( "Quitter le camp" )choice
	trunk-food chow_calc_anytime 2 * > if
		($ "La salle de sport est pleine de vieux appareils de musculation. " .. Thegroup .. " ne sait pas du tout comment les utiliser, mais " .. gthey .. " pourrait rester quelques jours pour essayer." $) +crtext
			choice( "S'entrainer 2 jours" )choice: OMENT-gymcamp-A
		then
		
;

// bandit events

// Chess Bandit

: bandit-wager-pay
	bandit-toll? if
		bandit-toll-pay haggler-morale 
	else
		trunk-food 4 > if
			eat-all bandit-ammomed2 haggler-morale			
		else
			bandit-ammomed 
			// check if in car
			vehicle.which@ 0 if
				bandit-gas
			else
				bandit-gastank
			then morale2-all
		then
	then
;

: bandit-wager
	bandit-toll? if
		($ bandit-toll .. " food." rbold $) +text
	else
		trunk-food 4 > if
			ezbandit? if 
				($ "le reste de votre nourriture et un quart de vos munitions et fournitures medicales." rbold $) 
			else
				($ "le reste de votre nourriture et la moitie de vos munitions et fournitures medicales." rbold $) 
			then +text
		else
			ezbandit? if
				($ "toute votre essence supplementaire et la moitie de vos munitions et fournitures medicales !" rbold $)
			else
				($ "toutes vos munitions, fournitures medicales et jerricanes d'essence !" rbold $)
			then +text
		then
	then
;

cyoa-choice: OMENT-bandit-chess-go
	cpet? cchar isgourmand? or if
		($ cname .. " starts eating the chess pieces!
		The perfect opening move!" .. "
		YOU CAN'T DO THAT! YOU CAN'T DO THAT!" pbold .. " shrieks the chessmaster. The game is postponed until the chess pieces 'pass'. Medical science says this will take about 20 years.
		" .. cname .. " feels extremely satisfied." $) text! goodfx morale3+
	then;
	cchar angrystrong? if
		($ cname .. " begins by picking up a Rook!" $) text!
		($ cname .. " hurle alors " .. "LES JEUX DE SOCIETE C'EST POUR LES NEEEERDS" fbold .. " et retourne l'echiquier avec " .. "UNE FORCE INCROYABLE ! " rbold .. cHe .. " envoie " .. chis .. " Tour entre les yeux du champion, l'assommant." $) +crtext attitudeREV strengthREV goodfx morale++all
		($ Thegroup .. " obtient un FUSIL A POMPE et un FUSIL DE CHASSE gratuits !" rbold $) +crtext
		1 WEAPON_HUNTING trunk.weapon+ 1 WEAPON_SHOTGUN trunk.weapon+
		12 20 rnd trunk-rifle-shell+ 9 15 rnd trunk-shotgun-shell+
	then;
	cchar oblivious? if
		($ cname .. " claims to have never heard of chess." $) text!
		($ "Comment ca vous n'avez jamais entendu parler des echecs ?" rbold .. " dit le champion." $) +crtext
		"Jamais entendu parler, desole. C'est comme Fortnite ?" bbold +crtext
		"PARTEZ !" rbold +crtext
		witsattREV goodfx
	then;
	cchar grating? if
		($ cname .. " joue contre le champion d'echecs de la facon la plus irritante que " .. che .. " puisse trouver. Presque infinily endless throat clearing, long pauses between every move, off-tune humming, zany catch phrases. The works!
		Le champion echiqueen devient si furieux qu'il ne peut plus reflechir. " .. cname .. " declare " .. "Echec et mat ! Je ne sais meme pas jouer aux echecs !" pbold $) text!
		" Le champion est trop en colere pour viser juste !" +text
		goodfx cool-it++ witsattREV morale++all
		"*Utiliser la Strategie Se Calmer aux Echecs compte comme un Point Se Calmer honoraire" rbold +crtext
	then;
	ctemper- if
		($ cHe .. " loses " .. chis .. " son calme pendant la partie d'echecs. " .. cHe .. " renverse l'echiquier et attaque le champion de presnge." $) text! bitefx ouch--
		"Le champion fuit ! Il ne peut pas recuperer ses gains, ce scenario comptant comme un 'match nul' aux echecs." +crtext temperREV
	then;
	($ cname .. " tries " .. chis .. " de son mieux, mais ne peut pas battre le champion d'echecs." $) text!
	bandit-wager-pay badfx
;

cyoa-bridge: OMENT-bandit-chess-pick4
	someicon
	"Qui devrait affronter le champion aux echecs ?" cyoa-text!
	' OMENT-bandit-chess-go cyoa-team-choice
;

cyoa: OMENT-bandit-chess
	"Partie d'Echecs pour votre VIE" cyoa-title! image-chess-board
	($ Thegroup .. " rencontre un homme qui se dit maitre des echecs itinerant. Arme jusqu'aux dents, il defie le groupe a une " .. "partie non optionnelle" bbold .. " d'echecs !" .. " Si vous perdez, il exige " rbold $) cyoa-text!
		bandit-wager
		"Qui devrait affronter ce champion aux echecs ?" +crtext
		team-count 3 > if
			' OMENT-bandit-chess-go 2 #cyoa-team-choice
			choice( "Choisir quelqu'un d'autre" )choice: OMENT-bandit-chess-pick4
		else
			' OMENT-bandit-chess-go 3 #cyoa-team-choice
		then
		bandit-fight
;

// Anime Bandits

: OMENT-anime-fancrush args( chara )
	<- chara .trait@ "Anime Fan" $= if
		<- chara .morale4-
	then
;

: OMENT-bandit-megaloot
	morale3+all 12 trunk-food+ 1 goodfx
	5 WEAPON_SHURIKEN trunk.weapon+ 5 WEAPON_OTAKU trunk.weapon+
	18 27 trunk-bullet+ 12 20 rnd trunk-rifle-shell+ 9 15 rnd trunk-shotgun-shell+
	2 4 trunk-medical+
	
;

cyoa-choice: OMENT-bandit-anime-coolit
	cpet? if
		($ cname .. " pete a l'idee meme du manga. Les bandits manga comprennent le message d'une facon ou d'une autre." $)
	else
		($ cname .. " dit aux bandits manga que " .. "LE MANGA C'EST PAS REEL ! 
	ALSO, COOL IT!" pbold $) then cyoa-text!
	cool-it-7 if
		($ "Cela ebranle les bandits jusqu'au plus profond d'eux-memes.
			" .. "C'EST VRAI ! ON A GACHE NOS VIES !!" rbold .. "
			The anime bandits leave in great shame. A lot of their supplies are left behind!" $) +crtext
			OMENT-bandit-megaloot cooled-it
	else
		cool-it++
			($ "Les bandits le prennent mal.
			" .. "NON ! VOUS AVEZ TORT ! ARRETEZ ! ARRETEZ !!" rbold .. "
			The bandits all focus their weapons on " .. cname .. "!" $) +crtext
			ouch2- bitefx ' OMENT-anime-fancrush foreach-team-char
	then attitudeREV witsREV 
;

: cguyorgirl
	cchar .female@ if "girl" else "guy" then

;

cyoa-choice: OMENT-bandit-animefan
	($ cname .. " exprime une opinion controversee et quelque peu degoutante : " .. "J'aime le manga !" pbold $) cyoa-text!
	($ "Heh... Hey, ce " rbold .. cguyorgirl rbold .. " est correct !" rbold $) +crtext
	"Les bandits vous laissent passer !" +crtext goodfx morale++all
;

cyoa-choice: OMENT-bandit-animegirl
	($ cname .. " tonne : " .. "JE SUIS LE MANGA ! JE SUIS LE MANGA INCARNE !" fbold $) cyoa-text!
	($ "Les bandits s'inclinent quand leur objet de culte marche sur terre !" .. " Veuillez accepter nos offrandes ! On adore le manga !" rbold $) +crtext
	OMENT-bandit-megaloot
;

cyoa-choice: OMENT-bandit-obliv
	// Decided not to do this one, as it's not an option for trade-anime and this update seems to be getting a lot of Oblivious choices, anyway
;

: isanimefan? .trait@ "Anime Fan" $= ;
: numanimefanfilt args( chara ) <- chara isanimefan? ;
: numanimefans team-stack ' numanimefanfilt stack-filter nip ;

: animefancheck
	checkchar isanimefan?
;

: OMENT-animefancheck
	checkchar .trait@ "Anime Fan" $= checkchar
;

: cyoa-animefan-choice team-stack gourmandfilt cyoa-char-stack-choice ;

: stpick-anime
	62 stpick if true then;
	63 stpick if true then;
	64 stpick if true then;
	65 stpick if true then;
	false
;

cyoa: OMENT-bandit-anime
	"Les Bandits Manga" cyoa-title!
	($ "Des bandits gardent un etroit troncon de route. Ils portent des tenues manga ridicules.
	" .. "Pour que vous puissiez passer, ils veulent " rbold $) cyoa-text!
		numanimefans 0 > if
			' animefancheck pick-team-char 0= if false then; pickchar true if choosechar then
			cchar charchoice( ": I like anime!" )choice: OMENT-bandit-animefan
		then
		most-grating if
			charchoice( " tells Bandits ANIME ISN'T REAL" fcoolit )choice: OMENT-bandit-anime-coolit
		then
		(* most-oblivious if
			charchoice( ": What's an anime?" )choice: OMENT-bandit-obliv
		then  *)
		stpick-anime if
			charchoice( ":" .. " I AM ANIME" fbold )choice: OMENT-bandit-animegirl
		then
		bandit-demand-fight
;

// common events

// The Sphinx



// Precognition - Seeing the Future

cyoa-choice: OMENT-thirdeye-A
	($ "Conformement a la prophetie, " .. thegroup .. " trouve un petit cache de fournitures un peu plus tard dans la journee !" $) text!
	homesearch1 ammosearch1 goodfx
;

cyoa-choice: OMENT-thirdeye-B
	($ "Conformement a la prophetie, " .. cname .. " apprend une importante lecon de vie via des hallucinations causees par " .. chim .. " ayant aussi mange une boite de viande mysterieuse." $) text!
	sting-- badfx
	// cchar statmod{ .sick }
	// ($ cname .. " est malade, avec moins de Forme et de moral jusqu'au repos !" rbold $) +crtext
	// Commented the sickness mod out because it's really harsh
	morale--
	33 %chance if 
		medical++
	else
		50 %chance if shooting++ else mechanic++ then
	then
;

// other side of this is in locplan.df, this lets you call locplan events in cyoa events
defer innereventdefer

: surprise-location innereventdefer
	"Lieu Surprise !" cyoa-title!
	($ "En roulant sur la Death Road, " .. thegroup .. " tombe sur un lieu inattendu : " $) text! ;

cyoa-choice: OMENT-thirdeye-C
	solo if
		($ "Conformement a la prophetie, " .. cname .. " se cogne l'orteil." $)
	else
		($ "Conformement a la prophetie, dans une serie d'accidents bizarres, tout le groupe se cogne les orteils respectifs." $)
	then text!
		sting--all morale--all bitefx badfx
	($ "Juste apres, " .. thegroup .. " tombe de maniere inattendue sur un lieu dangereux !" $) +crtext
	' surprise-location stack-road-action
;

cyoa: OMENT-thirdeye
	"Voir l'Avenir" cyoa-title! image-third-eye choosehuman badfx
	($ cname .. " hallucine apres avoir mange une boite de viande mysterieuse. C'etait probablement de la nourriture pour chat." $) text!
		sting-- morale--
	($ "Cela ouvre d'une facon ou d'une autre " .. chis .. " 'troisieme oeil'" rbold .. ", accordant un moment de " .. "PRECOGNITION" fbold .. " ! " .. cname .. " voit l'avenir :" $) +crtext
		choice( I-or-We .. "va trouver quelque chose de bien !" )choice: OMENT-thirdeye-A
		choosehuman cchar charchoice( " will learn something important!" )choice: OMENT-thirdeye-B
		choice( I-or-We .. "va faire face a un grand danger !" )choice: OMENT-thirdeye-C
;

// Dead End Detour

cyoa-choice: OMENT-deadend-A
	"Le Long Detour" cyoa-title! image-dead-end
	($ Thegroup .. " commence le long detour." $) text!
	detour-roll
	car-mpg 0 > if 
		"La deuxieme partie du detour commence." +crtext
		detour-roll
	then
	($ "Le long detour se termine et " .. thegroup .. " atteint une zone qui semble propice au pillage..." $) +crtext
	' innereventdefer stack-road-action
;

cyoa: OMENT-deadend
	"Detour en Impasse" cyoa-title! image-dead-end
	($ Thegroup .. " se perd dans ce labyrinthe de routes bloquees. " .. gThey .. " arrive" .. g1s .. " a a dead end." $) text!
	vehicle.which@ 0 = if
		($ gThey .. " se perdent pendant une journee entiere, avant de trouver un itineraire alternatif. " $) +crtext
		+cr fullcamp heal-event
	then;
	($ gHis .. " doit maintenant choisir entre un detour ou un plus long detour pouvant mener a du butin. " $) +crtext
	vehicle.which@ 0 > if
		($ gThey .. " pourrait aussi abandonner la voiture pour continuer a pied." $) +text
	then
		choice( "Prendre un detour" )choice: car-detour
		choice( "Prendre le plus long detour" )choice: OMENT-deadend-A
	vehicle.which@ 0 > if choice( "Abandonner la voiture" )choice: car-abandoned then
;

// Lone Dog
// Items currently placeholder: the same as the Steal from Cardboard Man event

0 value OMENT-lonedogprize

: lonedogprize
	OMENT-lonedogprize case
		1 of "NIGHTSTICK" endof
		2 of "SHOTGUN" endof
		3 of "RIFLE" endof
		4 of "DOLT45 REVOLVER" endof
		5 of "FIRE AXE" endof
		6 of "SNUBNOSE REVOLVER" endof
	endcase
;

: lonedogget
	OMENT-lonedogprize case
		1 of 1 WEAPON_NIGHTSTICK endof
		2 of 8 trunk-shotgun-shell+ 1 WEAPON_SHOTGUN endof
		3 of 12 trunk-rifle-shell+ 1 WEAPON_RIFLE endof
		4 of 6 trunk-bullet+ 1 WEAPON_DOLT endof
		5 of 1 WEAPON_FIRE endof
		6 of 6 trunk-bullet+ 1 WEAPON_SNUBNOSE endof
	endcase
;

cyoa-choice: OMENT-lonedog-go
	($ cname .. " s'approche du chien." $) text!
	cchar isdogpal? if
		($ pname .. " uses every bit of " .. phis .. " PSYCHOLOGIE CANINE. Ca consiste a ramasser des ordures par terre, a faire semblant d'etre super excite, puis a s'eloigner des ordures." $) +crtext
		($ cname .. " vole le precieux " .. lonedogprize rbold .. " du chien pendant qu'il est distrait !" $) +crtext
		lonedogget trunk.weapon+ goodfx
	then;
	cloyalty- if
		($ cHe .. " plans to attack the dog. The dog senses this malevolent intent, and runs.
		" .. cname .. " chases it, and doesn't see a lone zombie in the area until " .. che .. " practically runs into it." $) +crtext loyaltyREV ouch-- bitefx
	then;
	cchar oblivious? if
		($ cHe .. " s'amuse avec le vieux chien, ils s'amusent bien et font de l'exercice. Cependant, " .. cname .. " oublie completement le " .. lonedogprize rbold .. " !" $) +crtext witsattREV goodfx morale2+ fitness++
	then;
	cattitude+ ctemper+ or if
		($ "Le chien fuit " .. chim .. " pendant un bon moment, mais " .. che .. " persiste !" $) +crtext
		($ cname .. " vole le precieux " .. lonedogprize rbold .. "." $) +crtext
	lonedogget trunk.weapon+ goodfx
	ctemper+ if temperREV then cattitude+ if attitudeREV then
	then;
	cwits+ if
		($ cHis .. " les ruses ingenieuses ne font pas le poids face aux tactiques simples du chien : prendre l'objet, courir un peudistance, sit down, repeat." $) +crtext
	then
	($ cHe .. " finit par courir apres le chien un moment, mais finit par se decourager et abandonner !" $) +crtext morale-- cwits+ if witsREV then badfx
;

cyoa-choice: OMENT-lonedog-4
	"Qui devrait essayer d'attraper le jouet du chien ?" cyoa-text!
	' OMENT-lonedog-go cyoa-team-choice
;

cyoa: OMENT-lonedog
	"Le Chien et les Dingus" cyoa-title! image-lone-dog
	1 6 rnd to OMENT-lonedogprize
	($ "Il y a un vieux chien assis de l'autre cote de la route. Il est pres d'un " .. lonedogprize rbold .. " par terre. Chaque fois que " .. thegroup .. " essaie d'approcher, il prend l'objet et s'enfuit un peu plus loin." $) text!
		choice( "Ignorer le chien !" )choice
	solo if
		soloer choosechar choice( "Try to get that item" )choice: OMENT-lonedog-go
	else
		"Qui devrait essayer d'attraper l'objet ?" +crtext
		team-count 3 > if
				' OMENT-lonedog-go 2 #cyoa-team-choice
				choice( "Choisir quelqu'un d'autre" )choice: OMENT-lonedog-4
			else
				' OMENT-lonedog-go 3 #cyoa-team-choice
			then
	then
;

// Cooking a Meal
// This was going to be a dumbest check at first, but maybe that's too easy for getting fireproofing.
// dumbest-pass if dumbest charchoice if I change my mind

cyoa-choice: OMENT-cooking-gas
	image-gas-can
	($ Thegroup .. " takes the gas from the generator. There wasn't much left, but every little bit helps.
	Maybe there will be time for cooking later." $) text! 15 30 rnd trunk-gas+ goodfx
;

cyoa-choice: OMENT-cooking-full
	image-cooking-on-fire
	($ Thegroup .. " eats an extra full meal, cooked in a kitchen and brimming with flavor!
	What a morale booster! It's too bad that the next meal will be straight from a can." $) text!
	food-required neg trunk-food+
	goodfx morale3+all
;

cyoa-choice: OMENT-cooking-snack
	image-cooking-on-fire
	($ Thegroup .. " eats a nice snack, one actually cooked in a kitchen! It's a rare break from eating straight out of cans.
	What a morale booster!" $) text!
	team-count neg trunk-food+
	goodfx morale++all
;

: OMENT-cooking-megameal args( chara )
	// 1.2 <- chara .scale.body.y!
	1.3 <- chara .scale.body.x!
	<- chara .vitality++ <- chara .health++ -1 STAT_DEXTERITY <- chara .bonus+
;

cyoa-choice: OMENT-cooking-gourmand
	($ cname .. " prepare un MEGA REPAS ! La saveur est MEGA MAXIMISEE, sans parler des portions." $) text!
	food-required 2 * neg trunk-food+
	morale4+all goodfx
	' OMENT-cooking-megameal foreach-team-char
	($ Thegroup .. " feels very solid after that meal, but so slow!" $) +crtext
;

: OMENT-cooking-burn args( chara )
	<- chara isfireproof? not if
		<- chara .ouch--
	then
;

cyoa-choice: OMENT-cooking-fire
	($ cname .. " met presque immediatement toute la cuisine en feu par accident. MAINTENANT les choses commencent a chauffer!" $) text! badfx
	' OMENT-cooking-burn foreach-team-char
	cchar isfireproof? if
		($ cname .. " feels adequately spicy!" $) +crtext
		morale++
	else
		ouch--
		cchar alive? if
			($ cname .. " gets forged in the fires!
			" .. cHe .. " est maintenant " .. "quasiment ignifuge !" fbold $) +crtext
			cchar statmod{ .fireproof } goodfx
		else
			"Peut-etre un peu trop epice." +crtext
		then;
	then

;

cyoa: OMENT-cooking
	"Cuisine au Gaz" cyoa-title! image-cooking-on-fire
	($ Thegroup .. " attempts to loot a restaurant. " .. gThey  .. " find" .. g1s .. " pas de nourriture, mais plein d'epices et une cuisine fonctionnelle, grace a un generateur !" $) text!
		choice( "Prendre le Gaz du Generateur" )choice: OMENT-cooking-gas
		trunk-food team-count >= if
			choice( "Cuisiner un Snack - " .. team-count .. " Nourriture" )choice: OMENT-cooking-snack
		then
		trunk-food food-required >= if 
			choice( "Cuisiner un Repas - " .. food-required .. " Nourriture" )choice: OMENT-cooking-full
		then
		numgourmands 0 > trunk-food food-required 2 * >= and if
			' gourmandcheck pick-team-char 0= if false then; pickchar true if choosechar then
			cchar charchoice( ": Cook MEGA FEAST - " .. food-required 2 * .. " Food" )choice: OMENT-cooking-gourmand
		then
		most-oblivious if
			charchoice( ": Cook MEGA FEAST?" )choice: OMENT-cooking-fire
		then
;

// Maple Street

cyoa-choice: OMENT-maplest-run
	($ Thegroup .. " fuit pendant que la foule en colere le bombarde de pierres !" $) text!
	sting--all
	"Mais ce qui fait le plus mal c'est les cris mechants." +crtext
	morale--all badfx
;

cyoa-choice: OMENT-maplest-go
	($ cname .. " parle a la foule en colere." $) text!
	cpet? if
		($ cHe .. " can't talk, so instead " .. che .. " spins around excitedly! How fun!
		The mob forgets whatever their problem was." $) +crtext goodfx morale++all
	then;
	cchar grating? if
		($ cHe .. " hurle " .. "VOUS AUTRES... VOUS ETES LES VRAIS ZOMBIES !" pbold .. "
		The people of Maple Street are thus made ashamed of their words and deeds.
		" .. Thegroup .. " is let through." $) +crtext witsattREV goodfx cool-it++
	then;
	cchar oblivious? if
		($ cHe .. " demande, " .. "C'est quoi un zombie ?" pbold .. "
		The mob is bewildered and exasperated by this. 
		After failing to explain ANYTHING to " .. cname .. ", they decide the whole 'angry mob' thing is a waste of time. They put their pitchforks down and wander off. Hey, free pitchforks!" $) +crtext witsattREV goodfx 9 WEAPON_PITCHFORK trunk.weapon+
	then;
	cchar charming? if
		($ cHe .. " dit, " .. "Desole d'avoir cause cette epidemie de zombies !" pbold .. "
		" .. cname .. " winks.
		That's all the mob really wanted. An apology. 
		" .. cname .. " still gets beaten up, but it's a light beating." $) +crtext witsattREV sting-- bitefx goodfx
	then;
	ctemper- if
	($ cHe .. " loses " .. chis .. " temper almost right away, and yells at the mob that THEY caused the zombie outbreak.
		The angry mob and " .. cname .. " shout at each other for a long time until they both storm off. Each side thinks they won the argument, and somehow, no one gets hurt." $) +crtext goodfx temperREV morale++
	then;
	cwits+ if
		($ cHe .. " demonte expertement les accusations criees de la foule. La foule en colere s'excuse d'avoir dit des mechancetes, puis bat " .. cname .. " up for being a know-it-all.
		" .. cHe .. " still feels smug for being right." $) +crtext witsREV sting2- morale++ goodfx bitefx
	then;
	($ "Ca se passe tres mal pour " .. chim .. " !" $) +crtext ouch-- sting-- morale-- bitefx badfx
;

cyoa-choice: OMENT-maplest-pick4
	"Qui raisonne avec la foule en colere ?" text!
	' OMENT-maplest-go cyoa-team-choice
;

cyoa: OMENT-maplest
	"Les Monstres de la Rue de l'Erable" cyoa-title! image-maple-street
	($ Thegroup .. " s'arrete sur la Rue de l'Erable, qui a forme un village fortifie pour se defendre des zombies. Peu apres, une foule se forme avec des fourches et des torches, et blame " .. thegroup .. " pour l'epidemie de zombies !" $) text!
		choice( "Fuir !" )choice: OMENT-maplest-run
		solo if
			soloer charchoice( ": Try to reason with them" )choice: OMENT-maplest-go
		then;
		"Quelqu'un devrait-il essayer de les raisonner ?" +crtext
	team-count 3 > if
		' OMENT-maplest-go 2 #cyoa-team-choice
		choice( "Choisir quelqu'un d'autre" )choice: OMENT-maplest-pick4
	else
		' OMENT-maplest-go 3 #cyoa-team-choice
	then	
;

// THE RIDDLE OF THE SPHINX

cyoa-choice: OMENT-cat-go image-seat-cat
	"FELICITATIONS, VOUS AVEZ RESOLU MON ENIGME ! " rbold text!
	($ "Le chat griffe alors " .. solo if cname else "tout le monde" then .. "." $) +text bitefx
	solo if "Dans un rare acte de clemence pour un chat, il ne cherche pas a tuer." +crtext else ouch-- then 
	sting--all
	($ "Dans le reste de la maison, " .. thegroup .. " trouve un enorme butin !" $) +crtext
		9 12 trunk-food+ 18 27 trunk-bullet+ 12 20 rnd trunk-rifle-shell+ 9 15 rnd trunk-shotgun-shell+
		2 4 trunk-medical+
	"La perte de moral due a l'agression est parfaitement compensee par ca." +crtext
;

0 stack 
	"Euh... du carton ?" shove
	"Une souris ! Ce doit etre ca !" shove
	"LA REPONSE..... C'EST L'HOMME" shove
	"Je sais pas, quelque chose de degoutant ?" shove
	"... Cat food?" shove
	"C'est un piege ? C'est un piege." shove
	"Tu es l'enigme ! TOI tu es l'enigme !" shove
	"Comment je le saurais ?!" shove
value OMENT-catsayings-base
OMENT-catsayings-base shuffles var OMENT-catsayings


: OMENT-catsay 
	OMENT-catsayings depths 0= if OMENT-catsayings-base shuffles to OMENT-catsayings then
	pops nip
;

: OMENT-cat-choice-with-handler
	// dup choice( over character# cyoa-choice-charid! swap .name@ )choice choosechar
	dup charchoice( ": " .. OMENT-catsay )choice choosechar
	// dup cyoa-add-char-choice	
	dup cyoa-choice-handler!
;

: OMENT-cat-handlers ' OMENT-cat-choice-with-handler foreach ;

: OMENT-cat-choices2 ( ' cyoa-choice number -- )
	#team-stack-shuffled
	OMENT-cat-handlers
	2drop
;

defer OMENT-cat-what

: OMENT-cat-choices
		choice( "Quoi ?" )choice: OMENT-cat-what
		' OMENT-cat-go team-count 4 < if team-count else 3 then OMENT-cat-choices2
;

: OMENT-cat-riddle
	"WHAT DID I JUST EAT?
	*NOTE: Whoever answers gets mauled extra hard!" rbold +text
	OMENT-cat-choices
;

cyoa-choice: OMENT-cat-what_
	image-seat-cat
	($ "Le chat se racle la gorge et repete l'enigme :  " $) text!
	OMENT-cat-riddle
;

last to OMENT-cat-what

cyoa: OMENT-rare-cat
	"L'Enigme du Sphinx" cyoa-title! image-seat-cat
	($ "En cherchant du butin dans une maison en ruines, " .. thegroup .. " rencontre un chat assis dans un fauteuil moisi.
	The cat speaks from its throne! It's a riddle:  " $) text!
		OMENT-cat-riddle
;

// SECRET DOCUMENTS, EXPOSED

: OMENT-secretdoc-fail
	($ cname .. " essaie de dechiffrer les documents secrets, mais se frustre apres un moment et abandonne." $) text! badfx morale--
;

cyoa-choice: OMENT-secretdoc-go
	cpet? if
		($ cname .. " just starts eating the papers.
		I'm not sure what you were hoping for, here.
		" .. cname .. " is slightly pleased about solving this mystery." $) text! bitefx morale++
	then;

	cchar paranoid? if
		($ cname .. " gets PUMPED over the secret documents.
		" .. "Des papiers secrets du GOUVERNEMENT ? Avec plaisir !" bbold $)
		($ cname .. " pretend que les papiers documentent une organisation secrete appelee " .. "S*T*I*N*K*L*E" bbold .. " dont le but etait de creer la penurie de Milk Duds qui a conduit a la zombocalypse !
		FINALLY, the truth has been revealed!" $) text! witsattREV morale3+ 
		solo not if 
			($ "Absolument personne ne croit ce que " .. cname .. " dit." $) +crtext
			cchar morale--all-except
		then
	then;

	cchar oblivious? if
		($ cname .. " almost instantly forgets what " .. che .. " was doing and wanders off.
		However, " .. che .. " stumbles onto a small cache of supplies elsewhere in the office!" $) text!
		homesearch1 witsattREV goodfx
	then;
	
	cchar grating? if
		($ cname .. " essaie de dechiffrer le message secret un moment. Puis " .. che .. " fronce les sourcils et ecrit sans conviction " .. "SE CALMER !" rbold .. " sur un des papiers." $) text! witsattREV 
		($ cHe .. " n'est pas dans son assiette aujourd'hui." $) +crtext
		morale-- cool-it++ badfx
	then;

	cwits- if
		OMENT-secretdoc-fail witsREV
	then;

	cmechanic+ cmedical+ and if
		($ cname .. " tries to decode the secret documents.
		" .. cHe .. " recognizes many patterns in the papers. These are blueprints! It's designs for a car that is powered by being on top of a giant zombie, made larger through a massive all-cheese diet and electrical zaps! Mad science!!" $) text!
		morale3+ mechanic++ mechanicREV medical++ medicalREV goodfx
	then;

	cmechanic+ if
		($ cname .. " takes a crack at decoding the secret documents.
		" .. cHe .. " recognizes some patterns in the papers. These are blueprints! It's designs for an engine that runs off canned beans and expired cat food. Very interesting!" $) text!
		morale2+ mechanic++ mechanicREV goodfx
	then;
	
	cmedical+ if
		($ cname .. " attempts to decipher the secret documents.
		" .. cHe .. " figures out that these are actually medical papers. They are talking about a theory on how to possibly prevent future zombification through an all-cheese diet. Interesting!" $) text!
		morale2+ medical++ medicalREV goodfx
	then;
	
	ctemper- if
		($ cname .. " completely loses " .. chis .. " patience while trying to decode the papers!
		" .. cHe .. " takes out " .. chis .. " rage by kicking something. Unfortunately, that something was the heavy safe the papers came from." $) text!
		temperREV bitefx sting-- morale2-
	then;
	
	cwits+ if
		($ cname .. " decodes some of the secret documents!
		The papers are full of incredibly dry technical jargon, so they're still unreadable. Still, " .. cname .. " feels satisfied for decoding them." $) text!
		witsREV goodfx morale++
	then;
	
	OMENT-secretdoc-fail

;

cyoa-bridge: OMENT-secretdoc-pick
	"Qui devrait dechiffrer ces documents secrets ?" text!
	' OMENT-secretdoc-go cyoa-human-choice

;

cyoa: OMENT-secretdoc
	"Documents Secrets" cyoa-title! image-secret-documents
	($ "En fouillant un immeuble de bureaux, " .. thegroup .. " trouve un coffre laisse ouvert. Il n'y a que des papiers. Le texte est brouille et incomprehensible.
	They were locked up, they must be important! Who should decipher them?" $) text!
		choice( "Les laisser tranquilles" )choice
	numhums 3 > if
		' OMENT-secretdoc-go 2 #cyoa-team-choice
		choice( "Choisir quelqu'un d'autre" )choice: OMENT-secretdoc-pick
	else
		' OMENT-secretdoc-go cyoa-team-choice
	then
;

// FACE THE WHEEL

0 value OMENT-wheelspin

: OMENT-wheelspintext
	OMENT-wheelspin case
		0 of badfx "TOCARD-DOO" endof
		1 of badfx "TRAVAUX FORCES" endof
		2 of goodfx "PANIER CADEAU" endof
		3 of goodfx "MINCE ALORS" endof
	endcase
;

: OMENT-thewheel-labor args( @ )
	<- @ .cstrength+ if
		<- @ .fitness++
		<- @ .fitnessREV
	then;
	<- @ .strength++ 
	<- @ .strengthREV
;

: OMENT-thewheel-hair args( @ )
	<- @ dog? if
		0 20 rnd <- @ .bodytype!
	then;
	<- @ ispet? if
		0 17 rnd <- @ .bodytype!
	then;
	0 <- @ .hattype!
	0 45 rnd <- @ .hairtype!
;

cyoa-choice: OMENT-thewheel-go
	OMENT-wheelspintext cyoa-title! image-death-wheel
	OMENT-wheelspin 0 = if
		someicon
		"Les villageois commencent a scander. Ca semble mauvais..." text!
		"TOCARD-DOO ! TOCARD-DOO POUR TOI !" bbold +crtext
		($ "They change " .. thegroup .. "'s hairstyle" .. gs .. " in a forced makeover. This seems mildly irritating!" $) +crtext ' OMENT-thewheel-hair foreach-team-char morale--all badfx
	then;
	OMENT-wheelspin 1 = if
		($ "Les villageois condamnent " .. thegroup .. " a une semaine de travaux forces a la Fabrique de Papier Toilette !
		It's grueling work, but at least they feed you. It's also good exercise!" $) text!
		' OMENT-thewheel-labor foreach-team-char 7 calendar-day+ morale2-all goodfx
	then;
	OMENT-wheelspin 2 = if
		($ "Les villageois presentent a " .. thegroup .. " un panier cadeau de bon gout ! Ils ne veulent pas le faire, mais ils doivent absolument suivre la volonte de " .. "LA ROUE" rbold .. "
		It's delightful!" $) text! morale++all homesearch1 goodfx
	then;
		($ "MINCE ALORS" rbold .. " ? Ca semble vraiment mauvais !" $) text!
		($ "MINCE ALORS ! On dirait qu'on doit laisser " bbold .. ghim bbold .. " partir !" bbold $) +crtext
		($ "Quel soulagement ! Merci, " .. "LA ROUE" rbold .. " !" $) +crtext morale++all goodfx
;

: OMENT-thewheel-spin
	"LA ROUE tourne... elle s'arrete sur : " rbold +crtext
	0 3 rnd to OMENT-wheelspin
	OMENT-wheelspintext fbold +text
;

cyoa-choice: OMENT-thewheel-run
	"FUYEZ" cyoa-title! image-death-wheel
	($ Thegroup .. " refuses to let " .. ghis .. " fate be decided by some weird wheel!
	" .. gThey .. " decide" .. g1s .. " to run for it, but " .. gthey .. " must ditch the car during the escape." $) text!
	car-abandon
;



: OMENT-thewheel-choices
		choice( "Accepter ce sort" )choice: OMENT-thewheel-go
		choice( "Fuir, mais perdre la voiture !" )choice: OMENT-thewheel-run
;

cyoa-choice: OMENT-thewheel-again
	"AFFRONTEZ LA ROUE... ENCORE" cyoa-title! image-death-wheel
	"Recommencer ? Comment avez-vous su pour notre regle la plus sacree ?
	Well, fine, but you only get one!" bbold text!
	OMENT-thewheel-spin OMENT-thewheel-choices
;

cyoa: OMENT-thewheel
	"AFFRONTEZ LA ROUE" cyoa-title! image-death-wheel
	($ Thegroup .. " s'arrete dans un petit village. Plutot qu'etre un lieu de commerce sur, les choses tournent vite mal avec les locaux. En guise de punition, ils sortent..." .. "LA ROUE" rbold $) text!
		OMENT-thewheel-spin
		choice( "Exiger de recommencer !" )choice: OMENT-thewheel-again
		OMENT-thewheel-choices
;

