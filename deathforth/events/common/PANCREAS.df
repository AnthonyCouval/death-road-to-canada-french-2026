// Originally moved character declarations to charmisc.df out of necessity, but that screwed things up
// Then moved this file, PANCREAS.df, above cyoa-k-newbie-df
// Worked great! That's a nice spot for not running into problems
// Likely where the UPDATENAME.df files can vary due to update, or even just split them in future

: .poolify args( chara )
	130 <- chara .specialtype!
	1 <- chara .strength!
	1 <- chara .fitness!
	"Pool Champ" <- chara .name!
	"etait un joueur de billard professionnel. Il en a fait sa propre philosophie de guerrier." <- chara .job!
	' rosettagf-main-events <- chara .main_events!
	2 <- chara .carrying.slot_count!
	WEAPON_MEGAPOOLCUE <- chara .weapona!
	1 <- chara .weapon_nodropa!
	6 <- chara .attitude!
	0 <- chara .female!
;

: .honchoify args( chara )
	129 <- chara .specialtype!
	1 <- chara .strength!
	1 <- chara .fitness!
	2 <- chara .shooting!
	"Honcho" <- chara .name!
	"est un cowboy du VIEUX WEST. Manie deux armes a feu si elles sont dans les deux premiers emplacements !" <- chara .job!
	' dualwielder-main-events <- chara .main_events!
	// Originally tried a 2 slot lock, but was too limiting. However, 3 slots messed up the dual wield sometimes, so gave him a C locked melee weapon.
	WEAPON_WESTKNIFE <- chara .weaponc!
	1 <- chara .weapon_nodropc!
	0 <- chara .attitude!
	0 <- chara .female!
	2 STAT_SHOOTING <- chara .bonus!
;

: .vansmeltify args( chara )
	131 <- chara .specialtype!
	1 <- chara .strength!
	1 <- chara .fitness!
	4 <- chara .shooting!
	3 <- chara .headoff.y!
	"Van Smelt" <- chara .name!
	"est un chasseur de grand gibier. Visez les combos de tirs en tete a longue distance !" <- chara .job!
	// ' dualwielder-main-events <- chara .main_events!
	// 2 <- chara .carrying.slot_count!
	WEAPON_MARBELLE <- chara .weapona!
	1 <- chara .weapon_nodropa!
	0 <- chara .female!
;

// CYOA

cyoa{

// Pool Champ

cyoa-bridge: camp-pool-recruit
	ricon 4 recruitee .morale! clear-cyoa
	15 recruit-yes-food
	"Il suffit de penser au monde entier comme une table de billard !" pbold +crtext
	recruitee .strengthREV recruitee .fitnessREV recruitee .attitudeREV
;

cyoa: camp-rec-pool
	"Joueur de Billard Professionnel" cyoa-title!
	nearest .character@ choosechar cchar to recruitee ricon
	($ "Cet homme a la physique et le comportement d'un athlete pro. On sait instantanement, rien qu'en le regardant, qu'il joue aux flechettes ou au billard.
	Il est PEUT-ETRE plutot fan de bowling." $) cyoa-text! basic-tone
	"Ce personnage obtient des bonus d'endurance et de puissance en frappant les zombies a la pointe de sa portee melee ! Il a aussi 10% de chance d'obtenir des resultats explosifs avec ses attaques de pointe !" rbold +crtext
	trunk-food 14 > if
		choice( "Laisser pour l'instant" )choice
		choice( "L'engager - 15 nourriture" )choice: camp-pool-recruit
	else
		"Il faut 15 nourriture pour le recruter." +crtext
		choice( "Pas assez de nourriture" )choice
	then
;

// Honcho the Gunslinger

cyoa-bridge: camp-honcho-recruit
	ricon 4 recruitee .morale! clear-cyoa
	15 recruit-yes-food
	"OU SONT PASSES MES PISTOLETS ?
	SACREBLEU !" rainbold +crtext
	recruitee .attitudeREV
;

cyoa: camp-rec-honcho
	"L'HEURE DE GLOIRE" cyoa-title!
	nearest .character@ choosechar cchar to recruitee ricon
	($ "Cet homme bourru est vetu d'un poncho et d'un sombrero. Il a deux holsters de pistolet a ses cotes. En regardant de plus pres, les holsters sont vides." $) cyoa-text! basic-tone
	"QUELLE HEURE EST-IL ?
	C'EST L'HEURE DE GLOIRE." rainbold +crtext
	"Honcho le Pistolero peut manier deux armes a feu, si elles ont des munitions ! Mettez-les dans vos deux premiers emplacements, ou echangez (ou verrouillez dans le menu pause) jusqu'a ce qu'il tienne les deux." rbold +crtext
	trunk-food 14 > if
		choice( "Laisser pour l'instant" )choice
		choice( "L'engager - 15 nourriture" )choice: camp-honcho-recruit
	else
		"Il faut 15 nourriture pour le recruter." +crtext
		choice( "Pas assez de nourriture" )choice
	then
;

// Van Smelt the Big Game Hunter

cyoa-bridge: camp-vansmelt-recruit
	ricon 4 recruitee .morale! clear-cyoa
	15 recruit-yes-food
	"La chasse est ouverte !" pbold +crtext
	recruitee .shootingREV
;

cyoa: camp-rec-vansmelt
	"LE GIBIER LE PLUS DANGEREUX" cyoa-title!
	nearest .character@ choosechar cchar to recruitee ricon
	($ "L'homme qui se repose pres de ce feu de camp a l'apparence d'un chasseur de grand gibier d'antan. Casque colonial, tenue de chasse elegante, fusil lourd." $) cyoa-text! basic-tone
	"Ce personnage a un fusil qui peut etre vise manuellement pour des tirs en tete ! Le fusil devient plus puissant au fil des tirs en tete a longue distance. C'est encore plus fort avec des series de tirs en tete, surtout au-dela de 30 !" rbold +crtext
	trunk-food 14 > if
		choice( "Laisser pour l'instant" )choice
		choice( "L'engager - 15 nourriture" )choice: camp-vansmelt-recruit
	else
		"Il faut 15 nourriture pour le recruter." +crtext
		choice( "Pas assez de nourriture" )choice
	then		
;

}

: PANTEST1 pchar .poolify ;
last 1 hotkey!
: PANTEST2 pchar .honchoify ;
last 2 hotkey!
: PANTEST3 pchar .vansmeltify ;
last 3 hotkey!
: OPPTESTER "events/OPPmode.df" $load-region to-mission ;
last 4 hotkey!