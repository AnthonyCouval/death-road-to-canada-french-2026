: do-and-die args( me eventid )
	<- eventid THING_EVENT_TIMER = if 
			1 <- me .timer! 
			6 <- me .character@ .health! \ don't ever die 
			1 <- me .unseen! \ don't get bit 
				1 <- me  .character@ .weapon_nodropa!
		1 <- me  .character@ .weapon_nodropb!
			1 <- me .character@ .weapon_nodropc!
			
			\ dont pick up weapons 
			
			"" <- me .report \ dont complain when hurt 
			
			
			
	LOOT_BULLET <- me .character@ .user.special_counter@ #thing .character@ .lootamt@ LOOT_BULLET <- me .character@ .lootamt!
	LOOT_RIFLE_SHELL <- me .character@ .user.special_counter@ #thing .character@ .lootamt@ LOOT_RIFLE_SHELL <- me .character@ .lootamt! 	
	LOOT_SHOTGUN_SHELL <- me .character@ .user.special_counter@ #thing .character@ .lootamt@ LOOT_SHOTGUN_SHELL <- me .character@ .lootamt! 
	LOOT_GAS <- me .character@ .user.special_counter@ #thing .character@ .lootamt@ LOOT_GAS <- me .character@ .lootamt! 
	LOOT_JUNK <- me .character@ .user.special_counter@ #thing .character@ .lootamt@ LOOT_JUNK <- me .character@ .lootamt! 
	
	\ share all of my partner's ammo 
	
	0 <- me .weapon_state.frame! \ weapon reload black magic prevention 
	
	<- me .character@ .user.special_counter@ #thing .inside_id@ <- me .inside_id! 
	\ if im in the car, get in the car 
	
	
						<- me .character@ .user.special_counter@ #thing .move_angle@ <- me .move_angle!
				\	<- me .character@ .user.special_counter@ #thing <- me .turn-toward
				\ do as i do  
	
	
	<- me .character@ .user.special_counter@ #thing .targetid@ <- me .targetid! 
			\ share my target... 
			
		<- me .character@ .user.special_counter@ #thing .character@ .health@ 1 < if
			2 <- me .stun!
			0 <- me .clr.a! \ disappear when im dead 
		else 
			1 <- me .clr.a! \ and come back when im not 
		then 
		
		<- me .ammocount 0 = <- me .cooldown@ 0 <> weapondef{ <- me .character@ .weapona@ sel ammo_type@ } 3 > and and if 
			\ if this was my last shot, and i have finished shooting it, and i am not holding a melee 
			2 <- me .stun!
			0 <- me .anim.weapon_counter! 
		then 
			
			
		100 <- me .ai.wait! 
		
	then 
	
; 

: create-dualwielder args( me ) 
		
	dummy-npc 
	\ lt .invisible
	 \ 0 lt .clr.a! 
	1 lt .character@ .carrying.slot_count!  
	<- me .character@ .weaponb@ lt .character@ .weapona! 
	\ <- me .character@ .weaponb@ lt .character@ .weaponb!
	\ <- me .character@ .weaponb@ lt .character@ .weaponc! 	
	
	
	1 lt .character@ .weapon_nodropa!
		1 lt .character@ .weapon_nodropb!
			1 lt .character@ .weapon_nodropc!
	
	 \ 22 STAT_DEXTERITY lt .character@ .bonus! 
	
	<- me .pos lt .pos!
	\ <- me .move_angle@ lt .move_angle!
	\ <- me .angle@ lt .angle! 
	
	0 lt .cooldown!
	0 lt .action_cooldown!
	0 lt .stun! 
	
	\ 12 <- me .weapon_state.angle_add!
	"SPAWN TICK:" print 
	gameticks print 
	
	\ <- me .aim_angle@ lt .character@ .user.special_counter! 
	<- me .aim_angle@ lt .aim_angle!
	 \ <- me .vel lt .vel! 
	<- me lt .turn-toward
	1 lt .unseen!
	3 lt .tileflags! \ can go off map if necessary
	1 lt .nocollide! \ dont hit obbjs 
	\ <- me .targetid@ lt .targetid! 
	1 lt .anim.weapon_counter! 	
		
		
	<- me .character@ .shooting@ lt .character@ .shooting!

	
	\ lt .swapattack 
	
	\ lt .attack
\ 	lt .aim_angle@ print 
	
	1 lt .timer!
	' do-and-die lt .events!
	
;	
	
	
: lobotomise args( chara )
	0 <- chara .ai.loot_chance!
	0.1 <- chara .ai.attack_dist!
	0 <- chara .ai.attack_chance!
	125 <- chara .ai.safety_threshold!
	0 <- chara .ai.flee_dist!
	0 <- chara .ai.loot_chance!
	0 <- chara .ai.wander_chance! // Don't look around
	0	<- chara .ai.rush_chance!
	4	<- chara .ai.attack_level!
	\ -1   <- chara .ai.pickup_gun_max!
	\ -1  <- chara .ai.pickup_melee_max!
	0 <- chara .ai.threat_respond_chance! 
	
	
; 

	

: zeichboast 1 16 rnd case 
	1 of RAINBOW "IT'S 12PM." .. endof
	2 of RAINBOW "IT'S 12:00." .. endof
	3 of RAINBOW "IT'S HIGH NOON." .. endof
	4 of RAINBOW "YEEHAW." .. endof
	5 of RAINBOW "YA FEEL LOVELY, PUNK?" .. endof
	6 of RAINBOW "ROOTEM TOOTEM." .. endof
	7 of RAINBOW 50 %chance if "I'M A SHOOTIN COWBOY, NOT A SINGIN COWBOY." else "SOMEBODY'S POISONED THE WATERIN HOLE." then .. endof
	8 of RAINBOW "YIPPEE KI YAY." .. endof
	9 of RAINBOW "THERE'S A SNAKE IN MY BOOT." .. endof
	10 of RAINBOW "IT'S HIGH NOON?" .. endof 
	11 of RAINBOW "TOO SLOW ON THE DRAW." .. endof 
	12 of RAINBOW "YEE HAW." .. endof
	13 of RAINBOW "HIGH NOON." .. endof 
	14 of RAINBOW "IT'S HIGH NOON..." .. endof 
	15 of RAINBOW "IT'S HIIIIIGH NOON." .. endof
	16 of RAINBOW "IT'S HONCHO NOON." .. endof
	
	endcase
;
	

: dualwielder-thing-events args( me teid )

	<- teid THING_EVENT_TIMER = if
	
	1 <- me .timer! 
		<- me .character@ .health@ 1 < if then; 
		<- me .character@ .user.special_counter@ #thing 0 = if then; 
			
				\ <- me .wielded-stack 0 = not if 
				<- me .inside_id@ 0 = if 

					<- me .pos <- me .aim_angle@ sin 4 * <- me .aim_angle@ cos -4 * xyadd 0 -3 xyadd \ Without this minimum distance, the AI FREAKS OUT 
					
					\ the AI is admittedly still freaking out a little bit
					\ but all they do is just wander a bit more than usual, that's all
					\ it LOOKS natural enough 
					
					<- me .character@ .user.special_counter@ #thing .pos! \ stay attached 
					
					<- me .mapid@ <- me .character@ .user.special_counter@ #thing .mapid! \ stay on this map 
					
					<- me .flip@ 1 = if 
						<- me .aim_angle@ 12 + <- me .character@ .user.special_counter@ #thing .aim_angle!  \ ...why? why the 12 diff?
					else 
						<- me .aim_angle@ 12 - <- me .character@ .user.special_counter@ #thing .aim_angle!  
					then 	
				\ No idea 
					
					<- me .weapon_slot_using@ 0 = weapondef{ <- me .character@ .weapona@ sel ammo_type@ } 3 > <- me .ammocount 0 > weapondef{ <- me .character@ .weaponb@ sel ammo_type@ } 3 > weapondef{ <- me .character@ .weaponb@ sel ammo_type@ } <- me .character@ .lootamt@ 0 > and and and and if  
						\ using first slot 
						\ and takes ammo 
						\ and other wep takes ammo 
						\ and other wep has ammo 
						
						
						<- me .character@ .weaponb@ <- me .character@ .user.special_counter@ #thing .character@ .weapona!  
					else
						0 <- me .character@ .user.special_counter@ #thing .character@ .weapona!  
						1 <- me .character@ .user.special_counter@ #thing .stun!
					then 
					\ copy my weapon if im eligble else do nothin 
					
						\ particle{ 
							\ new
						\ pos!

						\ 0 wait!
						\ 1 ticks!
						\ 1 fade_out!
						\ 1 layer! }
						\ weapondef{ <- me .character@ .weapona@ sel spriteid@ } particle{ spriteid! } 
						\ <- me .aim_angle@ particle{ angle! } 
						\ <- me .flip@ particle{ flipx! } 
						\ <- me .pos.z@ particle{ pos.z! } 
						\ <- me .vel.z@ particle{ vel.z! } 
						\ <- me .vel particle{ vel! } 
					\ \ gameticks 9 * sin 10 * <- me .weapon_state.angle_add!	
				\ then 	
				then
		then 
		
		<- teid THING_EVENT_SHOOT = if 
		
			15 %chance if 
				zeichboast <- me .yellmsg \ I'm sure you can replace this as desired 
			then 
			
			<- me .character@ .mod_flags2@ 2 = if \ Scepter powerup 
				50 %chance if 
				weapondef{ <- me .wielded sel ammo_type@ } <- me .character@ .lootamt@ 1 + weapondef{ <- me .wielded sel ammo_type@ } <- me .character@ .lootamt!
			then then \ 50 % ammo efficiency 
			
			<- me .character@ .user.special_counter@ #thing 0 = if then; 
			\ <- me .character@ .weaponb@ WEAPON_LIST_FIREARM .is-weapon-type? if 
			<- me .weapon_slot_using@ 0 = weapondef{ <- me .character@ .weapona@ sel ammo_type@ } 3 > weapondef{ <- me .character@ .weaponb@ sel ammo_type@ } 3 > <- me .ammocount 0 > and and and if   \ holding a..."firearm"? 
		
			<- me .character@ .user.special_counter@ #thing .cooldown@ 0 = if 
				<- me .character@ .user.special_counter@ #thing .ammocount 0 > if 
					weapondef{ <- me .character@ .weaponb@ sel ammo_type@ } <- me .character@ .lootamt@ 0 >	if 
					<- me .character@ .user.special_counter@ #thing .attack 
					weapondef{ <- me .character@ .weaponb@ sel ammo_type@ } <- me .character@ .lootamt@ -1 + 0 999 clamp weapondef{ <- me .character@ .weaponb@ sel ammo_type@ } <- me .character@ .lootamt!
				then then then
			\ STOP EATING MY AMMO UNNECESSARILY!!!
			\ ammo logic for shooting the other gun in your inventory 
			
			\ IMPORTANT NOTE!!!!
			\ DUAL WIELD ONLY ACTIVATES WHEN USING THE FIRST WEAPON IN YOUR INVENTORY!!!!
			\ THIS IS AN INTENTIONAL DESIGN CHOICE 
			\ SO YOU CAN CHOOSE TO DUALWIELD OR NOT 

		
			<- me .character@ .weapona@ <- me .character@ .weaponb@ = if 
				<- me .cooldown@ 0.85 * <- me .cooldown! 
			then 
			
			\ synergy bonus. made sense to me 
		
			then 
		then 
	
				

;


: dualwielder-main-events ( teid ) args( chara eventid )

	<- eventid MAIN_EVENT_MISSION_START = if 
		
		<- chara .location@ 1 = if \ Not on rest... 
			<- chara .thing@ create-dualwielder
			lt .character@ lobotomise
			<- chara .thing@ .id@ lt .character@ .user.special_counter! 
			lt .id@ <- chara .user.special_counter! 
			
			<- chara .mod_flags2@ lt .character@ .mod_flags2! 
			\ 241 lt .character@ .specialtype! 
			0 lt .character@ .scale.head.x!
		\	0 lt .character@ .scale.head.y!
			0 lt .character@ .scale.body.x!
		\	0 lt .character@ .scale.body.y!
			-5 lt .rad.x!
			-5 lt .rad.y! \ stops weird object pickup inhibition  
			0 lt .rad.z! 
		then 
	then 
	 	
	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;
		<- chara .location@ 1 = if 
			1 <- chara .thing@ .timer!
			 <- chara .thing@ swap ( teid ) dualwielder-thing-events
		then 

	
;

