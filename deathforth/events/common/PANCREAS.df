// Special Gimmick Weapons Trader Camp

cyoa{ regiondef{

0 value special-3
0 value special-2
0 value special-1
0 value special-banner

cyoa-choice: trade-special-3
	($ Thegroup .. " buys the Duckhunter(TM)!
	" .. "- Shots will pierce and ricochet after they hit zombies!
	- Reloads one shell at a time, when you're not shooting
	- The last shell takes the longest to reload" pbold $) cyoa-text! goodfx
	1 WEAPON_SLAMFIRE trunk.weapon+ -30 trunk-food+ someicon ' special-3 ++
;

cyoa-choice: trade-special-2
	($ Thegroup .. " buys the Lever-Action!
	" .. "- Tap ATTACK with the right timing to fire much faster!
	- Keep an eye out on the indicators over your head
	- When the indicator is no longer transparent, tap ATTACK" pbold $) cyoa-text! goodfx
	1 WEAPON_FLIPARI trunk.weapon+ -20 trunk-food+ someicon ' special-2 ++
;

cyoa-choice: trade-special-1
	($ Thegroup .. " buys a Dolt Big Iron!
	" .. "- Hold ATTACK down to fire fast!
	- Shoots much slower if you only tap ATTACK
	- Has a reload period every 6 shots
	- You must fire all 6 shots to reload" pbold $) cyoa-text! goodfx
	1 WEAPON_SIXSHOOTER trunk.weapon+ -20 trunk-food+ someicon ' special-1 ++
;

cyoa-choice: trade-special-0
	($ Thegroup .. " buys a Kukri.
	" .. "- Single target
	- Low cooldown
	- Maims the target, slowing them
	- OK damage" pbold $) cyoa-text! goodfx
	1 WEAPON_KUKRI trunk.weapon+ -4 trunk-food+ someicon
;

cyoa-choice: trade-special-banner
	($ Thegroup .. " buys a trumpet with a flag.
	" .. "- Empowers teammates whilst held
	- Comes with 30s of charge time
	- Charge depletes whilst held
	- Minicrits apply to melee only" pbold $) cyoa-text! goodfx
	200 WEAPON_BUFFBANNER trunk.weapon+ -6 trunk-food+ someicon
;


cyoa: trade-special
	"Armes a Gimmick Special" cyoa-title!
	($ "J'ai modifie toutes ces armes personnellement ! Elles ont toutes un GIMMICK SPECIAL !" pbold $) cyoa-text! basic-tone foodamt
	"Duckhunter : Un fusil a pompe qui ricoches constamment !
	Levier-Action : Tire bien plus vite si vous tirez juste apres qu'il se retourne !
	Dolt Big Iron : Un pistolet qui vous encourage a tirer vite !
	Buff Banner : Une arme de soutien qui fournit des mini-crits !
	Kukri : Un couteau qui mutile les zombs, les ralentissant !" rbold +crtext
	(* most-ahole if
		charchoice( " devalise le marchand" )choice: trade-special-rob
	then
	most-grating if
		charchoice( " lui dit de SE CALMER" fcoolit )choice: trade-special-coolit
	then *)
	trunk-food 1 < if
		($ "Tu n'as plus de nourriture ! Le marchand donne a " .. thegroup .. " un vieux pistolet canon court en prix de consolation." $) +crtext goodfx 1 WEAPON_SNUBNOSE trunk.weapon+ clear-cyoa
	else
		choice( "Partir pour l'instant" )choice back-esc
		trunk-food 29 > special-3  1 < and if
			choice( "Duckhunter pour 30 nourriture" )choice: trade-special-3
		then
		trunk-food 19 > special-2 1 < and if
			choice( "Levier-Action pour 20 nourriture" )choice: trade-special-2
		then
		trunk-food 19 > special-1 2 < and if
			choice( "Dolt Big Iron pour 20 nourriture" )choice: trade-special-1
		then
		trunk-food 5 > special-banner 1 < and if
			choice( "Buff Banner pour 6 nourriture" )choice: trade-special-banner
		then
		trunk-food 3 > if
			choice( "Kukri pour 4 nourriture" )choice: trade-special-0
		then
	then
;

} }

