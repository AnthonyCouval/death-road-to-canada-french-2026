// Originally moved character declarations to charmisc.df out of necessity, but that screwed things up
// Then moved this file, PANCREAS.df, above cyoa-k-newbie-df
// Worked great! That's a nice spot for not running into problems
// Likely where the UPDATENAME.df files can vary due to update, or even just split them in future

: .poolify args( chara )
	130 <- chara .specialtype!
	1 <- chara .strength!
	1 <- chara .fitness!
	"Pool Champ" <- chara .name!
	"was a professional pool player. He has turned this into his own warrior-philosophy." <- chara .job!
	' rosettagf-main-events <- chara .main_events!
	2 <- chara .carrying.slot_count!
	WEAPON_MEGAPOOLCUE <- chara .weapona!
	1 <- chara .weapon_nodropa!
	6 <- chara .attitude!
	0 <- chara .female!
;

: .honchoify args( chara )
	129 <- chara .specialtype!
	1 <- chara .strength!
	1 <- chara .fitness!
	2 <- chara .shooting!
	"Honcho" <- chara .name!
	"is an OLD WEST cowboy. Dual-wields firearms if they're in the top two slots!" <- chara .job!
	' dualwielder-main-events <- chara .main_events!
	// Originally tried a 2 slot lock, but was too limiting. However, 3 slots messed up the dual wield sometimes, so gave him a C locked melee weapon.
	WEAPON_WESTKNIFE <- chara .weaponc!
	1 <- chara .weapon_nodropc!
	0 <- chara .attitude!
	0 <- chara .female!
	2 STAT_SHOOTING <- chara .bonus!
;

: .vansmeltify args( chara )
	131 <- chara .specialtype!
	1 <- chara .strength!
	1 <- chara .fitness!
	4 <- chara .shooting!
	3 <- chara .headoff.y!
	"Van Smelt" <- chara .name!
	"is a big game hunter. Aim for long distance headshot combos!" <- chara .job!
	// ' dualwielder-main-events <- chara .main_events!
	// 2 <- chara .carrying.slot_count!
	WEAPON_MARBELLE <- chara .weapona!
	1 <- chara .weapon_nodropa!
	0 <- chara .female!
;

// CYOA

cyoa{ 

// Pool Champ

cyoa-bridge: camp-pool-recruit
	ricon 4 recruitee .morale! clear-cyoa
	15 recruit-yes-food 
	"You just have to think of the whole world as a pool table!" pbold +crtext
	recruitee .strengthREV recruitee .fitnessREV recruitee .attitudeREV
;

cyoa: camp-rec-pool
	"Professional Pool Player" cyoa-title!
	nearest .character@ choosechar cchar to recruitee ricon
	($ "This man has the physicality and demeanor of a pro athlete. You instantly know, just from looking at him, that he plays darts or pool.
	He might POSSIBLY be into bowling, instead." $) cyoa-text! basic-tone
	"This character gets stamina and power bonuses for hitting zombies at the furthest tip of his melee range! He also has a 10% chance of getting explosive results from his tip attacks!" rbold +crtext
	trunk-food 14 > if
		choice( "Leave him for now" )choice
		choice( "Hire him - 15 food" )choice: camp-pool-recruit
	else
		"You need 15 food to recruit him to the party." +crtext
		choice( "Can't spare the food" )choice
	then		
;

// Honcho the Gunslinger

cyoa-bridge: camp-honcho-recruit
	ricon 4 recruitee .morale! clear-cyoa
	15 recruit-yes-food 
	"WHERE'D MY PISTOLS GO?
	CONSARN IT!" rainbold +crtext
	recruitee .attitudeREV
;

cyoa: camp-rec-honcho
	"HIGH NOON" cyoa-title!
	nearest .character@ choosechar cchar to recruitee ricon
	($ "This grizzled man is dressed up in a poncho and sombrero. He has two pistol holsters at his sides. On closer inspection, his holsters are empty." $) cyoa-text! basic-tone
	"WHAT TIME IS IT?
	IT'S HIGH NOON." rainbold +crtext
	"Honcho the Gunslinger can dual wield firearms, if they have ammo! Just put them in your top two slots, or just swap (or lock in the pause menu) until he's holding both." rbold +crtext
	trunk-food 14 > if
		choice( "Leave him for now" )choice
		choice( "Hire him - 15 food" )choice: camp-honcho-recruit
	else
		"You need 15 food to recruit him to the party." +crtext
		choice( "Can't spare the food" )choice
	then		
;

// Van Smelt the Big Game Hunter

cyoa-bridge: camp-vansmelt-recruit
	ricon 4 recruitee .morale! clear-cyoa
	15 recruit-yes-food 
	"The hunt is on!" pbold +crtext
	recruitee .shootingREV
;

cyoa: camp-rec-vansmelt
	"THE DEADLIEST GAME OF ALL" cyoa-title!
	nearest .character@ choosechar cchar to recruitee ricon
	($ "The man resting by this campfire has the appearance of an old-timey big game hunter. Pith helmet, dapper hunting outfit, heavy rifle." $) cyoa-text! basic-tone
	"This character has a rifle can be manually aimed for zombie headshots! The rifle gets more powerful as you land longer distance headshots. This gets even stronger as you get headshot streaks, especially past 30 headshots!" rbold +crtext
	trunk-food 14 > if
		choice( "Leave him for now" )choice
		choice( "Hire him - 15 food" )choice: camp-vansmelt-recruit
	else
		"You need 15 food to recruit him to the party." +crtext
		choice( "Can't spare the food" )choice
	then		
;

}

: PANTEST1 pchar .poolify ;
last 1 hotkey!
: PANTEST2 pchar .honchoify ;
last 2 hotkey!
: PANTEST3 pchar .vansmeltify ;
last 3 hotkey!
: OPPTESTER "events/OPPmode.df" $load-region to-mission ;
last 4 hotkey!