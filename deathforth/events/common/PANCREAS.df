\ .................................................................
\ LASIJA stuff below, the TIP HITTER
\ .................................................................

0 value xboundright
0 value xboundleft
0 value yboundup
0 value ybounddown 

\ For dynamic "offscreen" calculation 

: ringout 1 12 rnd case
	1 of RED "GAME!!!" .. endof 
	2 of RED "K.O!!!" .. endof 
	3 of RED "FATALITE !!!" .. endof
	4 of RED "BALLE DE MATCH !!!" .. endof
	5 of RED "RINGOUT!!!" .. endof
	6 of RED "ASSOMME !!!" .. endof
	7 of RED "TOUCHDOWN!!!" .. endof
	8 of RED "SERIE MEURTRIERE !!!" .. endof
	9 of RED "CARNAGE !!!" .. endof
	10 of RED "CA C'EST UN TROU D'UN COUP !!!" .. endof
	11 of RED "SCORE!!!" .. endof
	12 of RED "HOMERUN!!!" .. endof
	endcase
;

: no-more-di args( me eventid )
\	-4 <- me .vel.z!

	<- eventid THING_EVENT_WALL = if
		\ 50 %chance if
		\	RED "GAME!!!" .. <- me .report
		\ else
		\ 	RED "K.O!!!" .. <- me .report
		72 %chance if \ ~50% chance to bounce twice
			180 <- me .weapon_state.val@ - anglexy 9 xymul <- me .vel! \ Rungout zombs store their movement dir. as weapon_state.val.
		else

		 <- me .pos 1 xypowboom
			-1 lt .hitcheck.blast!
			0 <- me .hitpoints!
			ringout <- me .report
			then
		then

	<- eventid THING_EVENT_TIMER = if
		1 <- me .timer!
		\ -1.5 <- me .vel.z!
		<- me .vel xyangle <- me .weapon_state.val! \ move angle as weapon_state.val

		<- me .pos
				particle{ new pos! 10 ticks!
				\	pos@ -5 5 frnd + swap -5 5 frnd + swap pos!

				weapons_base_id 301 + spriteid!
				\ This is the red trail sprite from DRTS, originally meant for Eldritch Blast.

				\ angle@ -1 * 10 -10 frnd + anglexy 1 2 frnd xymul vel!

				20 ticks!
				10 fade_out!
				\ 1 clr.r!

				\ 0.8 1 frnd clr.g!
				\ 0 clr.b!
				\ glowy
				2 scalex!
				-3 pos.z!
				0.5 clr.a!
				1 layer!
				}

			<- me .vel xyangle particle{ angle! }


		camera.pos.x@ view_w 0.5 * + to xboundright
		camera.pos.x@ view_w -0.5 * + to xboundleft

		camera.pos.y@ view_h 0.5 * + to ybounddown
		camera.pos.y@ view_h -0.5 * + to yboundup

		<- me .pos.x@ xboundright > <- me .pos.x@ xboundleft < or if
			ringout <- me .report
			<- me .pos 1 xypowboom
			-1 lt .hitcheck.blast!
			0 <- me .hitpoints!

		then

		\ Offscreen logic....

		<- me .pos.y@ ybounddown > <- me .pos.y@ yboundup < or if
			ringout <- me .report
			<- me .pos 1 xypowboom
			-1 lt .hitcheck.blast!
			0 <- me .hitpoints!
		then

		<- me .vel xymag 0.1 < if
			ringout <- me .report
			<- me .pos 1 xypowboom
			-1 lt .hitcheck.blast!
			0 <- me .hitpoints!
		then

	then
;

: naginata-smash args( me )
	<- me .mass@ 100 > not if  \ Not relevant for base game; covers zombie bosses
		1 <- me .timer!
		-6 <- me .vel.z!
		' no-more-di <- me .events!
		0 <- me .rad.x!
		0 <- me .rad.y!
		0 <- me .rad.z!
		1 <- me .nocollide!
		\ 0.7 <- me .bounce_friction!
	then
;

: rosettagf-thing-events args( me teid )


	(* <- teid THING_EVENT_TIMER = if
		1 <- me .timer!

		<- me .character@ .weapona@ 0 = <- me .character@ .weaponb@ 0 = and if
			0.2 <- me .character@ .speed_bonus!
		then;

		<- me .character@ .weapona@ 0 <> <- me .character@ .weaponb@ 0 = and if
			0 <- me .character@ .speed_bonus!
		then;

		<- me .character@ .weapona@ 0 = <- me .character@ .weaponb@ 0 <> and if
			0 <- me .character@ .speed_bonus!
		then;

		<- me .character@ .weapona@ 0 <> <- me .character@ .weaponb@ 0 <> and if
			-0.1 <- me .character@ .speed_bonus!
		then;
		\ Logic to determine how many weapons are carried.
		\ This logic assumes that the third slot is always locked
		\ which it is, for Lasija.
		\ Speed bonus based on this.

	then *)

	<- teid THING_EVENT_DID_HIT = if

		<- me .pos <- me .just_hit_id@ #thing .pos xysub xymag weapondef{ <- me .wielded sel melee_range@ } - 5 - 5 - print
		<- me .just_hit_id@ #thing .typeid@ THING_ZOMBIE = if
			<- me .pos <- me .just_hit_id@ #thing .pos xysub xymag weapondef{ <- me .wielded sel melee_range@ } - 5 - 5 - >int 10.89 > if
			\ First, find the distance from the hit target. subtract melee range, player and zomb rad. if we are left at 11 or more, we
			\ must have hit near the tip. award extra damage


			<- me .fatigue@ 13 - 0 127 clamp <- me .fatigue! \ Reward with stamina recovery.

			// <- me .character@ .mod_flags2@ 2 = not
			90 %chance if \ Normal functionality, i.e non-scepter code
				<- me .pos <- me .just_hit_id@ #thing .pos xysub xynorm -9 xymul <- me .just_hit_id@ #thing .vel!
				50 %chance if
					-3 <- me .just_hit_id@ #thing .vel.z!
				else
					3 <- me .just_hit_id@ #thing .vel.z!
				then

				<- me .just_hit_id@ #thing .pos xyblast
				weapondef{ <- me .wielded sel power@ } 2 / lt .hitcheck.power!
				10 lt .hitcheck.rad!
				-1 lt .hitcheck.blast!
				\ 5 lt .hitcheck.knockback!

			else \ RINGOUT scepter code...for crits?

				5 <- me .just_hit_id@ #thing .hitpoints! \ don't die before ringout!
				\ 1 <- me .just_hit_id@ #thing .anim.state!


				<- me .just_hit_id@ #thing .anim.state@ 1 = if
					<- me .pos <- me .just_hit_id@ #thing .pos xysub xynorm -21 xymul <- me .just_hit_id@ #thing .vel! \ off the stage with you!
				else
					<- me .pos <- me .just_hit_id@ #thing .pos xysub xynorm -31 xymul <- me .just_hit_id@ #thing .vel!
				then

				<- me .pos <- me .just_hit_id@ #thing .pos xysub xyangle <- me .just_hit_id@ #thing .weapon_state.val!
				<- me .character@ .voice.fhi@ 1 + <- me .character@ .voice.fhi! \ Ringout score popup
				($ "POINTS: " .. <- me .character@ .voice.fhi@ $) <- me .report \ flyhead breaks this >:<<<
				<- me .just_hit_id@ #thing naginata-smash \ NO ITEMS, NO BS.
			then

					sfx{ zelda 0 d! 0 a! }
				then
			then
		then


;

: rosettagf-main-events ( teid ) args( chara eventid )

	<- eventid MAIN_EVENT_MISSION_CHARACTER_THING_EVENT <> if then;

	1 <- chara .thing@ .timer!
	 <- chara .thing@ swap ( teid ) rosettagf-thing-events


;

