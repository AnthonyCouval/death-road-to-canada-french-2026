0 value gbx
0 value gby
0 value gbx2
0 value gby2

' plotpave >defer ft

: pt
	xyp.xy ft // Plot the current floor by default
	 
	 xyp.i char C = if xyp.xy streetlamp lt-here then;
	 xyp.i char 5 = if xyp.xy streetlamp lt-here xyp.xy sycatilestreetblock then;
	 xyp.i char 8 = if xyp.xy sycatilestreetblock then;	 
	 xyp.i char J = if xyp.xy sycatile_railwallmain_passunder_roof then;
	 
	 
	xyp.i char @ = if xyp.xy bldg2 then;
	xyp.i char £ = if xyp.xy bldg3 then;
	
	xyp.i char H = if xyp.xy sycatilegrassset then;

	xyp.i char I = if xyp.xy fencea xyp.xy sycatilestreet then;
	
	xyp.i char G = if xyp.xy sycatile_dirtstairs_up then;
	
	xyp.i char t = if xyp.xy sycatileseawallmain_layerfix then;
	
	xyp.i char R = if xyp.xy sycatile_railmain then;
	
	xyp.i char Z = if xyp.xy sycatile_railwallmain_irongate then;
	
	xyp.i char ! = if xyp.xy sycatileseawalledge then;
	xyp.i char - = if xyp.xy sycatileseawallbot then;
	xyp.i char Q = if xyp.xy sycatile_railwallmain then;
	xyp.i char q = if xyp.xy sycatile_railwallmain_passunder then;
	xyp.i char O = if xyp.xy sycatile_railwallmain_passunder_block then;
	xyp.i char o = if xyp.xy sycatile_railwallmain_battlement then;
	
	// decor
	xyp.i char F = if xyp.xy sycatile_GTFO then;
	xyp.i char A = if xyp.xy sycatile_FREE then;
	xyp.i char a = if xyp.xy sycatile_railwallmain_passunder_FREE then;
	
	xyp.i char 1 = if xyp.xy sycatilegrassseasection then;
	xyp.i char 2 = if xyp.xy sycatilegrassedge then;
	xyp.i char 3 = if xyp.xy sycatilegrassedgeflip then;
	xyp.i char 4 = if xyp.xy sycatileseawallangleleft_withgate then;
	xyp.i char 6 = if xyp.xy sycatileseawallangleright_withgate then;
	
	xyp.i char D = if xyp.xy sycatileseawallangleleft then;
	xyp.i char E = if xyp.xy sycatileseawallangleright then;
	
	xyp.i char 7 = if xyp.xy sycatile_battlement then;
	xyp.i char 9 = if xyp.xy sycatile_battlement_hascover then;
	xyp.i char S = if xyp.xy sycatile_battlement_pmo then;
	
	xyp.i char < = if xyp.xy sycatile_railwallmain_windowbot then;
	xyp.i char > = if xyp.xy sycatile_railwallmain_windowtop then;
	
	xyp.i char T = if xyp.xy sycatile_gatehouseedge_left then;
	xyp.i char B = if xyp.xy sycatile_gatehouseedge_right then;
	
	xyp.i char r = if xyp.xy 66 %chance if rail_box else rail_box_rusty then lt-here lt .pos 0 26 xyadd lt .pos! then;
	
	\ xyp.i char a = if xyp.xy ammopile_bullet lt-here then;
	\ xyp.i char b = if xyp.xy ammopile_rifle lt-here then;
	\ xyp.i char c = if xyp.xy ammopile_shotgun lt-here then;
	
	
	
	
;

