: shine_a_light args( me eventid )
	<- eventid THING_EVENT_TIMER = if 
		1 <- me .timer!
		1 1 0.4 150 <- me .pos 0 30 xyadd d-light
	then 
	
	<- eventid THING_EVENT_WAS_HIT = if 
		<- me .weapon_state.val@ 0 = if 
			0 <- me .timer! 
			special_objects32_base_id 219 + <- me .spriteid!
			sfx{ glass 2 scale! } 
			1 <- me .weapon_state.val! 
		then 
	then 
; 	
	

