

uses paul/region-layout.df
uses paul/region-road-layout.df

"events/inner/baseapts.df" $load
"events/inner/policeloc.df" $load
"../deathforth/rooms/TEMPROOM.txt" $load-rooms
"../deathforth/rooms/city.txt" $load-rooms
"../deathforth/events/stomach/citadel.txt" $load-rooms

roomgen{ 

: ammout_rifle args( me )
	0 <- me .clr.a! 
	20 30 frnd LOOT_RIFLE_SHELL spawnscat <- me .pos lt .pos!
	clear-cyoa
	interactee silentkillit
;

: ammopile_rifle 
	spawn special_objects32_base_id 212 + lt .spriteid!
	as-metal 4000 lt .hitpoints! 4000 lt .mass!
	' ammout_rifle lt .cyoa!
;

: ammout_bullet args( me )
	0 <- me .clr.a! 
	20 30 frnd LOOT_BULLET spawnscat <- me .pos lt .pos!
	clear-cyoa
	interactee silentkillit
;

: ammopile_bullet
	spawn special_objects32_base_id 216 + lt .spriteid!
	as-metal 4000 lt .hitpoints! 4000 lt .mass!
	' ammout_bullet lt .cyoa!
;

: ammout_shotgun args( me )
	0 <- me .clr.a! 
	20 30 frnd LOOT_SHOTGUN_SHELL spawnscat <- me .pos lt .pos!
	clear-cyoa
	interactee silentkillit
;

: ammopile_shotgun
	spawn special_objects32_base_id 217 + lt .spriteid!
	as-metal 4000 lt .hitpoints! 4000 lt .mass!
	' ammout_shotgun lt .cyoa!
;

: basicbed spawn 0x 6 inside_objects_base_id + spriteid! bbox as-cloth dropswood 6 health! 0 lt .friction! ; \ STAY STILL

: mildrawers spawn 2 inside_objects_base_id + spriteid! bbox 33 %chance if openable container then as-wood 0 lt .friction! ;

: droplets args( me eventid )
	<- eventid THING_EVENT_TIMER = if
		12 <- me .timer!
			
			6 8 rnd for
			
			<- me .pos
			particle{ new pos! 15 ticks! 
			pos@ 0 2 3 frnd xyadd pos!
			
			particles_base_id 1+ spriteid!
			160 200 frnd anglexy 0.5 1.2 frnd xymul vel!
			
			0 clr.r!
			0.4 clr.g!
			1 clr.b!
			glowy

			}
			
		next
			
	then
;
	
	
: wallshower
	spawn special_objects16_base_id 48 + lt .spriteid! 3 lt .tileflags! 2000 lt .hitpoints! 4000 lt .mass! -2.1 lt .vel.y! 0 lt .rad.x! 0 lt .rad.y!
	 1 lt .timer! 1 lt .nocollide! 1 lt .no_hit! ' droplets lt .events!
;
	
	
: address_people 1 6 rnd case 
	1 of "ALL DINKS..." endof 
	2 of "DINKS, REPEAT, ALL DINKS..." endof 
	3 of "ALL NERDS..." endof
	4 of "ALL MEGABUFFS..." endof 
	5 of 1 %chance if "SYCAMORE..." else "KEPA..." then endof 
	6 of "HATCHET MAFIA..." endof 
	endcase
; 

: address_issue 1 5 rnd case 
	1 of "PLEASE REPORT TO..." endof 
	2 of "PLEASE SEE TO..." endof 
	3 of "PLEASE ATTEND..." endof 
	4 of "PLEASE FACILITATE..." endof 
	5 of "PLEASE PERFORM..." endof 
	endcase 
; 

: address_task 1 20 rnd case 
	1 of "BUTTCLEANING. THANK YOU" endof 
	2 of "BOTTOM SURGERY. THANK YOU" endof 
	3 of "THE TABLESMASH ROOM. THANK YOU" endof 
	4 of "PIPEBOMB EATING. THANK YOU" endof 
	5 of "CHICKEN OBLITERATION." endof 
	6 of "CANADA INVADING. THANK YOU" endof 
	7 of "MY THERMONUCLEAR BOMB. THANK YOU" endof 
	8 of "A FUNNY OFF-BEAT DANCE. THANK YOU" endof 
	9 of "YOUR MOM." endof 
	10 of "YOUR DAD." endof 
	11 of "THE TERMINATOR. THANK YOU" endof 
	12 of "A PILE OF BRICKS. THANK YOU" endof 
	13 of "BLOWING UP MY CAR. THANKS" endof 
	14 of "COOLING IT SILLY STYLE." endof 
	15 of "RIDING A PIG. THANK YOU" endof 
	16 of "BAD COUNTRY RECORDS. THANKS" endof 
	17 of "OBAMA. THANKS. THANKS OBAMA" endof 
	18 of "THE 90s. THANK YOU" endof 
	19 of "THIS GIANT CANDYBAR. THANKS" endof 
	20 of "MY WILL TO LIVE. THANKS" endof 
	endcase
;
	

: announce_bs args( me eventid )
	<- eventid THING_EVENT_TIMER = if 
		180 220 rnd <- me .timer! 
		
		<- me .weapon_state.val@ 2 = if 
			address_task <- me .yellmsg
			0 <- me .weapon_state.val!
		then; 
		
		<- me .weapon_state.val@ 1 = if 
			address_issue <- me .yellmsg
			2 <- me .weapon_state.val!
		then; 
		
		<- me .weapon_state.val@ 0 = if 
			address_people <- me .yellmsg
			1 <- me .weapon_state.val!
		then; 
	then 			
; 		

: speaker_mil 
	spawn special_objects32_base_id 220 + lt .spriteid!
	as-metal 30 lt .hitpoints! 200 lt .mass! 3 lt .tileflags! 
	-2 lt .vel.y! 
	' announce_bs lt .events!
	120 lt .timer! 
	
;
	
	
	
} 
	

locdef{

: bathroomplz 
	n random-edge-door "bathroom" only-with-door
;

: generate_bull 
	e random-edge-door "armorybullet" only-with-door
;  

: generate_rifle 
	e random-edge-door "armoryrifle" only-with-door
; 

\ hate room gen... 
location: citadel
		max-rooms: 3
		entry-tags: citadelentry
		pre-script: set-theme-bunker
		script:  set-theme-bunker
		post-script: nad ndx

		room-choice: citadelentry
			room-weight: 1
			room-count: 1
			room-script: ndx
			room-post-script: bathroomplz 5 %zombs
			filter-only
		
		room-choice: bathroom
			room-weight: 1
			room-count: 1
			room-script: ndx	
			
			
location: armory 
		max-rooms: 3
		entry-tags: armoryshot
		pre-script: set-theme-bunker
		script:  set-theme-bunker
		post-script: nad ndx

		room-choice: armoryshot
			room-weight: 1
			room-count: 1
			room-script: ndx
			room-post-script: generate_bull 5 %zombs
			filter-only	

		room-choice: armorybullet
			room-weight: 1
			room-count: 1
			room-script: ndx
			room-post-script: generate_rifle 5 %zombs
			filter-only		

		room-choice: armoryrifle
			room-weight: 1
			room-count: 1
			room-script: ndx
			room-post-script: 5 %zombs
			filter-only		
			

}


map{ regiondef{


: wave-events args( me eventid )
	<- eventid THING_EVENT_TIMER = if 
	
	<- me .scale.y@ 0.2 < if 
		<- me silentkillit
	then;
	
		-1.4 <- me .vel.y!
			particle{ new <- me .pos 0 360 frnd anglexy 2 -30 frnd xymul xyadd pos!
				15 fade_in!
				5 fade_out!
				30 ticks!
				-0.1 0.1 frnd vel.y!
				-0.1 0.1 frnd vel.x!
		//		waterclr 3 for 0.5 * 0.5 + rot next rgb!
		//		waterclr rgb!

				0.75 scale!
				1.01 grow!
				particles_base_id 0x 5d + spriteid!
				1 layer!
			}
			
		8 <- me .timer!
		
		<- me .scale.x@ -0.05 + <- me .scale.x!
		<- me .scale.y@ -0.05 + <- me .scale.y!
		
	then
	
	<- eventid THING_EVENT_OVERLAP = if
		<- me .overlapper .mass@ 1000001 = if then;
			<- me .scale.x@ -2 * <- me .overlapper .vel.y!
	
	then
	
;


: water_wave 
	spawn
	special_objects64_base_id 20 + lt .spriteid!
	1 lt .layer!
	1 lt .nocollide!
	1 lt .walkover! 
	1 1.25 rnd lt .scale.x!
	1 1.25 rnd lt .scale.y!
	0.8 lt .clr.a!
	' wave-events lt .events!
	8 lt .timer!
	40000000 lt .mass!
;

0 value playerbound1
0 value playerbound2

: wave_spawning args( me eventid )
	<- eventid THING_EVENT_TIMER = if 
	
	pchar .health@ 0 > if 
	
	player .pos.x@ -210 + 0 1200 clamp to playerbound1
	player .pos.x@ 210 + 0 1200 clamp to playerbound2
	
			30 <- me .timer!
			
				water_wave 
				508 lt .pos.y!
				playerbound1 playerbound2 rnd lt .pos.x!
				
			then
			
	then
;

: wave_spawner
	spawn
	400000 lt .mass!
	1 lt .invisible!
	1 lt .walkover!
	6 lt .timer!
	' wave_spawning lt .events!
;
	

: sycatile tile@
	dup LAYER_FLOOR inside_tiles_walls_id 3 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!
	
	dup LAYER_FLOORTOP inside_tiles_walltops_id 10 + .lspriteid!
	
	// 10 for regular walltop
	// 9 for right-hand up turn
	// 8 for right-hand end
	// 7 for left-facing-junction
	// 6 for downfacing left turn
	// 5 for straight up
	// 4 for upward end
	// 3 for upward left turn
	// 2 for lefthand end
	// 1 for downward end
	// 0 for tiny square
	
	dup LAYER_FLOORTOP 0 -16 .tile_layer.off!
	dup LAYER_FLOORTOP 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatileblock tile@

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatilewall tile@
	dup LAYER_FLOOR inside_tiles_walls_id 240 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	drop
;

