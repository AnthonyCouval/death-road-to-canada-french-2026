\ THE MECHA BANDIT  
cyoa: t-mechabandit 
	"BANDFORMERS...BANDITS IN DISGUISE" cyoa-title!
	\ image-submarine-def
	($ Thegroup .. " is travelling steadily along a stretch of road when a bandit in some kind of mech steps out from behind an apartment. Through a dry text-to-speech voice, it speaks:" $) cyoa-text!
	($ "ALL YOUR LOOT IS BELONG TO US." rbold $) +crtext 
	($ "The mech demands all of your gas and ammunition to pass." rbold $) +crtext 
	
	mechanicest charchoice( ": Dismantle it!" )choice: t-mech-disassemble  
	
	most-grating if
		charchoice( ": TELL HIM TO COOL IT" subcoolit )choice: t-mech-coolit  
	then
	
	most-paranoid if
		charchoice( " thought a giant mech might be nearby" )choice: t-mech-paranoid   
	then

	calmshot-check if
		charchoice( " blasts the mech's knees" )choice: t-mech-calmshot 
	then
	
	choice( "Pay the toll" )choice: t-mech-paytoll 
	bandit-fight
	
;

: copbanditcoolit 
	cool-it 3 > if 
	"!!!" fbold .. 
	then
;

0 stack
	WEAPON_PIPEBOMB shove
	WEAPON_MOLOTOV shove
	WEAPON_GRENADE shove 
constant WEAPON_LIST_ARSON

: team-has-arson? WEAPON_LIST_ARSON roadtrip-has-weapontype? ;

cyoa-choice: t-cop-ahole 
	($ cname .. " has no fear of cops. They reach into the pocket." $) cyoa-text! 
		
		team-has-arson? if 
			($ cname .. " pulls out a bomb and casually threatens the bandits with it!" $) +crtext
			($ "TAKE A LOOK AT THIS! IT'S US OR YOU, NERDS! YOUR CHOICE!" pbold $) +crtext
			($ "The bandits reluctantly agree to let " Thegroup .. " pass so they aren't blown to smithereens." .. $) +crtext
		else 
			($ cname .. " doesn't actually own anything pocket-sized and explosive enough, so is forced to pretend." $) +crtext
			($ "Luckily, " cname .. " is an amazing liar. " .. cHe .. " successfully fools the bandits with a bottle of juice!" .. $) +crtext
			($ "The bandits reluctantly agree to let " thegroup .. " pass so they aren't blown to smithereens." .. $) +crtext
		then 
			loyaltyREV morale++all morale++ goodfx

		cchar .perk@ "Pyromaniac" $= if 
			($ cname .. " sets fire to the police station anyway." $) +crtext
			morale++ 
		then 

;

cyoa-choice: t-cop-paranoid 
	($ cname .. " knew this would go awry and so prepared a plan in advance." $) cyoa-text! 
	($ cname .. " crashes through the walls of the police station with their car! Rubble flies everywhere! The car takes some damage." $) +crtext
	sting-- -2 -3 rnd car-chassis+
	($ "The bandits are terrified and begin to flee! " Thegroup .. " gets to pass for free!" .. $) +crtext 
	morale++all goodfx
;

cyoa-choice: t-cop-disguise 
	($ cname .. " insists that they were a cop too, just like they are!" $) cyoa-text! 
	($ "OH YEAH? PROVE IT THEN." rbold $) +crtext
	
		cwits+ cshooting+ and if 
			($ "Remembers reading a police training manual years ago. They shoot a couple of cans and accurately recite some of the manual!" $) +crtext 
			($ "SO YOU'RE A REAL HOTSHOT COP EH? GOOD ENOUGH. YOU CAN GO." rbold $) +crtext
			($ cname .. " can't believe that actually worked!" $) +crtext 
			($ "The bandits let the group go without fuss!" $) +crtext morale++all morale++ goodfx 
		else 
			witsroll shootingroll or if 
				($ "Doesn't actually know much about policing, and instead parrots random things from old TV shows." $) +crtext
				($ "YEAH SO IT'S REALLY IMPORTANT TO TURN THE SIRENS ON ALL THE TIME AND SAY 'OVER' REPEATEDLY. OVER." pbold $) +crtext
				($ "The cops pause and look at one another for a moment. Close enough!" $) +crtext
				($ "The bandits let the group go without fuss!" $) +crtext morale++all morale++ goodfx 
			else 
				($ "Splurts random lines from old cop films that sound cool to say." $) +crtext
				($ "ARE YOU FEELING PLUCKY...DINK?" pbold $) +crtext
				($ "The cop bandits look confused at one another momentarily and then start blasting! The group is caught in a bad spot!" $) +crtext
				ouch-- ouch--all badfx morale--all morale--
			then 
		then 

;

cyoa-choice: t-cop-grating 
	($ cname .. " screams " "COOL IT!" rbold .. " at the top of " .. chis .. " lungs." .. $) cyoa-text! 
			cool-it 3 > if 
				($ "OH, YOU MUST BE THE NEW CAPTAIN! WE DIDN'T RECOGNISE YOU. HERE, TAKE THIS!" pbold $) +crtext
				($ "The bandits deem that " cname .. " will be their new captain! They hand over many weapons!" .. $) +crtext
				cooled-it goodfx witsattREV
				
				1 WEAPON_CHROMESHOTGUN trunk.weapon+
				1 WEAPON_MP5 trunk.weapon+
				($ "CHROME SHOTGUN GET! MACHINEPISTOL GET!" rbold $) +crtext
				morale2+ 
				morale++all 
			then; 
		
		($ "The cops mistake this for some kind of super secret criminal dialect! This must be the most wanted criminal in history! They start blasting " cname .. " straight away!" .. $) +crtext
		ouch-- ouch-- sting-- badfx morale--all morale--  
		cool-it++  
			
;

cyoa-choice: t-cop-calmshot
	($ cname .. " draws " chis .. " firearms at blistering speed, trapping everybody in..." .. $) cyoa-text! 
	($ "THE GREAT (ONLY VAGUELY) MEXICAN SORT-OF-SITTING-ACTUALLY STANDOFF" fbold $) +crtext
	($ "For several hours, " thegroup .. " and the bandits point guns at one another awkwardly with some noises." .. $) +crtext
	
	composure-total team-count / >int 2 > if 
	\ if the group is, on average, average-ly composed, 
		($ Thegroup .. " is so patient that the bandits become bored and retreat! " Thegroup .. " passes the cop bandits for free!" .. $) +crtext
		morale++all
		morale++ 
		
	else 
	
		($ Thegroup .. " becomes bored and starts blasting! A fight ensues, but " thegroup .. " has the advantage!" .. $) +crtext 
		sting--all
		\ only a little bit of damage...almostttt meaningless 
	
	then 
	
	
;

