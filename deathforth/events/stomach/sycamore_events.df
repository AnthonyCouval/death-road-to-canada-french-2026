cyoa{ road{

: image-bison-def 79 cyoa-image-icon! ;


cyoa-choice: drts-bison-calmshot
	($ Thegroup .. " gathers, firearms in hand. Maybe if they simply scare the bison with their guns, they can get on with the day." $) text!

	($ cname .. " fires off a few rounds. One pings off of a lamppost and nails a nearby bison. Woops!" $) +crtext 

	($ "The bison disperse, fleeing in rapid terror! At least it's over quickly." $) +crtext
	morale++all 
	goodfx 
	
	($ cname .. " thinks that was a pretty good shot." $) +crtext
	cchar .shooting++ 
	cchar .morale++ 
	
	($ "Some spare meat is scavenged from the fallen bison after the rest of the horde is gone." $) +crtext
	4 trunk-food+
	
;

cyoa-choice: drts-bison-angrystrong
	($ cname .. " steps forward to take on the horde, all on " .. chis .. " own. For most this would be suicide; bison are dangerous creatures." $) cyoa-text! 
	
	cchar .trait@ "BERSERK!" $= if 
		($ PURPLE "BERSERRRRRKKKKKKKKKKKK!!!" .. $) +crtext  1 rumble 
	then 
	
	STAT_STRENGTH cchar .effstat 11 < if 
		($ WHITE "For " .. cname .. ", it IS suicide. Even though " .. che .. " is fairly strong, they'll never be as strong as a multi-tonne horde of beese (plural for bison.)" .. $) +crtext 
	else 
		($ "...but " cname .. " is built different. As hardy and manical as any bison, they tear through the horde one-by-one, suplexing and batting away several of the herd's members." .. $) +crtext
		($ "The herd disperses. They know their superior. They know the tale of the " RAINBOW "MEGABUFF!!!" .. .. $) +crtext
		($ "The group is able to get past, without even damaging their car!" $) +crtext
		10 trunk-food+
		morale++all morale++all goodfx    
	then;
	
	($ "Unfortunately, " .. cname .. " gets mauled pretty bad." rbold $) +crtext 
	
	badfx 
	morale-- 
	morale-- 
	ouch--
	ouch--
	
	cchar .trait@ "BERSERK!" $= if
		cchar .health@ 0 > if 
		($ cname .. WHITE "TRIUMPHS!?" .. $) +crtext
		($ FLASHY "MAX STRENGTH INCREASED?!" .. $) +crtext 
		1 STAT_STRENGTH cchar .bonus+ 
		\ nice reward... if you can survive!! ;3 
		then 
	then 
	
	($ WHITE "The car survives without damage, at least." .. $) +crtext
	cchar .strength++
	
;

cyoa-choice: drts-bison-coolit 

	cchar .pet@ 0 = if 
		($ cname .. " stands atop of a footstool and proudly proclaims " .. chis .. " speech: " $) cyoa-text!
	else 
		($ cname .. " sits atop of a footstool and proudly yaps " .. chis .. " speech: " $) cyoa-text!
	then 
	
	($ "HI BISON PEOPLE. I THINK YOU SHOULD COOL IT. THAT WOULD BE AWESOME. I THINK." rbold $) +crtext
	
	($ "MOOO. MOOOOOO. HEY, WE'RE WALKIN' HERE. (American bison famously have urban dialects.)" bbold $) +crtext
	
	cool-it 3 > if 
		($ "Round the group the bison gather. This must be them... " $) +crtext
		($ "THE CHOSEN ONE" fbold $) +crtext
		($ "(Bison tales speak of a chosen individual they are duty-bound to help! What a rich and profound culture.)" bbold $) +crtext
		($ WHITE "The bison carry the group to a nearby gas station! It's loaded with supplies!" .. $) +crtext
		cooled-it 
		
		50 trunk-gas+ 
		8 trunk-food+ 
		2 trunk-medical+ 
		morale++all
		morale++all 
	then; 

	($ "To absolutely nobody's surprise, this doesn't work. How embarassing! Hours pass before the car finally has enough space to get through." $) +crtext
	
	cool-it++
	badfx
	
	morale--all
	morale--all
	
;

: drtc-terror-check args( chara )
	<- chara .composure@ 3 > if 
		($ <- chara .name@ pbold " is able to remain calm despite the loud noises." .. $) +crtext 
		<- chara .temperREV 
	else
		50 %chance if 
			($ <- chara .name@ pbold " FREAKS OUT! This is terrifying!" .. $) +crtext
			<- chara .attitudeREV
			<- chara .morale--
		else
			($ <- chara .name@ pbold " shrieks like a child!" .. $) +crtext
			<- chara .attitudeREV
			<- chara .morale--
		then 
	then 
;

cyoa-choice: drts-bison-massacre
	($ Thegroup .. " decides to just book it through the horde. Herds and hordes aren't so different, right?" $) text!
	
	($ "Two bison are knocked out the way before the rest start to angrily maul the car! Terror ensues." $) +crtext
	
	' drtc-terror-check  foreach-team-char
	
	morale--all
	
	($ "
	The group survives, but not before hours of mauling. Eventually, the bison lose interest, and retreat back to whence they came." $) +text
	
	car-plowthrough

	($ RED "
	...that could have been much, much worse!" .. $) +text
	badfx 
	
;

: drtc-bison-check args( @ )
	<- @ .cattitude+ if 
		($ <- @ .colourname .. " thinks the whole experience was beautiful, in a way." $) +crtext 
		<- @ .attitudeREV
	else
		50 %chance if 
			($ <- @ .colourname .. " hates waiting around! Waiting around is for dinks!" $) +crtext 
			<- @ .attitudeREV
			<- @ .morale--
		else
			($ <- @ .colourname .. " waits so long they pee themselves!" $) +crtext 
			<- @ .attitudeREV
			<- @ .morale--
			<- @ .morale--
		then 
	then 
;


cyoa-choice: drts-bison-wait
	($ Thegroup .. " decides to sit in the car and just wait the herd out; simply let nature take its course." $) text!
	
	($ "Hours pass..." $) +crtext
	
	($ "And then more hours pass..." $) +crtext

	($ "...And even more. " $) +crtext
	
	badfx 
	
	' drtc-bison-check  foreach-team-char +cr
	
;

cyoa-choice: drts-bison-nearby
	($ Thegroup .. " decides to go for a walk while the bison are crossing. Why spend all that time waiting?" $) text!
	
	($ "There's fields and fields of bison. All in one line, all politely crossing one-by-one." $) +crtext
	
	\ wits-total 6 > if 
	\	($ "This must be the annual trans-continental bison crossing! Yes, that MUST be it." $) +crtext
    \	then 
	
	\ waaaa theres no explorer interaction waaaa 
	\ NO there is NOTHING here its just FIELDS and BISON and a rest stop 

		($ "A few minutes after leaving their car, a bandit finds it and attempts to break in. Leaving your car alone is a perilous decision!" $) +crtext
	
		most-paranoid if choosechar
		\ car-stolen trunk.killer bandit-gas bandit-food bandit-med bandit-ammo2 morale3-all
			goodfx 
			($ cname .. " had a bad feeling about this place and went to check up on the car half-way through." $) +crtext
			($ "The carjacking is prevented! The bandit drops his crowbar and runs." $) +crtext
			1 WEAPON_CROWBAR trunk.weapon+ 
		else 
			badfx 
			($ "The bandit breaks in!" " The entire car is prime for the taking!" rbold .. $) +crtext
			car-stolen trunk.killer bandit-gas bandit-food bandit-med bandit-ammo2 morale3-all
		then 
	
	($ "By walking around for a bit, the group find a location or two nearby. If desired, they could loot the location while they wait." pbold $) +crtext
	($ "Pick a new location to explore:" bbold $) +crtext
	
	choice( "Rest Stop" )choice: rest-easy
	choice( "Quiet Yallmart" )choice: yallmart-easy
	choice( "Give up exploring" )choice 
	\ deja vu... 
;

: bicoolit 
	cool-it 3 > if 
	"!!!" fbold .. 
	then
;

cyoa: drts-bison 
	"Wish We Had A Lasso" cyoa-title!
	image-bison-def
	($ Thegroup .. " happens upon a herd crossing the road. The road is narrow and has hedges and walls either side. Something must be done quickly; the bison herd is already becoming " .. "irate." rbold $) text!
		most-angrystrong if
			charchoice( ": I'll take 'em!" )choice: drts-bison-angrystrong
		then
		most-grating if
			charchoice( ": TELL BISON TO COOL IT" bicoolit )choice: drts-bison-coolit 
		then
		calmshot-check if
			charchoice( ": Calmly scare them away" )choice: drts-bison-calmshot
		then
		vehicle.which@ 0 > if 
			choice( "Run them over" )choice: drts-bison-massacre
			choice( "Explore nearby on foot" )choice: drts-bison-nearby
		then 
		choice( "Wait them out" )choice: drts-bison-wait
	\ 	choice( "Explore nearby" )choice: drts-bison-nearby
;

\ uses extra/sycamore_events.df

: image-submarine-def 78 cyoa-image-icon! ;

: forge_insult 1 21 rnd case 
	1 of "SCURVY-RIDDEN " endof 
	2 of "TWINKLING " endof 
	3 of "BOTTOMFEEDER " endof 
	4 of "LITTLE MAMA'S BOY " endof 
	5 of "LANDGRUBBER " endof 
	6 of "DINKFEST " endof 
	7 of "TWO-TONGUE " endof 
	8 of "POOPDECK SHIRTSTAIN " endof 
	9 of "DINGUS " endof 
	10 of "OBSERVER-UN-MEMBER-STATE " endof 
	11 of "GOATLICKIN' SWINE " endof 
	12 of "PIGSTY " endof 
	13 of "HORSEMOUTH " endof 
	14 of "COLDPLAY-ENJOYIN' " endof 
	15 of "TIMES-TABLES STRUGGLING " endof 
	16 of "SCRUNGLEBERRY " endof 
	17 of "MOULDY TWITTER-POSTIN' " endof 
	18 of "BITE-OF-87 VICTIM SON OF A " endof
	19 of "COMPLETE FAILURE " endof 
	20 of "OUTDATED GAME ENGINE " endof
	21 of "SYCAMORE " endof 
	endcase
; 

0 value DUE_INSULT 

\ In future: construct random insult each time

cyoa-choice: drts-sub-rob
	($ cname .. " draws their weapons and demands the captain hand over his stuff. The captain has other ideas." $) cyoa-text!
	
	($ "OH YOU SCURVY-RIDDEN TWINKLING LITTLE MAMA'S BOY DIRTY ROTTEN LANDGRUBBER DINKFEST TWO-TONGUE POOPDECK SHIRTSTAIN OBSERVER-UN-MEMBER-STATE GOATLICKIN' SWINE." pbold $) +crtext 
	
	($ "There is no competition. No resistance. This captain has a mouth like a machine gun. " $) +crtext
	
	($ cname .. " doesn't even want to carry on with the robbery anymore. These insults hurt in places they didn't even know existed." $) +crtext
	
	sfx{ badfx }
	
	($ cname .. " has a crisis. Was this the sum of their entire life? Is this all they are? Had the skeleton been right, all along?" $) +crtext
	morale4- 
		
	($ "The survivors of this VERBAL BOMB decide to flee before the captain can undo their egos any further." $) +crtext
	
;

cyoa-choice: drts-sub-kill
	($ cname .. " launches at the undead creature with their weapons! Fragile knuckles be damned! " $) cyoa-text!
	
	($ "Skeletons are for losers! Also, I WANT YOUR HAT!" fbold $) +text
	
	\ cchar .strength@ STAT_STRENGTH cchar .bonus@ + 16 * print 
	cstrength+ if
	
	($ cname .. " fights the skeleton, tearing it limb from limb! Bones crack on both sides! The fight is intense. " $) +crtext
	
	($ cname .. " emerges victorious! The captain's hat is plucked from the viscera, along with other valuables." $) +crtext
		cchar .strength++ 
		sting--
		47 cchar .hattype!
		cchar .name@ "Cpt. " swap .. cchar .name! 
		4 WEAPON_FEMUR trunk.weapon+ 
		6 trunk-food+ 
		10 20 rnd trunk-gas+ 
		3 4 rnd trunk-medical+ 
		1 WEAPON_CUTLASS trunk.weapon+ 
	
	else 
	
	($ cname .. " fights the skeleton! It's not close. This captain is a seasoned combat veteran! Those boney fingers hurt!" $) +crtext
	
	sfx{ badfx } 
	
	sting--
	sting--
	morale-- 
	
	($ cname .. " yelps so loudly that nearby glass shatters. " $) +crtext
	
	($ "BEGONE WITH YE, FICKLE, FRAIL FLESHLING!" fbold $) +crtext
	
		most-calmshot if choosechar
			($ "And for most fights, that would be the end of it. Rather than let the captain get away, however, " cname .. " spies an opportunity." .. $) +crtext
			($ cname .. " grabs a nearby rock and lobs it squarely at the captain's head! The captain falls over into a limp pile." $) +crtext
			($ "The House of Undead Skeleton Fights would ordinarily look down upon such a timid victory, but this is the apocalypse. Who cares? Free loot!" $) +crtext
			
			4 WEAPON_FEMUR trunk.weapon+ 
			6 trunk-food+ 
			10 20 rnd trunk-gas+ 
			3 4 rnd trunk-medical+ 
			1 WEAPON_CUTLASS trunk.weapon+ 
			morale++all 
		then 
		\ No hat without first beating the captain in combat. The House says so! 

	then 
	
;

cyoa-choice: drts-sub-locker
	($ cname .. " decides to ask about the DANDY BONES FOOT LOCKER that they'd heard so much about. " $) cyoa-text!
	
	10 %chance if 
	\ "Sycamore - WTF is this?" 
	\ I don't know! xD I thought a copypasta would be fitting/funny. 
	($ "ARH, SO YOU BE WANTING TO KNOW MY TALE? I'VE SEEN THE LOCKER MY LAD. NAE, I OWN IT. COMMON MISCONCEPTION ABOUT THE LOCKER: TIS ACTUALLY MY WEBSITE. I SETS IT UP MYSELF SO I DID. TIS THE FINEST WEBSITE IN ALL THE ATLANTIC OCEAN, WHICH IS NOT AS IMPRESSIVE NOW I SAY IT ALOUD. I BE SELLIN' KOREAN POP MUSIC. VERY POPULAR DOWN THERE! I MAKE A KILLIN' OFF IT TOO. ALL ILLEGAL OBVIOUSLY, BUT WHO'S TO STOP ME? I'M TEN BILLION FEET UNDER THE FLOOR ME HEARTY. NO POLICE DOWN THERE." pbold $) +crtext
	\ ($ "ERRR...WHAT WERE YOU ASKING AGAIN? OH YES, THE LOCKER. I KNOW ABOUT IT. I HOST IT. GOOD DOMAIN TOO, I CALL 'ER THELOCKEROFJONES.COM. BOUGHT THE WEBSITE OFF SOME BLOKE IN FLORIDA. YOU SEE HE USED TO SELL OTHER STUFF. NOT ANYMORE OF COURSE. HE'S DEAD. I PUT HIM IN THE LOCKER. OH, FORGOT TO MENTION! THAT'S MY OTHER SERVICE. KILLING RANDOM STRANGERS. DON'T WORRY THOUGH, YOU GUYS ARE FINE. UNLESS YOU CALL THE POLICE, IN WHICH CASE, I'LL THINK ABOUT KILLING YOU." pbold $) +crtext
	($ " KILLING ISN'T THAT MUCH FUN. NOT AS FUN AS JPOP OR KPOP. YOU SHOULD TRY BOTH AT ONCE. I RECOMMEND IT. ANYWAY, JPOP. NO. KPOP. WANT MY ADVICE? OPEN A KPOP STORE. THEN OPEN A REGULAR POP STORE. THAT'S CALLED BRANDING." pbold $) +text 
	\ ($ "FIRST RULE OF BUSINESS: DON'T DO BUSINESS. OPEN A WEBSITE INSTEAD AND DO THAT. I OPENED MY WEBSITE AND NOW I'M KNOWN BY ABOUT THREE PEOPLE ONLINE. ANYWAY, VISIT MY WEBSITE. YOU'LL LIKE IT THERE. UNLESS YOU DON'T LIKE IT, IN WHICH CASE, PLEASE LET ME KNOW. UNFORTUNATELY DUE TO COMPANY POLICY, I WILL HAVE YOU TO KILL YOU IN THAT CASE. BUT WE DO HAVE A NICE REFUND POLICY. OH AND A NICE WEBSITE." pbold $) +crtext 
	($ "Months later, long, long after the group is gone, the skeleton captain is still ranting about his website. He's been set in motion, and he won't stop until the last syllable of recorded time." $) +crtext
	($ "Who knows how long they might've been there otherwise?" $) +crtext
	morale++all 
	
	choice( "COOL WEBSITE BRO" )choice
	then; 
	
	($ "AYE. TIS A SAD TALE. I WAS SUNK IN ME PRIME. ALAS, TIS THE WAY IT GOES. MAYBE IT WASN'T FOR ME. " pbold $) +crtext
	($ "BUT MAYBE IT'LL BE FOR YOU. YOU KNOW WHAT? HAVE THIS." pbold $) +crtext
	
	($ "The captain gives the group a spare weapon as thanks for listening to him!" $) +crtext
	
	morale++all 
	
	50 %chance if 
		50 %chance if 
			1 WEAPON_PISTOL trunk.weapon+ 
			($ "PISTOL GET!" rbold $) +crtext
		else
			1 WEAPON_SHOTGUN trunk.weapon+ 
			($ "SHOTGUN GET!" rbold $) +crtext
		then 
	else 
		50 %chance if 
			1 WEAPON_DOLT trunk.weapon+ 
			($ "DOLT GET!" rbold $) +crtext
		else
			1 WEAPON_RIFLE trunk.weapon+ 
			($ "RIFLE GET!" rbold $) +crtext
		then
	then 
	
;


cyoa-choice: drts-sub-sink
	($ cname .. " decides to ask how the submarine sank. " $) cyoa-text!
	
	($ "WELL, IT'S A LONG STORY. TO CUT IT SHORT, I POOPED MY PANTS REAL BAD. DON'T LAUGH. I SEE YOU LAUGHING. ARGH." pbold $) +crtext
	
	\ This is inspired by a real life event where a ww2 submarine captain had his ship sunk coz he pooped and flushed it incorrectly. 
	\ Lesson learned: never poop. 
	
	($ "HA. HAHAHAHA. LOSER. sorry." bbold $) +crtext 
	
	($ cname .. " learns a valuable but honestly only vaguely related lesson in naval warfare...and shooting!" $) +crtext
	
	($ cname .. " silently wonders where the submarine is now." $) +crtext
	
	cchar .shooting++ 
	morale++ 
;


: subcoolit 
	cool-it 6 > if 
	"!!!" fbold .. 
	then
;

\ Surprise!!! cooling it is actually ok!!! hes the original cool-it guy!!!
 
cyoa-choice: drts-sub-coolit 
	($ cname .. " tells the submarine captain to " "COOL IT..." rbold .. $) cyoa-text! 
	($ "COOL IT YE SAY? WHAT, LIKE ICE? GOOD IDEA. WE CAN COOL IT AT MY HIDEOUT. YARGH." pbold $) +crtext
	($ "The captain invites the group to his personal hideout and offers them drinks! This is great!" $) +crtext
	morale2+all 
	($ "I'VE TOLD PEOPLE TO COOL IT MY WHOLE LIFE. THE MOMENT I DO, THEY STOP BEING FRIENDS. COULDN'T POSSIBLY KNOW WHY. YARGH." pbold $) +crtext
	($ "How tragic. After a few hours of relaxing and talking, they say their farewells and head back onto their journey." $) +crtext

	cool-it 6 > if 
		($ "YARRRGGHHHHHH!!! WAIT! WAITTTT!!!" pbold $) +crtext
		($ "As the group exits, the captain chases after them, captain's hat in-hand." $) +crtext
		($ "HERE. TAKE THIS. YOU'RE THE FIRST FRIENDS I'VE HAD IN DECADES." pbold $) +crtext
		($ cname .. " puts the hat on. They feel strangely more powerful!" $) +crtext
		cooled-it
		morale2+ 
		($ "MAX STRENGTH & VITALITY INCREASED!" rbold $) +crtext
		STAT_STRENGTH cchar .bonus@ 1 + cchar .bonus! 
		cchar .vitality@ 1 + 0 6 clamp cchar .vitality! 
		47 cchar .hattype!
		cchar .name@ "Cpt. " swap .. cchar .name! 
		cooled-it
	then; 
	
	cool-it++ 
;

0 value THE_OFFER 

: take_car_give_food 
	THE_OFFER trunk-food+ 
	0 vehicle.which! 
	car-lost
; 

: take_food_give_car 
	THE_OFFER -1 * trunk-food+ 
	1 26 rnd vehicle.which!
; 

cyoa-choice: drts-sub-trade
	($ Thegroup .. " asks if the captain would like to trade. He proposes an offer: " $) cyoa-text!
	
	5 15 rnd to THE_OFFER
	

	
	vehicle.which@ 0 = if 
		($ "YE BE IN NEED OF A VEHICKLE VESSEL? YARGH. I CAN OFFER YE ONE, IF YE HAVE THE FUNDS!" pbold $) +crtext
		($ "The captain offers to take " THE_OFFER rbold " food " rbold .. .. "in exchange for giving you a (random) vehicle. You will keep your weapons and loot." .. $) +crtext 
		
		trunk-food 1 - THE_OFFER > not if
			($ "The group can't spare the food!" rbold $) 
		then 

		choice( "Reject offer" )choice 
		trunk-food 1 - THE_OFFER > if 
			choice( "Accept offer" )choice: take_food_give_car
		then 
	else 	
		($ "YARGH, WHY NOT. TIS A FINE LAND VESSEL YE POSSESS. I'LL TRADE YOU FOOD FOR IT." pbold $) +crtext
		($ "The captain offers " THE_OFFER rbold " food " rbold .. .. "in exchange for your vehicle. You will keep your weapons and loot." .. $) +crtext 
		choice( "Reject offer" )choice 
		choice( "Accept offer" )choice: take_car_give_food
	then 
	
	morale++ 
;

cyoa: drts-submarine  
	"THE U.S.S RUSTOLEUM" cyoa-title!
	image-submarine-def
	($ Thegroup .. " is exploring near the coast when they meet a skeleton captain of an old, withered submarine that sunk nearby! The apocalypse brought him out of his home." $) cyoa-text!
	($ "HI THERE. I'M NOT EVIL. PINKIE PROMISE!" pbold $) +crtext
	($ "His boney pinkie then falls off." $) +crtext 
	($ "What was the topic of their discussion?" $) +crtext 
	most-ahole if
	 	charchoice( ": Your loot, please!" )choice: drts-sub-rob
	then
	strongest charchoice( ": WANNA FIGHT?" )choice: drts-sub-kill 
	
	most-grating if
		charchoice( ": TELL HIM TO COOL IT" subcoolit )choice: drts-sub-coolit 
	then
	
	numhaggler 0 > if 
		choice( "Trade with him" )choice: drts-sub-trade 
	then 

	smartest charchoice( ": D*VY JONES LOCKER" )choice: drts-sub-locker
	calmest charchoice( ": How'd you sink?" )choice: drts-sub-sink
;


cyoa-choice: drts-carnival-strong
	($ cname .. " plays " "THE STRONGMANN GAME! " fbold .. "It's one of those old games where you smash a button with a hammer to see how SWOLE you are." .. $) cyoa-text! 

	strengthroll if 
		($ "DING DING DING DING DING" fbold $) +crtext
		($ "YOU'RE A REAL SWOLE MOLE!" fbold $) +crtext
		morale++ goodfx 
	else 
		($ "DING DING DING DING DING" fbold $) +crtext
		($ "FINAL VERDICT: MID-MUSCLE" fbold $) +crtext
		morale-- badfx 
	then 
		($ "These carnival games are really getting out of hand." $) +crtext
		($ "Smashing that button repeatedly was great exercise! " cname .. " feels so much stronger already!" .. $) +crtext
		cchar .strength++ 
; 


cyoa-choice: drts-carnival-shoot
	($ cname .. " plays " "THE CLAY BIRD SHOOTING GAME! " fbold .. "There's a clay disk launcher and an intact double-barrel shotgun." .. $) cyoa-text! 
	($ cname .. " finds some ammo and takes the shotgun for themselves." $) +crtext
	8 12 rnd LOOT_SHOTGUN_SHELL trunk.loot+ 
	1 WEAPON_DSHOTGUN trunk.weapon+ 

	($ "BANG BANG BANG!" fbold $) +crtext
	($ "WOW, NICE SHOT, YA DINGUS!" fbold $) +crtext
	($ "These carnival games are really getting out of hand." $) +crtext

	shootingroll if 
		($ cname .. " missed nearly every disk except the last! The launcher machine dispenses a singular can of beans." $) +crtext
		2 trunk-food+ 
		morale++ goodfx 
	else 
		($ cname .. " missed every single shot and almost fell over in the process! At least it was good shooting practice." $) +crtext
		morale-- badfx 
	then 
		($ "That was a tough challenge! " cname .. " is already a better shot as a result." .. $) +crtext
		cchar .shooting++ 
; 


cyoa-choice: drts-carnival-mech
	($ cname .. " plays " "THE DODGEMS SMASHING GAME! " fbold .. "There's a series of dinky iittle dodgem cars left to rot." .. $) cyoa-text! 
	($ cname .. " finds some gas and a wrench in the backrooms of the dodgems circuit." $) +crtext
	20 30 rnd LOOT_GAS trunk.loot+ 
	1 WEAPON_WRENCH trunk.weapon+ 

	($ "BOUNCE BOUNCE BOUNCE BOUNCE CRAAASSSSSSH!" fbold $) +crtext
	($ "AMAZING! YOU DRIVE LIKE A DRUNKEN SQUIRREL!" fbold $) +crtext
	($ "These carnival games are really getting out of hand." $) +crtext

	mechanicroll if 
		($ cname .. " bashes around on the dodgems for a while. They even manage to avoid breaking any bones!" $) +crtext 
		morale2+ goodfx 
	else 
		($ cname .. " crashes into a wall at high speed halfway through! Something cracks in their back. Youch!" $) +crtext
		morale-- sting-- badfx 
	then 
		($ "Driving around with some janky controls is difficult, but " cname .. " gains a slightly better understanding of machines as a result." .. $) +crtext
		cchar .mechanic++ 
; 


cyoa-choice: drts-carnival-fit
	($ cname .. " jumps on " "THE GIANT HAMPSTER WHEEL! " fbold .. "There's a bunch of wires attached that seem to lead everywhere." .. $) cyoa-text! 
	($ cname .. " finds a leather whip nearby. Whatever was this used for?" $) +crtext
	1 WEAPON_MIDWHIP trunk.weapon+ 

	($ "WHIRRRRR WHIRRRRR WHIRRRRRRRRRRR!" fbold $) +crtext
	($ "The rest of the carnival briefly illuminates! The wheel is a generator!" bbold $) +crtext
	($ "The lights look amazing!" $) +crtext
	morale++ 

	fitnessroll if 
		($ cname .. " runs like the wind! The wheel turns at blistering speeds!" $) +crtext 
		morale++ goodfx 
	else 
		($ cname .. " loses their balance and slips off the wheel. They pull something in their leg!" $) +crtext
		morale-- badfx 
	then 
		($ "All that running was great exercise! " cname .. " feels their glutes stregthen." .. $) +crtext
		cchar .fitness++ 
; 



cyoa: drts-carnival 
	"DARK CARNIVAL" cyoa-title!
	($ Thegroup .. " arrives at an old forgotten carnival grounds. Amidst many empty stalls, some barely functional games remain." $) cyoa-text!
	($ "Although many of them were just well-disguised scams before the apocalypse, there's nobody to stop them having fun now." $) +crtext
	($ "There's enough time to play a game. Which?" $) +crtext  

	strongest charchoice( ": Strongman Hammer!" )choice: drts-carnival-strong 
	shootest charchoice( ": Clay Shooting!" )choice: drts-carnival-shoot
	mechanicest charchoice( ": Dodgems!" )choice: drts-carnival-mech 
	fittest charchoice( ": Hampster Wheel!" )choice: drts-carnival-fit 

;

cyoa-choice: drts-cult-calmshot
	($ "Alone, " cname .. " faces down the alley, weapons drawn. They glance between each bandit; the bandits stare." .. $) cyoa-text! 
	($ "The bandits rush down the alleyway towards " cname .. "! " .. cname .. " quickly aims at each!" .. $) +crtext
	($ cHe .. " blasts the approaching bandits easily! The rest" " flee in terror!" fbold .. $) +crtext
	($ "ITS FLYYYYY MOON. No, wait that's not how it goes..." bbold $) +crtext
	($ "The group is able to get through unscathed!" $) +crtext
	morale2+all 
	morale++ 
	goodfx
	\ bonus morale for being so peak 
; 

cyoa-choice: drts-cult-paranoid
	($ "The plan is simple: charge down the alleyway at full speed, and take the distracted bandits by surprise." $) cyoa-text! 
	($ Thegroup .. " rushes down the alleyway, weapons ready! Combat ensues, but the group has the upper hand!" $) +crtext
 
	team-count 1 = strength-total 10 < or if 
		($ Thegroup .. " takes some hits. The fighting is intense! Perhaps the plan would've worked better if they'd been more swole." $) +crtext
		sting--all 
	else	
		($ "The bandits are beaten! They stood no chance against the team's strength!" $) +crtext
	then 
	goodfx 
	
	($ "The rest of the bandits flee! Everybody makes it safely through the remainder of the alleyway." $) 
	morale++all 

; 

cyoa-choice: drts-cult-ahole
	($ "Whilst most would fall victim to this bandit group, " cname .. " understands this is one of the oldest tricks in the book." .. $) cyoa-text! 
	($ cname .. " disguises themselves as a bandit, creating a hood with a nearby trash bag. Casually, " che .. " approaches the cultists." .. $) +crtext
	 
	($ "HEY FELLOW CULTISTS. COME WITH ME. I FOUND SOME LOSERS TO ROB!" bbold $) +crtext
	
	witsroll if 
		($ "The bandits believe the shoddy disguise! " cname .. " leads them right into their carefully planned trap!" .. $) +crtext 
		
		solo if 
			($ "Whilst the bandits are distracted, " che .. " slips away!" .. $) +crtext
		else 
			($ "The group robs the cultists instead! Free loot! Revenge!" $) +crtext
			5 trunk-food+ 
			20 trunk-gas+ 
			4 trunk-medical+ 
			18 32 rnd LOOT_SHOTGUN_SHELL trunk.loot+ 
			18 32 rnd LOOT_RIFLE_SHELL trunk.loot+ 
			18 32 rnd LOOT_BULLET trunk.loot+ 
			($ "The cultists are embarassed by their stupidity!" $) +crtext
			morale2+all
			goodfx 
		then 
	else 
		($ "The bandits see through the disguise almost immediately." $) +crtext
		($ "They beat up " cname .. " pretty bad with their weapons!" .. $) +crtext
		morale2-
		ouch--
		sting-- 
		sting--
		badfx 
		($ "The bandits finally disperse, allowing the group to traverse through." $) +crtext
	then 

; 

: revoke_weapons args( chara ) 
	0 <- chara .weapona! 
	0 <- chara .weaponb! 
	0 <- chara .weaponc! 
	
	0 <- chara .weapon_nodropa! 
	0 <- chara .weapon_nodropb! 
	0 <- chara .weapon_nodropc! 
; 

cyoa-choice: drts-cult-smart 
	($ cname .. " tries to reason with the bandits. Surely pure " "LOGIC AND REASON" fbold .. " can dispel their bandit ways?" .. $) cyoa-text!
	
	50 %chance if 
		($ "The bandits laugh at this zany attempt to disparage their " "SACRED OBAMA, THE FORETOLD GREAT CREATOR!" fbold .. $) +crtext
		($ "Then they rob the group for everything they're carrying." $) +crtext
		($ "CHARACTER WEAPONS LOST!" rbold $) +crtext
		' revoke_weapons foreach-team-char
		badfx 
		bandit-most
		($ "Having taken enough for themselves, the cultists let the group through." $) +crtext
	else 
		($ "WE...WE WERE WRONG? ALL THIS TIME? THE GREAT CREATOR WAS NOT OBAMA AFTER ALL?" pbold $) +crtext
		($ "YEAH HE'S JUST THE PRESIDENT OR SOMETHING. I DON'T KNOW, I DIDN'T PASS HISTORY." bbold $) +crtext
		($ "The bandits look at one another awkwardly. Obama...a mere president? They believed a lie, all this time?" $) +crtext
		($ "The group of bandits go their separate ways, clearing the way for the group to pass through the alleyway. That was easy!" $) +crtext
		morale++all
		goodfx
		cname witsREV 
	then 
; 

: composure-total 0 ' sum-composures foreach-team-char ;

cyoa-choice: drts-cult-sneak
	($ Thegroup .. " try to sneak around the cultists. This means going the whole long way around the edge of town, a lengthy and dangerous prospect." $) cyoa-text! 
	($ "Whilst trying to dodge the cultist patrols, they're forced to hide away in a dilapidated house." $) +crtext
	
	composure-total team-count / >int 2 > if 
	\ if the group is, on average, average-ly composed, 
		($ "Everybody keeps calm! The bandits are successfully evaded. Nobody even so much as squealed!" $) +crtext
		($ "Still, knowing that imminent death might be around the corner is mildly terrifying!" $) +crtext
		morale--all
		goodfx 
	else 
		($ Thegroup .. " is quickly discovered thanks to incessant " "shrieking and screaming!" fbold .. $) +crtext
		($ "Then bandits rob them for everything they're carrying." $) +crtext
		($ "CHARACTER WEAPONS LOST!" rbold $) +crtext
		' revoke_weapons foreach-team-char
		morale2-all
		bandit-most
		badfx 
		($ "The team is eventually allowed to pass and escape." $) +crtext
	then 
; 

cyoa-choice: drts-cult-fight
	($ "In the alleyway there's little cover for the fight. The fighting is brutal on both sides." $) cyoa-text!
	($ "After a protracted fight, the bandits flee down the alleyway. The path ahead is clear!
	" $)  +crtext bitefx ouch--all ouch--all
;


: image-cult-def 80 cyoa-image-icon! ;

cyoa: drts-cultists
	image-cult-def
	"OOGA CHAKA OOGA CHAKA" cyoa-title!
	($ "Whilst adventuring through a town, " Thegroup .. " gets lost. The only way back is through a single, dark alleyway." .. $) cyoa-text!
	($ "Down the alleyway, a group of " "hooded cult-like individuals " rbold .. "gather round burning drums, chanting some kind of horrible mantra." .. $) +crtext
	($ "These cultists look dangerous. Who knows what they're capable of?" rbold $) +crtext  
	($ "There's no way out but through. Something MUST be done:" $) +crtext  

	calmshot-check if 
		charchoice( ": SHOWDOWN TIME" )choice: drts-cult-calmshot 
	then 
	
	most-paranoid if 
		charchoice( ": Catch them off-guard!" )choice: drts-cult-paranoid 
	then 
	
	most-ahole if 
		charchoice( ": I know their tricks!" )choice: drts-cult-ahole 
	then  
	
	smartest charchoice( ": Reason with them" )choice: drts-cult-smart 
	
	choice( "Try to sneak around" )choice: drts-cult-sneak 
	choice( "Fight the bandits" )choice: drts-cult-fight 
;

\ ----------------------------------------
\ NEW EVENTS FOR TRACHEA BELOW -----------
\ ----------------------------------------

cyoa-choice: t-mech-disassemble
	($ cname .. " stands before the mech, gazing up at it to study it for weaknesses. " $) cyoa-text!
		cwits+ if 
			($ cname .. " quickly deduces that the 'mech' is actually just made of really compact cardboard." $) +text 
			
			cmechanic+ if
				($ "They kick the mech in the shins, where the glue and joints are weakest!" $) +crtext
				($ "The mech crumbles like a tower of blocks into rubble, followed by a loud CRASH. " $) +crtext
				($ "Usually, this wouldn't have worked. But the tinker-engineer type is always watching your craftsmanship. They know your sins. ALWAYS." $) +text 
				morale++ morale++ goodfx mechanicREV 
			else 
				($ cname .. " doesn't know what to do next! The robot picks them up and launches them into the ground. The group is forced to flee!" $) +crtext
				morale2-all ouch-- sting-- badfx mechanicREV 
			then 
		
		else 
			($ cname .. " awkwardly tries for several minutes to deduce a weakness." $) +text
			($ "The bandit mech becomes bored and kicks them at high velocity into a tree!" $) +crtext  
				morale2- ouch-- ouch-- badfx 
		then
		witsREV
;

cyoa-choice: t-mech-coolit 
	($ cname .. " yells " "COOL IT!!!" rbold .. $) cyoa-text! 

	cool-it 6 > if 
		($ "COOL...COOL IT? HMMM. MAYBE YOU'RE RIGHT. I DO NEED BETTER COOLING SYSTEMS...GREAT IDEA!" pbold $) +crtext
		($ "The mech gives the group payment for their ingenious idea!" $) +crtext
		65 165 rnd trunk-gas+ 
		50 LOOT_SHOTGUN_SHELL trunk.loot+ 
		50 LOOT_RIFLE_SHELL trunk.loot+ 
		50 LOOT_BULLET trunk.loot+ 
		cooled-it goodfx witsattREV
	then; 
	
	($ cname .. " and the robot hold a stare for several seconds before the mech starts attacking the team!" $) +crtext
		ezbandit? if 
			ouch--all
		else
			ouch12rnd--all
		then		
		
	car-break cool-it++ 
	
	team-count 0 > if 
		($ Thegroup .. " is forced to flee!" $) +crtext witsattREV
	else 
		($ "The group would flee...if there was anybody left." $) +crtext
	then 
	
;

cyoa-choice: t-mech-paranoid 
	($ cname .. " genuinely believed there was an enormous mech! You never know what's around the corner in the zombocalypse. They quickly form a plan!" $) cyoa-text!
	($ "EJECT! EJECT EJECT EJECT!" pbold $) +crtext
	($ "The robot makes a creaking, whirring noise. It can't tell the difference between the bandit's voice and " cname .. "! It ejects the bandit high into the atmosphere!" .. $) +crtext
	($ "CURSEEEE YOUUUUUU EJECTTTT BUTTONNNNNNNNNNNnnnnnnnn......" rbold $) +crtext
	morale++all morale++ goodfx
	
	cchar .perk@ "Pyromaniac" $= if 
		($ cname .. " sets fire to it anyway." $) +crtext
		morale++ 
	then 

;


cyoa-choice: t-mech-calmshot  
	($ cname .. " draws their weapons and aims for the knees of the robot!" $) cyoa-text!
	($ "They destroy the knees of the robot in a hail of bullet fury!" $) +crtext
	($ cname .. " is too quick for the mech bandit! It wobbles back and forth dramatically, before falling flat into a heap." $) +crtext 
	morale++all morale++ goodfx shootingREV temperREV shooting++
	
	12 38 rnd LOOT_SHOTGUN_SHELL trunk.loot+ 
	12 38 rnd LOOT_RIFLE_SHELL trunk.loot+ 
	12 38 rnd LOOT_BULLET trunk.loot+ 
;

: bandit-mechtakestuff
	trunk-gas 0 > if trunk-gas -1 * trunk-gas+ then
	trunk-bullet 0 > if trunk-bullet -1 * trunk-bullet+ then
	trunk-rifle-shell 0 > if trunk-rifle-shell -1 * trunk-rifle-shell+ then
	trunk-shotgun-shell 0 > if trunk-shotgun-shell -1 * trunk-shotgun-shell+ then
	
;

cyoa-choice: t-mech-paytoll
	($ Thegroup .. " decides to play it safe. " .. gThey .. " give" .. g1s .. " into the bandits' demands." $) cyoa-text! badfx
	bandit-mechtakestuff haggler-morale 
;

