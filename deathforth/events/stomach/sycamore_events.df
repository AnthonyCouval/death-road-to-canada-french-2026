	($ cname .. " yells " "COOL IT!" rbold .. " at the top of " .. chis .. " lungs." .. $) cyoa-text! 
			cool-it 3 > if 
				($ "COOL IT? I SUPPOSE YOU'RE RIGHT...WE'VE RUINED SO MUCH OF THIS TOWN." rbold $) +crtext
				($ "The bandits feel guilty for their trail of destruction! They resolve to make things right!" $) +crtext
				cooled-it goodfx witsattREV
			
				4 10 rnd trunk-food+ 
				20 40 rnd trunk-gas+ 
				2 5 rnd trunk-medical+ 
			
				morale2+all
			then; 
		
		($ "This message is highly antithetical to the bandit's philosophy! They torch " thegroup .. " in revenge!" .. $) +crtext
		ouch-- ouch-- badfx morale--all morale--  
		cool-it++  
