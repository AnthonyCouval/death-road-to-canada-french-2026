cyoa: sycacity_test1
	"Heure de Pointe" cyoa-title!
	someicon
	($ "Les zombies de cette ville se sont agites. Ils sont deja agressifs quand " .. thegroup .. " arrive." $) cyoa-text! basic-tone
	1 1.3 frnd 16 17 frnd 2 zforecast
	"events/stomach/syca_citytest.df" $load-region
		lot-draw
;
