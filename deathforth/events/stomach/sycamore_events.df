0 value gourmand_number 
0 value chara_gourmand

: count_gourmands args( chara )
	<- chara .trait@ "Gourmand" $= if
			<- chara .party@ 1 = if 
					<- chara .health@ 0 > if 
						gourmand_number 1 + to gourmand_number
					<- chara to chara_gourmand
	then then then 
;

