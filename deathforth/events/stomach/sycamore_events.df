\ LE MECHA BANDIT
cyoa: t-mechabandit
	"BANDFORMERS... DES BANDITS INCOGNITO" cyoa-title!
	($ Thegroup .. " avance tranquillement sur une route quand un bandit dans une sorte de mech sort de derriere un immeuble. D'une voix seche de synthese vocale, il parle :" $) cyoa-text!
	($ "TOUT VOTRE BUTIN NOUS APPARTIENNENT." rbold $) +crtext
	($ "Le mech exige tout votre essence et vos munitions pour passer." rbold $) +crtext

	mechanicest charchoice( ": Le demonter !" )choice: t-mech-disassemble

	most-grating if
		charchoice( ": LUI DIRE DE SE CALMER" subcoolit )choice: t-mech-coolit
	then

	most-paranoid if
		charchoice( " avait pressentis qu'un enorme mech pourrait etre par la" )choice: t-mech-paranoid
	then

	calmshot-check if
		charchoice( " fait exploser les genoux du mech" )choice: t-mech-calmshot
	then

	choice( "Payer le peage" )choice: t-mech-paytoll
	bandit-fight

;

: copbanditcoolit
	cool-it 3 > if
	"!!!" fbold ..
	then
;

0 stack
	WEAPON_PIPEBOMB shove
	WEAPON_MOLOTOV shove
	WEAPON_GRENADE shove
constant WEAPON_LIST_ARSON

: team-has-arson? WEAPON_LIST_ARSON roadtrip-has-weapontype? ;

cyoa-choice: t-cop-ahole
	($ cname .. " n'a pas peur des flics. Il plonge la main dans sa poche." $) cyoa-text!

		team-has-arson? if
			($ cname .. " sort une bombe et menace calmement les bandits avec !" $) +crtext
			($ "REGARDEZ CA ! C'EST NOUS OU VOUS, LES NULS ! A VOUS DE CHOISIR !" pbold $) +crtext
			($ "Les bandits acceptent a contrecoeur de laisser " Thegroup .. " passer pour ne pas etre pulverises." .. $) +crtext
		else
			($ cname .. " ne possede en fait rien d'assez petit et explosif dans sa poche, alors il fait semblant." $) +crtext
			($ "Heureusement, " cname .. " est un menteur incroyable. " .. cHe .. " reussit a bluffer les bandits avec une bouteille de jus !" .. $) +crtext
			($ "Les bandits acceptent a contrecoeur de laisser " thegroup .. " passer pour ne pas etre pulverises." .. $) +crtext
		then
			loyaltyREV morale++all morale++ goodfx

		cchar .perk@ "Pyromaniac" $= if
			($ cname .. " met quand meme le feu au commissariat." $) +crtext
			morale++
		then

;

cyoa-choice: t-cop-paranoid
	($ cname .. " savait que ca tournerait mal et avait prepare un plan a l'avance." $) cyoa-text!
	($ cname .. " fonce a travers les murs du commissariat avec leur voiture ! Des gravats volent partout ! La voiture prend des degats." $) +crtext
	sting-- -2 -3 rnd car-chassis+
	($ "Les bandits sont terrifes et commencent a fuir ! " Thegroup .. " peut passer gratuitement !" .. $) +crtext
	morale++all goodfx
;

cyoa-choice: t-cop-disguise
	($ cname .. " insiste sur le fait qu'il etait aussi flic, tout comme eux !" $) cyoa-text!
	($ "OH OUI ? PROUVEZ-LE ALORS." rbold $) +crtext

		cwits+ cshooting+ and if
			($ "Se souvient avoir lu un manuel de formation policiere il y a des annees. Il tire sur quelques boites et recite fidelement des passages du manuel !" $) +crtext
			($ "ALORS T'ES UN SACRE BON FLIC HEH ? CA SUFFIT. TU PEUX PASSER." rbold $) +crtext
			($ cname .. " n'en revient pas que ca ait vraiment marche !" $) +crtext
			($ "Les bandits laissent passer le groupe sans faire d'histoire !" $) +crtext morale++all morale++ goodfx
		else
			witsroll shootingroll or if
				($ "Ne sait pas vraiment grand chose sur la police, et repete plutot des trucs aleatoires de vieilles series tele." $) +crtext
				($ "OUAIS DONC C'EST TRES IMPORTANT D'ALLUMER LES SIRENES TOUT LE TEMPS ET DE DIRE 'TERMINE' SANS ARRET. TERMINE." pbold $) +crtext
				($ "Les flics marquent une pause et se regardent un instant. Ca ira !" $) +crtext
				($ "Les bandits laissent passer le groupe sans faire d'histoire !" $) +crtext morale++all morale++ goodfx
			else
				($ "Crache des repliques aleatoires de vieux films de flics qui sonnent bien." $) +crtext
				($ "ALORS ON SE SENT D'ATTAQUE... NULOS ?" pbold $) +crtext
				($ "Les flics bandits se regardent une seconde, confus, puis ouvrent le feu ! Le groupe est dans une mauvaise posture !" $) +crtext
				ouch-- ouch--all badfx morale--all morale--
			then
		then

;

cyoa-choice: t-cop-grating
	($ cname .. " crie " "SE CALMER !" rbold .. " a tue-tete." .. $) cyoa-text!
			cool-it 3 > if
				($ "OH, VOUS DEVEZ ETRE LE NOUVEAU CAPITAINE ! ON NE VOUS AVAIT PAS RECONNU. TENEZ, PRENEZ CA !" pbold $) +crtext
				($ "Les bandits estiment que " cname .. " sera leur nouveau capitaine ! Ils remettent de nombreuses armes !" .. $) +crtext
				cooled-it goodfx witsattREV

				1 WEAPON_CHROMESHOTGUN trunk.weapon+
				1 WEAPON_MP5 trunk.weapon+
				($ "FUSIL A POMPE CHROME RECUP ! PISTOLET-MITRAILLEUR RECUP !" rbold $) +crtext
				morale2+
				morale++all
			then;

		($ "Les flics prennent ca pour une sorte de dialecte criminel super secret ! Ce doit etre le criminel le plus recherche de l'histoire ! Ils commencent a tirer sur " cname .. " illico !" .. $) +crtext
		ouch-- ouch-- sting-- badfx morale--all morale--
		cool-it++

;

cyoa-choice: t-cop-calmshot
	($ cname .. " degaine " chis .. " armes a une vitesse fulgurant, plongeant tout le monde dans..." .. $) cyoa-text!
	($ "LE GRAND VAGUE-MENT MEXICAIN A PEU PRES ASSIS EN FAIT FACE A FACE" fbold $) +crtext
	($ "Pendant plusieurs heures, " thegroup .. " et les bandits se pointent des armes dessus maladroitement avec des bruits." .. $) +crtext

	composure-total team-count / >int 2 > if
		($ Thegroup .. " est tellement patient que les bandits s'ennuient et battent en retraite ! " Thegroup .. " passe les flics bandits gratuitement !" .. $) +crtext
		morale++all
		morale++

	else

		($ Thegroup .. " s'ennuie et commence a tirer ! Un combat s'engage, mais " thegroup .. " a l'avantage !" .. $) +crtext
		sting--all
		\ only a little bit of damage...almostttt meaningless 
	
	then 
	
	
;

: bandit-coptakestuff
	trunk-bullet 0 > if trunk-bullet -1 * trunk-bullet+ then
	trunk-rifle-shell 0 > if trunk-rifle-shell -1 * trunk-rifle-shell+ then
	trunk-shotgun-shell 0 > if trunk-shotgun-shell -1 * trunk-shotgun-shell+ then

;

cyoa-choice: t-cop-paytoll
	($ Thegroup .. " decide de jouer la securite. " .. gThey .. " ced" .. g1s .. " aux exigences des bandits." $) cyoa-text! badfx
	bandit-coptakestuff haggler-morale
	trunk.killer
;

