	($ "Out of nowhere, " cname .. " runs up to a bandit and hurls him away like a bowling ball!" .. $) cyoa-text!
	
	($ "Then, as the bandits are still in shock, " che .. " picks up another bandit and slams them down onto their back!" .. $) +crtext

	($ "The bandits are terrified! They back away slowly from the carnage. " Thegroup .. " gets to pass for free!" ..  $) +crtext
	
	goodfx
	morale++all
	morale++ 

