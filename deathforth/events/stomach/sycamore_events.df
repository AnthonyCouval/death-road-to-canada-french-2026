cyoa: t-copbandits
	"SALE HAROLD 8 : ENCORE EN TRAIN DE TIRER SUR DES CRIMINELS" cyoa-title!
	($ Thegroup .. " tombe sur ce qui semble etre un commissariat. Des qu'ils entrent, des flics bandits les encerclent !" $) cyoa-text!
	($ "Ils sont tous en uniformes voles miteux, positionnes derriere des tables renversees avec leurs revolvers prets." $) +crtext
	($ "Les flics bandits exigent toutes vos armes et munitions de rechange." rbold $) +crtext

	most-ahole if
		charchoice( " a une surprise..." )choice: t-cop-ahole
	then

	most-paranoid team-count 1 > vehicle.which@ 0 > and and if
		charchoice( " savait qu'il y aurait des ennuis !" )choice: t-cop-paranoid
	then

	most-grating if
		charchoice( " crie SE CALMER" copbanditcoolit )choice: t-cop-grating
	then

	roadtrip-has-firearm? if
		smartest charchoice( " est VRAIMENT un flic !" )choice: t-cop-disguise
	then

	calmshot-check if
		charchoice( ": FACE A FACE MEXICAIN" )choice: t-cop-calmshot
	then

	choice( "Ceder les munitions et armes" )choice: t-cop-paytoll
	bandit-fight

;


: .pyroperson? args( chara )

	<- chara .perk@ "Pyromaniac" $=
;

: ispyroperson? .pyroperson? ;
: numpyroppl team-stack ' ispyroperson? stack-filter ;
: pyroperson? numpyroppl 0 > ;


cyoa-choice: t-pyro-paranoid
	($ cname .. " est toujours pret pour un incendie ! Il avait apporte un extincteur improvise des le moment ou il avait vu des batiments brules." $) cyoa-text!

	($ "Les armes des bandits sont eteintes ! " cname .. " a l'air content. Quelqu'un aurait pu se blesser SERIEUSEMENT." .. $) +crtext

	($ cname .. " a eteint leur feu de camp special ! Les bandits attaquent, mais en position de faiblesse." $) +crtext

	2 WEAPON_FIREEX trunk.weapon+

	goodfx
	morale++
	sting--all

;

cyoa-choice: t-pyro-ception
	($ Thegroup .. " reconnait les bandits comme des pyromanes comme eux !" $) cyoa-text!

	($ Thegroup .. " et les bandits se perdent dans une conversation sur" " l'incendie criminel, la securite incendie, et les avantages du kerosene comme carburant." pbold .. $) +crtext

	($ "Au milieu de cette conversation, les bandits oublient completement de braquer ! Ils donnent au groupe un molotov honorifique." $) +crtext

	($ "MOLOTOV RECUP !" rbold $) +crtext

	1 WEAPON_MOLOTOV trunk.weapon+
	goodfx

	morale2+all

;

cyoa-choice: t-pyro-angrystrong
	($ "De nulle part, " cname .. " court vers un bandit et le propulse comme une boule de bowling !" .. $) cyoa-text!

	($ "Puis, alors que les bandits sont encore sous le choc, " che .. " attrape un autre bandit et le claque sur son dos !" .. $) +crtext

	($ "Les bandits sont terrifes ! Ils reculent lentement devant le carnage. " Thegroup .. " peut passer gratuitement !" ..  $) +crtext

	goodfx
	morale++all
	morale++

;


0 value gourmand_number
0 value chara_gourmand

: count_gourmands args( chara )
	<- chara .trait@ "Gourmand" $= if
			<- chara .party@ 1 = if
					<- chara .health@ 0 > if
						gourmand_number 1 + to gourmand_number
					<- chara to chara_gourmand
	then then then
;

cyoa-choice: t-pyro-gourmand
	($ cname .. " sort quelque chose de sa poche, un piment rouge vaguement brillant." $) cyoa-text!

	($ "VOUS VOULEZ VOIR DU FEU ? REGARDEZ CA." pbold $) +crtext

	($ cname .. " avale le GASTGANO DELUXE ULTRA CALIFORNIA REAPER " rainbold .. " en entier ! Il crache du feu dans un spectacle repete !" .. $) +crtext

	($ "Les bandits sont extremement impressionnes ! " cname .. " est cependant contrarie d'avoir utilise son piment special." .. $) +crtext

	morale--

;

cyoa-choice: t-pyro-coolit
	($ cname .. " crie " "SE CALMER !" rbold .. " a tue-tete." .. $) cyoa-text!
			cool-it 3 > if
				($ "SE CALMER ? JE SUPPOSE QUE VOUS AVEZ RAISON...ON A DETRUIT TELLEMENT DE CETTE VILLE." rbold $) +crtext
				($ "Les bandits se sentent coupables de leur sillage de destruction ! Ils decidend de reparer les choses !" $) +crtext
				cooled-it goodfx witsattREV

				4 10 rnd trunk-food+
				20 40 rnd trunk-gas+
				2 5 rnd trunk-medical+

				morale2+all
			then;

		($ "Ce message est hautement antitheique a la philosophie des bandits ! Ils brulent " thegroup .. " en represailles !" .. $) +crtext
		ouch-- ouch-- badfx morale--all morale--
		cool-it++
;

: bandit-pyrotakestuff
	trunk-gas 0 > if trunk-gas -1 * trunk-gas+ then
;

cyoa-choice: t-pyrobandits-paytoll
	($ Thegroup .. " decide de ne pas prendre de risque. " .. gThey .. " ced" .. g1s .. " aux exigences des bandits." $) cyoa-text! badfx
	bandit-pyrotakestuff haggler-morale 
	trunk.killer 
	
	\ ($ "TRUNK WEAPONS LOST!" rbold $) +crtext
;


cyoa: t-pyrobandits
	"A TRAVERS LE FEU ET LES FLAMMES" cyoa-title!
	($ "En explorant une ville brulee, " thegroup .. " est pris en embuscade par un groupe de bandits !" .. $) cyoa-text!
	($ "Ils brandissent tous des lance-flammes allumes, des torches, et de petits briquets minuscules. L'un d'eux est litteralement en feu." $) +crtext
	($ "Les bandits exigent toute votre essence et vos armes de rechange !" rbold $) +crtext

	most-paranoid if
		charchoice( " est toujours pret pour un incendie !" )choice: t-pyro-paranoid
	then

	numpyroppl 0 > if
		choice( "Saluer vos camarades pyromanes" )choice: t-pyro-ception
	then

	most-angrystrong if
		charchoice( ": SUPLEX !" )choice: t-pyro-angrystrong
	then

	' count_gourmands foreach-team-char

	gourmand_number 0 > if
		chara_gourmand 
		charchoice( ": JALAPENO BONANZA" )choice: t-pyro-gourmand
	then 
	\ "but numgourmands exists" yes i know. but im doing it this way coz i want
	\ to actually pick a gourmand character for cname and such 
	
	most-grating if 
		charchoice( ": COOL IT" copbanditcoolit )choice: t-pyro-coolit 
	then 
	
	choice( "Ceder essence et armes" )choice: t-pyrobandits-paytoll
	
	bandit-fight

;

cyoa-choice: t-mystery-food
	($ Thegroup .. " insere " "8 nourriture" rbold .. " dans le receptacle specialement concu." $) cyoa-text!
	-8 trunk-food+

	($ "La machine emet une variete de bruits de broyage forts, des etincelles partout, et s'arrete brusquement." $) +crtext
	($ "Un panneau s'ouvre et une arme vole dehors !" $) +crtext
;

\ TODO: FINIR CA

cyoa: t-mystery
	"...ON SE DEMANDE QUI L'A ENVOYE ?" cyoa-title!
	($ "Au milieu d'un magasin abandonne, " thegroup .. " tombe sur une enorme boite metallique." .. $) cyoa-text!
	($ "Fixee au sol. Exterieur metallique. Marquage officiel DINKSCO. Le forfait complet." $) +crtext
	($ "Elle semble avoir une sorte de systeme d'insertion de nourriture." $) +crtext
	($ "PRIX : 8 NOURRITURE || ARME : ...PROBABLEMENT" rbold $) +crtext

	trunk-food 7 > if
		choice( "Deposer de la nourriture - 8 nourriture" )choice: t-mystery-food
	then

;

\ Refonte des villes STOMACH pour plus de variete

