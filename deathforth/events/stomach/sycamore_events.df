	($ cname .. " is always prepared for a fire! They brought an improvised fire extinguisher with them the moment they saw burnt buildings." $) cyoa-text!
	
	($ "The bandits weapons are extinguished! " cname .. " looks pleased. Somebody could've gotten SERIOUSLY hurt." .. $) +crtext

	($ cname .. " extinguished their special campfire! The bandits attack, but at a disadvantage." $) +crtext
	
	2 WEAPON_FIREEX trunk.weapon+ 
	
	goodfx
	morale++ 
	sting--all

;

cyoa-choice: t-pyro-ception
	($ Thegroup .. " recognises the bandits as fellow pyromaniacs!" $) cyoa-text!
	
	($ Thegroup .. " and the bandits get lost in a conversation about" " arson, fire safety, and the advantages of kerosene as fuel." pbold .. $) +crtext

	($ "In the midst of this conversation, the bandits completely forget about robbing! They give the group an honorary molotov." $) +crtext
	
	($ "MOLOTOV GET!" rbold $) +crtext
	
	1 WEAPON_MOLOTOV trunk.weapon+ 
	goodfx
	
	morale2+all 

;

