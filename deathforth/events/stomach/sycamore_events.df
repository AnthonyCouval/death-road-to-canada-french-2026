	trunk-gas 0 > if trunk-gas -1 * trunk-gas+ then
;

cyoa-choice: t-pyrobandits-paytoll
	($ Thegroup .. " decides to play it safe. " .. gThey .. " give" .. g1s .. " into the bandits' demands." $) cyoa-text! badfx
	bandit-pyrotakestuff haggler-morale 
	trunk.killer 
	
	\ ($ "TRUNK WEAPONS LOST!" rbold $) +crtext
;


cyoa: t-pyrobandits 
	"THROUGH THE FIRE AND FLAMES" cyoa-title!
	\ image-submarine-def
	($ "When exploring a burnt down town, " thegroup .. " is ambushed by a group of bandits!" .. $) cyoa-text!
	($ "They're all wielding lit flamethrowers, torches, and tiny little cigarette lighters. One of them is quite literally just on fire." $) +crtext 
	($ "The bandits demand all your gas and spare weapons!" rbold $) +crtext 
	
	most-paranoid if 
		charchoice( " is always prepared for a fire!" )choice: t-pyro-paranoid 
	then 

	numpyroppl 0 > if 
		choice( "Greet your fellow pyromaniacs" )choice: t-pyro-ception 
	then 
	
	most-angrystrong if
		charchoice( ": SUPLEX!" )choice: t-pyro-angrystrong
	then
	
	' count_gourmands foreach-team-char
	
	gourmand_number 0 > if
		chara_gourmand 
		charchoice( ": JALAPENO BONANZA" )choice: t-pyro-gourmand
	then 
	\ "but numgourmands exists" yes i know. but im doing it this way coz i want
	\ to actually pick a gourmand character for cname and such 
	
	most-grating if 
		charchoice( ": COOL IT" copbanditcoolit )choice: t-pyro-coolit 
	then 
	
	choice( "Give up gas and weapons" )choice: t-pyrobandits-paytoll
	
	bandit-fight
	
;

: random_mystery_weapon 
	
	
	
; 	

cyoa-choice: t-mystery-food 
	($ Thegroup .. " inserts " "8 food" rbold .. " into the specially designed receptacle." $) cyoa-text!
	-8 trunk-food+ 
	
	($ "The weapon makes a variety of loud churning noises, emits sparks everywhere and stops suddenly." $) +crtext
	($ "A panel opens and a weapon flies out!" $) +crtext
	
	
	
;

\ TODO: FINISH THIS 

cyoa: t-mystery
	"...WONDER WHO IT'S FROM?" cyoa-title!
	\ image-submarine-def
	($ "In the middle of an abandoned store, " thegroup .. " comes across a huge metal box." .. $) cyoa-text!
	($ "Nailed down. Metal exterior. Official DINKSCO branding. The full package." $) +crtext 
	($ "It seems to have some kind of food insertion system." $) +crtext
	($ "PRICE: 8 FOOD || WEAPON: ...PROBABLY" rbold $) +crtext

	trunk-food 7 > if 
		choice( "Deposit food - 8 food" )choice: t-mystery-food 
	then 
	
;

