

uses paul/region-layout.df
uses paul/region-road-layout.df

"events/inner/baseapts.df" $load
"events/inner/policeloc.df" $load
"../deathforth/events/stomach/forge.txt" $load-rooms
"../deathforth/rooms/city.txt" $add-rooms
"events/stomach/syca_city_commons.df" $load 

roomgen{ 



: the_forge  
	spawn
	special_objects64_base_id 24 + lt .spriteid!
	bbox 
	0 lt .flammability! 
	4000 lt .mass!
	100 lt .hitpoints! 
;

: anvil  
	spawn
	special_objects48_base_id 87 + lt .spriteid!
	bbox 
	0 lt .flammability! 
	10 lt .mass!
	50 lt .hitpoints! 
;

: cooling_tub 
	spawn 
	special_objects64_base_id 25 + lt .spriteid! 
	bbox 
	10 lt .flammability! 
	15 lt .mass! 
	100 lt .hitpoints! 
;

: ammout_rifle args( me )
	0 <- me .clr.a! 
	20 30 frnd LOOT_RIFLE_SHELL spawnscat <- me .pos lt .pos!
	clear-cyoa
	interactee silentkillit
;

: ammopile_rifle 
	spawn special_objects32_base_id 212 + lt .spriteid!
	as-metal 4000 lt .hitpoints! 4000 lt .mass!
	' ammout_rifle lt .cyoa!
;

: ammout_bullet args( me )
	0 <- me .clr.a! 
	20 30 frnd LOOT_BULLET spawnscat <- me .pos lt .pos!
	clear-cyoa
	interactee silentkillit
;

: ammopile_bullet
	spawn special_objects32_base_id 216 + lt .spriteid!
	as-metal 4000 lt .hitpoints! 4000 lt .mass!
	' ammout_bullet lt .cyoa!
;

: ammout_shotgun args( me )
	0 <- me .clr.a! 
	20 30 frnd LOOT_SHOTGUN_SHELL spawnscat <- me .pos lt .pos!
	clear-cyoa
	interactee silentkillit
;

: ammopile_shotgun
	spawn special_objects32_base_id 217 + lt .spriteid!
	as-metal 4000 lt .hitpoints! 4000 lt .mass!
	' ammout_shotgun lt .cyoa!
;

: basicbed spawn 0x 6 inside_objects_base_id + spriteid! bbox as-cloth dropswood 6 health! 0 lt .friction! ; \ STAY STILL

: mildrawers spawn 2 inside_objects_base_id + spriteid! bbox 33 %chance if openable container then as-wood 0 lt .friction! ;

: droplets args( me eventid )
	<- eventid THING_EVENT_TIMER = if
		12 <- me .timer!
			
			6 8 rnd for
			
			<- me .pos
			particle{ new pos! 15 ticks! 
			pos@ 0 2 3 frnd xyadd pos!
			
			particles_base_id 1+ spriteid!
			160 200 frnd anglexy 0.5 1.2 frnd xymul vel!
			
			0 clr.r!
			0.4 clr.g!
			1 clr.b!
			glowy

			}
			
		next
			
	then
;
	
	
: wallshower
	spawn special_objects16_base_id 48 + lt .spriteid! 3 lt .tileflags! 2000 lt .hitpoints! 4000 lt .mass! -2.1 lt .vel.y! 0 lt .rad.x! 0 lt .rad.y!
	 1 lt .timer! 1 lt .nocollide! 1 lt .no_hit! ' droplets lt .events!
;
	
	
: address_people 1 6 rnd case 
	1 of "ALL DINKS..." endof 
	2 of "DINKS, REPEAT, ALL DINKS..." endof 
	3 of "ALL NERDS..." endof
	4 of "ALL MEGABUFFS..." endof 
	5 of 1 %chance if "SYCAMORE..." else "KEPA..." then endof 
	6 of "HATCHET MAFIA..." endof 
	endcase
; 

: address_issue 1 5 rnd case 
	1 of "PLEASE REPORT TO..." endof 
	2 of "PLEASE SEE TO..." endof 
	3 of "PLEASE ATTEND..." endof 
	4 of "PLEASE FACILITATE..." endof 
	5 of "PLEASE PERFORM..." endof 
	endcase 
; 

: address_task 1 20 rnd case 
	1 of "BUTTCLEANING. THANK YOU" endof 
	2 of "BOTTOM SURGERY. THANK YOU" endof 
	3 of "THE TABLESMASH ROOM. THANK YOU" endof 
	4 of "PIPEBOMB EATING. THANK YOU" endof 
	5 of "CHICKEN OBLITERATION." endof 
	6 of "CANADA INVADING. THANK YOU" endof 
	7 of "MY THERMONUCLEAR BOMB. THANK YOU" endof 
	8 of "A FUNNY OFF-BEAT DANCE. THANK YOU" endof 
	9 of "YOUR MOM." endof 
	10 of "YOUR DAD." endof 
	11 of "THE TERMINATOR. THANK YOU" endof 
	12 of "A PILE OF BRICKS. THANK YOU" endof 
	13 of "BLOWING UP MY CAR. THANKS" endof 
	14 of "COOLING IT SILLY STYLE." endof 
	15 of "RIDING A PIG. THANK YOU" endof 
	16 of "BAD COUNTRY RECORDS. THANKS" endof 
	17 of "OBAMA. THANKS. THANKS OBAMA" endof 
	18 of "THE 90s. THANK YOU" endof 
	19 of "THIS GIANT CANDYBAR. THANKS" endof 
	20 of "MY WILL TO LIVE. THANKS" endof 
	endcase
;
	

: announce_bs args( me eventid )
	<- eventid THING_EVENT_TIMER = if 
		180 220 rnd <- me .timer! 
		
		<- me .weapon_state.val@ 2 = if 
			address_task <- me .yellmsg
			0 <- me .weapon_state.val!
		then; 
		
		<- me .weapon_state.val@ 1 = if 
			address_issue <- me .yellmsg
			2 <- me .weapon_state.val!
		then; 
		
		<- me .weapon_state.val@ 0 = if 
			address_people <- me .yellmsg
			1 <- me .weapon_state.val!
		then; 
	then 			
; 		

: speaker_mil 
	spawn special_objects32_base_id 220 + lt .spriteid!
	as-metal 30 lt .hitpoints! 200 lt .mass! 3 lt .tileflags! 
	-2 lt .vel.y! 
	' announce_bs lt .events!
	120 lt .timer! 
	
;
	
	
	
} 
	

