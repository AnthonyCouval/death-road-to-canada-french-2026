: car_parts_railyard
	
		car-armor 1 + to car-armor
		0 3 "Free car armor!" popup_dis 1 popup_mode!
		
; 

: crate_loot_railyard 1 10 rnd case 
	1 of 1 2 rnd LOOT_FOOD spawnloot endof 
	2 of 5 10 rnd LOOT_GAS spawnloot endof 
	3 of 10 20 rnd LOOT_RIFLE_SHELL spawnloot endof 
	4 of 10 20 rnd LOOT_BULLET spawnloot endof 
	5 of 10 20 rnd LOOT_SHOTGUN_SHELL spawnloot endof 
	6 of meleeweapons endof 
	7 of blowtorch endof
	8 of chainsaw endof 
	9 of commonranged endof 
	10 of vehicle.which@ 0 = not if car_parts_railyard 5 10 rnd LOOT_GAS spawnloot else healspray 3 lt .item.charges! then endof 
	endcase
; 
	

: open_crate args( me ) 
	<- me .spriteid@ 1 + <- me .spriteid! 
; 

: check_crowbar_then_loot args( me ) 
	WEAPON_CROWBAR team-has-weapon? if
		<- me open_crate 
		clear-cyoa
		sfx{ goodfx } 
		crate_loot_railyard <- me .pos -32 0 xyadd lt .pos! 
	else 
		"I'd need a crowbar to open this." <- me .interact_id@ #thing .yellmsg 
	then 
; 

