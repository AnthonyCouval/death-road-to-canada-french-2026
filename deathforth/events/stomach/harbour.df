constant maplayout

: plotmap
	0 -1 maplayout xyplot: pt
;





: keep-colour 
	
	0 weather!
		
	timer_retrigger
		
;

: site-setup

	' plotpave to ft

	plotmap
	
	11 o'clock
	\ 1 no_time!
	
	10 %zombs 
		
	95 %chars-up
	95 %mv-up 
	
	map{ 1 water_colour_r! 1 water_colour_b! 1 water_colour_g! }
	
	1 "skel" %some-anyobj
	
	wave_spawner
	
	"Zombonita Beach.mp3" $music-load
	
;

region: specialcamp-3
	w: maplayout layoutw
	h: maplayout layouth
	\ on-foot no-rest 
	post-script: site-setup 

} }
