

uses paul/region-layout.df
uses paul/region-road-layout.df


"events/inner/baseapts.df" $load
"../deathforth/events/stomach/harbour.txt" $load-rooms

locdef{

: bathroomplz 
	50 %chance if 
		n random-edge-door "bathroom" only-with-door
	else 
		n random-edge-door "bedroom" only-with-door
	then 
; 

: lead2nexthall 
	e random-edge-door "hall2" only-with-door 
; 

: lead2stairwell  
	n random-edge-door "stairwell" only-with-door 
; 

: lead2landing 
	n random-edge-door "landing" only-with-door 
; 

: gsx
		e edge-inc e random-inset-door "minorroom"  only-with-door
		w edge-inc w random-inset-door "minorroom"  only-with-door
; 

: gsm

		n edge-inc n random-inset-door "minorroom"  only-with-door
		s edge-inc s random-inset-door "minorroom"  only-with-door
; 

: hmcert 
	n edge-inc n random-inset-door "minorroom"  only-with-door
	s edge-inc n random-inset-door "masterroom"  only-with-door
; 

: melwep 
	meleeweapons
; 
\ script char limit again... 

: set-theme-harbourmaster
	0x 13 12 - loc-ftheme!
	
	wall-wood
	0 4 rnd loc-dtheme!
	0 5 rnd to theme-num 
;

location: harbourmaster
		max-rooms: 17
		entry-tags: hall1
		pre-script: set-theme-harbourmaster
		script:  set-theme-harbourmaster
		post-script: nad 5 %zombs 
			
		room-choice: bathroom
			room-weight: 1
			room-count: 1
			room-script:
			filter-only

		room-choice: landing
			room-weight: 1
			room-count: 1
			room-script:
			room-post-script: lead2nexthall
			
		room-choice: masterroom
			room-weight: 1
			room-count: 1
			room-script:
			room-post-script: lead2nexthall	
			
		room-choice: minorroom 
			room-weight: 1 
			room-count: 12 
			room-script: nad 
			room-post-script: melwep melwep
			filter-only

		room-choice: stairwell
			room-weight: 1
			room-count: 1
			room-script:
			room-post-script: lead2landing
			
		room-choice: hall2
			room-weight: 1
			room-count: 1
			room-script:
			room-post-script: bathroomplz gsm gsm hmcert
			filter-only		

		room-choice: hall1 
			room-weight: 1
			room-count: 1
			room-script:
			room-post-script: lead2stairwell gsx gsx gsx
				

}

\ hazel rules for room generation 
\ 1. dont make a room that is only stairs. always include normal tile space. 
\ 2. be careful when making rooms that are not square or rectangles. 
\ 3. try to avoid putting random walls as pillars. not impossible, just makes stuff harder. 
\ 4. try to make use of forceful scripting as much as possible 
\ 5. always inspect the output of the room editor, as even spaces or TABs can make rooms not gen 
\ 6. nad = "no auto door", ndx = "no exit door" 

map{ regiondef{

0 value harbkey

: wave-events args( me eventid )
	<- eventid THING_EVENT_TIMER = if 
	
	<- me .scale.y@ 0.4 < if 
		<- me silentkillit
	then;
	
		-1.4 <- me .vel.y!
			particle{ new <- me .pos 0 360 frnd anglexy 2 -30 frnd xymul xyadd pos!
				15 fade_in!
				5 fade_out!
				30 ticks!
				-0.1 0.1 frnd vel.y!
				-0.1 0.1 frnd vel.x!
		//		waterclr 3 for 0.5 * 0.5 + rot next rgb!
		//		waterclr rgb!

				0.75 scale!
				1.01 grow!
				particles_base_id 0x 5d + spriteid!
				1 layer!
			}
			
		8 <- me .timer!
		
		<- me .scale.x@ -0.025 + <- me .scale.x!
		<- me .scale.y@ -0.025 + <- me .scale.y!
		
	then
	
	<- eventid THING_EVENT_OVERLAP = if
		<- me .overlapper .mass@ 1000001 = if then;
			<- me .scale.x@ -2 * <- me .overlapper .vel.y!
	
	then
	
;


: water_wave 
	spawn
	special_objects64_base_id 20 + lt .spriteid!
	1 lt .layer!
	1 lt .nocollide!
	1 lt .walkover! 
	1 1.25 rnd lt .scale.x!
	1 1.25 rnd lt .scale.y!
	0.8 lt .clr.a!
	' wave-events lt .events!
	8 lt .timer!
	40000000 lt .mass!
	16 lt .wallbox.x! 
	16 lt .wallbox.y! 
;

0 value playerbound1
0 value playerbound2

: wave_spawning args( me eventid )
	<- eventid THING_EVENT_TIMER = if 
	
	pchar .health@ 0 > if 
	
	player .pos.x@ -210 + 0 1200 clamp to playerbound1
	player .pos.x@ 210 + 0 1200 clamp to playerbound2
	
			30 <- me .timer!
			
				water_wave 
				map{ pixelh } lt .pos.y!
				playerbound1 playerbound2 rnd lt .pos.x!
				
			then
			
	then
;

: wave_spawner
	spawn
	400000 lt .mass!
	1 lt .invisible!
	1 lt .walkover!
	6 lt .timer!
	' wave_spawning lt .events!
;
	

: sycatile tile@
	dup LAYER_FLOOR inside_tiles_walls_id 3 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!
	
	dup LAYER_FLOORTOP inside_tiles_walltops_id 10 + .lspriteid!
	
	// 10 for regular walltop
	// 9 for right-hand up turn
	// 8 for right-hand end
	// 7 for left-facing-junction
	// 6 for downfacing left turn
	// 5 for straight up
	// 4 for upward end
	// 3 for upward left turn
	// 2 for lefthand end
	// 1 for downward end
	// 0 for tiny square
	
	dup LAYER_FLOORTOP 0 -16 .tile_layer.off!
	dup LAYER_FLOORTOP 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatileblock tile@

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatilewall tile@
	dup LAYER_FLOOR inside_tiles_walls_id 240 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatilewalltop tile@
	dup LAYER_FLOOR inside_tiles_walls_id 12 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	drop
;

