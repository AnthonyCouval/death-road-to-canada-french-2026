\ "this doesnt look like the mooring posts ive seen" well it looks like one IVE seen 


: sycatiledeepsea tile@
	dup LAYER_FLOOR street_tiles_base_id 522 526 rnd + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!

	1 over .wet!
	TILE_BLOCK_FLOOR over .id!

	drop
;

: streetlight-flicker args( me eventid )	
	<- eventid THING_EVENT_TIMER = if
			1 <- me .timer!		
			
		gameticks 200 360 frnd % if			
			1 1 0.4 150 <- me .pos d-light
				else
				30 <- me .timer!
				then
			then
	
;

: streetlamp spawn special_objects96_base_id 4 + lt .spriteid! 4000 lt .mass! 40 lt .hitpoints! 20 lt .timer! ' streetlight-flicker lt .events! -1 lt .layer! 54 lt .rad.y! 6 lt .rad.x! 1 lt .walkover! -4 lt .vel.y! -1 lt .vel.x! 1 lt .nocollide! 3 lt .tileflags! 0.12 lt .vel.x!  ;
: streetlomp spawn special_objects96_base_id 4 + lt .spriteid! 4000 lt .mass! 40 lt .hitpoints! 20 lt .timer! -1 lt .layer! 64 lt .rad.y! 6 lt .rad.x! 1 lt .no_hit! 54 lt .rad.y! 6 lt .rad.x! 1 lt .walkover! 3 lt .tileflags! 0.12 lt .vel.x! ;

: bldg2 tanchor!
	"harbourmaster" $picklocid addloc 
	WHITE "HARBOUR" .. RED .. BLINKY .. "MASTER" ..   sign-text!
		0 0 0 sign-bg!
		1 1 1 sign-border!
		1 1 1 sign-fg!
		1 sign-glow!
	prefab{ mrand 12 0 building }
;

0 value totalcollected


: collectthis
	' totalcollected ++
	totalcollected interactee .report
	clear-cyoa
	
	totalcollected 8 = if
	0 2 RAINBOW "YIPPEE!" .. popup_dis 1 popup_mode!
	
	niceweapons
	player .pos lt .pos!
	
	then
;

: roadsign1
	spawn special_objects32_base_id 194 + lt .spriteid!
	bbox
	20000 lt .mass!
	100 lt .hitpoints!
	1 lt .unseen!
	-3.2 lt .vel.y!
;

: roadsign2
	spawn special_objects32_base_id 195 + lt .spriteid!
	bbox
	20000 lt .mass!
	100 lt .hitpoints!
	1 lt .unseen!
	-3.2 lt .vel.y!
;

cyoa{ 


cyoa: recruit-doakes-yes

	($ rname .. " mumbles something about " "lizards" bbold .. " and " .. "ice" bbold .. ". A birthday plan turned awry?" .. $) cyoa-text! 
	
	team-full? if
		($ "The group is full.
		Who would you like to replace to make room for " .. rname .. "?" $) +crtext
		recruit-replace?
	then;
	ricon
	($ Thegroup .. " accepts " .. rname .. " to the team!" $) +crtext 2 300 tone
		recruited
	recruitee .showitall 
;


\ SURPRISE MFER 
\ dexter easter egg because of that one harbour scene 
cyoa: doakes_surprise 
	"DEXTEROUS MORNING" cyoa-title! 
	interactee .character@ to recruitee
	($ "SURPRISE, DINKFATHER! I wanted to surprise you. For your birthday. What do you mean it's not your birthday?" bbold  $) cyoa-text! 
	($ "Since this guy went to all that trouble to surprise you for your alleged birthday, it might be a nice gesture to recruit him." $) +crtext
	choice( "Cautiously recruit" )choice: recruit-doakes-yes
	choice( "Leave him behind" )choice 
; 	

} 

: doakes_easter_egg
	new-npc 
	player .pos lt .pos! 
	"Sgt. Oates" lt .character@ .name! 
	"really just wanted to surprise you, then the apocalypse happened." lt .character@ .job! 
	0 lt .character@ .female! 
	2 lt .character@ .bodytype!
	27 lt .character@ .headtype!
	39 lt .character@ .torsotype!
	50 lt .character@ .legstype!
	6 lt .character@ .facetype!
	0 lt .character@ .hairtype!
	0 lt .character@ .hattype!
	0 lt .character@ .glassestype!
	15 lt .character@ .skincolour!
	9 lt .character@ .haircolour!
	WEAPON_THE1911 lt .character@ .weapona! 
	20 LOOT_BULLET lt .character@ .lootamt!
	3 lt .character@ .shooting! 
	0 lt .character@ .composure! 
	cyoa{ ' doakes_surprise } lt .cyoa! 
; 
	

: crate_loot_harbour 1 10 rnd case 
	1 of 2 LOOT_FOOD spawnloot endof 
	2 of 2 3 rnd LOOT_MEDICAL spawnloot endof 
	3 of 20 25 rnd LOOT_RIFLE_SHELL spawnloot endof 
	4 of 20 25 rnd LOOT_BULLET spawnloot endof 
	5 of 20 25 rnd LOOT_SHOTGUN_SHELL spawnloot endof 
	6 of 66 %chance if pistol else dolt then endof 
	7 of 66 %chance if hunting else fn_fal then endof
	8 of 66 %chance if shotgun else chromeshotgun then endof 
	9 of 66 %chance if the1911 else mp5 then endof 
	10 of healspray 2 3 rnd lt .item.charges! endof 
	endcase
	
; 
	
: open_crate args( me ) 
	<- me .spriteid@ 1 + <- me .spriteid! 
; 

: check_key_then_loot args( me ) 
	harbkey 1 = if 
		<- me open_crate 
		clear-cyoa
		sfx{ goodfx } 
		crate_loot_harbour <- me .pos -32 0 xyadd lt .pos!
		
			1 %chance if 
				doakes_easter_egg sfx{ goodfx } 
			then 
		
	else 
		"I'd need the masterkey to open it." <- me .interact_id@ #thing .yellmsg 
	then 
; 

\ these all correspond to cars i think are actually worth having. 
: car_loot_harbour 1 13 rnd case 
	1 of 1 endof 
	2 of 4 endof 
	3 of 5 endof 
	4 of 6 endof 
	5 of 7 endof 
	6 of 8 endof 
	7 of 9 endof
	8 of 10 endof 
	9 of 11 endof 
	10 of 12 endof 
	11 of 25 endof 
	12 of 26 endof 
	13 of 27 endof 
	endcase
; 
	

: check_key_then_car args( me ) 
	harbkey 1 = if 
		<- me open_crate 
		clear-cyoa
		sfx{ goodfx } 
		car_loot_harbour spawncar <- me .pos 81 0 xyadd lt .pos! 2 lt .vel.x! -1 lt .vel.y! 
		lt .hitpoints@ 1.5 * lt .hitpoints! 
		lt .engine@ 1.5 * lt .engine! 
		\ Harbour vehicles are sturdier, because they have been preserved in their containers. 
	else 
		"I'd need the masterkey to open it." <- me .interact_id@ #thing .yellmsg 
	then 
; 

: rail_box

	spawn 
	special_objects96_base_id 6 + lt .spriteid! 
	bbox 
	15 lt .mass!
	80 lt .hitpoints!
	42 lt .rad.x! 
	19 lt .rad.y! 
	64 lt .wallbox.y! 
	0 lt .friction! 
	\ 4 lt .rad.x! 
	1 lt .flammability! 
	' check_key_then_loot lt .cyoa! 
; 

: rail_box_car 

	spawn 
	special_objects96_base_id 6 + lt .spriteid! 
	bbox 
	15 lt .mass!
	80 lt .hitpoints!
	42 lt .rad.x! 
	19 lt .rad.y! 
	64 lt .wallbox.y! 
	0 lt .friction! 
	\ 4 lt .rad.x! 
	1 lt .flammability! 
	' check_key_then_car lt .cyoa! 
	1 lt .flip!
; 

: rail_box_rusty

	spawn 
	special_objects96_base_id 8 + lt .spriteid! 
	bbox 
	15 lt .mass!
	80 lt .hitpoints!
	42 lt .rad.x! 
	19 lt .rad.y! 
	64 lt .wallbox.y! 
	0 lt .friction! 
	\ 4 lt .rad.x! 
	1 lt .flammability! 
	\ ' check_crowbar_then_loot lt .cyoa! 
; 

: rail_box_chooser 
	25 %chance if 
		rail_box
	else 
		rail_box_rusty
	then 
; 

0 value obj_in_question 

: %some-anyobj ( num, obj_word_name ) 

	to obj_in_question
	
	w h + 4 / * 
		for
			obj_in_question evaluate scatter
		next 

;

\ example usage:
\ 1 "tire" %some-anyobj 

map{ roomgen{ 

: diningset
	table
	75 %chance if chair -1 movey drift then
	75 %chance if chair 1 movey drift then
	50 %chance if chair -1 movex drift then
	50 %chance if chair 1 movex drift then
;

: obs spawn special_objects32_base_id 1 + lt .spriteid! 50 lt .hitpoints! bbox 50 lt .mass! ;

\ 0 value harbkey

: keys_harb args( me ) 
	regiondef{ 1 to harbkey }  
	"It's the harbour master key." interactee .yellmsg 
	<- me silentkillit
; 

: harbourkey spawn special_objects16_base_id 24 + spriteid! 50 lt .hitpoints! bbox 1 lt .mass! 1 lt .walkover! ' keys_harb lt .cyoa! masterkey ; 

\ todo : doakes funny easter egg @ 1% 
\ harbour key system
\ car spawning system
\ not krilling myself 

: harbourweapons 1 5 rnd case 
	1 of clawhammer endof 
	2 of lowwhip endof 
	3 of metal endof 
	4 of blackhammer endof 
	5 of meleeweapons endof 
	endcase
; 

: fishstuff 
	fishing skel 
	33 %chance if 
	1 LOOT_FOOD spawnloot
	then 
; 

: ledger spawn special_objects16_base_id 69 + spriteid! 2 health! bbox 3 mass! ;

: execdesk
	spawn special_objects32_base_id 0x 69 + lt .spriteid!
	bbox as-wood
;

: execdeskup
	spawn special_objects32_base_id 0x 5d + lt .spriteid!
	bbox as-wood
;

: execdesk
	spawn special_objects32_base_id 0x 69 + lt .spriteid!
	bbox as-wood
;

: execdeskup
	spawn special_objects32_base_id 0x 5d + lt .spriteid!
	bbox as-wood
;

: filecabinet_bank
	66 %chance if 
		filecabinet
	else
		ledger 0 360 rnd lt .angle!
	then

	10 %chance if 
		skel 
	then 
; 


} }
	
0 value gbx
0 value gby
0 value gbx2
0 value gby2

' plotpave >defer ft

: pt
	xyp.xy ft // Plot the current floor by default

	 xyp.i char b = if xyp.xy sycatilestreet3 then;
	 xyp.i char c = if xyp.xy sycatilestreet2 then;
	 xyp.i char d = if xyp.xy sycatilestreet then;
	 xyp.i char e = if xyp.xy sycatilestreet1 then;
	 xyp.i char g = if xyp.xy sycatilestreet4 then;
	 xyp.i char h = if xyp.xy sycatilestreet5 then;
	 xyp.i char j = if xyp.xy sycatilestreet6 then;
	 xyp.i char p = if xyp.xy sycatilestreet7 then;
	 xyp.i char i = if xyp.xy sycatilestreet8 then;
	 xyp.i char o = if xyp.xy sycatilestreet9 then;
	 xyp.i char O = if xyp.xy sycatilewall then;
	 xyp.i char E = if xyp.xy sycatilewalltop then;
	 xyp.i char D = if xyp.xy sycatilewalltopend then;
	 
	 xyp.i char C = if xyp.xy streetlamp lt-here then;
	\  xyp.i char 5 = if xyp.xy streetlamp lt-here xyp.xy sycatilestreetblock then;
	 xyp.i char 8 = if xyp.xy sycatilestreetblock then;	 
	
	xyp.i char H = if xyp.xy sycatile_harbwall then;
	xyp.i char A = if xyp.xy sycatile_harbconc then;
	xyp.i char B = if xyp.xy sycatile_harbwalldip then;
	xyp.i char G = if xyp.xy sycatile_harbwalledge then;
	xyp.i char L = if xyp.xy sycatile_harbwall_nofalloff_L then;
	xyp.i char R = if xyp.xy sycatile_harbwall_nofalloff_R then;
	
	xyp.i char M = if xyp.xy sycatile_harbwall_nofalloff_L xyp.xy sycatile_harb_moorpost then;
	xyp.i char N = if xyp.xy sycatile_harbwall_nofalloff_R xyp.xy sycatile_harb_moorpost then;
	xyp.i char s = if xyp.xy sycatiledeepsea then;
	
	xyp.i char S = if xyp.xy sycatilesea then;
	xyp.i char ! = if xyp.xy sycatileseawalledge then;
	xyp.i char | = if xyp.xy sycatileseawallmain then;
	xyp.i char - = if xyp.xy sycatileseawallbot then;
	xyp.i char > = if xyp.xy sycatileseawallstairs then;
	xyp.i char q = if xyp.xy sycatileseawallbotdanger then;
	xyp.i char I = if xyp.xy sycatileseawallpier then;
	
	// decor
	xyp.i char F = if xyp.xy fishstuff lt-here xyp.xy sycatile_harbconc then;
	xyp.i char 1 = if xyp.xy roadsign2 lt-here xyp.xy sycatile_harbconc then;
	xyp.i char 2 = if xyp.xy roadsign1 lt-here xyp.xy sycatilestreet then;
	
	xyp.i char 5 = if xyp.xy rail_box_chooser lt-here xyp.xy sycatile_harbconc then;
	xyp.i char 6 = if xyp.xy rail_box_car lt-here xyp.xy sycatile_harbconc then;
	xyp.i char 7 = if 3 for xyp.xy indcrate lt-here -1 1 frnd -1 1 frnd lt .vel! next 20 %chance if harbourweapons lt-here then xyp.xy sycatile_harbconc then;
	
	xyp.i char @ = if xyp.xy bldg2 xyp.xy sycatile_harbconc then;
	
;

