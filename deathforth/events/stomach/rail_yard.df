;

: sycatile_railmain tile@ 
	dup LAYER_FLOORTOP street_tiles_base_id 549 + .lspriteid!
	dup LAYER_FLOORTOP 0 0 .tile_layer.off!
	dup LAYER_FLOORTOP 0 .tile_layer.flipx!
	

	drop
;

: sycatile_railjoin tile@ 
	dup LAYER_FLOORTOP street_tiles_base_id 550 + .lspriteid!
	dup LAYER_FLOORTOP 0 0 .tile_layer.off!
	dup LAYER_FLOORTOP 0 .tile_layer.flipx!
	

	drop
;

: sycatile_railbed tile@ 
	dup LAYER_FLOORTOP street_tiles_base_id 551 + .lspriteid!
	dup LAYER_FLOORTOP 0 0 .tile_layer.off!
	dup LAYER_FLOORTOP 0 .tile_layer.flipx!
	
	drop
;

: cemfence args( spr )
	xyp.xy tile@ LAYER_FINAL street_tiles_base_id 0x 145 + <- spr + .lspriteid!
	 xyp.xy blocked
	xyp.xy 1- tile@ LAYER_FINAL street_tiles_base_id 0x 135 + <- spr + .lspriteid!
	\ xyp.xy 1- blocked
;


: fencea 0 cemfence ;
: fenceA 1 cemfence ;

: fenceb 3 cemfence ;
: fenceB 2 cemfence ;

: sycatile_dirtstairs_up tile@ 
	dup LAYER_WALLSIDE street_tiles_base_id 552 + .lspriteid!
	dup LAYER_WALLSIDE 0 0 .tile_layer.off!
	dup LAYER_WALLSIDE 0 .tile_layer.flipx!
	
	drop
;

: sycatile_GTFO tile@

	TILE_BLOCK over .id!

;


: provide_light args( me eventid ) 
	<- eventid THING_EVENT_TIMER = if 
		1 1 1 45 <- me .pos d-light
		1 <- me .timer!
	then 
; 

: rail_overhang 


	spawn 
	special_objects64_base_id 22 + lt .spriteid! 
	1000 lt .mass!
	-3 lt .layer! 
	1 lt .nocollide!
	1 lt .no_hit!
	1 lt .timer! 
	' provide_light lt .events! 
	5 lt .flammability! 
 
; 

: rail_signal


	spawn 
	special_objects64_base_id 23 + lt .spriteid! 
	9 lt .mass!
	35 lt .hitpoints!
	bbox 
	0 lt .friction! 
	4 lt .rad.x! 
	4 lt .rad.y! 
	5 lt .flammability! 
; 

: car_parts_railyard
	
		car-armor 1 + to car-armor
		0 3 "Free car armor!" popup_dis 1 popup_mode!
		\ Good in theory. Bit silly in reality.
		\ If you were very unlucky you might roll this 10 times in a row.
		\ Suddenly your starter car eats 20 MPG. Lol
; 


: aturfeet
	player FORTH_NONE = if then; 
	player .pos lt .pos!
; 




: commonranged_ry \ mimics generic commonranged. will suck if that ever changes 
	1 2 rnd case
1 of 
95 %chance if 
	10 30 rnd sbullet aturfeet pistol 
else 
	50 %chance if
		20 50 rnd sbullet aturfeet uzi 
	else 
		20 40 rnd srifle aturfeet ak47 
	then 
then endof
2 of 
	50 %chance if 10 20 rnd srifle aturfeet huntcowboy else 66 %chance if 6 15 rnd sshot aturfeet shotgun else 6 15 rnd sshot aturfeet flet then then
endof endcase ;

: niceranged_ry
1 2 rnd case
1 of commonranged_ry endof
2 of 20 %chance if 8 30 rnd srifle aturfeet ak47 else 50 %chance if 17 40 rnd sbullet aturfeet uzi else 75 %chance if 17 40 rnd sbullet aturfeet fosbury else 17 40 rnd sbullet aturfeet blackmamba then then then endof
endcase ;

: exoticweapons_ry 75 %chance if 50 %chance if 20 50 rnd sgas aturfeet chainsaw else woodclub then else 50 %chance if blackmamba else fosbury then then ;

: niceweapons_ry 30 %chance if meleeweapons else 30 %chance if commonranged_ry else 90 %chance if niceranged_ry else exoticweapons_ry then then then ;

: crate_loot_railyard 1 10 rnd case 
	1 of 1 2 rnd LOOT_FOOD spawnloot endof 
	2 of 5 10 rnd LOOT_GAS spawnloot endof 
	3 of 10 20 rnd LOOT_RIFLE_SHELL spawnloot endof 
	4 of 10 20 rnd LOOT_BULLET spawnloot endof 
	5 of 10 20 rnd LOOT_SHOTGUN_SHELL spawnloot endof 
	6 of meleeweapons endof 
	7 of blowtorch lt .item.charges@ 0.33 0.4 frnd * lt .item.charges! endof
	8 of niceweapons_ry endof 
	9 of commonranged_ry endof 
	10 of healspray 1 lt .item.charges! endof 
	endcase
; 
	\ IM LOSING MY MINDDDDDDDDD >:((((((((((( 
	\ ARGHHHHHHHHHHHHHHHHHHHHHHHh
	
: open_crate args( me ) 
	<- me .spriteid@ 1 + <- me .spriteid! 
; 

: check_crowbar_then_loot args( me ) 
	team-has-breakin? if
		<- me open_crate 
		clear-cyoa
		sfx{ goodfx } 
		crate_loot_railyard <- me .pos -32 0 xyadd lt .pos!
	else 
		"I'd need something heavy to open it." <- me .interact_id@ #thing .yellmsg 
	then 
; 

: rail_box

	spawn 
	special_objects96_base_id 6 + lt .spriteid! 
	bbox 
	15 lt .mass!
	80 lt .hitpoints!
	42 lt .rad.x! 
	19 lt .rad.y! 
	64 lt .wallbox.y! 
	0 lt .friction! 
	\ 4 lt .rad.x! 
	1 lt .flammability! 
	' check_crowbar_then_loot lt .cyoa! 
; 

: rail_box_rusty

	spawn 
	special_objects96_base_id 8 + lt .spriteid! 
	bbox 
	15 lt .mass!
	80 lt .hitpoints!
	42 lt .rad.x! 
	19 lt .rad.y! 
	64 lt .wallbox.y! 
	0 lt .friction! 
	\ 4 lt .rad.x! 
	1 lt .flammability! 
	\ ' check_crowbar_then_loot lt .cyoa! 
; 

: rail_bogie
	
	\ was originally going to have these slide along the tracks,
	\ then i looked it up; these things weigh several tons. 

	spawn 
	special_objects96_base_id 9 + lt .spriteid! 
	5000 lt .mass!
	bbox 
	400 lt .hitpoints!
	28 lt .rad.x! 
	13 lt .rad.y! 
	48 lt .wallbox.y! 
	0 lt .friction! 
	\ 4 lt .rad.x! 
	1 lt .flammability! 
	\ ' check_crowbar_then_loot lt .cyoa! 
; 


0 value obj_in_question 
\ probably belongs in globals or things someday 

: %some-anyobj ( num, obj_word_name ) 

	to obj_in_question
	
	w h + 4 / * 
		for
			obj_in_question evaluate scatter
		next 

;

\ example usage:
\ 1 "tire" %some-anyobj 


map{ roomgen{ 

: diningset
	table
	75 %chance if chair -1 movey drift then
	75 %chance if chair 1 movey drift then
	50 %chance if chair -1 movex drift then
	50 %chance if chair 1 movex drift then
;


} }
	
0 value gbx
0 value gby
0 value gbx2
0 value gby2

' plotpave >defer ft

: pt
	xyp.xy ft // Plot the current floor by default

	 xyp.i char b = if xyp.xy sycatilestreet3 then;
	 xyp.i char c = if xyp.xy sycatilestreet2 then;
	 xyp.i char d = if xyp.xy sycatilestreet then;
	 xyp.i char e = if xyp.xy sycatilestreet1 then;
	 xyp.i char g = if xyp.xy sycatilestreet4 then;
	 xyp.i char h = if xyp.xy sycatilestreet5 then;
	 xyp.i char j = if xyp.xy sycatilestreet6 then;
	 xyp.i char p = if xyp.xy sycatilestreet7 then;
	 xyp.i char i = if xyp.xy sycatilestreet8 then;
	 xyp.i char o = if xyp.xy sycatilestreet9 then;
	 xyp.i char E = if xyp.xy sycatilewalltop then;
	 xyp.i char D = if xyp.xy sycatilewalltopend then;
	\ xyp.i char T = if xyp.xy trashblock xyp.xy sycatilestreet1 then;
	\  xyp.i char t = if xyp.xy trashblock xyp.xy sycatilestreet then;
	 
	 xyp.i char C = if xyp.xy streetlamp lt-here then;
	 xyp.i char 5 = if xyp.xy streetlamp lt-here xyp.xy sycatilestreetblock then;
	 xyp.i char 8 = if xyp.xy sycatilestreetblock then;	 
	 xyp.i char J = if xyp.xy oldpine
	 
	 0.5 1 frnd lt .clr.r!
	 0.5 1 frnd lt .clr.b!
	 0.5 1 frnd lt .clr.g!
	
	 25 %chance if
	 0.75 1.4 frnd lt .scale.x!
	 0.74 1.5 frnd lt .scale.y!
	 then 
	 
	 lt-here xyp.xy sycatilestreet then;
	 
	 
 
	\ xyp.i char @ = if xyp.xy bldg2 xyp.xy sycatilestreet then;
	 xyp.i char @ = if xyp.xy skel 50 %chance if 50 %chance if shovel else tire then then lt-here then;
	
	xyp.i char H = if xyp.xy sycatilegrassset map{ pine } lt-here  then;

	xyp.i char I = if xyp.xy fencea xyp.xy sycatilestreet then;
	
	xyp.i char G = if xyp.xy sycatile_dirtstairs_up then;
	
	xyp.i char t = if xyp.xy sycatileseawallmain_layerfix then;
	
	xyp.i char R = if xyp.xy sycatile_railmain then;
	xyp.i char T = if xyp.xy sycatile_railjoin then;
	xyp.i char B = if xyp.xy sycatile_railbed then;
	
	xyp.i char Z = if xyp.xy tanchor! 5 zombs-clump then;
	
	xyp.i char ! = if xyp.xy sycatileseawalledge then;
	xyp.i char - = if xyp.xy sycatileseawallbot then;
	xyp.i char Q = if xyp.xy sycatile_railwallmain then;
	
	// decor
	xyp.i char F = if xyp.xy sycatile_GTFO then;
	xyp.i char 9 = if xyp.xy sycatilestreet then;
	xyp.i char 1 = if xyp.xy sycatilegrassseasection then;
	xyp.i char 2 = if xyp.xy sycatilecliffedge then;
	xyp.i char 3 = if xyp.xy sycatilecliffedgeflip then;
	xyp.i char 4 = if xyp.xy sycatileseawallangleleft then;
	xyp.i char 6 = if xyp.xy sycatileseawallangleright then;
	
	xyp.i char 7 = if carwreck lootable car-loot lt-here then;
	
	xyp.i char O = if xyp.xy 5 for rail_overhang lt-here lt .pos 0 i 1 - 64 * 16 - xyadd lt .pos! next then;
	 
	xyp.i char S = if xyp.xy rail_signal lt-here lt .pos 0 26 xyadd lt .pos! then;
	
	xyp.i char r = if xyp.xy 66 %chance if rail_box else rail_box_rusty then lt-here lt .pos 0 26 xyadd lt .pos! then;
	
	xyp.i char > = if xyp.xy rail_bogie lt-here lt .pos 0 -6 xyadd lt .pos!  then;
	
	
	
;

