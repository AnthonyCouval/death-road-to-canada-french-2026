constant maplayout

: plotmap
	0 -1 maplayout xyplot: pt
;



: site-setup

	' plotgravel to ft

	plotmap

	5diff 0.66 * %zombs 
	
	7 crowbar .scatter \ needed to open containers
	5 pickaxe .scatter 
	
	99 %chars-up
	\ 75 %mv-up

	0.25 "tire" %some-anyobj
	1 "skel" %some-anyobj
	1 "indcrate" %some-anyobj
	
	map{ 1 water_colour_r! 1 water_colour_b! 1 water_colour_g! }

	
	
;


region: specialcamp-3
	w: maplayout layoutw
	h: maplayout layouth
	on-foot no-rest
	post-script: site-setup 
	script: timeofday o'clock

} }
