: plotmap
	tstart 0 -1 maplayout xyplot: pt "PLOTTING TIME " type tend
;

: plotmap_illu
	0 -1 grass_illusion xyplot: pt
;

: plotmap_illu_alt
	0 -1 grass_illusionalt xyplot: pt
;

\ todo: investigate zombs and 3 anim state

: go_backwards args( me )

	<- me .pos.y@ 65 < <- me .pos.y@ 170 > or if \ if you are not within the train boundaries,
		<- me .typeid@ THING_PROJECTILE = not if
				<- me .layer@ 20 = not if
				<- me .pos -8 0 xyadd <- me .pos!
				\ 59 <- me .anim.weapon_counter!
				\ 3 <- me .anim.state!
				\ 0 <- me .vel.y!
				\ 20 <- me .stun!
				\ -0.1 <- me .pos.z!
				\ 0 <- me .gravity!

				<- me .charid@ 0 = not if
					0 <- me .character@ .health!
				then \ No cheesing the train!
				\ Not like you'd survive bailing a train irl
			then
		then
	then

	<- me .pos.x@ 2 < if
		<- me .typeid@ THING_ZOMBIE = if
			map{ w } 16 * <- me .pos.x!
		then
	then
	\ reset at map bounds

	<- me .pos.x@ <- me .rad.x@ - 2 < <- me .pos.x@ <- me .wallbox.x@ - 2 < or if
		<- me .typeid@ THING_ZOMBIE = not if
			<- me silentkillit
		then
	then

	<- me .pos.y@ 155 > if \ do not cling to train walls or edge
		<- me .pos.y@ 173 < if
			<- me .typeid@ THING_ZOMBIE = if
				0 <- me .hitpoints!
	then then then
;

: %chars-right 0 100 clamp 100 / map{ pixelw * pixelw } swap - args( posx )
	team-stack begin depths while
		pops .cur_thingid@ dup if
			<- posx over #thing .pos.x! drop
		else drop then
	repeat
	drop

	player .pos.x@ camera.pos.x!
;

0 value TRACKS_COUNTER

: process_move_illu

	TIMESTOP_ACTIVE 0 = if \ Coz I just know basement is gonna try this xDDD
		TRACKS_COUNTER 1 + 0 5 clamp to TRACKS_COUNTER

		TRACKS_COUNTER 3 < if
			regiondef{ plotmap_illu }


		else
			regiondef{ plotmap_illu_alt }

		then

		TRACKS_COUNTER 5 = if
			0 to TRACKS_COUNTER
		then

		' go_backwards foreach-active-thing
	then

	timer_retrigger
;

: dofall_train

	\ # Alligators on a train... #

	' xyzombceil 5sdiff 1.2 * 5 15 rnd zwave-ex

	timer_retrigger
;

: process_siege_text

	FLASHY "HOLDOUT!" $cat 60 view_w 0.5 * 16 msgtickxy
	1 1 camera.pos alertlcxy
	siege_minutes 5 + to siege_minutes

	timer_retrigger

;

: site-setup

	' plotgrass to ft

	plotmap

	\ 5diff %zombs

	600 ' dofall_train timer_add

	5 60 * ' process_siege_text timer_add

	180 ' train_noiser timer_add
	\ clack-clack clack-clack ...

	1 ' process_move_illu timer_add
	\ the train is totally moving guys i promise

	4 crowbar .scatter
	\ 5 pickaxe .scatter

	\ 20 for
	\ 	1 skel .scatter
	\ 	70 140 lt .pos.y!
	\ next

	51 %chars-up
	51 %chars-right

	map{ 1 water_colour_r! 1 water_colour_b! 1 water_colour_g! }

	\ mission{ siege-start }


;


region: specialcamp-3
	w: maplayout layoutw
	h: maplayout layouth
	on-foot no-rest
	post-script: site-setup
	script: timeofday o'clock

} }
