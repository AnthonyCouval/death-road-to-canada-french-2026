

\ uses paul/region-layout.df
\ uses paul/region-road-layout.df

"events/inner/baseapts.df" $load

map{ regiondef{


: sycatileblock tile@

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatilestreet tile@ // main
	dup LAYER_FLOOR street_tiles_base_id 17 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!


	drop
;

: sycatilestreetblock tile@ // main
	dup LAYER_FLOOR street_tiles_base_id 17 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	drop
;


: sycatile_GTFO tile@

	TILE_BLOCK over .id!
	drop

;


0 value obj_in_question
\ probably belongs in globals or things someday

: %some-anyobj ( num, obj_word_name )

	to obj_in_question

	w h + 4 / *
		for
			obj_in_question evaluate scatter
		next

;

\ example usage:
\ 1 "tire" %some-anyobj



\ Tiles to reconstruct walls - an "indoor" map outside
\ "Why sycamore"?
\ coz this way I can have the illusion of movement.


: sycamallvertical tile@
	dup LAYER_FLOOR inside_tiles_floors_id 160 162 rnd + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!

	dup LAYER_FLOORTOP inside_tiles_walltops_id 5 + .lspriteid!

	// 10 for regular walltop
	// 9 for right-hand up turn
	// 8 for right-hand end
	// 7 for left-facing-junction
	// 6 for downfacing left turn
	// 5 for straight up
	// 4 for upward end
	// 3 for upward left turn
	// 2 for lefthand end
	// 1 for downward end
	// 0 for tiny square

	dup LAYER_FLOORTOP 0 -16 .tile_layer.off!
	dup LAYER_FLOORTOP 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	dup LAYER_WALLSIDE 0 .lspriteid!
	drop
;

: sycamallleftcap tile@
	dup LAYER_WALLSIDE inside_tiles_walls_id 33 + .lspriteid!
	dup LAYER_FLOOR inside_tiles_floors_id 160 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_WALLSIDE 0 .tile_layer.flipx!
	dup LAYER_WALLSIDE 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!

	dup LAYER_FLOORTOP inside_tiles_walltops_id 2 + .lspriteid!

	// 10 for regular walltop
	// 9 for right-hand up turn
	// 8 for right-hand end
	// 7 for left-facing-junction
	// 6 for downfacing left turn
	// 5 for straight up
	// 4 for upward end
	// 3 for upward left turn
	// 2 for lefthand end
	// 1 for downward end
	// 0 for tiny square

	dup LAYER_FLOORTOP 0 -16 .tile_layer.off!
	dup LAYER_FLOORTOP 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!

	drop
;

