: tube_window
	spawn special_objects16_base_id 72 + spriteid! 3 lt .tileflags! 1 lt .no_hit! 1 lt .nocollide! 500 lt .hitpoints! 500 lt .mass!
;
\ district line my unbeloved

: tube_door_L
	spawn special_objects16_base_id 73 + spriteid! 3 lt .tileflags! 1 lt .no_hit! 1 lt .nocollide! 500 lt .hitpoints! 500 lt .mass!
;

: tube_door_R
	spawn special_objects16_base_id 73 + spriteid! 3 lt .tileflags! 1 lt .no_hit! 1 lt .nocollide! 500 lt .hitpoints! 500 lt .mass! 1 lt .flip!
;



: train_echonoiser

	2 for
		sfx{ thump 0.45 0.55 frnd pitch! 74 freq! i 15 * delay! }
		1 rumble
	next

;

: train_noiser

	2 for
		sfx{ thump 0.45 0.55 frnd pitch! 74 freq! i 15 * delay! }
		1 rumble
	next

	timer_retrigger

	35 ' train_echonoiser timer_add
;

: turn_trainwheels args( me eventid )

	<- eventid THING_EVENT_TIMER = if
		5 <- me .timer!
			<- me .flip@ 1 + 2 % <- me .flip!

		\ 10 %chance if
		\ 	10 <- me .smashychunks
		\ then

	then

;

: train_wheel
	spawn special_objects16_base_id 74 + spriteid! 3 lt .tileflags! 1 lt .no_hit! 1 lt .nocollide! 500 lt .hitpoints! 500 lt .mass! 0 1 rnd lt .flip!
	' turn_trainwheels lt .events! 30 lt .timer! 20 lt .layer!
;
\ layer 20...bit overkill. shouldnt matter

\ also: make train wheels spark periodically

: train_seat
	spawn special_objects16_base_id 76 + spriteid! 30 lt .hitpoints! 6 lt .mass! 0 1 rnd lt .flip! 2 lt .bolted! 3 lt .boltstr!
;

: tree_maker args( me eventid )
	<- eventid THING_EVENT_TIMER = if
			90 150 rnd <- me .timer!

			\ 1 "HAHA!" <- me .reportdurnow
			\ sfx{ fm }

			map{ tree }
			camera.pos.x@ view_w 0.66 * + lt .pos.x!
			<- me .pos.y@ -32 32 rnd + lt .pos.y!
			map{ pixelw } 0.5 * <- me .pos.x!
		then
;

: train_fauna_generator

	spawn 3 lt .tileflags! 1 lt .walkover! 100 lt .hitpoints! 1 lt .no_hit! 0 lt .clr.a!
	1 lt .timer! ' tree_maker lt .events!

;

: stations_list 1 33 rnd case
	1 of "CROUPIONVILLE" endof
	2 of "TROCARDSVILLE" endof
	3 of "TONYVILLE-DES-SANS-LE-SOUS" endof
	4 of "CHEZ TA MERE" endof
	5 of "TOCARDS-SUR-MER" endof
	6 of "GARE DES FESSES" endof
	7 of "TOCARDS CENTRAL" endof
	8 of "FESSES-SUR-MER" endof
	9 of "USINE A TOCARDS" endof
	10 of "TOCARDSVILLE" endof
	11 of "TOCARDSTOWN" endof
	12 of "VILLE DES TOCARDS" endof
	13 of "VILLE DES DINKS" endof
	14 of "VILLE DES FESSES" endof
	15 of "FORTNITE" endof
	16 of "AU BORD DU GOUFFRE" endof
	17 of "JUSTE DERRIERE NOUS" endof
	18 of "DINKSICO" endof
	19 of "GARE DES PRETENTIEUX" endof
	20 of "XERIA CITY" endof
	21 of "LEGO CITY" endof
	22 of "CENTRALE DES TOCARDS" endof
	23 of "TOCARDTOWN" endof
	24 of "AU-DELA DE L'ARC-EN-CIEL" endof
	25 of "MILE END" endof
	26 of "ALDERAAN" endof
	27 of "L'ENFER LUI-MEME" endof
	28 of "TOCARDINGTON" endof
	29 of "GROS-FESSETON" endof
	30 of "CROTTE-VILLE" endof
	31 of "JE SAIS PAS..." endof
	32 of "CA ARRIVE, JE CROIS" endof
	33 of "QUELQUE PART ?" endof
	endcase
;


: announce_bs_2 args( me eventid )
	<- eventid THING_EVENT_TIMER = if
		440 <- me .timer!

		<- me .weapon_state.val@ 1 = if
			stations_list <- me .yellmsg
			0 <- me .weapon_state.val!
		then;

		<- me .weapon_state.val@ 0 = if
			"LA PROCHAINE GARE EST..." <- me .yellmsg
			1 <- me .weapon_state.val!
			60 <- me .timer!
		then;
	then
;

: speaker_train
	spawn special_objects32_base_id 220 + lt .spriteid!
	as-metal 30 lt .hitpoints! 200 lt .mass! 3 lt .tileflags!
	-1.7 lt .vel.y!
	0.75 dup lt .scale.x! lt .scale.y!
	' announce_bs_2 lt .events!
	60 lt .timer!
	1 lt .no_hit! 1 lt .nopush! 1 lt .nocollide!

;



0 value siege_minutes

\ loc-pick-rare
\ loc-pick-stack

0 value trainlocs_picked

road{
: get-train-ride-results

	siege_minutes 55 > if

		siege_minutes 60 - 15 / >int 1 4 clamp for
			loc-pick-rare
			depths 0= if loc-pick-rare-base shuffles to loc-pick-rare then
			pops nip
			execute
			' trainlocs_picked ++
		next

		4 trainlocs_picked - 0 4 clamp for
			loc-pick-stack
			depths 0= if loc-pick-stack-base shuffles to loc-pick-stack then
			pops nip
			execute
		next

	else

		siege_minutes 60 - 15 / >int 1 4 clamp for
			loc-pick-stack
			depths 0= if loc-pick-stack-base shuffles to loc-pick-stack then
			pops nip
			execute
		next
	then


;

}

cyoa{

: deduce_siege_rarity
	siege_minutes 55 > if
		RAINBOW "RARE " .. "(" .. siege_minutes 60 - 15 / >int 1 4 clamp .. ")" ..
	then;

	"COMMUN ou " RED "PEU COMMUN" .. ..
;

cyoa-choice: train_halt

	($ "Le train freine sans grace jusqu'a l'arret, comme une espece de chauve-souris mecanique grinçante." $) cyoa-text!
	($ "Une fois le train arrete, les survivants de l'assaut ferroviaire ont l'opportunite d'explorer de nouveaux lieux." $) +crtext

	road{ get-train-ride-results }
;

cyoa: emergencystoplever
	"Des Alligators dans un Train" cyoa-title!
	($ "Ce train roule depuis un moment. Peut-etre qu'en tirant le levier STOP, vous finirez quelque part de nouveau." $) cyoa-text! goodfx
	($ "Plus vous attendez, meilleurs seront les lieux que vous trouverez. Les lieux sont a environ 15m d'intervalle." rbold $) +crtext
	($ "Vous avez tenu : " siege_minutes .. "m" .. $) +crtext
	($ "Les lieux trouves seront... " deduce_siege_rarity .. $) +crtext

	choice( "Continuez a vous battre !" )choice
	choice( "Tirez le levier STOP !" )choice: train_halt

;

}


: emergency_stop
	spawn special_objects16_base_id 77 + spriteid!
	as-metal 30 lt .hitpoints! 200 lt .mass! 3 lt .tileflags!
	-1.7 lt .vel.y!
	1 lt .no_hit! 1 lt .nopush! 1 lt .nocollide!
	cyoa{ ' emergencystoplever } lt .cyoa!

;

: illuminate_carriages args( me eventid )
	<- eventid THING_EVENT_TIMER = if

		12 for
			1 1 1 67 <- me .pos 12 16 i * * 0 xyadd d-light
		next

		1 <- me .timer!
	then
;

: carriage_lights_generator

	spawn 3 lt .tileflags! 1 lt .walkover! 100 lt .hitpoints! 1 lt .no_hit! 0 lt .clr.a! 1000 lt .mass!
	1 lt .timer! ' illuminate_carriages lt .events!

;

: train_decor
	spawn special_objects16_base_id 79 83 rnd + spriteid!
	as-metal 30 lt .hitpoints! 200 lt .mass! 3 lt .tileflags!
	-1.7 lt .vel.y!
	1 lt .no_hit! 1 lt .nopush! 1 lt .nocollide!

;

