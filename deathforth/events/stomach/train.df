: sycamall_window tile@
	dup LAYER_WALLSIDE street_tiles_base_id 581 + .lspriteid!
	dup LAYER_WALLSIDE 0 0 .tile_layer.off!
	dup LAYER_WALLSIDE 0 .tile_layer.flipx!

	dup LAYER_WALLTOP inside_tiles_walltops_id 10 + .lspriteid!

	// 10 for regular walltop
	// 9 for right-hand up turn
	// 8 for right-hand end
	// 7 for left-facing-junction
	// 6 for downfacing left turn
	// 5 for straight up
	// 4 for upward end
	// 3 for upward left turn
	// 2 for lefthand end
	// 1 for downward end
	// 0 for tiny square

	dup LAYER_WALLTOP 0 -16 .tile_layer.off!
	dup LAYER_WALLTOP 0 .tile_layer.flipx!

	TILE_BLOCK over .id!
	drop
;

: sycamall_bot_window tile@
	dup LAYER_WALLSIDE street_tiles_base_id 581 + .lspriteid!
	dup LAYER_WALLSIDE 0 0 .tile_layer.off!
	dup LAYER_WALLSIDE 0 .tile_layer.flipx!

	dup LAYER_WALLTOP inside_tiles_walltops_id 10 + .lspriteid!

	// 10 for regular walltop
	// 9 for right-hand up turn
	// 8 for right-hand end
	// 7 for left-facing-junction
	// 6 for downfacing left turn
	// 5 for straight up
	// 4 for upward end
	// 3 for upward left turn
	// 2 for lefthand end
	// 1 for downward end
	// 0 for tiny square

	dup LAYER_WALLTOP 0 -16 .tile_layer.off!
	dup LAYER_WALLTOP 0 .tile_layer.flipx!

	dup LAYER_FLOORTOP street_tiles_base_id 575 + .lspriteid!
	dup LAYER_FLOORTOP 0 8 .tile_layer.off!

	TILE_BLOCK over .id!
	drop
;

\ I preferred windows as actual objects, but they have to be integrated within the tileset or else
\ We hit the object limit very easily, especially on endless.

: train_subloot 1 7 rnd case
	1 of 1 LOOT_FOOD spawnloot endof
	2 of 3 LOOT_GAS spawnloot endof
	3 of 3 8 rnd LOOT_BULLET spawnloot endof
	4 of 1 2 rnd LOOT_MEDICAL spawnloot endof
	5 of purse endof
	6 of cleaver endof
	7 of pipebomb endof
	endcase
;


defer ft

: pt
	xyp.xy ft

	\ .s console-open

	xyp.i char . = if then;
	xyp.i char R = if xyp.xy sycatile_railmain then;
	xyp.i char T = if xyp.xy sycatile_railjoin then;
	\ xyp.i char B = if xyp.xy sycatile_railbed then;

	 xyp.i char b = if xyp.xy sycamall then;
	 xyp.i char c = if xyp.xy sycamallvertical then;

	\ xyp.i char t = if xyp.xy sycamallverticaltpost then;

	  xyp.i char 9 = if xyp.xy sycatilestreetblock then;
	  xyp.i char 8 = if xyp.xy sycatilestreet then;

	  xyp.i char C = if xyp.xy sycamall_bot then;

	  xyp.i char l = if xyp.xy sycamall-leftend then;
	  xyp.i char r = if xyp.xy sycamall-rightend then;

	  xyp.i char g = if xyp.xy sycamall-corner-rightup then;
		xyp.i char h = if xyp.xy sycamall-corner-leftup then;
	  xyp.i char 3 = if xyp.xy sycamall-corner-rightdown then;
	  xyp.i char 4 = if xyp.xy sycamall-corner-leftdown then;
	  xyp.i char 5 = if xyp.xy sycamall-straightupordown xyp.xy sycatilestreet_rightadjust then;
	  xyp.i char 0 = if xyp.xy sycamall-straightupordown xyp.xy sycatilestreet_leftadjust then;

	  xyp.i char J = if xyp.xy sycatile_carriagejoiner then;
	  xyp.i char 7 = if xyp.xy sycatile_carriagejoiner_floor then;
	  xyp.i char 6 = if xyp.xy sycatile_carriagejoiner_floor_block then;

	  xyp.i char W = if xyp.xy train_seat lt-here lt .pos 0 -4 xyadd lt .pos! 10 %chance if skel lt-here lt .pos 1 4 rnd 1 4 rnd xyadd lt .pos! then xyp.xy sycatilestreet then;
	 ( * tube_window lt-here -1.66 lt .vel.y! 1 dup lt .scale.x! lt .scale.y! tube_window lt-here 4.7 lt .vel.y! 1 dup lt .scale.x! lt .scale.y! * )

	  xyp.i char 1 = if xyp.xy tube_door_L lt-here -1.66 lt .vel.y! 1 dup lt .scale.x! lt .scale.y! tube_door_L lt-here 4.7 lt .vel.y! 1 dup lt .scale.x! lt .scale.y! sycatilestreet then;
	  xyp.i char 2 = if xyp.xy tube_door_R lt-here -1.66 lt .vel.y! 1 dup lt .scale.x! lt .scale.y! tube_door_R lt-here 4.7 lt .vel.y! 1 dup lt .scale.x! lt .scale.y! sycatilestreet then;

	  xyp.i char F = if xyp.xy sycatile_GTFO then;

	  xyp.i char w = if xyp.xy train_wheel lt-here -1.5 lt .vel.y! then;

	  xyp.i char f = if train_fauna_generator lt-here then;

	  xyp.i char S = if xyp.xy sycatilestreet  speaker_train lt-here then;
	  xyp.i char E = if xyp.xy sycatilestreet emergency_stop lt-here then;

	  xyp.i char L = if xyp.xy sycatilestreet carriage_lights_generator lt-here then;

	  xyp.i char D = if xyp.xy 50 %chance if train_decor lt-here then then;

	  xyp.i char Z = if xyp.xy tanchor! 5 zombs-clump then;

	  \ window tiles e & a
	  xyp.i char a = if xyp.xy sycamall_window then;
	  xyp.i char e = if xyp.xy sycamall_bot_window then;

	  xyp.i char G = if xyp.xy train_subloot lt-here then;

;




