cyoa{ regiondef{

// Army Surplus

0 value army-1
0 value army-2
0 value army-3
0 value army-4
0 value army-5
0 value army-6
0 value army-7

cyoa-choice: trade-army-1
	($ Thegroup .. " glisse de la nourriture dans la fente de la benne et une grenade sort. Ca pourrait faire beaucoup de degats !
	" .. "Attendez, la goupille etait encore dessus ?" pbold $) cyoa-text! basic-tone
	1 WEAPON_GRENADE trunk.weapon+ -4 trunk-food+ picon ' army-1 ++
;

cyoa-choice: trade-army-2
	($ Thegroup .. " glisse de la nourriture dans la benne et un tas de grenades tombent, une par une. Ca pourrait etre utile !
	" .. "Faites attention a ne pas les faire tomber ici." pbold $) cyoa-text! basic-tone
	3 WEAPON_GRENADE trunk.weapon+ -12 trunk-food+ picon ' army-2 ++
;

cyoa-choice: trade-army-3
	($ Thegroup .. " glisse beaucoup de nourriture dans la benne. Quelqu'un pousse un uzi dehors ! Il peut cracher des balles a une vitesse incroyable ! Attention, meme un bon tireur aura du mal avec le recul.
	" .. "Amusez-vous ! Et partez, s'il vous plait." pbold $) cyoa-text! basic-tone
	1 WEAPON_UZI trunk.weapon+ -15 trunk-food+ picon ' army-3 ++
;

cyoa-choice: trade-army-4
	($ Thegroup .. " glisse une enorme quantite de nourriture dans la benne. Une pause, puis quelqu'un pousse un fusil d'assaut ! Ca pourrait vraiment aider le voyage !
	" .. "Merci pour toute cette nourriture ! Bonne chance la-dehors !" pbold $) cyoa-text! goodfx
	1 WEAPON_AK47 trunk.weapon+ -25 trunk-food+ picon ' army-4 ++
;

cyoa-choice: trade-army-5
	($ Thegroup .. " glisse une enorme quantite de nourriture dans la fente. Une pause, puis quelqu'un dans la benne commence a pousser une douzaine de grenades.
	" .. "Soyez vraiment prudents avec ca !" pbold $) cyoa-text! goodfx
	12 WEAPON_GRENADE trunk.weapon+ -40 trunk-food+ picon ' army-5 ++
;

cyoa-choice: trade-army-6
	($ Thegroup .. " glisse une quantite massive de nourriture dans la fente. Quelqu'un de l'autre cote se debat pour sortir un lance-flammes de la benne.
	" .. "Crachez le feu !" pbold $) cyoa-text! goodfx
	1 WEAPON_FLAMETHROWER trunk.weapon+ -50 trunk-food+ picon ' army-6 ++
;

cyoa-choice: trade-army-7
	($ Thegroup .. " glisse lentement une voiture pleine de nourriture dans la benne. Des bruits de raclement se font entendre puis un canon de minigun est pousse depuis l'obscurite. Le cadre de la fente est deforme par la taille du minigun qu'on force a passer.
	" .. "Merci infiniment ! Je peux me cacher ici pendant des mois maintenant !" pbold $) cyoa-text! goodfx
	1 WEAPON_MINIGUN trunk.weapon+ -75 trunk-food+ picon ' army-7 ++
;

cyoa: trade-army
	"Fort Surplus Militaire" cyoa-title!
	($ Thegroup .. " trouve une benne. Fermee a clef, avec une fente sur le cote. Des noms d'armes et des prix sont griffonnes pres du trou.
	" .. "Glissez juste la nourriture ici !" pbold .. " dit une toute petite voix dans la benne." $) cyoa-text! basic-tone foodamt
	choice( "Laisser tomber" )choice back-esc
	trunk-food 5 < if
		($ "Pas assez de nourriture pour la personne dans la benne !" $) +crtext badfx // clear-cyoa
	else
		trunk-food 74 > army-7 1 < and if
			choice( "Minigun pour 75 nourriture" )choice: trade-army-7
		then
		trunk-food 49 > army-6 1 < and if
			choice( "Lance-flammes pour 50 nourriture" )choice: trade-army-6
		then
		trunk-food 39 > army-5 1 < and if
			choice( "12 grenades pour 40 nourriture" )choice: trade-army-5
		then
		trunk-food 24 > army-4 1 < and if
			choice( "Fusil d'assaut pour 25 nourriture" )choice: trade-army-4
		then
		trunk-food 14 > army-3 1 < and if
			choice( "Uzi pour 15 nourriture" )choice: trade-army-3
		then
		trunk-food 11 > army-2 1 < and if
			choice( "3 grenades pour 12 nourriture" )choice: trade-army-2
		then
		trunk-food 3 > army-1 1 < and if
			choice( "1 grenade pour 4 nourriture" )choice: trade-army-1
		then
	then
;

// Shotgun seller

0 value shotgun-1
0 value shotgun-2
0 value shotgun-3
0 value shotgun-4

cyoa-choice: trade-shotgun-coolit
	cpet? if
		($ cname .. " pete juste devant le vendeur de fusils a pompe." $)
	else
		($ cname .. " dit au vendeur de fusils a pompe de " .. "SE CALMER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Ca lui provoque une sorte de crise existentielle.
		" .. "T'as raison ! Mais qu'est-ce que je fais de ma vie ?!" pbold .. "
		Il donne a " .. cname .. " son " .. "precieux fusil a pompe auto." rbold $) +crtext goodfx
		1 WEAPON_AUTOSHOT trunk.weapon+
		// used to also give a shotgun, a rifled slug shotgun, and the BIG DAWG. Too much. Busting down the value of mega coolit to about 40-50 food or so instead of like 150.
		// Busted it down even further, to just giving an autoshotgun.
		cooled-it clear-cyoa
	else cool-it++
		($ "Le vendeur est vraiment agace par ca.
		" .. "J'essaie de gagner ma vie ici !" pbold .. "
		Il commence alors a tirer ses fusils a pompe en l'air de facon menacante, forcant " .. thegroup .. " a fuir !" $) badfx +crtext quitmission
	then attitudeREV witsREV
;

cyoa-choice: trade-shotgun-4
	($ Thegroup .. " achete le " .. "FUSIL A DEUX CANONS !" rbold .. " Le fusil d'un vrai connaisseur. Il crache d'enormes gerbes de chevrotine, mais est un peu difficile a manier." $) cyoa-text! goodfx ' shotgun-4 ++
	1 WEAPON_DSHOTGUN trunk.weapon+ -12 trunk-food+ picon charm-shotgun-shell
;

cyoa-choice: trade-shotgun-3
	($ Thegroup .. " achete un fusil a pompe a balles pleines. Il tire une balle solide et lourde au lieu de chevrotine. Un bon tireur pourrait detruire une rangee entiere de zombies en un seul tir !" $) cyoa-text! goodfx ' shotgun-3 ++
	1 WEAPON_SLUG trunk.weapon+ -25 trunk-food+ picon charm-shotgun-shell
;

cyoa-choice: trade-shotgun-2
	($ Thegroup .. " achete un fusil a pompe automatique. Cette arme tire bien plus vite qu'un fusil a pompe normal, devastant les hordes !" $) cyoa-text! goodfx ' shotgun-2 ++
	1 WEAPON_AUTOSHOT trunk.weapon+ -30 trunk-food+ picon charm-shotgun-shell
;

cyoa-choice: trade-shotgun-1
	($ Thegroup .. " achete un fusil a pompe. Le vendeur ajoute quelques cartouches gratuitement !" $) cyoa-text! goodfx
	1 WEAPON_SHOTGUN trunk.weapon+ -7 trunk-food+ 15 trunk-shotgun-shell+ picon charmhalf-shotgun-shell
	 ' shotgun-1 ++
;

cyoa: trade-shotgun
	"Vendeur de Fusils a Pompe" cyoa-title!
	($ "Cet homme porte plusieurs fusils a pompe, la plupart attaches dans son dos. Il annonce un argumentaire de vente simple mais efficace :
	" .. "DES FUSILS A POMPE A VENDRE ! DES FUSILS A POMPE A VENDREUUUH !" pbold $) cyoa-text! basic-tone foodamt
	choice( "Le laisser" )choice back-esc
	most-grating if
		charchoice( " lui dit de SE CALMER" fcoolit )choice: trade-shotgun-coolit
	then
	trunk-food 5 < if
		($ "Pas assez de nourriture ! Par pitie, il donne a " .. thegroup .. " quelques cartouches gratuites." $) +crtext goodfx 5 trunk-shotgun-shell+ clear-cyoa
	else
		trunk-food 24 > shotgun-3 1 < and if
			choice( "Fusil a balles pleines pour 25 nourriture" )choice: trade-shotgun-3
		then
		trunk-food 29 > shotgun-2 1 < and if
			choice( "Fusil a pompe auto pour 30 nourriture" )choice: trade-shotgun-2
		then
		trunk-food 11 > shotgun-4 2 < and if
			choice( "Fusil a deux canons pour 12 nourriture" )choice: trade-shotgun-4
		then
		(* trunk-food 14 > if
			choice( "75 cartouches pour 15 nourriture" )choice: trade-shotgun-shell-15
		then *)
		trunk-food 6 > shotgun-1 3 < and if
			choice( "Fusil a pompe pour 7 nourriture" )choice: trade-shotgun-1
		then
		(* trunk-food 9 > if
			choice( "50 cartouches pour 10 nourriture" )choice: trade-shotgun-shell-10
		then
		trunk-food 4 > if
			choice( "25 cartouches pour 5 nourriture" )choice: trade-shotgun-shell-5
		then *)

	then
;

// Rifle Collector

0 value rifle-1
0 value rifle-2
0 value rifle-3
0 value rifle-4
0 value rifle-moar

cyoa-choice: trade-rifle-coolit
	cpet? if
		($ cname .. " jette un oeil a la collection puis leve les yeux au ciel." $)
	else
		($ cname .. " dit a la sympathique collectionneuse de " .. "SE CALMER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Elle hoche la tete en signe d'accord.
		" .. "Ouais, ma collection devient trop grosse. Ca te derangerait de prendre ca ?" pbold .. "
		La collectionneuse donne a " .. cname .. " un " .. "fusil d'assaut." rbold $) goodfx
		1 WEAPON_AK47 trunk.weapon+ cooled-it clear-cyoa
	else cool-it++
		($ "La collectionneuse semble blessee par ca.
		" .. "Je... je suis calme..." pbold .. "
		Elle dit a " .. thegroup .. " de quitter le camp de commerce avant qu'elle sorte son minigun." $) badfx quitmission
	then +crtext attitudeREV witsREV
;

cyoa-choice: trade-rifle-4
	($ Thegroup .. " achete le " .. "MINIGUN" rbold .. ". La collectionneuse semble ravie de le vendre.
	" .. "Techniquement, c'est pas un fusil ! Et j'arrivais pas a l'accrocher au mur, alors..." pbold $) cyoa-text! goodfx
	1 WEAPON_MINIGUN trunk.weapon+ -65 trunk-food+ picon charm-rifle-shell ' rifle-4 ++
;

cyoa-choice: trade-rifle-3
	($ Thegroup .. " achete un fusil de chasse haute puissance. La collectionneuse vous fait un super prix, elle en a plusieurs.
	" .. "Le top avec les fusils de chasse, c'est qu'un tir peut eclabousser plein de zombies. Mon record c'est 7 en un seul tir !" pbold $) cyoa-text! goodfx
	1 WEAPON_HUNTING trunk.weapon+ -15 trunk-food+ picon charm-rifle-shell ' rifle-3 ++
;

cyoa-choice: trade-rifle-2
	($ Thegroup .. " achete un fusil d'assaut. Presque aussi puissant qu'un fusil de cow-boy tir apres tir, et il tire bien plus vite.
	" .. "Je prefere les fusils a tir unique, personnellement. Les automatiques consomment trop de munitions et percent moins bien." pbold $) cyoa-text! goodfx
	1 WEAPON_AK47 trunk.weapon+ -25 trunk-food+ picon charm-rifle-shell ' rifle-2 ++
;

cyoa-choice: trade-rifle-1
	($ Thegroup .. " achete un fusil de cow-boy. La collectionneuse ajoute des munitions gratuitement, et un deuxieme fusil !
	" .. "Les fusils de cow-boy sont super pour les debutants. Facile a manier, agreable a tirer. J'en trouve des tonnes, donc prenez-en deux !" pbold $) cyoa-text! goodfx
	2 WEAPON_RIFLE trunk.weapon+ -10 trunk-food+ 20 trunk-rifle-shell+ picon charmhalf-rifle-shell ' rifle-1 ++
;

cyoa-choice: trade-rifle-moar
	($ Thegroup .. " achete le M.O.A.R : La Mere de Tous les Fusils. Le summum des armes a tir lent, le M.O.A.R traverse des colonnes de zombies ou des voitures avec facilite.
	" .. "Ce bijou etait interdit dans 58 pays, pour de bonnes raisons. On pourrait vraiment blesser quelqu'un avec ca... c'est une arme pour un VRAI tireur d'elite." pbold $) cyoa-text! goodfx
	1 WEAPON_MOARGUN trunk.weapon+ -32 trunk-food+ picon charm-rifle-shell ' rifle-moar ++
;

cyoa: trade-rifle
	"Collectionneuse de Fusils" cyoa-title!
	($ Thegroup .. " parle a une femme d'apparence timide. Elle vous invite a voir sa collection de fusils.
	" .. "J'en ai trouve tellement que j'en cherche a vendre quelques-uns !" pbold $) cyoa-text! basic-tone foodamt
	choice( "La laisser" )choice back-esc
	most-grating if
		charchoice( " lui dit de SE CALMER" fcoolit )choice: trade-rifle-coolit
	then
	trunk-food 10 < if
		($ "Pas assez de nourriture pour acheter quoi que ce soit ! Pour etre aimable, la collectionneuse donne a " .. thegroup .. " des munitions de fusil gratuites." $) +crtext goodfx 10 trunk-rifle-shell+ clear-cyoa
	else
		trunk-food 64 > rifle-4 1 < and if
			choice( "Minigun pour 65 nourriture" )choice: trade-rifle-4
		then
		trunk-food 31 > rifle-moar 1 < and if
			choice( "Fusil M.O.A.R pour 32 nourriture" )choice: trade-rifle-moar
		then
		trunk-food 24 > rifle-2 1 < and if
			choice( "Fusil d'assaut pour 25 nourriture" )choice: trade-rifle-2
		then
		trunk-food 14 > rifle-3 1 < and if
			choice( "Fusil de chasse pour 15 nourriture" )choice: trade-rifle-3
		then
		(* trunk-food 14 > if
			choice( "90 balles fusil pour 15 nourriture" )choice: trade-rifle-shell-15
		then *)
		trunk-food 9 > rifle-1 3 < and if
			choice( "Fusil de cow-boy pour 10 nourriture" )choice: trade-rifle-1
		then
		(* trunk-food 9 > if
			choice( "60 balles fusil pour 10 nourriture" )choice: trade-rifle-shell-10
		then
		trunk-food 4 > if
			choice( "30 balles fusil pour 5 nourriture" )choice: trade-rifle-shell-5
		then *)
	then
;

// Weapon Fanatic

0 value fanatic-1
0 value fanatic-2
0 value fanatic-3
0 value fanatic-4
0 value fanatic-5
0 value fanatic-6

cyoa-choice: trade-fanatic-coolit
	cpet? if
		($ cname .. " dit la phrase " .. "SE CALMER" pbold .. " en petant ! Incroyable !" $)
	else
		($ cname .. " dit a la femme fanatique de " .. "SE CALMER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Elle en est ravie, d'une certaine facon.
		" .. "WAOUH !...WAOUH OUAH OUAH OUAHHHH !" rbold .. "
		La marchande donne a " .. cname .. " 7 molotovs et une " .. "tronconneuse gratuite." rbold $) goodfx +crtext
		1 WEAPON_CHAINSAW trunk.weapon+ 7 WEAPON_MOLOTOV trunk.weapon+ cooled-it clear-cyoa
	else cool-it++
		($ "La marchande d'armes est furieuse.
		" .. "SE CALMER ? SE CALMER ??! LES LOSERS SE CALMENT !!
		" rbold .. Thegroup .. " realise que c'etait une tres mauvaise idee ! La marchande met en marche sa tronconneuse !" $) +crtext bitefx rob-megafail trade-flee
	then attitudeREV witsREV
;

cyoa-choice: trade-fanatic-1
	($ Thegroup .. " achete quelques cocktails molotov.
	" .. "Un peu de feu peut faire beaucoup de chemin !" rbold $) cyoa-text! goodfx
	2 WEAPON_MOLOTOV trunk.weapon+ -5 trunk-food+ picon charm-gas ' fanatic-1 ++
;
cyoa-choice: trade-fanatic-2
	($ Thegroup .. " achete cinq cocktails molotov.
	" .. "Dans le doute, tout bruler !!" rbold $) cyoa-text! goodfx
	5 WEAPON_MOLOTOV trunk.weapon+ -10 trunk-food+ picon charm-gas ' fanatic-2 ++
;
cyoa-choice: trade-fanatic-4
	($ Thegroup .. " achete huit cocktails molotov.
	" .. "Ne les utilisez pas tous au meme endroit !" rbold $) cyoa-text! goodfx
	8 WEAPON_MOLOTOV trunk.weapon+ -15 trunk-food+ picon charm-gas ' fanatic-4 ++
;
cyoa-choice: trade-fanatic-3
	($ Thegroup .. " achete un parcmetre ? C'est tres lourd.
	" .. "On l'a arrache du sol ! C'est comme ca qu'on peut vous faire des economies !" rbold $) cyoa-text! goodfx
	1 WEAPON_PARKING trunk.weapon+ -10 trunk-food+ picon ' fanatic-3 ++
;
cyoa-choice: trade-fanatic-5
	($ Thegroup .. " achete une tronconneuse ! Elle convertit l'essence de rechange en destruction de zombies.
	" .. "Hahaha ! PARFAIT ! Dechiquetez-les tous !" rbold $) cyoa-text! goodfx
	1 WEAPON_CHAINSAW trunk.weapon+ -20 trunk-food+ picon charm-gas ' fanatic-5 ++
;
cyoa-choice: trade-fanatic-6
	($ Thegroup .. " achete un lance-flammes ! Essayez de ne pas griller vos coequipiers avec.
	" .. "Aaaaaaa ! Ca vous va SUPER bien !!" rbold $) cyoa-text! goodfx
	1 WEAPON_FLAMETHROWER trunk.weapon+ -40 trunk-food+ picon charm-gas ' fanatic-6 ++
;

// chainsaw 40 - flamethrower 100 - molotovs 2 5 10 for 5 10 20 - 15 parking meter
cyoa: trade-fanatic
	"Armes de Carnage" cyoa-title!
	($ "Une femme d'allure particulierement intense propose de vendre une arme en rab. " .. "Je transporte seulement le MEILLEUR !
	" rbold .. "Elle met en marche sa tronconneuse et la fait vrombir quelques fois pour souligner le propos." $) cyoa-text! basic-tone foodamt
	choice( "Partir pour l'instant" )choice back-esc
	most-grating if
		charchoice( " lui dit de SE CALMER" fcoolit )choice: trade-fanatic-coolit
	then
	trunk-food 5 < if
		($ "Pas assez de nourriture pour acheter quoi que ce soit ! La marchande donne un molotov gratuit a " .. thegroup .. ", juste pour promouvoir la destruction de zombies." $) +crtext goodfx 1 WEAPON_MOLOTOV trunk.weapon+ clear-cyoa
	else
		trunk-food 39 > fanatic-6 1 < and if
			choice( "Lance-flammes pour 40 nourriture" )choice: trade-fanatic-6
		then
		trunk-food 19 > fanatic-5 1 < and if
			choice( "Tronconneuse pour 20 nourriture" )choice: trade-fanatic-5
		then
		trunk-food 14 > fanatic-4 1 < and if
			choice( "8 molotovs pour 15 nourriture" )choice: trade-fanatic-4
		then
		trunk-food 9 > fanatic-3 1 < and if
			choice( "Parcmetre pour 10 nourriture" )choice: trade-fanatic-3
		then
		trunk-food 9 > fanatic-2 1 < and if
			choice( "5 molotovs pour 10 nourriture" )choice: trade-fanatic-2
		then
		trunk-food 4 > fanatic-1 1 < and if
			choice( "2 molotovs pour 5 nourriture" )choice: trade-fanatic-1
		then
	then
;

// Blade Master

0 value blade-claymore
0 value blade-knight
0 value blade-machete
0 value blade-katana

cyoa-choice: trade-blade-rob

		($ "Le Maitre des Lames repousse " .. thegroup .. " grace a sa considerable connaissance des epees et ses katanas de centre commercial. " .. cname .. " attrape un coupe-coupe solide par terre." $) cyoa-text! bitefx rob-fail 1 WEAPON_MACHETE2 trunk.weapon+
		aholeREV trade-flee
;
cyoa-choice: trade-blade-coolit
	cpet? if
		($ cname .. " commence a macher un des fourreaux du Maitre des Lames, par depit." $)
	else
		($ cname .. " dit au Maitre des Lames de " .. "SE CALMER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Il se remplit de doutes.
		" .. "Ma vie est un mensonge ! Je vais arreter ce truc avec les epees et commencer a collectionner des lance-flammes." pbold .. "
		L'ancien Maitre des Lames donne a " .. cname .. " l'une de ses meilleures armes, une " .. "Epee de Chevalier." rbold $) goodfx
		1 WEAPON_KNIGHT trunk.weapon+ cooled-it clear-cyoa
	else cool-it++
		($ "Le Maitre des Lames ignore ca.
		Il commence a parler de combien les epees sont cool et n'arrete jamais. " .. Thegroup .. " est force de se faufiler hors du camp pendant ses divagations infinies." $) badfx quitmission
	then +crtext attitudeREV witsREV
;

cyoa-choice: trade-blade-4
	($ Thegroup .. " achete le " .. "PUISSANT CLAYMORE" rbold .. ". Le claymore est lent et difficile a manier, mais extremement puissant. Il peut couper 4 zombies d'un coup !" $) cyoa-text! goodfx
	1 WEAPON_CLAYMORE trunk.weapon+ -35 trunk-food+ someicon ' blade-claymore ++
;

cyoa-choice: trade-blade-3
	($ Thegroup .. " achete le type d'epee qu'un chevalier du Moyen Age porterait. Ca va faire une excellente arme ! Elle peut facilement toucher deux zombies en un seul coup." $) cyoa-text! goodfx
	1 WEAPON_KNIGHT trunk.weapon+ -20 trunk-food+ someicon ' blade-knight ++
;

cyoa-choice: trade-blade-2
	($ Thegroup .. " achete un coupe-coupe tres solide mais leger. Assez robuste pour abattre des arbres, il ne se cassera pas avec 'un usage de road trip'." $) cyoa-text! goodfx
	1 WEAPON_MACHETE2 trunk.weapon+ -12 trunk-food+ someicon ' blade-machete ++
;

cyoa-choice: trade-blade-1
	($ Thegroup .. " achete un katana du genre qu'on trouve dans un centre commercial. Il a l'air sur le point de se casser a tout moment. Quelle arnaque." $) cyoa-text! goodfx
	1 WEAPON_OTAKU trunk.weapon+ -5 trunk-food+ someicon ' blade-katana ++
;

cyoa: trade-blade
	"Maitre des Lames" cyoa-title!
	($ Thegroup .. " rencontre un homme qui porte beaucoup d'epees. Elles s'entrechoquent quand il bouge.
	" .. "Un jour je fabriquerai la plus belle epee a trancher les zombies qu'on ait jamais vue ! Je dois juste d'abord comprendre comment fabriquer des epees. Je vous en vends quelques-unes que j'ai trouvees !" pbold $) cyoa-text! basic-tone foodamt
	choice( "Le laisser" )choice back-esc
	most-ahole if
		charchoice( " vole le marchand" )choice: trade-blade-rob
	then
	most-grating if
		charchoice( " lui dit de SE CALMER" fcoolit )choice: trade-blade-coolit
	then
	trunk-food 5 < if
		($ "Pas assez de nourriture pour acheter quoi que ce soit ! En consolation le marchand donne a " .. thegroup .. " un couperet de boucher." $) +crtext goodfx 1 WEAPON_CLEAVER trunk.weapon+ clear-cyoa
	else
		trunk-food 34 > blade-claymore 1 < and if
			choice( "Puissant Claymore pour 35 nourriture" )choice: trade-blade-4
		then
		trunk-food 19 > blade-knight 1 < and if
			choice( "Epee de Chevalier pour 20 nourriture" )choice: trade-blade-3
		then
		trunk-food 11 > blade-machete 1 < and if
			choice( "Solide Coupe-coupe pour 12 nourriture" )choice: trade-blade-2
		then
		trunk-food 4 > blade-katana 3 < and if
			choice( "Katana pas cher pour 5 nourriture" )choice: trade-blade-1
		then
	then
;

// Axe Merchant

0 value axe-medieval
0 value axe-guitar
0 value axe-fireaxe
0 value axe-hatchet

cyoa-choice: trade-axe-rob
	40 %chance if
		($ cname .. " vole le marchand de haches, qui reste la sans reagir du tout. " .. cname .. " prend la hache medievale mais est trop flippe. " $) cyoa-text! 0.4 1100 tone
		notsolo if
			($ Theothersare .. " aussi tres flippes." $) +text
		then morale3-all 1 WEAPON_MEDIEVAL trunk.weapon+
	else
		($ "Le marchand de haches bouge bien trop vite. En un eclair, il tient une enorme hache medievale dans une main robee. " .. Thegroup .. " est bien trop terrifie pour continuer la tentative de vol." $) cyoa-text! morale3-all
	then aholeREV badfx trade-flee
;
cyoa-choice: trade-axe-coolit
	cpet? if
		($ cname .. " lache un pet particulierement bruyant." $)
	else
		($ cname .. " dit au marchand de haches de " .. "SE CALMER." pbold $)
	then cyoa-text!
	cool-it++
	($ "Le marchand de haches ne semble pas reagir.
	" .. "....." rbold .. "
	" .. cname .. " n'a aucune idee s'il a ete entendu ou non." $)
	+crtext attitudeREV witsREV 0.3 600 tone
	($ Thegroup .. " se sent tellement mal a l'aise qu'" .. gthey .. " quitt" .. g1s .. " le camp de commerce le plus vite possible." $) +crtext quitmission badfx
;

cyoa-choice: trade-axe-4
	($ Thegroup .. " achete la " .. "HACHE MEDIEVALE" rbold .. ". Ce truc est vraiment lourd et lent. Elle peut toucher beaucoup de zombies dans une zone ! A donner a quelqu'un de fort et en forme." $) cyoa-text! goodfx
	1 WEAPON_MEDIEVAL trunk.weapon+ -20 trunk-food+ picon ' axe-medieval ++
;

cyoa-choice: trade-axe-3
	($ Thegroup .. " achete une guitare en forme de hache. Ca ferait une arme stylee." $) cyoa-text! goodfx
	1 WEAPON_GUITAR trunk.weapon+ -10 trunk-food+ picon ' axe-guitar ++
;

cyoa-choice: trade-axe-2
	($ Thegroup .. " achete une hache d'incendie. Elle s'appelle comme ca parce que c'est ce que les pompiers utilisaient pour couper les zombies." $) cyoa-text! goodfx
	1 WEAPON_FIRE trunk.weapon+ -6 trunk-food+ picon ' axe-fireaxe ++
;

cyoa-choice: trade-axe-1
	($ Thegroup .. " achete une hachette. C'est la plus petite petite hache." $) cyoa-text! goodfx
	1 WEAPON_HATCHET trunk.weapon+ -3 trunk-food+ picon ' axe-hatchet ++
;

cyoa: trade-axe
	"Marchand de Haches" cyoa-title!
	($ Thegroup .. " rencontre une etrange et menacante silhouette. Elle porte un masque et une robe.
	" .. "Je vends des haches... Juste des haches..." rbold $) cyoa-text! foodamt
	choice( "Le laisser" )choice back-esc
	most-ahole if
		charchoice( " vole le marchand" )choice: trade-axe-rob
	then
	most-grating if
		charchoice( " lui dit de SE CALMER" )choice: trade-axe-coolit
	then
	trunk-food 3 < if
		($ "Pas assez de nourriture pour acheter quoi que ce soit ! En consolation le marchand donne a " .. thegroup .. " un baton de hockey, qui est en quelque sorte en forme de hache." $) +crtext goodfx 1 WEAPON_HOCKEY trunk.weapon+ clear-cyoa
	else 0.3 600 tone
		trunk-food 19 > axe-medieval 1 < and if
			choice( "Hache Medievale pour 20 nourriture" )choice: trade-axe-4
		then
		trunk-food 9 > axe-guitar 1 < and if
			choice( "Guitare Electrique pour 10 nourriture" )choice: trade-axe-3
		then
		trunk-food 5 > axe-fireaxe 2 < and if
			choice( "Hache d'Incendie pour 6 nourriture" )choice: trade-axe-2
		then
		trunk-food 2 > axe-hatchet 2 < and if
			choice( "Hachette pour 3 nourriture" )choice: trade-axe-1
		then
	then
;

// General Firearms, with ability to unlock a secret super shop

0 value firearms-flame
0 value firearms-assault
0 value firearms-autoshot
0 value firearms-uzi
0 value firearms-goodstuff
0 value firearms-shotgun
0 value firearms-cowboy
0 value firearms-revolver

cyoa-choice: trade-firearms-80
	($ Thegroup .. " achete un lance-flammes. Le marchand ne dit pas ou il l'a eu. Essayez de ne pas vous enflammer avec !" $) cyoa-text! basic-tone
	1 WEAPON_FLAMETHROWER trunk.weapon+ -35 trunk-food+ charm-gas ' firearms-flame ++ ' firearms-goodstuff ++
;

cyoa-choice: trade-firearms-40
	($ Thegroup .. " achete un fusil a pompe automatique. LA on parle ! Vous etes pares jusqu'a court de cartouches." $) cyoa-text! basic-tone
	1 WEAPON_AUTOSHOT trunk.weapon+ -25 trunk-food+ charm-shotgun-shell ' firearms-autoshot ++ ' firearms-goodstuff ++
;

cyoa-choice: trade-firearms-30
	($ Thegroup .. " achete un fusil d'assaut. Celui qui l'utilise a besoin de beaucoup de competence en tir pour bien le manier !" $) cyoa-text! basic-tone
	1 WEAPON_AK47 trunk.weapon+ -20 trunk-food+ charm-rifle-shell ' firearms-assault ++ ' firearms-goodstuff ++
;

cyoa-choice: trade-firearms-20
	($ Thegroup .. " achete un uzi. Super pour arroser des balles PARTOUT. Meme un excellent tireur aura du mal a le manier." $) cyoa-text! basic-tone
	1 WEAPON_UZI trunk.weapon+ -12 trunk-food+ charm-bullet ' firearms-uzi ++ ' firearms-goodstuff ++
;

cyoa: trade-firearms-mega

	($ "Le marchand decide de montrer a " .. thegroup .. " LES BONNES AFFAIRES." $) cyoa-text! goodfx foodamt
	choice( "Partir pour l'instant" )choice back-esc
	trunk-food 34 > firearms-flame 1 < and if
		choice( "Lance-flammes pour 35 nourriture" )choice: trade-firearms-80
	then
	trunk-food 24 > firearms-autoshot 1 < and if
		choice( "Fusil a pompe auto pour 25 nourriture" )choice: trade-firearms-40
	then
	trunk-food 19 > firearms-assault 1 < and if
		choice( "Fusil d'assaut pour 20 nourriture" )choice: trade-firearms-30
	then
	trunk-food 11 > firearms-uzi 1 < and if
		choice( "Uzi pour 12 nourriture" )choice: trade-firearms-20
	then
;

cyoa-choice: trade-firearms-15
	($ Thegroup .. " achete un fusil a pompe. Un choix classique ! Cette arme est efficace dans les mains de presque n'importe qui." $) cyoa-text! basic-tone
	1 WEAPON_SHOTGUN trunk.weapon+ -5 trunk-food+ charmhalf-shotgun-shell ' firearms-shotgun ++
;

cyoa-choice: trade-firearms-10
	($ Thegroup .. " achete un fusil de cow-boy. Comme les cowboys. Quelqu'un avec une bonne competence de tir pourrait vraiment en tirer parti." $) cyoa-text! basic-tone
	1 WEAPON_RIFLE trunk.weapon+ -5 trunk-food+ charmhalf-rifle-shell ' firearms-cowboy ++
;

cyoa-choice: trade-firearms-5
	($ Thegroup .. " achete un revolver. Entre de bonnes mains, cela pourrait permettre a quelqu'un utilisant des balles bon marche de faire beaucoup de degats zombie." $) cyoa-text! basic-tone
	1 WEAPON_DOLT trunk.weapon+ -5 trunk-food+ charmhalf-bullet ' firearms-revolver ++
;

cyoa-choice: trade-firearms-1
	($ Thegroup .. " achete un pistolet. C'etait tres bon marche, mais c'est le meme genre qu'on trouve partout." $) cyoa-text! basic-tone
	1 WEAPON_PISTOL trunk.weapon+ -1 trunk-food+
;

cyoa: trade-firearms
	"Expo Armes Mobile" cyoa-title! picon
	($ Thegroup .. " trouve un homme qui vend plein d'armes a feu. Il tient un minigun equipe d'une lunette, d'une visee laser et d'une lampe torche.
	Cependant, sa selection semble plutot ordinaire." $) cyoa-text! basic-tone foodamt
	choice( "Partir pour l'instant" )choice back-esc
	shootest-pass trunk-food 11 > firearms-goodstuff 4 < and and if
		shootest charchoice( " exige de voir les bonnes affaires" )choice: trade-firearms-mega
	then
	trunk-food 1 < if
		($ "Malheureusement, pas assez de nourriture pour commercer." $) +cr +text
	else
		trunk-food 4 > firearms-shotgun 1 < and if
			choice( "Fusil a pompe pour 5 nourriture" )choice: trade-firearms-15
		then
		trunk-food 4 > firearms-cowboy 1 < and if
			choice( "Fusil de cow-boy pour 5 nourriture" )choice: trade-firearms-10
		then
		trunk-food 4 > firearms-revolver 1 < and if
			choice( "Revolver pour 5 nourriture" )choice: trade-firearms-5
		then
		choice( "Pistolet pour 1 nourriture" )choice: trade-firearms-1

	then
;

// Pipebomb dude

0 value pipebomb-8
0 value pipebomb-5
0 value pipebomb-2

cyoa-choice: trade-pipebomb-rob
	($ "Au premier signe de probleme, le marchand ouvre son manteau pour reveler qu'il est couvert de bombes artisanales. D'un geste rapide, il allume la meche d'une d'elles.
	" .. cname .. " est juste a cote de lui, et a juste assez de temps pour regretter profondement toute cette affaire de vol." $) cyoa-text! bitefx
		rob-megafail aholeREV trade-flee
;
cyoa-choice: trade-pipebomb-coolit
	cpet? if
		($ cname .. " pete tres bruyamment en direction du gars aux bombes artisanales." $)
	else
		($ cname .. " dit au gars aux bombes artisanales de " .. "SE CALMER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Il interprete ca comme " .. cname .. " qui joue dur dans la negoce.
		" .. "NON ! PRENEZ MES BOMBES ! ECHANTILLONS GRATUITS !" pbold .. "
		Il lui donne " .. chim .. " 20 bombes artisanales ! C'est une quantite massive !" $) goodfx
		20 WEAPON_PIPEBOMB trunk.weapon+ cooled-it clear-cyoa
	else cool-it++
		($ "TOI TU TE CALMES ! TOI TU TE CALMES !!" pbold .. "
		L'ambiance devient vraiment tendue avec le gars qui vend des explosifs, alors " .. thegroup .. " doit quitter le camp de commerce." $) badfx quitmission
	then +crtext attitudeREV witsREV
;
: charm-pipebomb
	most-charming if
		choosechar ($ " Le marchand donne a " .. cname .. " une bombe artisanale supplementaire dans une tentative extremement maladroite de flirt ou d'amitie. Difficile a dire." $) +cr +text 1 WEAPON_PIPEBOMB trunk.weapon+ cicon
	then
;
cyoa-choice: trade-pipebomb-20
	($ Thegroup .. " achete 8 bombes artisanales." $) cyoa-text! basic-tone
	8 WEAPON_PIPEBOMB trunk.weapon+ -15 trunk-food+ picon charm-pipebomb ' pipebomb-8 ++
;

cyoa-choice: trade-pipebomb-10
	($ Thegroup .. " achete 5 bombes artisanales." $) cyoa-text! basic-tone
	5 WEAPON_PIPEBOMB trunk.weapon+ -10 trunk-food+ picon charm-pipebomb ' pipebomb-5 ++
;

cyoa-choice: trade-pipebomb-5
	($ Thegroup .. " achete 2 bombes artisanales." $) cyoa-text! basic-tone
	2 WEAPON_PIPEBOMB trunk.weapon+ -5 trunk-food+  picon 50 %chance if charm-pipebomb then ' pipebomb-2 ++
;

cyoa: trade-pipebomb
	"Fournisseur de Bombes Artisanales" cyoa-title!
	($ Thegroup .. " trouve un homme nerveux qui vend des bombes faites maison. Il porte un manteau epais avec des bosses qui depassent dessous.
	" .. "ACHETEZ MES BOMBES !" pbold $) cyoa-text! basic-tone foodamt
	choice( "Reculer lentement" )choice back-esc
	most-ahole if
		charchoice( " vole le marchand" )choice: trade-pipebomb-rob
	then
	most-grating if
		charchoice( " lui dit de SE CALMER" fcoolit )choice: trade-pipebomb-coolit
	then
	trunk-food 5 < if
		($ "Malheureusement, pas assez de nourriture pour commercer, mais il donne quand meme une bombe artisanale gratuite !" $) +cr +text
		1 WEAPON_PIPEBOMB trunk.weapon+ clear-cyoa
	else
		trunk-food 14 > pipebomb-8 1 < and if
			choice( "8 bombes pour 15 nourriture" )choice: trade-pipebomb-20
		then
		trunk-food 9 > pipebomb-5 1 < and if
			choice( "5 bombes pour 10 nourriture" )choice: trade-pipebomb-10
		then
		trunk-food 4 > pipebomb-2 1 < and if
			choice( "2 bombes pour 5 nourriture" )choice: trade-pipebomb-5
		then
	then
;

// Anime merchant

0 value anime-1
0 value anime-2
0 value anime-3
0 value anime-4

cyoa-choice: trade-anime-rob
	70 %chance if
		($ cname .. " vole au marchand des epees et des shuriken, mais ecrase quelques animes parfaitement utilisables dans le process. " $) cyoa-text! goodfx
		notsolo if
			($ Theothersare .. " entraines dedans." $) +text
		then
		5 WEAPON_SHURIKEN trunk.weapon+ 4 WEAPON_OTAKU trunk.weapon+ rob-guilt
	else
		($ Thegroup .. " est dejoue quand le marchand monte dans son vehicule, claque les volets blindes du camion, et s'en va." $) cyoa-text! badfx morale--all
	then aholeREV trade-flee
;
: charm-anime
	most-charming if
		choosechar ($ " Le marchand donne a " .. cname .. " un katana supplementaire.
		" .. "OFFRE PROMOTIONNELLE, RIEN QUE POUR VOUS ! *CLIN D'OEIL*" pbold $)
		+cr +text 1 WEAPON_OTAKU trunk.weapon+ cicon
	then
;
cyoa-choice: trade-anime-20
	($ Thegroup .. " achete une etoile de ninja geante.
	" .. "C'EST L'ETOILE OFFICIELLE DU VENT UTILISEE DANS LA VERSION EN LIVE-ACTION DE L'ANIME L'ETOILE DU VENT !! EXCELLENT CHOIX !" pbold $) cyoa-text! basic-tone
	1 WEAPON_WINDSTAR trunk.weapon+ -15 trunk-food+ picon charm-anime ' anime-4 ++
;
: trade-anime-roll args( chara )
	<- chara .trait@ "Anime Fan" $= if
		<- chara .morale4+
	then;
	<- chara .cwits+ if
		<- chara .morale--
	else
		<- chara .morale3+
	then
;
: trade-anime-fancrush args( chara )
	<- chara .trait@ "Anime Fan" $= if
		<- chara .morale4-
	then
;
cyoa-choice: trade-anime-10
	($ Thegroup .. " achete une figurine anime. Elle semble vraiment chere...
	" .. "JE VOIS QUE VOUS AVEZ UN GOUT EXQUIS !" pbold $) cyoa-text! basic-tone
	' trade-anime-roll foreach-team-char -10 trunk-food+ picon charm-anime ' anime-3 ++
;

cyoa-choice: trade-anime-5
	($ Thegroup .. " achete 4 katanas.
	" .. "ASSEZ POUR TOUT UN GROUPE ! COUPEZ A TRAVERS TOUT !" pbold $) cyoa-text! basic-tone
	4 WEAPON_OTAKU trunk.weapon+ -5 trunk-food+ picon charm-anime ' anime-2 ++
;

cyoa-choice: trade-anime-1
	($ Thegroup .. " achete 5 Shuriken.
	" .. "AFFAIRE INCROYABLE !" pbold $) cyoa-text! basic-tone
	5 WEAPON_SHURIKEN trunk.weapon+ -1 trunk-food+ picon ' anime-1 ++
;
cyoa-choice: trade-anime-coolit
	cpet? if
		($ cname .. " detruit des animes, en guise de protestation contre l'existence meme de l'anime. Le marchand d'anime comprend le message." $)
	else
		($ cname .. " dit au marchand d'anime de " .. "SE CALMER.
	L'ANIME C'EST PAS LA REALITE NON PLUS !" pbold $) then cyoa-text!
	cool-it++
		($ "Il n'y avait aucune chance qu'il prenne ca bien.
		" .. "NON ! T'AS TORT ! ARRETE ! NOooooooon !" rbold .. "
		Il monte dans le camion et demarre en trombe de rage et de confusion. Les autres marchands sont sous le choc !" $) badfx +crtext attitudeREV witsREV
		' trade-anime-fancrush foreach-team-char
		trade-flee
;
cyoa-choice: trade-anime-anime
	picon
	($ pname .. " dit son expression signature.
	" .. "Ahem. " pbold .. "'Rayon d'Amour'" rainbold .. " *toussote*" pbold $) text! goodfx
	($ "L'homme anime " .. "PETE LES PLOMBS" fbold .. " et cede tout son stock et une bonne partie de ses provisions personnelles en cadeau !" $) +crtext clear-cyoa
	morale3+all 12 trunk-food+ 1 WEAPON_WINDSTAR trunk.weapon+
	5 WEAPON_SHURIKEN trunk.weapon+ 5 WEAPON_OTAKU trunk.weapon+
;
cyoa: trade-anime
	"La Derniere Vente Anime" cyoa-title!
	"Cet homme vend des animes et accessoires anime depuis un camion-restaurant reconverti." text!
	pchar .trait@ "Anime Fan" $= if
		($ pname .. " PETE LES PLOMBS" fbold .. " devant le Camion Anime !" $) +crtext
		pchar .morale4+ goodfx +cr
	else
		($ "JE FAIS MA PART POUR GARDER LA CIVILISATION ENSEMBLE, UNE VENTE D'ANIME A LA FOIS !" pbold $) +crtext
	then
	basic-tone foodamt
	choice( "N'acheter AUCUN anime" )choice back-esc
	most-ahole if
		charchoice( " vole le marchand" )choice: trade-anime-rob
	then
	most-grating if
		charchoice( " lui dit de SE CALMER" )choice: trade-anime-coolit
	then
	pchar anime? if
		pchar charchoice( " dit son expression anime" rainbold )choice: trade-anime-anime
	then
	trunk-food 1 < if
		($ "Malheureusement, pas assez de nourriture pour l'anime, mais il donne un shuriken gratuit en souvenir." $) +cr +text
		1 WEAPON_SHURIKEN trunk.weapon+ clear-cyoa
	else
		trunk-food 14 > anime-4 1 < and if
			choice( "Etoile du Vent pour 15 nourriture" )choice: trade-anime-20
		then
		trunk-food 9 > anime-3 1 < and if
			choice( "Figurine Anime pour 10 nourriture" )choice: trade-anime-10
		then
		trunk-food 4 > anime-2 1 < and if
			choice( "4 Katanas pour 5 nourriture" )choice: trade-anime-5
		then
		anime-1 1 < if
			choice( "5 Shuriken pour 1 nourriture" )choice: trade-anime-1
		then
	then
;

// Blunt Master

0 value blunt-sledge
0 value blunt-megamaul

cyoa-choice: trade-blunt-rob

		($ "La Maitresse des Masses repousse " .. thegroup .. " en leur lancant un tas de marteaux, dont une masse. " .. cname .. " les ramasse par terre." $) cyoa-text! bitefx rob-fail 1 WEAPON_SLEDGE trunk.weapon+ 1 WEAPON_BALLPEEN trunk.weapon+ 2 WEAPON_CLAWHAMMER trunk.weapon+
		aholeREV trade-flee
;
cyoa-choice: trade-blunt-coolit
	cpet? if
		($ cname .. " mache la masse de la Maitresse des Masses." $)
	else
		($ cname .. " dit a la Maitresse des Masses de " .. "SE CALMER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Elle glousse.
		" .. "Enfin ! Quelqu'un qui comprend l'importance de se detendre ! Il etait temps." pbold .. "
		La Maitresse des Masses donne a " .. cname .. " sa meilleure arme, une " .. "Mega-Masse." rbold $) goodfx
		1 WEAPON_MEGAMAUL trunk.weapon+ cooled-it clear-cyoa
	else cool-it++
		($ "Son humeur paisible est gachez.
		Elle commence a lancer des marteaux dans une rage aveugle. " .. Thegroup .. " est force de fuir le camp de commerce." $) badfx quitmission
	then +crtext attitudeREV witsREV
;

cyoa-choice: trade-blunt-special
	($ Thegroup .. " achete le " .. "PACK SPECIAL" rainbold .. " !
	" .. "Aujourd'hui seulement ! Voici une tonne d'armes contondantes !" pbold $) cyoa-text! goodfx
	1 WEAPON_MEGAMAUL trunk.weapon+ 1 WEAPON_SLEDGE trunk.weapon+ 1 WEAPON_BALLPEEN trunk.weapon+
	1 WEAPON_CLAWHAMMER trunk.weapon+ 1 WEAPON_LOG trunk.weapon+
	-8 trunk-food+ someicon ' blunt-megamaul ++
;

cyoa-choice: trade-blunt-4
	($ Thegroup .. " achete la " .. "MEGA-MASSE" rbold .. ", jadis vue a la tele. Peut ecraser jusqu'a 3 zombies d'un coup, avec de la chance. Comme dans les vieilles pubs.
	" .. "La... la Reine des Marteaux. Je l'ai vendue si pas cher seulement parce que vous etes un fan d'armes contondantes." pbold $) cyoa-text! goodfx
	1 WEAPON_MEGAMAUL trunk.weapon+ -16 trunk-food+ someicon ' blunt-megamaul ++
;

cyoa-choice: trade-blunt-3
	($ Thegroup .. " achete une masse. Pret a ecraser des zombies.
	" .. "La on parle ! C'est une arme contondante puissante, si vous avez la force et la forme pour ca." pbold $) cyoa-text! goodfx
	1 WEAPON_SLEDGE trunk.weapon+ -8 trunk-food+ someicon ' blunt-sledge ++
;

cyoa-choice: trade-blunt-2
	($ Thegroup .. " achete un lourd marteau de forgeron.
	" .. "Parfait pour les cranes de zombies ! J'en ai beaucoup plus, si vous en voulez d'autres." pbold $) cyoa-text! goodfx
	1 WEAPON_BALLPEEN trunk.weapon+ -3 trunk-food+ someicon
;

cyoa-choice: trade-blunt-1
	($ Thegroup .. " achete un beau marteau a griffe neuf.
	" .. "Merci pour le commerce. J'en ai une quantite infinie." pbold $) cyoa-text! goodfx
	1 WEAPON_CLAWHAMMER trunk.weapon+ -2 trunk-food+ someicon
;

cyoa: trade-blunt
	"Maitresse des Masses" cyoa-title!
	($ Thegroup .. " rencontre une femme couverte de marteaux. Ils pendent de plusieurs ceintures a outils et bandoulieres.
	" .. "Vous voulez un secret ?
	J'adore les armes contondantes. Je vous vends mes reserves, pas cher !" pbold $) cyoa-text! basic-tone foodamt
	choice( "La laisser" )choice back-esc
	most-ahole if
		charchoice( " vole le marchand" )choice: trade-blunt-rob
	then
	most-grating if
		charchoice( " lui dit de SE CALMER" fcoolit )choice: trade-blunt-coolit
	then
	trunk-food 2 < if
		($ "Pas assez de nourriture pour acheter quoi que ce soit ! En consolation le marchand donne a " .. thegroup .. " une buche en bois, l'arme contondante de la nature." $) +crtext goodfx 1 WEAPON_LOG trunk.weapon+ clear-cyoa
	else
		time.month 3 = time.month.day 20 = and if
			trunk-food 7 > blunt-megamaul 1 < and if
				choice( "PACK SPECIAL AUJOURD'HUI" rainbold .. " pour 8 nourriture !" )choice: trade-blunt-special
			then
		else
			trunk-food 15 > blunt-megamaul 1 < and if
				choice( "Mega-Masse pour 16 nourriture" )choice: trade-blunt-4
			then
		then
		trunk-food 7 > blunt-sledge 2 < and if
			choice( "Masse pour 8 nourriture" )choice: trade-blunt-3
		then
		trunk-food 2 > if
			choice( "Marteau de Forgeron pour 3 nourriture" )choice: trade-blunt-2
		then
		trunk-food 1 > if
			choice( "Marteau a Griffe pour 2 nourriture" )choice: trade-blunt-1
		then
	then
;

