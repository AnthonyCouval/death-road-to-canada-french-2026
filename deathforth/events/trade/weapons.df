	($ Thegroup .. " achete la " .. "BARDICHE" rbold .. " !
	" .. "Faites attention en la balancant, elle est tres lourde ! Poussez avec les genoux, pas avec le dos." pbold $) cyoa-text! goodfx
	1 WEAPON_BARDICHE trunk.weapon+ -25 trunk-food+ someicon ' polearm-bardiche ++
;

cyoa-choice: trade-polearm-3
	($ Thegroup .. " achete une lance faite par le marchand." $) cyoa-text! goodfx
		polearm-spear 0 = if
			($ "C'est le dernier modele en matiere de conception de lances anti-zombies ! Tres facile a utiliser. Tres tactique.
			L'effet de levier permet aussi de n'utiliser qu'environ la moitie de l'effort pour attaquer par rapport a la plupart des autres armes !" pbold $) +crtext
		then
		polearm-spear 2 = if
			($ "C'est la derniere que j'ai en stock. J'espere que votre phalange va bien marcher !" pbold $) +crtext
		then
	1 WEAPON_MODSPEAR trunk.weapon+ -9 trunk-food+ someicon ' polearm-spear ++
;

cyoa-choice: trade-polearm-5
	($ Thegroup .. " achete une pique. Elle est presque aussi longue qu'une voiture !" $) cyoa-text! goodfx
		polearm-pike 0 = if
			($ "Je les ai pillees dans un musee. Ne demandez pas.
			Non seulement elles sont puissantes, mais elles ont une portee tremendous. Combattez avec facilite ! Un groupe de piques peut etre assez intimidant." pbold $) +crtext
		then
		polearm-pike 2 = if
			($ "C'est ma derniere pique. La cavalerie ferait bien de se tenir a l'ecart de vous !" pbold $) +crtext
		then
	1 WEAPON_STEELPIKE trunk.weapon+ -16 trunk-food+ someicon ' polearm-pike ++
;

cyoa-choice: trade-polearm-2
	($ Thegroup .. " achete une chaussure attachee a un baton.
	" .. "Je l'ai inventee ! Brevet en cours.
	Les problemes sont encore en cours de resolution. Pas de remboursement." pbold $) cyoa-text! goodfx
	1 WEAPON_STICKBOOT trunk.weapon+ -6 trunk-food+ someicon ' polearm-boot ++
;

cyoa-choice: trade-polearm-1
	($ Thegroup .. " achete une fourche.
	" .. "J'en ai plein a vendre ! Elles sont un peu ordinaires, mais ca marche." pbold $) cyoa-text! goodfx
	1 WEAPON_PITCHFORK trunk.weapon+ -3 trunk-food+ someicon
;

cyoa: trade-polearm
	"Ami des Armes d'Hast" cyoa-title!
	($ Thegroup .. " rencontre un homme qui brandit une lance faite maison. Malgre le fait que ce soit juste un couteau attache a un baton, ca aurait l'air d'etre une arme vraiment efficace.
	" .. "Rien ne bat les armes d'hast pour chasser les zombies !" pbold $) cyoa-text! basic-tone foodamt
	choice( "Le laisser" )choice back-esc
	most-ahole if
		charchoice( " vole le marchand" )choice: trade-polearm-rob
	then
	most-grating if
		charchoice( " lui dit de SE CALMER" fcoolit )choice: trade-polearm-coolit
	then
	trunk-food 3 < if
		($ "Pas assez de nourriture pour acheter quoi que ce soit ! En consolation le marchand donne a " .. thegroup .. " une queue de billard." $) +crtext goodfx 1 WEAPON_POOLCUE trunk.weapon+ clear-cyoa
	else
		trunk-food 24 > polearm-bardiche 1 < and if
			choice( "Bardiche pour 25 nourriture" )choice: trade-polearm-4
		then
		trunk-food 15 > polearm-pike 3 < and if
			choice( "Pique d'Acier pour 16 nourriture" )choice: trade-polearm-5
		then
		trunk-food 8 > polearm-spear 3 < and if
			choice( "Lance Tactique pour 9 nourriture" )choice: trade-polearm-3
		then
		trunk-food 5 > polearm-boot 1 < and if
			choice( "Botte-a-Baton pour 6 nourriture" )choice: trade-polearm-2
		then
		trunk-food 2 > if
			choice( "Fourche pour 3 nourriture" )choice: trade-polearm-1
		then
	then
;

// Silent Gun Trader

0 value silent-pistol
0 value silent-rifle
0 value silent-shotgun

cyoa-choice: trade-silent-3
	($ Thegroup .. " achete un fusil a pompe silencieux.
	" .. "Ca resout le probleme habituel des fusils a pompe : attirer tous les zombies de la ville.
	La cadence de tir est entre un fusil a pompe normal et un automatique. Ca peut faire des degats." pbold $) cyoa-text! goodfx
	1 WEAPON_SILENTSHOTGUN trunk.weapon+ -30 trunk-food+ someicon ' silent-shotgun ++
;

cyoa-choice: trade-silent-2
	($ Thegroup .. " achete un fusil de sniper !
	" .. "Bon choix. C'est mon prefere.
	Je l'ai modifie pour avoir un tres fort potentiel de perforation. Entre de bonnes mains, il pourrait faire sauter toute une rangee de zombies en un seul tir. A longue portee, dans un quasi-silence." pbold $) cyoa-text! goodfx
	1 WEAPON_SILENTRIFLE trunk.weapon+ -25 trunk-food+ someicon ' silent-rifle ++
;

cyoa-choice: trade-silent-1
	($ Thegroup .. " achete un pistolet silencieux." $) cyoa-text! goodfx
		silent-pistol 0 = if
			($ "J'en ai quelques autres a vendre, si vous voulez des armes silencieuses pour tout un groupe !" pbold $) +crtext
		then
		silent-pistol 3 = if
			($ "C'est mon dernier pistolet. Profitez de votre nouvel arsenal discret mais mortel !" pbold $) +crtext
		then
	1 WEAPON_SILENTPISTOL trunk.weapon+ -3 trunk-food+ someicon ' silent-pistol ++
;

cyoa: trade-silent
	"Discret Mais Mortel" cyoa-title!
	($ "Cette personne suspecte porte un masque et tient un beau fusil de sniper silencieux.
	" .. "Mes armes sont tellement silencieuses. Vous attirerez bien moins de zombies par tir." pbold $) cyoa-text! basic-tone foodamt
	(* most-ahole if
		charchoice( " devalise le marchand" )choice: trade-silent-rob
	then
	most-grating if
		charchoice( " tells him to COOL IT" fcoolit )choice: trade-silent-coolit
	then *)
	trunk-food 3 < if
		($ "Pas assez de nourriture pour acheter quoi que ce soit ! En consolation le marchand donne a " .. thegroup .. " un pistolet silencieux gratuit." $) +crtext goodfx 1 WEAPON_SILENTPISTOL trunk.weapon+ clear-cyoa
	else
		choice( "Partir pour l'instant" )choice back-esc
		trunk-food 2 > silent-pistol 4 < and if
			choice( "Pistolet Silencieux pour 3 nourriture" )choice: trade-silent-1
		then
		trunk-food 24 > silent-rifle 1 < and if
			choice( "Fusil de Sniper pour 25 nourriture" )choice: trade-silent-2
		then
		trunk-food 29 > silent-shotgun 1 < and if
			choice( "Fusil a Pompe Silencieux pour 30 nourriture" )choice: trade-silent-3
		then
	then
;

// Handy Tools Trader

0 value handy-flashlight
0 value handy-spray
0 value handy-tacticop

cyoa-choice: trade-handy-3
	($ Thegroup .. " achete un TactiCop Lite[MC] !
	" .. "Le roi des lampes torches ! Aussi bien pour cogner des cranes de zombies !" pbold $) cyoa-text! goodfx
	1 WEAPON_TACTICOP trunk.weapon+ -5 trunk-food+ someicon ' handy-tacticop ++
;

cyoa-choice: trade-handy-2
	($ Thegroup .. " achete un Spray de Soins !
	" .. "Vaporisez quelqu'un pour le soigner. Vous pouvez vous vaporiser en marchant dans le nuage de soins ! En cas d'urgence, vous pouvez aussi faire fondre des zombies avec." pbold $) cyoa-text! goodfx
	3 WEAPON_HEALSPRAY trunk.weapon+ -6 trunk-food+ someicon ' handy-spray ++
;

cyoa-choice: trade-handy-1
	($ Thegroup .. " achete une lampe torche." $) cyoa-text! goodfx
		handy-flashlight 0 = if
			($ "J'en ai un million, si vous avez besoin de centaines de lampes torches." pbold $) +crtext
		then
	1 WEAPON_FLASHLIGHT trunk.weapon+ -1 trunk-food+ someicon ' handy-flashlight ++
;


// Could add more to handy survival tools later, likely have the healing spray get pushed offscreen
// Firecrackers would be good here, maybe land mines?
cyoa: trade-handy
	"Outils de Survie Pratiques" cyoa-title!
	($ "Ce marchand agite une solide lampe torche militaire. C'est une vieille astuce commerciale pour attirer les clients.
	" .. "Mieux vaut etre prepare !" pbold $) cyoa-text! basic-tone foodamt
	(* most-ahole if
		charchoice( " devalise le marchand" )choice: trade-handy-rob
	then
	most-grating if
		charchoice( " tells him to COOL IT" fcoolit )choice: trade-handy-coolit
	then *)
	trunk-food 1 < if
		($ "Vous n'avez plus de nourriture ! Le marchand donne a " .. thegroup .. " une lampe torche gratuite." $) +crtext goodfx 1 WEAPON_FLASHLIGHT trunk.weapon+ clear-cyoa
	else
		choice( "Partir pour l'instant" )choice back-esc
		trunk-food 5 > handy-spray 3 < and if
			choice( "Spray de Soins pour 6 nourriture" )choice: trade-handy-2
		then
		trunk-food 4 > handy-tacticop 1 < and if
			choice( "TactiCop Lite pour 5 nourriture" )choice: trade-handy-3
		then
		trunk-food 0 > if
			choice( "Lampe Torche pour 1 nourriture" )choice: trade-handy-1
		then
	then
;

// Heavy Weapons Trader

0 value heavy-mine2
0 value heavy-glaunch
0 value heavy-mine1
0 value heavy-bazooka

cyoa-choice: trade-heavy-mine2
	($ Thegroup .. " achete 8 mines terrestres." $) cyoa-text! goodfx
		($ "Posez un piege pour les zombies avec ca, puis laissez les explosions faire tout le travail !" pbold $) +crtext
	8 WEAPON_LANDMINE trunk.weapon+ -20 trunk-food+ someicon ' heavy-mine2 ++
;

cyoa-choice: trade-heavy-1
	($ Thegroup .. " achete un lance-grenades avec 6 tirs !
	" .. "Vous pouvez tirer ca directement dans une foule de zombies ! Les grenades explosent apres une seconde." pbold $) cyoa-text! goodfx
	6 WEAPON_GLAUNCH trunk.weapon+ -12 trunk-food+ someicon ' heavy-glaunch ++
;

cyoa-choice: trade-heavy-2
	($ Thegroup .. " achete un bazooka et trois roquettes !
	" .. "C'est L'OUTIL pour faire exploser une foule de zombies, vite." pbold $) cyoa-text! goodfx
	3 WEAPON_BAZOOKA trunk.weapon+ -12 trunk-food+ someicon ' heavy-bazooka ++
;

cyoa-choice: trade-heavy-mine1
	($ Thegroup .. " achete 2 mines terrestres." $) cyoa-text! goodfx
		($ "Posez-en une par terre, puis courez et attendez l'explosion !" pbold $) +crtext
	2 WEAPON_LANDMINE trunk.weapon+ -6 trunk-food+ someicon ' heavy-mine1 ++
;

cyoa: trade-heavy
	"Artillerie Lourde" cyoa-title!
	($ Thegroup .. " rencontre un homme qui tient un bazooka et une sacoche bourree de mines bip-bip. Il a l'air tellement content avec ses explosifs.
	" .. "Ces armes ne vous decevront pas ! Sauf, bien sur, si vous vous faites exploser avec." pbold $) cyoa-text! basic-tone foodamt
	trunk-food 6 < if
		($ "Vous n'avez plus de nourriture ! Le marchand donne a " .. thegroup .. " une mine terrestre offerte." $) +crtext goodfx 1 WEAPON_LANDMINE trunk.weapon+ clear-cyoa
	else
		choice( "Partir pour l'instant" )choice back-esc
		trunk-food 19 > heavy-mine2 1 < and if
			choice( "8 Mines Terrestres pour 20 nourriture" )choice: trade-heavy-mine2
		then
		trunk-food 11 > heavy-bazooka 1 < and if
			choice( "Bazooka - 3 tirs - 12 nourriture" )choice: trade-heavy-2
		then
		trunk-food 11 > heavy-glaunch 1 < and if
			choice( "Lance-grenades - 6 tirs - 12 nourriture" )choice: trade-heavy-1
		then
		heavy-mine1 1 < if
			choice( "2 Mines Terrestres pour 6 nourriture" )choice: trade-heavy-mine1
		then
	then
;

// Fireworks Trader

0 value fireworks-4
0 value fireworks-3
0 value fireworks-2
0 value fireworks-1

cyoa-choice: trade-fireworks-special
	($ Thegroup .. " achete un fouet de feu ! Des braises rebondissent doucement sur son extremite incandescente." $) cyoa-text! goodfx
		($ "Je l'ai vole a un gars qui gerait un cirque.
		Surtout ne vous frappez pas avec ! Meilleur usage sur des groupes d'ennemis.
		Il est assez leger, donc peut-etre le donner a vos personnages peu athletiques." pbold $) +crtext
	1 WEAPON_HIGHWHIP trunk.weapon+ -20 trunk-food+ someicon
;

cyoa-choice: trade-fireworks-4
	($ Thegroup .. " achete un KO Boomer ! Anciennement illegal dans presque tous les pays !" $) cyoa-text! goodfx
		($ "J'entends que c'est encore vraiment illegal au Canada !
		25% de chances de se faire exploser ! Tentez votre chance !
		Si ca chauffe dans votre main, essayez de le lacher et de courir TRES vite !" pbold $) +crtext
	20 WEAPON_KOBOOMER trunk.weapon+ -5 trunk-food+ someicon ' fireworks-4 ++
;

cyoa-choice: trade-fireworks-3
	($ Thegroup .. " achete une chandelle romaine !
	" .. "C'est tellement joli ! Les zombies adorent ca !" pbold $) cyoa-text! goodfx
	10 WEAPON_ROMANCANDLE trunk.weapon+ -3 trunk-food+ someicon ' fireworks-3 ++
;

cyoa-choice: trade-fireworks-2
	($ Thegroup .. " achete un pack de deux Mont Dingus" .. "[MC]" pbold .. " !
	LE feu d'artifice LE PLUS decevant du marche.
	" .. "Il n'explose meme pas ! Il crache juste des petites etincelles !
	Je le deteste !" pbold $) cyoa-text! goodfx
	2 WEAPON_MOUNTDINGUS trunk.weapon+ -3 trunk-food+ someicon ' fireworks-2 ++
;

cyoa-choice: trade-fireworks-1
	($ Thegroup .. " achete 3 paquets de petards." $) cyoa-text! goodfx
		($ "Allumez un paquet, puis regardez les zombies le poursuivre !" pbold $) +crtext
	3 WEAPON_FIRECRACKERS trunk.weapon+ -2 trunk-food+ someicon ' fireworks-1 ++
;

cyoa: trade-firework
	"Passionnee de Feux d'Artifice" cyoa-title!
	($ Thegroup .. " rencontre une femme qui tient une chandelle romaine. Elle n'est pas allumee. Elle semble prete a l'allumer a " .. "N'IMPORTE QUEL MOMENT.
	" rbold
	.. "Tellement puissants ! Tellement jolis ! Tellement pratiques !" pbold $) cyoa-text! basic-tone foodamt
	trunk-food 4 > fireworks-4 3 < and if
		"Je ne serai pas responsable si vous vous faites exploser avec le KO Boomer !" pbold +crtext
	then
	trunk-food 2 < if
		($ "Vous n'avez plus de nourriture ! Le marchand donne a " .. thegroup .. " un paquet de petards offert." $) +crtext goodfx 1 WEAPON_FIRECRACKERS trunk.weapon+ clear-cyoa
	else
		choice( "Partir pour l'instant" )choice back-esc
		trunk-food 19 > if
			choice( "Fouet de Feu - 20 nourriture" )choice: trade-fireworks-special
		then
		trunk-food 4 > fireworks-4 3 < and if
			choice( "KO Boomer - 5 nourriture" )choice: trade-fireworks-4
		then
		trunk-food 2 > fireworks-3 3 < and if
			choice( "Chandelle Romaine - 3 nourriture" )choice: trade-fireworks-3
		then
		trunk-food 2 > fireworks-2 2 < and if
			choice( "2 Mont Dingus" .. "[MC]" pbold .. " - 3 nourriture" )choice: trade-fireworks-2
		then
		fireworks-1 3 < if
			choice( "3 Petards - 2 nourriture" )choice: trade-fireworks-1
		then
	then
;

} } 
