cyoa: trade-rifle-shell
	"Vendeur de Balles de Fusil" cyoa-title! picon!
	($ Thegroup .. " tombe sur quelqu'un qui vend des balles de fusil supplementaires. Elle dit etre econome avec ses munitions, tuant souvent plusieurs zombies en un seul tir." $) text!
	rifle-shell-bought 15 < if
		"Elle propose 6 balles de fusil par unite de nourriture." +crtext foodamt
		choice( "Non merci" )choice back-esc
		most-ahole if
			charchoice( " devalise la marchande" )choice: trade-rifle-shell-rob
		then
	else
		clear-cyoa "Elle est a court de balles de fusil." +crtext
	then basic-tone
	trunk-food 0 > if
		trunk-food 14 > rifle-shell-bought 5 < and if
			choice( "Echanger 15 nourriture" )choice: trade-rifle-shell-15
		then
		trunk-food 9 > rifle-shell-bought 10 < and trunk-food and if
			choice( "Echanger 10 nourriture" )choice: trade-rifle-shell-10
		then
		rifle-shell-bought 15 < if
			trunk-food 4 > if
				choice( "Echanger 5 nourriture" )choice: trade-rifle-shell-5
			else
