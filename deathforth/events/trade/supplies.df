cyoa{ regiondef{

: trade-flee
    team-count-alive-permanent if
        // ($ Thegroup .. " est force de fuir le camp de marchands !" $) +crtext quitmission
        team-stack-living depths 1 > if drop "Le groupe" else shuffles pops nip .colourname then
        " est force de fuir le camp de marchands !" .. +crtext quitmission
    else 
        clear-streak delete-the-game
        ' quit-to-title cyoa-choice-handler! 
    then
;

// Trading gas for food

0 value gas-to-food-bought

cyoa-choice: trade-gas-food-rob 
	($ cname .. " renverse l'homme, attrape un sac de nourriture et s'enfuit. " $) cyoa-text! badfx
	notsolo if
		($ Theothersare .. " dragged into it." $) +text
	then
	6 10 rnd trunk-food+ rob-guilt
	aholeREV trade-flee
;

cyoa-choice: trade-gas-food-2
	($ Thegroup .. " echange 25 unites d'essence contre 2 nourriture." $) cyoa-text! basic-tone
	-25 trunk-gas+ 2 trunk-food+ 2 ' gas-to-food-bought +!
;

cyoa-choice: trade-gas-food-4
	($ Thegroup .. " echange 50 unites d'essence contre 4 nourriture." $) cyoa-text! basic-tone
	-50 trunk-gas+ 4 trunk-food+ 4 ' gas-to-food-bought +!
;

cyoa-choice: trade-gas-food-8
	($ Thegroup .. " echange 100 unites d'essence contre 8 nourriture." $) cyoa-text! basic-tone
	-100 trunk-gas+ 8 trunk-food+ 8 ' gas-to-food-bought +!
;

cyoa: trade-gas-food
	"Conversion Essence-en-Vivres" cyoa-title!
//	iicon
	($ Thegroup .. " sees a man standing near an SUV." $) cyoa-text!
	gas-to-food-bought 20 < if
		($ "Tu as de l'essence de rechange ? J'en manque !
		" pbold .. "Il propose de te donner 2 boites de nourriture pour 25 unites d'essence." $)
		+crtext gasamt
		choice( "Non merci" )choice back-esc
		most-ahole if
			charchoice( " le devalise" )choice: trade-gas-food-rob
		then
	else
		clear-cyoa ($ "Merci pour toute l'essence !" pbold $) +crtext
	then basic-tone 
	trunk-gas 25 < if
		($ "Pas assez a epargner." $) +text
	else
		trunk-gas 99 > gas-to-food-bought 13 < and if
			choice( "Echanger 100 essence" )choice: trade-gas-food-8
		then
		trunk-gas 49 > gas-to-food-bought 17 < and if
			choice( "Echanger 50 essence" )choice: trade-gas-food-4
		then
		trunk-gas 24 > gas-to-food-bought 19 < and if
			choice( "Echanger 25 essence" )choice: trade-gas-food-2
		then
	then
;

// Gas

0 value gas-bought

cyoa-choice: trade-gas-rob 
	($ cname .. " attrape quelques jerricanes d'essence et s'enfuit. " $) cyoa-text! badfx
	notsolo if
		($ Theothersare .. " dragged into it." $) +text
	then
	40 70 rnd trunk-gas+ rob-guilt
	aholeREV trade-flee
;

cyoa-choice: trade-gas-5
	($ Thegroup .. " echange 5 nourriture contre 50 unites d'essence." $) cyoa-text! basic-tone
	food-5-to-gas 5 ' gas-bought +!
;

cyoa-choice: trade-gas-10
	($ Thegroup .. " echange 10 nourriture contre 100 unites d'essence." $) cyoa-text! basic-tone
	food-10-to-gas 10 ' gas-bought +!
;

cyoa-choice: trade-gas-15
	($ Thegroup .. " echange 15 nourriture contre 150 unites d'essence." $) cyoa-text! basic-tone
	food-15-to-gas 15 ' gas-bought +!
;

cyoa-choice: trade-gas-all
	($ Thegroup .. " trades " .. ghis .. " nourriture restante contre de l'essence." $) cyoa-text! basic-tone
	food-all-to-gas 5 ' gas-bought +!
;

cyoa: trade-gas
	"Essence a Vendre" cyoa-title! picon!
	($ Thegroup .. " trouve un homme pres d'un camion rouille. Le camion est plein de jerricanes et de chiffons graisseux. L'homme et le camion puent l'essence." $) cyoa-text!
	gas-bought 15 < if
		"Il propose de vendre 10 unites d'essence contre chaque unite de nourriture." +crtext 
		foodamt
		choice( "Non merci" )choice back-esc
		most-ahole if
			charchoice( " devalise le marchand" )choice: trade-gas-rob
		then
	else
		clear-cyoa "Il est a court d'essence." +crtext 
	then basic-tone 
	// Possibly replace some with weaselest-pass if weaselest
	trunk-food 0 > if
		trunk-food 14 > gas-bought 5 < and if
			choice( "Echanger 15 nourriture" )choice: trade-gas-15
		then
		trunk-food 9 > gas-bought 10 < and if
			choice( "Echanger 10 nourriture" )choice: trade-gas-10
		then
		gas-bought 15 < if
			trunk-food 4 > if
				choice( "Echanger 5 nourriture" )choice: trade-gas-5
			else	
				choice( "Echanger " .. trunk-food .. " nourriture" )choice: trade-gas-all
			then
		then
	then
;

// Bullets

0 value bullet-bought

cyoa-choice: trade-bullet-rob 
	($ cname .. " attrape quelques boites de balles et s'enfuit. La fouilleur mentait sur les armes, et envoie quelques balles supplementaires vers " .. thegroup .. "." $) cyoa-text! bitefx 50 80 rnd trunk-bullet+
		rob-fail
	aholeREV trade-flee
;

cyoa-choice: trade-bullet-5
	($ Thegroup .. " echange 5 nourriture contre 40 balles." $) cyoa-text! basic-tone
	food-5-to-bullet 5 ' bullet-bought +!
;

cyoa-choice: trade-bullet-10
	($ Thegroup .. " echange 10 nourriture contre 80 balles." $) cyoa-text! basic-tone
	food-10-to-bullet 10 ' bullet-bought +!
;

cyoa-choice: trade-bullet-15
	($ Thegroup .. " echange 15 nourriture contre 120 balles." $) cyoa-text! basic-tone
	food-15-to-bullet 15 ' bullet-bought +!
;

cyoa-choice: trade-bullet-all
	($ Thegroup .. " trades " .. ghis .. " nourriture restante contre des balles." $) cyoa-text! basic-tone
	food-all-to-bullet 5 ' bullet-bought +!
;

cyoa: trade-bullet
	"Surplus de Balles" cyoa-title! picon!
	($ Thegroup .. " parle a une fouilleure sympathique qui vend des balles supplementaires. Elle pretend ne pas utiliser de pistolets car les coups de feu agitent les zombies." $) text!
	bullet-bought 15 < if 
		"Elle propose 8 balles pour chaque unite de nourriture." +crtext foodamt
		choice( "Non merci" )choice back-esc
		most-ahole if
			charchoice( " devalise la marchande" )choice: trade-bullet-rob
		then		
	else
		clear-cyoa "Elle vient de manquer de balles." +crtext
	then basic-tone
	trunk-food 0 > if
		trunk-food 14 > bullet-bought 5 < and if
			choice( "Echanger 15 nourriture" )choice: trade-bullet-15
		then
		trunk-food 9 > bullet-bought 10 < and if
			choice( "Echanger 10 nourriture" )choice: trade-bullet-10
		then
		bullet-bought 15 < if
			trunk-food 4 > if
				choice( "Echanger 5 nourriture" )choice: trade-bullet-5
			else	
				choice( "Echanger " .. trunk-food .. " nourriture" )choice: trade-bullet-all
			then
		then
	then
;

// Shotgun Shells

0 value shotgun-shell-bought

cyoa-choice: trade-shotgun-shell-rob 
	($ cname .. " prend une grande boite de cartouches et s'en va. Dans un geste calme et fluide, le marchand degaine son fusil a pompe et starts blasting." $) cyoa-text! bitefx
		30 40 rnd trunk-shotgun-shell+ rob-fail	aholeREV trade-flee
;

cyoa-choice: trade-shotgun-shell-5
	($ Thegroup .. " echange 5 nourriture contre 25 cartouches." $) cyoa-text! basic-tone
	food-5-to-shotgun-shell 5 ' shotgun-shell-bought +!
;

cyoa-choice: trade-shotgun-shell-10
	($ Thegroup .. " echange 10 nourriture contre 50 cartouches." $) cyoa-text! basic-tone
	food-10-to-shotgun-shell 10 ' shotgun-shell-bought +!
;

cyoa-choice: trade-shotgun-shell-15
	($ Thegroup .. " echange 15 nourriture contre 75 cartouches." $) cyoa-text! basic-tone
	food-15-to-shotgun-shell 15 ' shotgun-shell-bought +!
;

cyoa-choice: trade-shotgun-shell-all
	($ Thegroup .. " trades " .. ghis .. " nourriture restante contre des cartouches." $) cyoa-text! basic-tone
	food-all-to-shotgun-shell 5 ' shotgun-shell-bought +!
;

cyoa: trade-shotgun-shell
	"Stand de Cartouches" cyoa-title! picon!
	($ Thegroup .. " voit un homme bourru pres d'un camion de glaces. Les mots " .. "GLACES" pbold .. " ont ete barres sur le panneau avec " .. "CARTOUCHES" rbold .. " ecrit a la place." $) cyoa-text!
	shotgun-shell-bought 15 < if
		"Il propose de vendre 5 cartouches pour chaque unite de nourriture." +crtext foodamt
		choice( "Non merci" )choice back-esc
		most-ahole if
			charchoice( " devalise le marchand" )choice: trade-shotgun-shell-rob
		then
	else
		clear-cyoa "Il est a court de cartouches." +crtext
	then basic-tone
	trunk-food 0 > if
		trunk-food 14 > shotgun-shell-bought 5 < and if
			choice( "Echanger 15 nourriture" )choice: trade-shotgun-shell-15
		then
		trunk-food 9 > shotgun-shell-bought 10 < and if
			choice( "Echanger 10 nourriture" )choice: trade-shotgun-shell-10
		then
		shotgun-shell-bought 15 < if
			trunk-food 4 > if
				choice( "Echanger 5 nourriture" )choice: trade-shotgun-shell-5
			else
				choice( "Echanger " .. trunk-food .. " nourriture" )choice: trade-shotgun-shell-all
			then
		then
	then
;

// Rifle Shells

0 value rifle-shell-bought

cyoa-choice: trade-rifle-shell-rob
	($ Thegroup .. "'s tentative de vol tourne mal. La vendeuse a deux fusils d'assaut charges. Elle tire dans tous les sens, un dans chaque main, arrosant ammo everywhere." $) cyoa-text! bitefx
		40 65 rnd trunk-rifle-shell+ rob-fail aholeREV trade-flee
;

cyoa-choice: trade-rifle-shell-5
	($ Thegroup .. " echange 5 nourriture contre 30 balles de fusil." $) cyoa-text! basic-tone
	food-5-to-rifle-shell 5 ' rifle-shell-bought +!
;

cyoa-choice: trade-rifle-shell-10
	($ Thegroup .. " echange 10 nourriture contre 60 balles de fusil." $) cyoa-text! basic-tone
	food-10-to-rifle-shell 10 ' rifle-shell-bought +!
;
cyoa-choice: trade-rifle-shell-15
	($ Thegroup .. " echange 15 nourriture contre 90 balles de fusil." $) cyoa-text! basic-tone
	food-15-to-rifle-shell 15 ' rifle-shell-bought +!
;

cyoa-choice: trade-rifle-shell-all
	($ Thegroup .. " trades " .. ghis .. " nourriture restante contre des balles de fusil." $) cyoa-text! basic-tone
	food-all-to-rifle-shell 5 ' rifle-shell-bought +!
