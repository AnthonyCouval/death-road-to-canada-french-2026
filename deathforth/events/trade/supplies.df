cyoa: trade-weapon-buy
	"Troc d'Armes" cyoa-title!
//	iicon
	($ Thegroup .. " voit une femme debout pres d'un stock de caisses. Les caisses semblent contenir une grande quantite de nourriture et de boissons." $) cyoa-text!
		($ "J'ai de la nourriture ! Je cherche de super armes !
		" pbold .. "Elle jette un rapide coup d'oeil a ce que " .. pname .. " transporte..." $) +crtext
	pchar-weapon-sell-check if
		choice( "Ne rien donner pour l'instant" )choice back-esc
	else 
		"Elle ne voit rien qui l'interesse !" +crtext
		WEAPON_LIST_SELLABLE roadtrip-has-weapontype? if
			" Cependant, il y a quelque chose que tu peux vendre " +text
			WEAPON_LIST_SELLABLE team-has-weapontype? if
				"sur un autre personnage."
			else
				"dans le coffre de la voiture."
			then +text
		then
		choice( "Revenir plus tard" )choice back-esc
	then
	pchar ahole? if
		pchar charchoice( " robs her" )choice: trade-weapon-buy-rob
	then
	basic-tone 

	// WEAPON_ pchar-weapon? if choice( "Sell  - 1 food" )choice: trade-weapon- then
	// Prices roughly a quarter of their buy prices
	// This can vary, or better if the item is rare
	WEAPON_BARDICHE pchar-weapon? if choice( "Sell Bardiche - 6 food" )choice: trade-weapon-bardiche then
	WEAPON_SKULLMACE pchar-weapon? if choice( "Sell Skull Mace - 10 food" )choice: trade-weapon-skullmace then
