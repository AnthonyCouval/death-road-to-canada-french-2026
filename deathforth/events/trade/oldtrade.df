// Collectionneuse de Fusils

cyoa-choice: trade-rifle-coolit
	cpet? if
		($ cname .. " jette un oeil a la collection puis leve les yeux au ciel." $)
	else
		($ cname .. " dit a la sympathique collectionneuse de " .. "SE CALMER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Elle hoche la tete en signe d'accord.
		" .. "Ouais, ma collection devient trop grosse. Ca t'irait de m'en prendre quelques-uns ?" pbold .. "
		La collectionneuse donne a " .. cname .. " un fusil de chasse a lunette et un " .. "fusil d'assaut." rbold $) goodfx
		1 WEAPON_HUNTING trunk.weapon+ 1 WEAPON_AK47 trunk.weapon+ cooled-it
	else cool-it++
		($ "La collectionneuse semble blessee par ca.
		" .. "Je... je suis calme..." pbold .. "
		Elle dit ensuite a " .. thegroup .. " de partir." $) badfx
	then +crtext attitudeREV witsREV
;

