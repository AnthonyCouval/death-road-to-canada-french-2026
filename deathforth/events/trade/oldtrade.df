;

cyoa-choice: trade-blade-2
	($ Thegroup .. " achete un coupe-coupe tres solide mais leger. Assez robuste pour abattre des arbres, il ne se cassera pas avec 'un usage de road trip'." $) cyoa-text! goodfx
	1 WEAPON_MACHETE2 trunk.weapon+ -15 trunk-food+ someicon
;

cyoa-choice: trade-blade-1
	($ Thegroup .. " achete un katana du genre qu'on trouve dans un centre commercial. Il a l'air sur le point de se casser a tout moment. Quelle arnaque." $) cyoa-text! goodfx
	1 WEAPON_OTAKU trunk.weapon+ -5 trunk-food+ someicon
;

cyoa: trade-blade
	"Maitre des Lames" cyoa-title!
	($ Thegroup .. " rencontre un homme qui avance peniblement sur la route. Il porte de nombreuses epees dans des fourreaux ou attachees a son sac.
	" .. "Un jour je fabriquerai la plus belle epee a trancher les zombies qu'on ait jamais vue ! Meme si je dois d'abord comprendre comment fabriquer des epees. Je les ai juste trouves trainant la. Je vous en vends une !" pbold $) cyoa-text! basic-tone
	choice( "Partir" )choice
	most-ahole if
		charchoice( " vole le marchand" )choice: trade-blade-rob
	then
