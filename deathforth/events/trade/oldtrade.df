uses base.df
uses charfilt.df
uses charstats.df
uses road.df

cyoa{ road{



// if you have to do two things in a foreach-team-char word, use dup between each
// The above was wrong, I had to remove the second dup from everything
: trade-shoot-group! dup .shootingREV .shooting++ ;
: trade-strength-group! dup .strengthREV .strength++ ;
: trade-fitness-group! dup .fitnessREV .fitness++ ;
: trade-medical-group! dup .medicalREV .medical++ ;
: trade-mechanic-group! dup .mechanicREV .mechanic++ ;

: trade-train-amt team-count 3 * 3 + ;
// tried to use numhums instead of team-count but it didn't work right. The option wouldn't appear for group training.
: trade-train-pay? trunk-food trade-train-amt 1 - > notsolo and ; // previously notsolo and
// numhums 1 > was tried for above but made it buggy
: trade-train-pay trade-train-amt -1 * trunk-food+ ;

// Tir

cyoa-choice: trade-shoot-charm
	charmroll if
		($ cname .. " obtient une formation aux armes a feu GRATUITE ! " .. cHe .. " se sent deja plus precis." $) cyoa-text!
		cchar .shooting@ 5 > if
			($ "Ca n'a pas vraiment ameliore " .. chis .. " tir, mais c'etait GRATUIT !" $) +crtext
		then
		shootingREV shooting++ goodfx
	else
		($ cname .. " passe accidentellement pour quelqu'un de bizarre.
		" .. gHe .. " se fait expulser." $) cyoa-text! badfx
	then
;

cyoa-choice: trade-shoot-train
	cchar .shooting@ 6 < if
		($ cname .. " apprend de nouvelles techniques avec les armes a feu ! Les zombies n'ont qu'a bien se tenir." $) goodfx
	else
		($ cname .. " n'a rien appris de nouveau. " .. cHe .. " avait deja decouvert ces astuces par lui-meme." $) badfx
	then cyoa-text!
	-6 trunk-food+
	shootingREV shooting++
;

cyoa-choice: trade-shoot-group
	($ "Tout le groupe s'entraine aux armes a feu !" $) cyoa-text! goodfx
	trade-train-pay someicon
	' trade-shoot-group! foreach-human-char
;

cyoa: trade-shoot-give
	solohuman if
		choosehuman trade-shoot-train
	then;
	"Qui doit recevoir la formation au maniement des armes a feu ?" cyoa-text!
	' trade-shoot-train cyoa-human-choice
;

cyoa-choice: trade-shoot-coolit
	cpet? if
		($ cname .. " pete bruyamment en direction du coach de tir, puis se roule par terre." $)
	else
		($ cname .. " dit au coach de tir de " .. "LE DIRE PAS LE POSTILLONNER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Un miracle se produit : elle decide de ne pas tirer !
		" .. "On dirait que vous avez besoin de toute l'aide possible..." pbold .. "
		Elle enseigne ses secrets de tir a " .. cname .. " !
		" .. cname .. " -> COMPETENCE DE TIR AU MAXIMUM !" rbold $) goodfx 6 cchar .shooting! cooled-it
	else cool-it++
		($ "Sa reaction est un bref degout." .. "
		Oh. Ouais, ok. T'es un de ces types, hein ?" pbold .. "
		Elle repose son fusil sur son epaule et s'eloigne." $) badfx
	then +crtext shootingREV
;

cyoa: trade-shoot
	"Coach de Tir" cyoa-title!
	($ Thegroup .. " tombe sur une femme armee d'un fusil. Elle pretend avoir entraine des gens au tir de competition.
	Elle a plein d'astuces pour garder sa visee stable en mouvement, et meme quelques tirs multi-cibles. " .. "Les zombies sont des cibles lentes. C'est vraiment facile !" pbold $) cyoa-text! basic-tone
	trunk-food 6 < if
		($ "Malheureusement, il ne reste pas assez de nourriture pour commercer." $) +cr +text
	else
		choice( "Donner 6 nourriture pour la formation" )choice: trade-shoot-give
		trade-train-pay? if
			choice( "Donner " .. trade-train-amt .. " nourriture pour la formation de groupe" )choice: trade-shoot-group
		then
	then
		most-charming if
			charchoice( " use son charme" )choice: trade-shoot-charm
		then
		most-grating if
			charchoice( ": LE DIRE PAS LE POSTILLONNER" fcoolit )choice: trade-shoot-coolit
		then
		choice( "Partir" )choice
;

// Force - Jon a voulu quelque chose d'un peu different ici
// On peut couper certaines options si tout est disponible, actuellement on perd l'option "Partir" dans ce cas.

cyoa-choice: trade-strength-pose
	cchar .strength 6 > if
		($ cname .. " flechit une seule fois, a moitie effort. Mais le concours est deja plié.
		" .. "IMPOSSIBLE ! C'EST IMPOSSIBLE !" fbold .. " hurle le Coach de Force d'une voix etrangement aigue.
		" .. "ETES-VOUS 'LE MUSCLE QUI ETAIT PROMIS' ?" fbold .. " puis il se transforme en pierre et, quelques instants plus tard, explose en un million de fragments." $) cyoa-text! goodfx
		morale2+
	then;
	strengthroll if
		($ cname .. " gagne le concours de pose !" $) cyoa-text! goodfx
		cpet? if
			"C'etait plutot difficile de gagner un concours de musculation en tant qu'animal !" +crtext
		then
		strengthREV strength++ morale++
	else
		($ cname .. " perd le concours de pose.
		" .. cHe .. " ressent une " .. "GRANDE HONTE." rbold $) cyoa-text! badfx
		morale2-
	then
;

cyoa-choice: trade-strength-charm
	charmroll if
		($ cname .. " obtient une formation a la force GRATUITE ! " .. cHe .. " ressent deja clairement une 'pompe', comme disaient les bodybuilders avant qu'ils soient tous extermines." $) cyoa-text!
		cchar .strength@ 5 > if
		($ "Ca n'a pas vraiment ameliore " .. chis .. " force, mais c'etait GRATUIT !" $) +crtext
		then
		strengthREV strength++ goodfx

	else
		($ cname .. " passe accidentellement pour quelqu'un de bizarre.
		" .. gHe .. " se fait expulser." $) cyoa-text! badfx
	then
;

cyoa-choice: trade-strength-train
	cchar .strength@ 6 < if
		($ cname .. " est completement pompe par la routine d'entrainement de force !" $) goodfx
	else
		($ cname .. " n'a pas ete impressionne par ce petit entrainement minable. " .. cHe .. " doit trouver une meilleure routine !" $) badfx
	then cyoa-text!
	-6 trunk-food+
	strengthREV strength++
;

cyoa-choice: trade-strength-group
	($ "Tout le groupe s'entraine a la force !" $) cyoa-text! goodfx
	trade-train-pay someicon
	' trade-strength-group! foreach-human-char
;

cyoa: trade-strength-give
	solohuman if
		choosehuman trade-strength-train
	then;
	"Qui doit faire cet INTENSE entrainement de force ?" cyoa-text!
	' trade-strength-train cyoa-human-choice
;

cyoa-choice: trade-strength-coolit
	cpet? if
		($ cname .. " pete bruyamment en direction du coach de force." $)
	else
		($ cname .. " dit au coach de force de " .. "LE DIRE PAS LE POSTILLONNER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "OUAIS ! C'EST L'ATTITUDE QU'IL FAUT POUR ETRE UN TOP BODYBUILDER ! ON VA RECONSTRUIRE CE SPORT ! OUAIS !" fbold .. "
		Il prend " .. cname .. " comme son meilleur eleve, pour devenir ENORME a une cadence effrayante !
		" .. cname .. " -> COMPETENCE DE FORCE AU MAXIMUM !" rbold $) goodfx 6 cchar .strength! cooled-it
	else cool-it++
		($ "Il le prend tres mal." .. "
		DEGAGEZ D'ICI ESPECE D'AVORTON ! VOUS NE MERITEZ PAS DE DEVENIR ENORME !" fbold .. "
		Il continue de crier pendant que " .. thegroup .. " s'eloigne." $) badfx
	then +crtext strengthREV
;

cyoa: trade-strength
	"Coach de Force" cyoa-title!
	($ Thegroup .. " rencontre un vieil homme tres musculeux en survêtement gris assorti.
	Il hurle quelque chose sur " .. "CONSTRUIRE LA MASSE ET LE VOLUME " fbold .. " avec une " .. "ROUTINE DE FORCE INTENSE !" fbold .. "
	Il se rue vers des objets lourds eparpilles autour." $) cyoa-text! basic-tone
	trunk-food 6 < if
		($ "Malheureusement, il ne reste pas assez de nourriture pour commercer." $) +cr +text
	else
		choice( "Donner 6 nourriture pour la formation" )choice: trade-strength-give
		trade-train-pay? if
			choice( "Donner " .. trade-train-amt .. " nourriture pour la formation de groupe" )choice: trade-strength-group
		then
	then
		most-charming if
			charchoice( " use son charme" )choice: trade-strength-charm
		then
		strongest .strength 3 > if
			strongest charchoice( " defie en concours de pose !" )choice: trade-strength-pose
		then
		most-grating if
			charchoice( ": LE DIRE PAS LE POSTILLONNER" fcoolit )choice: trade-strength-coolit
		then
		choice( "Partir" )choice
;

// Fitness

cyoa-choice: trade-fitness-charm
	charmroll if
		($ cname .. " obtient une formation fitness GRATUITE ! " .. cHe .. " transpire grace a l'exercice intense !" $) cyoa-text!
		cchar .fitness@ 5 > if
			($ "Ca n'a pas vraiment ameliore " .. chis .. " forme, mais c'etait GRATUIT !" $) +crtext
		then
		goodfx fitnessREV fitness++
	else
		($ cname .. " passe accidentellement pour quelqu'un de bizarre.
		" .. gHe .. " se fait expulser." $) cyoa-text! badfx
	then
;

cyoa-choice: trade-fitness-train
	cchar .fitness@ 6 < if
		($ cname .. " transpire enormement grace a la routine fitness !" $) goodfx
	else
		($ cname .. " n'a meme pas transpire ! La monitrice de fitness est confuse, meme elle a un peu fatigue." $) badfx
	then cyoa-text!
	-6 trunk-food+
	fitnessREV fitness++
;

cyoa-choice: trade-fitness-group
	($ "Tout le groupe s'entraine au fitness !" $) cyoa-text! goodfx
	trade-train-pay someicon
	' trade-fitness-group! foreach-human-char
;

cyoa: trade-fitness-give
	solohuman if
		choosehuman trade-fitness-train
	then;
	"Qui veut un exercice intense pour le bien de sa forme ?" cyoa-text!
	' trade-fitness-train cyoa-human-choice
;

cyoa-choice: trade-fitness-coolit
	cpet? if
		($ cname .. " pete aigu en direction de la monitrice de fitness." $)
	else
		($ cname .. " dit a la monitrice de fitness de " .. "LE DIRE PAS LE POSTILLONNER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "C'est ce que j'aime entendre ! Vous etes pret pour la ROUTINE FITNESS MIRACLE !" pbold .. "
		Elle a probablement mal entendu " .. cname .. ". Une serie de callisthenies de pointe incroyables s'ensuit.
		" .. cname .. " -> COMPETENCE FITNESS AU MAXIMUM !" rbold $) goodfx 6 cchar .fitness! cooled-it
	else cool-it++
		($ "Sa reaction est surtout de la deception." .. "
		Ouais, bonne chance pour ne pas vous faire manger par des zombies." pbold .. "
		Elle recule en trottinant jusqu'a disparaitre. Puis elle est partie." $) badfx
	then +crtext fitnessREV
;

cyoa: trade-fitness
	"Monitrice de Fitness" cyoa-title!
	($ Thegroup .. " trouve une femme couverte de bandeaux, de jambières, et de tenues de sport. Tout en neon fluo.
	" .. "Seuls les plus en forme survivront dans ce monde infeste de zombies ! Je peux vous aider a vous mettre en forme, vite !" pbold .. "
	Elle court sur place depuis tout ce temps." $) cyoa-text! basic-tone
	trunk-food 6 < if
		($ "Malheureusement, il ne reste pas assez de nourriture pour commercer." $) +cr +text
	else
		choice( "Donner 6 nourriture pour la formation" )choice: trade-fitness-give
		trade-train-pay? if
			choice( "Donner " .. trade-train-amt .. " nourriture pour la formation de groupe" )choice:  trade-fitness-group
		then
	then
		most-charming if
			charchoice( " use son charme" )choice: trade-fitness-charm
		then
		most-grating if
			charchoice( ": LE DIRE PAS LE POSTILLONNER" fcoolit )choice: trade-fitness-coolit
		then
		choice( "Partir" )choice
;

// Medecine

cyoa-choice: trade-medical-charm
	charmroll if
		($ cname .. " obtient une formation medicale GRATUITE !" $) cyoa-text!
		cchar .medical@ 5 > if
			($ "Ca n'a pas vraiment ameliore " .. chis .. " savoir medical, mais c'etait GRATUIT !" $) +crtext
		then
		goodfx medicalREV medical++
	else
		($ cname .. " passe accidentellement pour quelqu'un de bizarre, meme selon les standards de la Fac de Med EZ : Campus Baraque-Sinistre-a-Meurtres.
		" .. gHe .. " se fait expulser." $) cyoa-text! badfx
	then
;

cyoa-choice: trade-medical-train
	cchar .medical@ 6 < if
		($ cname .. " apprend de nouvelles choses sur les soins medicaux d'urgence aupres du professeur crasseux." $) goodfx
	else
		($ "Bien que le professeur crasseux soit un excellent enseignant, " .. cname .. " n'a rien appris de nouveau." $) badfx
	then cyoa-text!
	-6 trunk-food+
	medicalREV medical++
;

cyoa-choice: trade-medical-group
	($ "Tout le groupe s'entraine aux soins medicaux !" $) cyoa-text! goodfx
	trade-train-pay someicon
	' trade-medical-group! foreach-human-char
;

cyoa: trade-medical-give
	solohuman if
		choosehuman trade-medical-train
	then;
	"Qui doit recevoir la formation medicale ?" cyoa-text!
	' trade-medical-train cyoa-human-choice
;

cyoa-choice: trade-medical-coolit
	cpet? if
		($ cname .. " reussit d'une certaine facon a dire quelque chose comme LE DIRE PAS LE POSTILLONNER dans une bizarre voix animale." $)
	else
		($ cname .. " dit a l'homme en salopette de " .. "LE DIRE PAS LE POSTILLONNER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Il hoche la tete avec une sagesse profonde. L'a-t-il mal entendu ? Il se met a enseigner des techniques medicales de survie zombie incroyables comme on en avait jamais vues." .. "
		" .. cname .. " -> COMPETENCE MEDICALE AU MAXIMUM !" rbold $) goodfx 6 cchar .medical! cooled-it
	else cool-it++
		($ "*C'EST VOUS* QUI NE LE DITES PAS ET NE LE POSTILLONNEZ PAS ! AAAAAAARGH !" rbold .. "
		Il est furieux ! " .. thegroup .. " est force de partir." $) badfx
	then +crtext medicalREV
;

cyoa: trade-medicalt
	"Fac de Med EZ" cyoa-title!
	($ Thegroup .. " decouvre une baraque insalubre et inquietante. Elle a un panneau qui dit " .. "FAC DE MED EZ" rbold .. " accroché de travers au-dessus de la porte.
	A l'interieur se trouve un type insalubre et inquietant en salopette.
	" .. "ALORS ? QUI VEUT APPRENDRE LA CHIRURGIE ?" pbold $) cyoa-text! basic-tone
	trunk-food 6 < if
		($ "Malheureusement, il ne reste pas assez de nourriture pour commercer." $) +cr +text
	else
		choice( "Donner 6 nourriture pour la formation" )choice: trade-medical-give
		trade-train-pay? if
			choice( "Donner " .. trade-train-amt .. " nourriture pour la formation de groupe" )choice:  trade-medical-group
		then
	then
		most-charming if
			charchoice( " use son charme" )choice: trade-medical-charm
		then
		most-grating if
			charchoice( ": LE DIRE PAS LE POSTILLONNER" fcoolit )choice: trade-medical-coolit
		then
		choice( "Partir" )choice
;

// Mecanique

cyoa-choice: trade-mechanic-charm
	charmroll if
		($ cname .. " obtient une formation GRATUITE dans l'art et la science du genie anti-zombie !" $) cyoa-text!
		cchar .mechanical@ 5 > if
			($ "Ca n'a pas vraiment ameliore " .. chis .. " competence mecanique, mais c'etait GRATUIT !" $) +crtext
		then
		goodfx mechanicREV mechanic++
	else
		($ cname .. " passe accidentellement pour quelqu'un de bizarre.
		" .. gHe .. " se fait expulser." $) cyoa-text! badfx
	then
;

cyoa-choice: trade-mechanic-train
	cchar .mechanical@ 6 < if
		($ cname .. " suit un cours accelère en reparation, barricades efficaces, et autres techniques de genie anti-zombie !" $) goodfx
	else
		($ cname .. " n'a rien appris de nouveau. " .. cHe .. " connaissait deja tout ce que la mecanicienne pouvait enseigner." $) badfx
	then cyoa-text!
	-6 trunk-food+
	mechanicREV mechanic++
;

cyoa-choice: trade-mechanic-group
	($ "Tout le groupe s'entraine a la mecanique !" $) cyoa-text! goodfx
	trade-train-pay someicon
	' trade-mechanic-group! foreach-human-char
;

cyoa-choice: trade-mechanic-coolit
	cpet? if
		($ cname .. " pete tres bruyamment en direction de la mecanicienne, dans les graves." $)
	else
		($ cname .. " dit a la mecanicienne de " .. "LE DIRE PAS LE POSTILLONNER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Elle trouve ca hilarant ! Ravie, la mecanicienne promet d'apprendre a " .. cname .. " absolument tout ce qu'elle sait en un cours intensif." .. "
		" .. cname .. " -> COMPETENCE MECANIQUE AU MAXIMUM !" rbold $) goodfx 6 cchar .mechanical! cooled-it
	else cool-it++
		($ "Elle repond en fouillant dans ses poches pour trouver un boulon, puis le lance sur " .. cname .. ". Elle continue ainsi, sans dire un mot, jusqu'a ce que " .. thegroup .. " soit force de partir." $) badfx
	then +crtext mechanicREV
;

cyoa: trade-mechanic-give
	solohuman if
		choosehuman trade-mechanic-train
	then;
	"Qui doit recevoir la formation de la mecanicienne ?" cyoa-text!
	' trade-mechanic-train cyoa-human-choice
;

cyoa: trade-mechanic
	"Mecanicienne de Genie" cyoa-title!
	($ Thegroup .. " rencontre une femme en combinaison tachee de cambouis.
	" .. "Je peux vous aider a mieux reparer et construire des trucs. C'est une competence vraiment utile. Pourrait vous sauver la vie." pbold .. "
	Ca faciliterait au moins les reparations de voiture." $) cyoa-text! basic-tone
	trunk-food 6 < if
		($ "Malheureusement, il ne reste pas assez de nourriture pour commercer." $) +cr +text
	else
		choice( "Donner 6 nourriture pour la formation" )choice: trade-mechanic-give
		trade-train-pay? if
			choice( "Donner " .. trade-train-amt .. " nourriture pour la formation de groupe" )choice:  trade-mechanic-group
		then
	then
		most-charming if
			charchoice( " use son charme" )choice: trade-mechanic-charm
		then
		most-grating if
			charchoice( ": LE DIRE PAS LE POSTILLONNER" fcoolit )choice: trade-mechanic-coolit
		then
		choice( "Partir" )choice
;



// Fort Surplus Militaire

cyoa-choice: trade-army-1
	($ Thegroup .. " glisse de la nourriture dans la fenetre et une grenade sort. Ca pourrait faire beaucoup de degats !
	" .. "Attendez, la goupille etait encore dessus ?" pbold $) cyoa-text! basic-tone
	1 WEAPON_GRENADE trunk.weapon+ -4 trunk-food+ someicon
;

cyoa-choice: trade-army-2
	($ Thegroup .. " glisse de la nourriture dans la fenetre et un tas de grenades tombent, une par une. Ca pourrait etre utile !
	" .. "Faites attention a ne pas les faire tomber ici." pbold $) cyoa-text! basic-tone
	3 WEAPON_GRENADE trunk.weapon+ -12 trunk-food+ someicon
;

cyoa-choice: trade-army-3
	($ Thegroup .. " glisse beaucoup de nourriture dans la fenetre. Quelqu'un pousse un uzi dehors ! Il peut cracher des balles a une vitesse incroyable ! Attention, meme un bon tireur aura du mal avec le recul.
	" .. "Amusez-vous ! Et partez, s'il vous plait." pbold $) cyoa-text! basic-tone
	1 WEAPON_UZI trunk.weapon+ -15 trunk-food+ someicon
;

cyoa-choice: trade-army-4
	($ Thegroup .. " glisse une enorme quantite de nourriture dans la fenetre. Une pause, puis quelqu'un pousse un fusil d'assaut ! Ca pourrait vraiment aider le voyage !
	" .. "Merci pour toute cette nourriture ! Bonne chance la-dehors !" pbold $) cyoa-text! goodfx
	1 WEAPON_AK47 trunk.weapon+ -25 trunk-food+ someicon
;

cyoa-choice: trade-army-5
	($ Thegroup .. " glisse une enorme quantite de nourriture dans la fenetre. Une pause, puis quelqu'un derriere la porte se met a pousser une douzaine de grenades.
	" .. "Soyez vraiment prudents avec ca !" pbold $) cyoa-text! goodfx
	12 WEAPON_GRENADE trunk.weapon+ -40 trunk-food+ someicon
;

cyoa-choice: trade-army-6
	($ Thegroup .. " glisse une quantite massive de nourriture dans la fenetre. Quelqu'un de l'autre cote se debat pour pousser un lance-flammes par la petite fenetre.
	" .. "Crachez le feu !" pbold $) cyoa-text! goodfx
	1 WEAPON_FLAMETHROWER trunk.weapon+ -60 trunk-food+ someicon
;

cyoa-choice: trade-army-7
	($ Thegroup .. " glisse lentement une voiture pleine de nourriture dans la fenetre. Des bruits de raclement se font entendre puis un canon de minigun est pousse depuis l'obscurite. Le cadre de la fenetre est brise par la taille du minigun qu'on force a passer.
	" .. "Merci infiniment ! Je peux rester cache ici pendant des mois maintenant !" pbold $) cyoa-text! goodfx
	1 WEAPON_MINIGUN trunk.weapon+ -75 trunk-food+ someicon
;

cyoa: trade-army
	"Fort Surplus Militaire" cyoa-title!
	($ Thegroup .. " trouve un magasin de surplus militaire couvert de barricades. Verrou hermétique. Il y a un panneau de prix d'armes sur un mur dehors, pres d'une petite fenetre.
	" .. "Glissez juste la nourriture par la fenetre !" pbold .. " dit une toute petite voix dans l'obscurite." $) cyoa-text! basic-tone
	choice( "Partir" )choice
	trunk-food 5 < if
		($ "Il n'y a pas assez de nourriture pour acheter quoi que ce soit ! " .. Thegroup .. " doit partir." $) +crtext badfx
	else
		trunk-food 74 > if
			choice( "Minigun pour 75 nourriture" )choice: trade-army-7
		then
		trunk-food 59 > if
			choice( "Lance-flammes pour 60 nourriture" )choice: trade-army-6
		then
		trunk-food 39 > if
			choice( "12 grenades pour 40 nourriture" )choice: trade-army-5
		then
		trunk-food 24 > if
			choice( "Fusil d'assaut pour 25 nourriture" )choice: trade-army-4
		then
		trunk-food 14 > if
			choice( "Uzi pour 15 nourriture" )choice: trade-army-3
		then
		trunk-food 11 > if
			choice( "3 grenades pour 12 nourriture" )choice: trade-army-2
		then
		trunk-food 3 > if
			choice( "1 grenade pour 4 nourriture" )choice: trade-army-1
		then
	then
;

// Vendeur de Fusils a Pompe

cyoa-choice: trade-shotgun-coolit
	cpet? if
		($ cname .. " pete juste devant le vendeur de fusils a pompe." $)
	else
		($ cname .. " dit au vendeur de fusils a pompe de " .. "SE CALMER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Ca lui provoque une sorte de crise existentielle.
		" .. "T'as raison ! Mais qu'est-ce que je fais de ma vie ?!" pbold .. "
		Il donne a " .. cname .. " son " $) +crtext goodfx
		50 %chance if "fusil a pompe automatique et un tas de cartouches !" 1 WEAPON_AUTOSHOT trunk.weapon+ else "fusil a pompe a balles pleines et un tas de cartouches !" 1 WEAPON_SLUG trunk.weapon+ then +text
		50 trunk-shotgun-shell+ cooled-it
	else cool-it++
