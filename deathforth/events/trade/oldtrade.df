// Armes de Carnage

cyoa-choice: trade-fanatic-coolit
	cpet? if
		($ cname .. " dit la phrase " .. "SE CALMER" pbold .. " en petant ! Incroyable !" $)
	else
		($ cname .. " dit a la femme fanatique de " .. "SE CALMER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Elle en est ravie, d'une certaine facon.
		" .. "WAOUH ! WAOUH OUAH OUAH OUAHHHHH !" rbold .. "
		La commerçante donne a " .. cname .. " presque tout son stock. 8 molotovs, un parcmetre, et une " .. "tronconneuse." rbold $) goodfx +crtext
		1 WEAPON_CHAINSAW trunk.weapon+ 1 WEAPON_PARKING trunk.weapon+ 8 WEAPON_MOLOTOV trunk.weapon+ cooled-it
	else cool-it++
		($ "La marchande d'armes est furieuse.
		" .. "SE CALMER ? SE CALMER ??! LES LOSERS SE CALMENT !!\n" rbold .. Thegroup .. " realise que c'etait une tres mauvaise idee ! La marchande fait signe au reste de son groupe d'attaquer !" $) +crtext bitefx rob-megafail
	then attitudeREV witsREV
;

