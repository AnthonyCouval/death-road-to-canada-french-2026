// Maitre des Lames

: trade-blade-three 1 WEAPON_KNIGHT trunk.weapon+ 1 WEAPON_MACHETE2 trunk.weapon+ ;

cyoa-choice: trade-blade-rob
	50 %chance if
		($ cname .. " vole au Maitre des Lames deux de ses meilleures armes. Les deux sont de puissantes armes de melee a leur facon." $) cyoa-text! goodfx
		notsolo if
			($ Theothersare .. " entraines dedans." $) +text
		then
		trade-blade-three rob-guilt
	else
		($ "Le Maitre des Lames reussit a repousser " .. thegroup .. " grace a sa considerable connaissance des epees et son katana de centre commercial." $) cyoa-text! bitefx rob-fail
	then aholeREV
;
cyoa-choice: trade-blade-coolit
	cpet? if
		($ cname .. " commence a macher un des fourreaux du Maitre des Lames, par depit." $)
	else
		($ cname .. " dit au Maitre des Lames de " .. "SE CALMER." pbold $)
	then cyoa-text!
	cool-it-7 if
		($ "Il se remplit de doutes.
		" .. "Ma vie est un mensonge ! Je vais arreter ce truc avec les epees et commencer a collectionner des lance-flammes." pbold .. "
		L'ancien Maitre des Lames donne a " .. cname .. " deux de ses meilleures armes. Un solide coupe-coupe et une " .. "epee de chevalier." rbold $) goodfx
		trade-blade-three cooled-it
	else cool-it++
		($ "Le Maitre des Lames ignore ca.
		Il commence a parler de combien les epees sont cool et " .. thegroup .. " n'a jamais la chance d'acheter quoi que ce soit." $) badfx
	then +crtext attitudeREV witsREV
;

cyoa-choice: trade-blade-4
	($ Thegroup .. " achete le " .. "PUISSANT CLAYMORE" rbold .. ". Le claymore est lent et difficile a manier, mais extremement puissant. Il peut parfois couper 4 zombies d'un coup !" $) cyoa-text! goodfx
	1 WEAPON_CLAYMORE trunk.weapon+ -35 trunk-food+ someicon
;

cyoa-choice: trade-blade-3
	($ Thegroup .. " achete le type d'epee qu'un chevalier du Moyen Age porterait. Ca va faire une excellente arme ! Elle peut facilement toucher deux zombies en un seul coup." $) cyoa-text! goodfx
