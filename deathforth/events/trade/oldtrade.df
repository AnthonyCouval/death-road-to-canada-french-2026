// Soins

cyoa-choice: trade-groupheal-rob
	50 %chance if
		($ cname .. " vole l'hopital, ecrasant les defenseurs avant qu'ils comprennent ce qui se passe. Bien joue. " $) cyoa-text! badfx
		notsolo if
			($ Theothersare .. " entraines dedans." $) +text
		then
		10 16 rnd trunk-medical+ rob-guilt2
	else
		($ Thegroup .. " tente de voler l'hopital. Leurs nombreux defenseurs montrent comment ils ont reussi a survivre si longtemps." $) cyoa-text! bitefx rob-fail
	then aholeREV
;

: trade-groupheal-guy
	cchar damage 0 = if
		($ cname .. " passe un bilan de sante, mais il n'y a rien qui ne va chez " .. chim .. "." $)
	else
		($ cname .. " se fait soigner " .. chis .. " blessures." $)
	then cchar .fullheal
;

cyoa-choice: trade-groupheal-heal
	trade-groupheal-guy
	cyoa-text! goodfx
	-6 trunk-food+
;

cyoa-choice: trade-groupheal-group

	team-damage 0 = if
		($ Thegroup .. " passe un bilan de sante, mais personne n'a rien." $) cyoa-text!
	else
		7 groupheal
		($ Thegroup .. " se fait soigner " $) cyoa-text!
		team-damage 1 < if
			"toutes" +text
		else
			"la plupart de" +text
		then
			" ses blessures." +text
	then
	goodfx
	-15 trunk-food+
;

: trade-groupheal-give
	cyoa-start
	solo if
		soloer choosechar trade-groupheal-heal
	then;
	"Qui doit recevoir les soins ?" cyoa-text!
	' trade-groupheal-heal cyoa-team-choice
;

cyoa-choice: trade-groupheal-charm
	charmroll if
		($ cname .. " convainc le personnel de l'hopital d'offrir ses services gratuitement !
		" .. cHe .. " est tellement charmant que ca." $) cyoa-text! goodfx
		trade-groupheal-guy +crtext
	else
		($ cname .. " passe accidentellement pour quelqu'un de bizarre.
		" .. gHe .. " est expulse de l'hopital et prié de ne jamais revenir." $) cyoa-text! badfx
	then
;

cyoa: trade-groupheal
	"Hopital Fonctionnel" cyoa-title! someicon
	($ Thegroup .. " trouve un campement installe dans un hopital. Les lumieres sont encore allumees, quelques medecins sont encore la, et ils sont encore ouverts !
	Ils proposent des soins en echange de nourriture. 10 nourriture pour un traitement complet." $) cyoa-text! basic-tone
	trunk-food 6 < if
		($ "Malheureusement, il n'y a pas assez de nourriture pour leurs services." $) +cr +text
	else
		choice( "Donner 6 nourriture pour les soins" )choice: trade-groupheal-give
		trunk-food 14 > notsolo and if
			choice( "Donner 15 nourriture pour les soins de groupe" )choice: trade-groupheal-group
		then
	then
		most-charming if
			charchoice( " use son charme" )choice: trade-groupheal-charm
		then
		most-ahole if
			charchoice( " vole l'hopital" )choice: trade-groupheal-rob
		then
		choice( "Partir" )choice
;

