// Works like the skill check, but picks the personality stats.
// Also instead of the highest, picks the numbers furthest away from 3. So 0 and 6 tie with each other.
// Each one then has different lines for under 2 or over 4 checks. If it fails both, does a generic line.
: epilogue-personality-check args( char )

	// Gender check to ehis for less clumsy pronouns
	// <- char .female@ 0 > if "female" . 1 else "male" . 0 then to epilogue-gender

	<- char .female@ 0 > if
 		1 to epilogue-gender
 	else
 		0 to epilogue-gender
	then

	// Special Characters

	<- char .mason? 		  if "... :D" then;
	<- char .hermit? 		  if "Peuh ! Je n'arrive pas a croire qu'on m'a convaincu de quitter ma cabane." then;
	<- char .specialtype@ 3 = if "Joyeux Noel a tous !" then;
	<- char .specialtype@ 4 = if "HO!HO!HO!HO!HO!HO!HO!HO!HO!HO!HO!HO!HO!" fbold then;
	<- char .specialtype@ 5 = if "burbleburble" then;
	<- char .specialtype@ 6 = if "Tout cet entrainement a ete utile !" then;
	<- char .specialtype@ 7 = if "C'etait une bonne bataille. Je suppose." then;
	<- char .specialtype@ 8 = if "Ca m'a fait penser a un nouveau mouvement de lutte ! La MECHA PRESSE !" then;
	<- char .specialtype@ 9 = if "Un-deux... un-deux... Je suis brutal et sans pitie !" then;
	<- char .specialtype@ 10 = if "La connaissance triomphe encore ! Je suis le meilleur." then;
	<- char .specialtype@ 11 = if "J'ai besoin de plus de nourriture pour chats !" then;
	<- char .specialtype@ 12 = if "Il va me falloir des vetements d'hiver stylises..." then;
	<- char .specialtype@ 13 = if "Quel pays enchanteur !" then;
	<- char .specialtype@ 14 = if "C'etait facile ! Le roller derby est plus dangereux." then;
	<- char .specialtype@ 19 = if "!!!!" then;
	<- char .specialtype@ 20 = if "Je n'ai jamais cru que j'y arriverais !" then;
	<- char .specialtype@ 21 = if "Hhhhheh je gererai cet endroit en une semaine, max." then;
	<- char .specialtype@ 22 = if "WOOF!" then;
	<- char .specialtype@ 25 = if tstc-personality-endsay depths 0= if drop "SUIS-JE ENFIN TROP MUSCLE ?" else pops nip then then;
	<- char .specialtype@ 26 = if "Yes!" then;
	<- char .specialtype@ 27 = if "gobble gobble" then;
	<- char .specialtype@ 29 = if "HA ! L'HEURE D'UNE NOUVELLE AVENTURE !" then;
	<- char .specialtype@ 30 = if "C'est ma victoire !" then;
	<- char .specialtype@ 31 = if "JE DETESTE PROFONDEMENT LES LUNDIS !" then;
	<- char .specialtype@ 33 = if "Ooooh ! Ne m'oublie jamais ! Oooooo !" then;
	<- char .specialtype@ 34 = if "NEIGH!" then;
	<- char .specialtype@ 35 = if "EEEEEEEEEEEEEEEEE!" then;
	<- char .specialtype@ 36 = <- char .specialtype@ 37 = or if "thankyouverymuch" then;
	<- char .specialtype@ 45 = if "We really.... cleaned up!" then;
	<- char .specialtype@ 46 = if "Je suis un mercenaire.... un mercenaire a louer." then;
	<- char .specialtype@ 49 = if "...." then;
	<- char .specialtype@ 50 = if "Half-Life 3 ne sortira PAS, desole." then;
	<- char .specialtype@ 52 = if "HYAAAAAAAAAAAAAAAAAAAAAAAAAAAGH!" fbold then;
	<- char .specialtype@ 58 = if "fart" then;
	<- char .specialtype@ 61 = if "Abracadabra, les intellos !" then;
	<- char anime? if animegirl-personality-endsay depths 0= if drop "Suis-je Kawaii ?" else pops nip then then;
	<- char .specialtype@ 73 = <- char .specialtype@ 74 = or if "NE ME REGARDEZ PAAAAAS !" then;
	<- char .specialtype@ 76 = if "GNORT!" then;
	<- char .specialtype@ 77 = if "nurrrrrp!" then;
	<- char .specialtype@ 81 = if "INTERFEREZ AVEC LES ACTIVITES DE LA SORCIERE, RECEVEZ UNE BALLE DE SON PISTOLET !" then;
	<- char .specialtype@ 82 = if "BLAUGH!" then;
	<- char .specialtype@ 83 = if "blaugh" then;
	<- char .perk@ "Skeleton Queen" $= if "Je dois tout aux squelettes !" then;
	<- char .specialtype@ 88 = if "Il parait que Toronto a une scene de GN florissante !" then;
	<- char .specialtype@ 90 = if "Waouh ! Un nouvel endroit a bruler." then;
	<- char .specialtype@ 91 = if "Je suis toujours coince dans ce costume ! A l'aide !" then;
	<- char .specialtype@ 92 = if "PRENDS PAS LA VACHE, MEC" then;
	<- char .specialtype@ 93 = if "........." then;
	<- char .specialtype@ 94 = if "EET PANT!" then;
	<- char .specialtype@ 95 = if "Objectif de mission en vue !" then;
	<- char .specialtype@ 96 = if "Parfait ! Je peux terroriser bien plus d'humains ici !" then;
	<- char .specialtype@ 97 = if "BON BOULOT, GUS !" then;
	<- char .specialtype@ 98 = if "Il fait bien trop froid ici pour cette tenue !" then;
	<- char .specialtype@ 102 = if "Uuurrrrgh ice everywhere." then;
	<- char .specialtype@ 104 = if "L'AMERIQUE #1 ! WOO ! WOOOOOOOOOO !" then;
	<- char .specialtype@ 105 = if "Une nouvelle victoire pour le Volontarisme Americain 100% !" then;
	<- char .specialtype@ 106 = if "Mon journal dit que c'est un bon endroit pour rester." then;
	<- char .specialtype@ 108 = if "Yarrrr!" then;
	<- char .charbro? 		   if "Sacre bleu ! NOTE DU TRADUCTEUR : CA VEUT VAGUEMENT DIRE 'YARE YARE DAZE'" then;
	<- char .broom?            if "J'ai un aveu a faire... J'etais en fait un balai depuis le debut." then;
	<- char .saguts?		   if "I-GER UPPERCUT!" then;
	<- char .bryu?		   	   if "HADOOK! KADOOSHIN'!" then;
	<- char .hhell?		   	   if "Heh... tout grace a la Douce Dame Propane." then;
	<- char .efudd?		   	   if "Je suis victorieux ! Moi ! E*FUDD !" then;
	<- char .brck? 				if "Maintenant que je suis ici, il est temps de rendre visite a mes amis... et quelques femmes." then;
	<- char .cart? 				if "C'est tellement excitant d'etre dans l'inconnu !" then;
	<- char .arq? 				if "Waouh. Le Canada. Cool, je suppose." then;
	<- char .brckmon? 			if "..." then;

	<- char .specialtype@ 129 = if "IL EST L'HEURE... noooon, c'est juste apres 16h. Super !" then; \ Honcho
	<- char .specialtype@ 130 = if "Pile au bon moment. Ca va, vous pouvez me tuer maintenant." then; \ Pool player
	<- char .specialtype@ 131 = if "RECHARGEMENT, LES GARS !" then; \ Van Smelt

	<- char .specialtype@ 132 = if "Hmm. Je me demande si je peux publier mes articles de doctorat ici..." then; \ Rohoa Hawke
	<- char .specialtype@ 133 = if "LA MORT THERMIQUE DE L'UNIVERS SUIT CHACUNE DE NOS ACTIONS ET PENSEES. HOURRA !" then; \ Ember
	<- char .specialtype@ 134 = if "JE VOUS PRESENTE - DES BILLETS A MOITIE PRIX ! PAYEZ MOINS, PAYEZ LA MOITIE ! LES MERVEILLES DU CAPITALISME !!!" then; \ Johannes

	<- char .specialtype@ 144 = if "Mer fraiche, air pur, le soleil qui brille sur nous... c'est ce dont j'ai toujours reve." then; \ Isabelle
	<- char .specialtype@ 145 = if "Vous etes tous nuls dans vos boulots, vous po- o-oh. Oh. J'ai oublie de lancer arret du temps. Euh..." then; \ Lasija - chronomancer
	<- char .specialtype@ 146 = if "th-s plac3...it - is...h0me?" then; \ Defective

	<- char .specialtype@ 148 = if "Tant qu'il y a des zombies, je continuerai a les ecraser. Mwah !~" then; \ Bayonetta
	<- char .specialtype@ 149 = if "HAHAHAHA. LE CANADA EST A MOI... PAR DROIT ET PAR LA FORCE." then; \ Zeus
	<- char .specialtype@ 150 = if "Grand-Amiral Merenja Raven, arme et pret. EN AVANT TOOOOOUTE !" then; \ Admiral
	<- char .specialtype@ 151 = if "Quel talent ! Quels sortileges ! Quel plaisir !" then; \ Rubick

	<- char .specialtype@ 121 = if "Aww, merci de m'avoir choisie ! Dis-moi que tu y es arrive ! ;3" then; \ Sycamore
	<- char .specialtype@ 152 = if "OH NON, C'EST EXACTEMENT COMME LA FOIS OU J'ETAIS ALLE AU CANADA PARCE QUE LES ZOMBIES ETAIENT PARTOUT." then; \ Pewter
	<- char .specialtype@ 153 = if "C'EST UNE BLAGUE CET ENDROIT OU QUOI ?" then; \ Jimbo

	<- char dog? if dog-personality-endsay depths 0= if drop "Ouaf." else pops nip then then;
	<- char cat? if "MEOW!" then;
	<- char goat? if "BAAAAA!" then;
	<- char pig? if "OINK!" then;
	<- char ispet? if "HRONK!" then;

	<- char .trait@ "CARL!" $= if "CAAARRRL!" then;
	<- char .trait@ "IS KEPA" $= if "Oh hey, j'ai reussi. Merci d'avoir joue a Death Road to Canada !" then;

	<- char .dexterity@ 2 > if dex-personality-endsay depths 0= if drop "Super-mega cool !" else pops nip then then;

	<- char .trait@ "Anime Fan" $= if animefan-personality-endsay depths 0= if drop "Je t'aime, Canada-chan." else pops nip then then;
	<- char .trait@ "Phoenix" $= if "Le Phoenix se leve ! ==bat les bras comme des ailes==" then;
	<- char .perk@ "T*S*T*C" $= if tstc-personality-endsay depths 0= if drop "Suis-je enfin trop muscle ?" else pops nip then then;
	<- char .trait@ "Hero Type" $= if herotype-personality-endsay depths 0= if drop "Je serai toujours ton garde du corps." else pops nip then then;
	<- char .trait@ "Gourmand" $= if gourmand-personality-endsay depths 0= if drop "Delicieux !" else pops nip then then;

	// If a character has the berserker trait, gives them an ending line for it.
	<- char .trait@ "BERSERK!" $= if berserk-personality-endsay depths 0= if drop "BERSERK !" else pops nip then then;

	// Rare checks above, common checks below.

	<- char .xtreme-stat-stack depths 0= if 0 else shuffles pops then to EPILOGUE-PICK drop

	EPILOGUE-PICK STAT_ATTITUDE = if
		<- char .cattitude+ if
			att-high-endsay depths 0= if drop "Ouais !" else pops nip then
		then;
		<- char .cattitude- if
			att-low-endsay depths 0= if drop "Peuh." else pops nip then
		then;
	then

	EPILOGUE-PICK STAT_COMPOSURE = if
		<- char .ctemper+ if
			comp-high-endsay depths 0= if drop "Ouf." else pops nip then
		then;
		<- char .ctemper- if
			comp-low-endsay depths 0= if drop "Argh !" else pops nip then
		then;
	then

	EPILOGUE-PICK STAT_WITS = if
		<- char .cwits+ if
			wits-high-endsay depths 0= if drop "Je le savais !" else pops nip then
		then;
		<- char .cwits- if
			wits-low-endsay depths 0= if drop "Euh, quoi ?" else pops nip then
		then;
	then

	EPILOGUE-PICK STAT_LOYALTY = if
		<- char .cloyalty+ if
			team-count-alive 1 > if loyal-high-endsay else loyal-high-endsay-solo then
			depths 0= if drop "est devenu un citoyen exemplaire du Canada.*" else pops nip then
		then;
		<- char .cloyalty- if
			loyal-low-endsay depths 0= if drop "a continue d'etre un enorme tocard.*" else pops nip then
		then;
	then

	generic-personality-endsay depths 0= if drop "Hourra !" else pops nip then

;


// Skill sayings
// Note: Needs 4 for each category, minimum, or you could run out of sayings

0 stack
	($ "a ete expulse du Canada apres avoir refuse de renoncer aux armes.*" $) shove
	($ "a canalise son obsession pour les armes dans un loisir productif : la collection de pommes de pin.*" $) shove
	"est devenu une attraction de tir acrobatique celebre au Cirque Canadien.*" shove
	($ "s'est accidentellement tire une balle dans le pied, dans les 5 minutes suivant l'entree au Canada.*" $) shove
	"a abattu un pingouin par accident, violant la Prime Directive Canadienne.*" shove
