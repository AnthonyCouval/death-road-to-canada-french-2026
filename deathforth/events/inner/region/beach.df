constant maplayout

: plotmap
	0 -1 maplayout xyplot: pt
;





: keep-colour 
	
	0 weather!
	\ 0.5 1 frnd wind_force!
	
	// 1 0.9 0.1 tint_near!
	// 1 0.9 0.1 tint_far!
	// 1 light_mode!
	// 61 tint_trigger
	
	//	0 clr_near_set_r!
	//	0 clr_near_tile_r!
	//	0 clr_near_thing_r!
		
		// 0 clr_near_set_b!
		// 0 clr_near_tile_b!
		// 0 clr_near_thing_b!
		
		// 0 clr_near_set_g!
		// 0 clr_near_tile_g!
		// 0 clr_near_thing_g!
		
		timer_retrigger
		
		
;

: site-setup

	' plotpave to ft

	plotmap
	
	11 o'clock
	\ 1 no_time!
	
	5 %zombs 
	
	shovel .scatter
	
	5 umbrella .scatter
	
	3 wind_force! 
	
	1 ' keep-colour timer_add

	// Put char and chars in middle of map
	
	// map{ street-junk }
	
	9 for 
		meleeweapons .scatter
	next
	
		\ Basement skeleton request - beach noodles. 
	7 for 
		50 %chance if 
				pool1 
			else
				pool2 
			then 
		0 1200 rnd lt .pos.x! 
		280 320 rnd lt .pos.y! 
	next 
		
	33 %chars-up
	75 %mv-up
	
	map{ 1 water_colour_r! 1 water_colour_b! 1 water_colour_g! }
	
	wave_spawner
	
	"Zombonita Beach.mp3" $music-load
	
;

region: specialcamp-3
	w: maplayout layoutw
	h: maplayout layouth

	post-script: site-setup

} }
