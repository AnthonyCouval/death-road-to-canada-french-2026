// using objs

: streetlight-flicker args( me eventid )	
	<- eventid THING_EVENT_TIMER = if
			1 <- me .timer!		
			
		gameticks 200 360 frnd % if			
			1 1 0.4 150 <- me .pos d-light
				else
				30 <- me .timer!
				then
			then
	
;

: streetlamp spawn special_objects96_base_id 4 + lt .spriteid! 4000 lt .mass! 40 lt .hitpoints! 20 lt .timer! ' streetlight-flicker lt .events! -1 lt .layer! 54 lt .rad.y! 6 lt .rad.x! 1 lt .walkover! -4 lt .vel.y! -1 lt .vel.x! 1 lt .nocollide! 3 lt .tileflags! 0.12 lt .vel.x!  ;
: streetlomp spawn special_objects96_base_id 4 + lt .spriteid! 4000 lt .mass! 40 lt .hitpoints! 20 lt .timer! -1 lt .layer! 64 lt .rad.y! 6 lt .rad.x! 1 lt .no_hit! 54 lt .rad.y! 6 lt .rad.x! 1 lt .walkover! 3 lt .tileflags! 0.12 lt .vel.x! ;

: bldg2 tanchor!
	"fillerhouse" $picklocid addloc 
		prefab{
		0 3 rnd 11 4 shop }
;

: beachumbrella	
	spawn
	special_objects32_base_id 200 202 rnd + lt .spriteid!
	10 lt .mass!
	bbox
	45 -45 rnd lt .angle!
	1.4 lt .scale.x!
	1.4 lt .scale.y!
;

: deckchair
	spawn
	special_objects32_base_id 203 + lt .spriteid!
	10 lt .mass!
	bbox
;

: beachblanket
	spawn
	special_objects32_base_id 204 205 rnd + lt .spriteid!
	10 lt .mass!
	1 lt .walkover!
	1 lt .layer!
;

: talktome
	"Inspired by Walton-On-The-Naze, England." interactee .report
;

: beachsign
	spawn
	special_objects32_base_id 206 + lt .spriteid!
	immovable
	bbox
	' talktome lt .cyoa!
	1.3 lt .scale.x! 1.3 lt .scale.y!
;


: musicchange
	interactee .weapon_state.val@ 1 = if 
		0 interactee .weapon_state.val!
		"Zombonita Beach.mp3" $music-load
	then;

	interactee .weapon_state.val@ 1 + interactee .weapon_state.val!
	no-music
;

: beachradio
	spawn
	special_objects32_base_id 207 + lt .spriteid!
	immovable
	bbox
	' musicchange lt .cyoa!

;

0 value totalcollected


: collectthis
	' totalcollected ++
	totalcollected interactee .report
	clear-cyoa
	
	totalcollected 8 = if
	0 2 RAINBOW "YIPPEE!" .. popup_dis 1 popup_mode!
	
	niceweapons
	player .pos lt .pos!
	
	then
;

: beachring
	spawn
	special_objects32_base_id 196 + lt .spriteid!
	immovable
	bbox
	' collectthis lt .cyoa!

; 

: roadsign1
	spawn special_objects32_base_id 194 + lt .spriteid!
	bbox
	20000 lt .mass!
	100 lt .hitpoints!
	1 lt .unseen!
	-3.2 lt .vel.y!
;

: roadsign2
	spawn special_objects32_base_id 195 + lt .spriteid!
	bbox
	20000 lt .mass!
	100 lt .hitpoints!
	1 lt .unseen!
	-3.2 lt .vel.y!
;


// tiles

: rangewall tile@ args( spriteid t ) <- t LAYER_WALLSIDE <- spriteid .lspriteid! TILE_BLOCK_FLOOR <- t .id! ;

: fencerange	args( x y s )

	building_misc_tiles_base_id 14 7 * + 7 + <- s + -> s

	2 for
		<- s i 1- 14 * + <- x <- y rangewall
		<- x <- y tile@ TILE_BLOCK_FLOOR 0 0 .tile_layer.off!
		<- x <- y tile@ TILE_BLOCK_FLOOR rnd5050 .tile_layer.flipx!
		<- y 1- -> y
	next
;

: trashblock tile@ tbwreck ;

		: .teammate? dup .character@ args( me chara ) <- me .charid@ 0= if 0 then;
		<- chara .team_status@ TEAM_STATUS_RECRUITED =
		;
		
		: .removegas dup .character@ args( me chara ) 
			-5 <- me .wielded-stack+
		;
		
		: .nogas dup .character@ args( me chara ) 
			<- me .wielded-stack 0 =
		;
		
		//				dup .wielded WEAPON_LIST_FUEL .is-weapon-type? if
		//		  1 swap dup .wielded-stack+ 



map{ roomgen{ 

: diningset
	table
	75 %chance if chair -1 movey drift then
	75 %chance if chair 1 movey drift then
	50 %chance if chair -1 movex drift then
	50 %chance if chair 1 movex drift then
;


} }
	
0 value gbx
0 value gby
0 value gbx2
0 value gby2

' plotpave >defer ft

: pt
	xyp.xy ft // Plot the current floor by default

	 xyp.i char b = if xyp.xy sycatilestreet3 then;
	 xyp.i char c = if xyp.xy sycatilestreet2 then;
	 xyp.i char d = if xyp.xy sycatilestreet then;
	 xyp.i char e = if xyp.xy sycatilestreet1 then;
	 xyp.i char g = if xyp.xy sycatilestreet4 then;
	 xyp.i char h = if xyp.xy sycatilestreet5 then;
	 xyp.i char j = if xyp.xy sycatilestreet6 then;
	 xyp.i char p = if xyp.xy sycatilestreet7 then;
	 xyp.i char i = if xyp.xy sycatilestreet8 then;
	 xyp.i char o = if xyp.xy sycatilestreet9 then;
	 xyp.i char O = if xyp.xy sycatilewall then;
	 xyp.i char E = if xyp.xy sycatilewalltop then;
	 xyp.i char D = if xyp.xy sycatilewalltopend then;
	 xyp.i char T = if xyp.xy trashblock xyp.xy sycatilestreet1 then;
	 xyp.i char t = if xyp.xy trashblock xyp.xy sycatilestreet then;
	 
	 xyp.i char C = if xyp.xy streetlamp lt-here then;
	 xyp.i char 5 = if xyp.xy streetlamp lt-here xyp.xy sycatilestreetblock then;
	 xyp.i char 8 = if xyp.xy sycatilestreetblock then;	 
	 xyp.i char J = if xyp.xy oldpine
	 
	 0.5 1 frnd lt .clr.r!
	 0.5 1 frnd lt .clr.b!
	 0.5 1 frnd lt .clr.g!
	
	 25 %chance if
	 0.75 1.4 frnd lt .scale.x!
	 0.74 1.5 frnd lt .scale.y!
	 then 
	 
	 lt-here xyp.xy sycatilestreet then;
	 
	 
 
	xyp.i char @ = if xyp.xy bldg2 xyp.xy sycatilestreet then;
	
	xyp.i char H = if xyp.xy sycatilesand then;
	xyp.i char A = if xyp.xy sycatilesandedge then;
	xyp.i char S = if xyp.xy sycatilesea then;
	xyp.i char ! = if xyp.xy sycatileseawalledge then;
	xyp.i char | = if xyp.xy sycatileseawallmain then;
	xyp.i char - = if xyp.xy sycatileseawallbot then;
	xyp.i char > = if xyp.xy sycatileseawallstairs then;
	xyp.i char q = if xyp.xy sycatileseawallbotdanger then;
	xyp.i char I = if xyp.xy sycatileseawallpier then;
	
	// decor
	xyp.i char F = if xyp.xy trashcan lt-here xyp.xy sycatilestreet then;
	xyp.i char 9 = if beachsign lt-here xyp.xy sycatilesand then;
	xyp.i char 1 = if xyp.xy roadsign1 lt-here xyp.xy sycatilestreet then;
	xyp.i char 2 = if xyp.xy roadsign2 lt-here xyp.xy sycatilestreet then;
	xyp.i char 4 = if xyp.xy diningset lt-here xyp.xy sycatilestreet then;
	xyp.i char 6 = if beachradio lt-here xyp.xy sycatilesand then;
	
	xyp.i char 7 = if carwreck lootable car-loot lt-here then;
	\ xyp.i char 3 = if new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here xyp.xy sycatilesea then;
	
	\ xyp.i char X = if specialshell lt-here xyp.xy sycatilesand then;
	
	xyp.i char Q = if 
	
		beachumbrella lt-here
		50 %chance if
			deckchair lt-here
		then
		66 %chance if 
			beachblanket lt-here
		then
		66 %chance if
			chair lt-here
		then
		25 %chance if
			1 2 rnd LOOT_FOOD spawnloot lt-here
		then
		33 %chance if 
			1 2 rnd LOOT_FOOD spawnloot lt-here
		then
		22 %chance if 
			shovel lt-here
		then 
		22 %chance if 
			snowshovel lt-here
		then
		
		xyp.xy sycatilesand
		
	then;
	
	
	
;

