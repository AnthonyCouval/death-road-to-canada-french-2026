: cellbarsphysical 
	spawn
	special_objects32_base_id 0x 60 + lt .spriteid!
	5000 5000 * lt .mass!
	5000 5000 * lt .hitpoints!
	1 lt .no_hit!
	1 lt .tileflags!
	8 lt .rad.x!
	2 lt .rad.y!
	
	-0.5 lt .vel.y!
	
