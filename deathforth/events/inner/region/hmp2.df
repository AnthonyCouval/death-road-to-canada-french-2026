// I'm not sure what happened to the other stuff above. Broken copy/paste from crackmesa I guess.
// And yeah, this location is a very loose cousin of crackmesa. Makes indoor locations from scratch so much easier.



: policecounter
		spawn special_objects32_base_id 0x 68 + lt .spriteid!
		25 health! bbox immovable as-wood dropswood
;	

: evidenceloot
	75 %chance if skelscat then
	20 %chance if nightstick .scatter then
	40 %chance if shiv .drift then
	1 5 rnd case
		1 of 90 %chance if snubnose .drift 12 LOOT_BULLET else autoshot .drift 15 LOOT_SHOTGUN_SHELL then spawnloot drift endof
		2 of 20 LOOT_SHOTGUN_SHELL spawnloot drift endof
		3 of 3 for pipebomb .drift next endof
		4 of otaku .drift endof
		5 of knucks .drift endof
	endcase
;
} }

location: prison
		max-rooms: 1
		entry-tags: prisonplaceB
		pre-script: set-theme-prison
		script: set-theme-prison
//		post-script: 
		post-script:
		
			room-choice: prisonplaceB
			room-weight: 10
			room-count: 1
			room-script: ndx nad
			room-post-script: 1 ' alarmcheck timer_add 10diff 2 * %zombs settingupeverythingdirector2 5 nightstick .scatter
			filter-only 


regiondef{


	: site-setup "PRISON MAP 2" print ;

	region: prison
		script: timeofday o'clock
		spooky-music
		site-setup

		inside

		loc-choice: prison
			loc-weight: 99
			loc-count: 1

		post-script: inspawn
}
