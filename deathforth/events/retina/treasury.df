: sycatile_bank_roof_R tile@ 
	dup LAYER_FINAL street_tiles_base_id 565 + .lspriteid!
	dup LAYER_FINAL 1 .tile_layer.flipx!

	TILE_BLOCK over .id!
	
	drop
;

: sycatile_bank_brickcolumn_L tile@ 
	dup LAYER_FINAL street_tiles_base_id 566 + .lspriteid!
	dup LAYER_FINAL 0 .tile_layer.flipx!

	TILE_BLOCK over .id!
	
	drop
;

: sycatile_bank_brickcolumn_R tile@ 
	dup LAYER_FINAL street_tiles_base_id 566 + .lspriteid!
	dup LAYER_FINAL 1 .tile_layer.flipx!

	TILE_BLOCK over .id!
	
	drop
;

: sycatile_bank_main_final tile@ 
	dup LAYER_FINAL street_tiles_base_id 563 + .lspriteid!
	dup LAYER_FINAL 0 1 rnd .tile_layer.flipx!

	TILE_BLOCK over .id!
	
	drop
;


map{ roomgen{ 

: diningset
	table
	75 %chance if chair -1 movey drift then
	75 %chance if chair 1 movey drift then
	50 %chance if chair -1 movex drift then
	50 %chance if chair 1 movex drift then
;

: plantbox 
		spawn 
		12 lt .hitpoints!
		3 lt .mass!
		100 lt .flammability! 
		special_objects32_base_id 198 + lt .spriteid! 
		0.2 lt .friction!
		0 1 rnd lt .flip! 
;

: teevee
	spawn
	special_objects16_base_id 67 + lt .spriteid!
	1 lt .layer! 
	\ 0 lt .friction!
	1 lt .walkover!
	3 lt .tileflags!
	1 lt .nocollide!
	300 lt .mass!
	-1.5 lt .vel.y!
	1 lt .vel.x! 
	
	couch 
	-2 lt .vel.x! 
	1 2 rnd for 
	meleeweapons next  
	lt .pos -4 4 rnd 0 xyadd lt .pos! 
;

: officecounter_bank
	\ more of a desk setup 
	spawn special_objects32_base_id 0x 15 0 1 rnd + + lt .spriteid! bbox as-metal
	
	chair 
	lt .pos 0 5 xyadd lt .pos! 
	
	filecabinet 
	lt .pos -5 0 xyadd lt .pos! 
	
	50 %chance if 
		skel
	then 
	
	10 %chance if 
		1 2 rnd LOOT_FOOD spawnloot
	then 
;

: officecounter
	spawn special_objects32_base_id 0x 4b + lt .spriteid!
	25 health! bbox immovable as-wood dropswood
;

0 value vault_combo 
0 value rotwheel_1
0 value rotwheel_2
0 value rotwheel_3
0 value rotwheel_4 

0 value vaultkey 

: open_vault args( me ) 
	vaultkey 0 > if 
		0 to vaultkey
		sfx{ goodfx } 
		<- me silentkillit
	else
		"Il me faut une cle pour ouvrir ca." interactee .yellmsg 
	then 
; 

: vd
	spawn 
	special_objects16_base_id 68 + lt .spriteid!
	bbox 
	30000 lt .mass!
	3 lt .tileflags!
	1.4 lt .scale.x! 
	1.4 lt .scale.y! 
	-0.4 lt .vel.y!
	' open_vault lt .cyoa! 
;

: bank_coin 
	spawn special_objects16_base_id 70 + spriteid! 2 health! bbox 3 mass! 5 lt .wallbox.x! 5 lt .wallbox.y!
; 

: coinpile
	3 5 rnd for 
		bank_coin
		-1.5 1.5 frnd 0.5 1.5 frnd lt .vel!  
	next
; 

: bloot1
	5 for 24 4 6 rnd spawnloot -3 lt .vel.x! 	lt .pos -8 -5 xyadd lt .pos!  next
; 

: bloot2
	5 for 2 LOOT_MEDICAL spawnloot -3 lt .vel.x!	lt .pos -8 -5 xyadd lt .pos!   next 
; 

: bloot3
	5 for 2 LOOT_FOOD spawnloot -3 lt .vel.x! 	lt .pos -8 -5 xyadd lt .pos!  next 
;



: v_loot 1 6 rnd case
	1 of hunting endof 
	2 of bloot1 endof 
	3 of bloot2 endof 
	4 of bloot3 endof 
	5 of uzi endof 
	6 of truekatana endof 
	endcase
; 

: obs spawn special_objects32_base_id 1 + lt .spriteid! 50 lt .hitpoints! bbox 50 lt .mass! ;

: compass_finder case 
	0 of "OUEST" endof 
	1 of "NORD" endof 
	2 of "EAST" endof 
	3 of "SOUTH" endof 
	endcase
; 

0 value combo_1 0 value combo_2 0 value combo_3 0 value combo_4

0 3 rnd to combo_1
0 3 rnd to combo_2
0 3 rnd to combo_3
0 3 rnd to combo_4

cyoa{
cyoa: combonote
	"Time Lock" cyoa-title!
	($ "This piece of paper has a series of directions on it. It's today's vault code!
	" .. pname .. " picks it up." $) cyoa-text! goodfx
	
	($ "Il affiche le code suivant :" $) +crtext 
	($ combo_1 compass_finder $) +crtext
	($ combo_2 compass_finder $) +crtext
	($ combo_3 compass_finder $) +crtext
	($ combo_4 compass_finder $) +crtext
	($ "Utilisez les 4 vannes pour entrer le code !" rbold $) +crtext 
;

} 

: wrotenote spawn special_objects16_base_id 23 + spriteid! 50 health! bbox 1 mass! walkover cyoa{ ' combonote } lt .cyoa! ;

: rot1 args( me ) 
	special_objects16_base_id 60 + rotwheel_1 4 % + <- me .spriteid!
	rotwheel_1 1 + to rotwheel_1
	rotwheel_1 4 % to rotwheel_1
	rotwheel_1 compass_finder <- me .report 
; 

: turnywheel_1 
	spawn 
	special_objects16_base_id 63 + lt .spriteid!
	1 lt .layer! 
	\ 0 lt .friction!
	1 lt .walkover!
	3 lt .tileflags!
	1 lt .nocollide!
	300 lt .mass!
	-1 lt .vel.y!
	' rot1 lt .cyoa! 
	0 to rotwheel_1
; 
	
: rot2 args( me ) 
	special_objects16_base_id 60 + rotwheel_2 4 % + <- me .spriteid!
	rotwheel_2 1 + to rotwheel_2
	rotwheel_2 4 % to rotwheel_2
	rotwheel_2 compass_finder <- me .report 
; 

