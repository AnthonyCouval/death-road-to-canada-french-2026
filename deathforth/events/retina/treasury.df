: reveal_me args( me )
	<- me .spriteid@ 2 + <- me .spriteid!
	2 LOOT_FOOD spawnloot 
	<- me .pos lt .pos!
	clear-cyoa
; 

: execdesk
	spawn special_objects32_base_id 0x 69 + lt .spriteid!
	bbox as-wood
;

: execdeskup
	spawn special_objects32_base_id 0x 5d + lt .spriteid!
	bbox as-wood
;

