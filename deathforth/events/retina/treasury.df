0 value gbx
0 value gby
0 value gbx2
0 value gby2

' plotpave >defer ft

: pt
	xyp.xy ft // Plot the current floor by default

	 xyp.i char b = if xyp.xy sycatilestreet3 then;
	 xyp.i char c = if xyp.xy sycatilestreet2 then;
	 xyp.i char d = if xyp.xy sycatilestreet then;
	 xyp.i char e = if xyp.xy sycatilestreet1 then;
	 xyp.i char g = if xyp.xy sycatilestreet4 then;
	 xyp.i char h = if xyp.xy sycatilestreet5 then;
	 xyp.i char j = if xyp.xy sycatilestreet6 then;
	 xyp.i char p = if xyp.xy sycatilestreet7 then;
	 xyp.i char i = if xyp.xy sycatilestreet8 then;
	 xyp.i char o = if xyp.xy sycatilestreet9 then;
	 
	 xyp.i char L = if xyp.xy streetlamp lt-here then;
	 xyp.i char U = if xyp.xy streetlamp lt-here xyp.xy sycatilestreetblock then;
	 xyp.i char 8 = if xyp.xy sycatilestreetblock then;	 
	 xyp.i char J = if xyp.xy oldpine
	 
	 0.5 1 frnd lt .clr.r!
	 0.5 1 frnd lt .clr.b!
	 0.5 1 frnd lt .clr.g!
	
	 25 %chance if
	 0.75 1.4 frnd lt .scale.x!
	 0.74 1.5 frnd lt .scale.y!
	 then 
	 
	 lt-here xyp.xy sycatilestreet then;
	 
	 
 
	xyp.i char @ = if xyp.xy bldg2 xyp.xy sycatilestreet then;
	
	xyp.i char A = if xyp.xy sycatile_stonewallmain then;
	xyp.i char > = if xyp.xy sycatile_dirtstairs_up then;
	
	\ dont use 5 or 8 
	
	xyp.i char 1 = if xyp.xy sycatile_bank_base_main then;
	xyp.i char 2 = if xyp.xy sycatile_bank_base_side_L then;
	xyp.i char 3 = if xyp.xy sycatile_bank_base_side_R then;
	xyp.i char 4 = if xyp.xy sycatile_bank_main then;
	xyp.i char 6 = if xyp.xy sycatile_bank_side_L then;
	xyp.i char 7 = if xyp.xy sycatile_bank_side_R then;
	xyp.i char 9 = if xyp.xy sycatile_bank_window then;
	xyp.i char O = if xyp.xy sycatile_bank_window_top_L then;
	xyp.i char 0 = if xyp.xy sycatile_bank_window_top_R then;
	
	xyp.i char R = if xyp.xy sycatile_bank_roof then;
	xyp.i char N = if xyp.xy sycatile_bank_roof_L then;
	xyp.i char M = if xyp.xy sycatile_bank_roof_R then;
	
	xyp.i char C = if xyp.xy sycatile_bank_brickcolumn_L then;
	xyp.i char E = if xyp.xy sycatile_bank_brickcolumn_R then;
	xyp.i char D = if xyp.xy sycatile_bank_main_final then;
	
	xyp.i char W = if carwreck lootable car-loot lt-here then;

	\ xyp.i char 3 = if new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here xyp.xy sycatilesea then;
	
	\ xyp.i char X = if specialshell lt-here xyp.xy sycatilesand then;
	
	
	
;

