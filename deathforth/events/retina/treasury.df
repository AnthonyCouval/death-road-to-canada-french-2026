constant maplayout

: plotmap
	0 -1 maplayout xyplot: pt
;


: site-setup

	' plotpave to ft

	plotmap
	
	11 o'clock
	\ 1 no_time!
	
	10 %zombs 
		
	33 %chars-up
	33 %mv-up
	
	map{ 1 water_colour_r! 1 water_colour_b! 1 water_colour_g! }
	
;

region: specialcamp-3
	w: maplayout layoutw
	h: maplayout layouth

	post-script: site-setup

} }
