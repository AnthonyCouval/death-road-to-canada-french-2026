: code_detector args( me eventid )
	
	<- eventid THING_EVENT_TIMER = if 
		1 <- me .timer! 
		
		combo_1 rotwheel_1 = if 
			combo_2 rotwheel_2 = if 
				combo_3 rotwheel_3 = if 
					combo_4 rotwheel_4 = if 
						<- me silentkillit
						sfx{ goodfx }  
					then
				then
			then
		then 
	then 
;
	
: lockdowndoor
		spawn special_objects32_base_id 211 + lt .spriteid!
		as-metal 4000 lt .hitpoints! 1 lt .tileflags! 40000 lt .mass! 1.3 lt .scale.x! 16 lt .rad.y! 1.5 lt .scale.y! 4 lt .rad.x!
		' code_detector lt .events!
		1 lt .timer! 

		-0.25 lt .vel.y!
;

: keys_bank args( me ) 
	1 to vaultkey 
	"I can open one vault with this." interactee .yellmsg 
	<- me silentkillit
; 

: goldkeybank spawn special_objects16_base_id 24 + spriteid! 50 lt .hitpoints! bbox 1 lt .mass! 1 lt .walkover! ' keys_bank lt .cyoa! ; 

