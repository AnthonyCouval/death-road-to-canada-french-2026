: siegesetup mission{ siege-start-dig } ;

: fauna_generator
	41 for 
		spawn 
		2 lt .hitpoints!
		1 lt .mass!
	\	1 lt .no_hit!
		1 lt .walkover!
		100 lt .flammability! 
		0.8 1 frnd lt .clr.r!
		0.8 1 frnd lt .clr.b!
		bbox 
		0.8 1 frnd lt .clr.g!
		0 map{ h } 16 * frnd lt .pos.y!
		0 map{ w } 16 * frnd lt .pos.x! 
		special_objects16_base_id 52 59 rnd + lt .spriteid! 
		10 lt .wallbox.x!
		10 lt .wallbox.y!
		\ 0 5 frnd lt .flies!
		0.1 lt .friction!
	next 
	
; 
		

: site-setup

	fauna_generator

	' plotdirt to ft

	marsh_gunner
	
	plotmap
	
	1 hunting .scatter 
	1 fosbury .scatter 
	1 steelpike .scatter 
	
	4 60 * ' dodig_marsh timer_add 
	
	\ 11 o'clock
	\ 1 no_time!
	
	\ \ 5 shovel .scatter
	\ 5 tire .scatter 
	
	\ skel .scatter
	
	66 %chance if 
		1 weather! 
	then 
	
	1.5 2.2 frnd wind_force! 

	10diff mil-zombsplit 
		
	\ 33 %chars-up
	\ 75 %mv-up
	
	4 region.zombie_alertscale! 
	
	map{ 0.1 water_colour_r! 0.2 water_colour_b! 0.5 water_colour_g! }

	
	
;

region: specialcamp-3
	w: maplayout layoutw
	h: maplayout layouth
	on-foot no-rest
	post-script: site-setup
	script: timeofday o'clock

} }
