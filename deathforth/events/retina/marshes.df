0 value gbx
0 value gby
0 value gbx2
0 value gby2

' plotpave >defer ft

: pt
	xyp.xy ft // Plot the current floor by default

	 xyp.i char b = if xyp.xy sycatilestreet3 then;
	 xyp.i char c = if xyp.xy sycatilestreet2 then;
	 xyp.i char d = if xyp.xy sycatilestreet then;
	 xyp.i char e = if xyp.xy sycatilestreet1 then;
	 xyp.i char g = if xyp.xy sycatilestreet4 then;
	 xyp.i char h = if xyp.xy sycatilestreet5 then;
	 xyp.i char j = if xyp.xy sycatilestreet6 then;
	 xyp.i char p = if xyp.xy sycatilestreet7 then;
	\  xyp.i char i = if xyp.xy sycatilestreet8 then;
	 xyp.i char o = if xyp.xy sycatilestreet9 then;
	 xyp.i char O = if xyp.xy sycatilewall then;
	 xyp.i char E = if xyp.xy sycatilewalltop then;
	 xyp.i char D = if xyp.xy sycatilewalltopend then;
	\ xyp.i char T = if xyp.xy trashblock xyp.xy sycatilestreet1 then;
	 xyp.i char t = if xyp.xy shitbox lt-here then;
	 
	 xyp.i char C = if xyp.xy streetlamp lt-here then;
	 \ xyp.i char 5 = if xyp.xy streetlamp lt-here xyp.xy sycatilestreetblock then;
	 xyp.i char 8 = if xyp.xy sycatilestreetblock then;	 
	 xyp.i char J = if xyp.xy marshtree
	
	 25 %chance if
	 0.75 1.4 frnd lt .scale.x!
	 0.74 1.5 frnd lt .scale.y!
	 then 
	 
	 lt-here xyp.xy sycatilegrassset then;
	 
	 
 
	\ xyp.i char @ = if xyp.xy bldg2 xyp.xy sycatilestreet then;
	 xyp.i char @ = if xyp.xy skel 50 %chance if 50 %chance if shovel else tire then then lt-here then;
	
	xyp.i char H = if xyp.xy sycatilegrassset map{ pine } lt-here  then;
	xyp.i char A = if xyp.xy sycatilesandedge then;
	xyp.i char S = if xyp.xy sycatilesea then;
	xyp.i char ! = if xyp.xy sycatileseawalledge then;
	xyp.i char Q = if xyp.xy sycatileseawallmain then;
	xyp.i char - = if xyp.xy sycatileseawallbot then;
	xyp.i char > = if xyp.xy sycatileseawallstairs then;
	xyp.i char i = if xyp.xy sycatile_dirtstairs_up then;
	xyp.i char I = if xyp.xy sycatile_dirtstairs_up then;
	
	xyp.i char B = if xyp.xy 24 spawncar cyoa{ ' cyoa-locked-carboat } lt .cyoa! lt to the_carboat 	4 lt .rad.z! 32 lt .rad.x! 4 lt .rad.y! lt-here then;
	
	xyp.i char Z = if xyp.xy tanchor! 12 zombs-clump then;
	xyp.i char z = if xyp.xy sycatilegrassset xyp.xy tanchor! 12 zombs-clump then;
	
	xyp.i char K = if xyp.xy sycatilegrassset key_spawner lt-here then;
	
	// decor
	xyp.i char F = if xyp.xy cliff then;
	xyp.i char f = if xyp.xy sycatilecliffnorth then;
	xyp.i char 9 = if xyp.xy sycatilegrassset then;
	xyp.i char 6 = if xyp.xy marshreed lt-here then;
	xyp.i char 7 = if xyp.xy sycatilegrassset marshreed lt-here then;
	xyp.i char 5 = if xyp.xy sycatilegrassset chair lt-here chair lt-here 50 %chance if table then lt-here 4 LOOT_FOOD spawnloot lt-here then;
	
	xyp.i char 1 = if xyp.xy sycatilesea marshpond lt-here then;
	
	xyp.i char 3 = if xyp.xy sycatile_cliffedge_eastwest then;
	
	xyp.i char 4 = if xyp.xy sycatilegrassset xyp.xy sycatile_cliffedge_bottom then;
	
	xyp.i char 7 = if carwreck lootable car-loot lt-here then;
	\ xyp.i char 3 = if new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here new-npc lt .character@ .seagullify lt-here xyp.xy sycatilesea then;
	
	\ xyp.i char X = if specialshell lt-here xyp.xy sycatilesand then;
	
	
	
	
;

