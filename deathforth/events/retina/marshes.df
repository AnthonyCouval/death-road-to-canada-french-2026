: sycatile_dirtstairs_up tile@ 
	dup LAYER_FLOORTOP street_tiles_base_id 552 + .lspriteid!
	dup LAYER_FLOORTOP 0 0 .tile_layer.off!
	dup LAYER_FLOORTOP 0 .tile_layer.flipx!
	
	drop
;

: sycatile_dirtstairs_down tile@ \ actually looked better as the up sprite than the down one lol 
	dup LAYER_FLOORTOP street_tiles_base_id 552 + .lspriteid!
	dup LAYER_FLOORTOP 0 0 .tile_layer.off!
	dup LAYER_FLOORTOP 0 .tile_layer.flipx!
	
	drop
;

: marshtree spawn
	trees_base_id 2 5 * + 0 4 rnd + lt .spriteid! treeify
;

: marshpond
		spawn 
		200 lt .hitpoints!
		400 lt .mass!
		1 lt .no_hit!
		1 lt .walkover!
		0 lt .flammability! 
		special_objects32_base_id 214 + lt .spriteid! 
		10 lt .wallbox.x!
		10 lt .wallbox.y!
		\ 0 5 frnd lt .flies!
		0 lt .friction!
		2 lt .layer!
; 


: marshreed
		spawn 
		200 lt .hitpoints!
		400 lt .mass!
		3 lt .tileflags!
		1 lt .no_hit!
		1 lt .walkover!
		0 lt .flammability! 
		special_objects32_base_id 215 + lt .spriteid! 
		1 lt .nocollide!
		0 1 rnd lt .flip!
		0.9 1.1 frnd dup lt .scale.x! lt .scale.y! 
		\ 0 5 frnd lt .flies!
		0 lt .friction!
		\ -2 lt .layer!
		
; 

0 value digstart
0 value digend

: dodig_marsh

	player not if then;  
	
	player .pos xyzombdig

	timer_retrigger
;

0 value key_r
0 value key_b
0 value key_y
0 value key_g

: key_b_pickup args( me ) 
	1 to key_b
	clear-cyoa
	BLUE "Blue Key Get!" .. <- me .report 
	<- me silentkillit
;

: key_g_pickup args( me ) 
	1 to key_g
	clear-cyoa
	GREEN "Green Key Get!" .. <- me .report 
	<- me silentkillit
;

: key_r_pickup args( me ) 
	1 to key_r
	clear-cyoa
	RED "Red Key Get!" .. <- me .report 
	<- me silentkillit
;

: key_y_pickup args( me ) 
	1 to key_y
	clear-cyoa
	YELLOW "Yellow Key Get!" .. <- me .report 
	<- me silentkillit
;

: carboat_key_r
	 spawn special_objects16_base_id 24 + spriteid! 
	 50 lt .hitpoints! 
	 bbox 
	 1 lt .mass! 
	 1 lt .walkover! 
	 0 lt .clr.b! 0 lt .clr.g! 
	 ' key_r_pickup lt .cyoa! 
;

: carboat_key_b
	 spawn special_objects16_base_id 24 + spriteid! 
	 50 lt .hitpoints! 
	 bbox 
	 1 lt .mass! 
	 1 lt .walkover! 
	 0 lt .clr.r! 0.5 lt .clr.g! 
	 ' key_b_pickup lt .cyoa! 
;

: carboat_key_g
	 spawn special_objects16_base_id 24 + spriteid! 
	 50 lt .hitpoints! 
	 bbox 
	 1 lt .mass! 
	 1 lt .walkover! 
	 0 lt .clr.b! 0 lt .clr.r! 
	 ' key_g_pickup lt .cyoa! 
;

: carboat_key_y
	 spawn special_objects16_base_id 24 + spriteid! 
	 50 lt .hitpoints! 
	 bbox 
	 1 lt .mass! 
	 1 lt .walkover! 
	 ' key_y_pickup lt .cyoa! 
;

: shitbox 
		spawn 
		25 lt .hitpoints!
		6 lt .mass!
		100 lt .flammability! 
		special_objects32_base_id 199 + lt .spriteid! 
		\ 0 1 rnd lt .flip!
		0.2 lt .friction!
;		
		
\ todo:
\ outhouses 
\ carboat 
\ key puzzle 
\ viaduct shadows
\ events to access locs 


0 stack 
	1 shove 
	2 shove 
	3 shove 
	4 shove 
var KEY_SPAWNS 


: key_case_marsh case 
	1 of carboat_key_b endof 
	2 of carboat_key_g endof 
	3 of carboat_key_r endof 
	4 of carboat_key_y endof
	endcase 
; 
	
: key_spawner 

	KEY_SPAWNS shuffles pops \ randomise key spawning order 
		 
		dup 
		" SPAWNED KEY #" .. print 
		 
		key_case_marsh
		
;		

: sycatilecliffnorth tile@ 
	dup LAYER_FLOORTOP street_tiles_base_id 553 554 rnd + .lspriteid!
	\ dup LAYER_FLOOR 16 0 .tile_layer.off!
	dup LAYER_FLOORTOP 1 .tile_layer.flipx!
	
	dup LAYER_FLOOR street_tiles_base_id 0x a9 + 0 3 rnd + .lspriteid!

	TILE_BLOCK over .id!
	
	drop
;

0 value the_carboat 

cyoa{ 

cyoa: cyoa-locked-carboat 

	key_b 0 > key_g 0 > key_r 0 > key_y 0 > and and and if
	"C'EST L'HEURE" cyoa-title!
		($ "Avec les quatre cles en place, la voiture prend vie." $) cyoa-text!
		($ RED "IGNITION ON" .. $) +crtext
		($ BLUE "TURRET READY" .. $) +crtext
		($ GREEN "POWER FLOW OK" .. $) +crtext
		($ YELLOW "AMMO FEED OK" .. $) +crtext
			goodfx
			choice( "Monter dans la voiture" )choice: get-into-car
			choice( "Laisser pour l'instant" )choice
			interactee .car-cyoa-default
	else
	"Carboat Verrouille" cyoa-title!
		"Ce carboat a l'air en tres bon etat.
		A l'interieur, il semble y avoir 4 types de cles, etiquetees :" cyoa-text!
		($ RED "IGNITION: " .. $) key_r 0 > if WHITE "TROUVE !" .. else WHITE "MANQUANT..." .. then .. +crtext
		($ BLUE "TURRET: " .. $) key_b 0 > if WHITE "TROUVE !" .. else WHITE "MANQUANT..." .. then .. +crtext
		($ GREEN "POWER: " .. $) key_g 0 > if WHITE "TROUVE !" .. else WHITE "MANQUANT..." .. then .. +crtext
		($ YELLOW "AMMO FEED: " .. $) key_y 0 > if WHITE "TROUVE !" .. else WHITE "MANQUANT..." .. then .. +crtext
		choice( "Laisser pour l'instant" )choice
		1 to TURRET_ACTIVE
	then

;
}


: carboat_gunner args( me teid )

	1 <- me .timer!
	
	<- teid THING_EVENT_TIMER = if
		the_carboat if
		
			TURRET_ACTIVE 0 = if 
				2 <- me .stun! 
				0 <- me .clr.a! 
			else 
			
			1 <- me .clr.a! 
		
			6 <- me .character@ .health!
			"" <- me .report
			the_carboat .pos.x@ 36 + <- me .pos.x!
			the_carboat .pos.y@ <- me .pos.y!
			the_carboat .pos.z@ <- me .pos.z!
			<- me .pos.y@ -17 + <- me .pos.y!
			
			<- me .targetid@ 0 = if 
					90 <- me .move_angle!
				then	
			
			then 
		then
	then
	
	<- teid THING_EVENT_BREAK <> if
			mission.vehicle@ not if
				2 <- me .stun! 
				0 <- me .clr.a! 
			then
		then
	
;

: marsh_gunner
		\ 4 mission.vehicle@ .rad.z!
		\ 32 mission.vehicle@ .rad.x!
		\ 4 mission.vehicle@ .rad.y!

		new-npc
		
		3 lt .walkover!
		-3 lt .layer!
		1 lt .character@ .carrying.slot_count!
		WEAPON_CARBOATCANNON lt .character@ .weapona!
		1 lt .unseen!
		\ 1 lt .invisible
		1 lt .timer!
		1 lt .nocollide!
		3 lt .tileflags!
		
		1 lt .character@ .default-ai-setup
		1 lt .character@ .party! // defend the leader
		-1 lt .character@ .ai.attack_level!
		1 lt .character@ .ai.attack_chance!
		300 lt .character@ .ai.attack_dist!
		
		lt immovable
		\ 144 lt .character@ .specialtype!
		0 lt .character@ .scale.head.x!
		0 lt .character@ .scale.body.x!
		lt ' carboat_gunner swap .events!
		300 LOOT_RIFLE_SHELL lt .character@ .lootamt!
; 

 

