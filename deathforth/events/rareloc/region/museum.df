// "../deathforth/events/rareloc/weird.txt" $load-rooms
"../deathforth/rooms/bigoffice.txt" $add-rooms
"../deathforth/rooms/restroom.txt" $add-rooms
"events/inner/officeloc.df" $load

roomgen{ 

: provide_light_ceil args( me eventid ) 
	<- eventid THING_EVENT_TIMER = if 
		1 1 1 45 <- me .pos d-light
		1 <- me .timer!
	then 
	
	
; 

: chandelier spawnflip special_objects32_base_id 0x a7 + lt .spriteid! bcircle 12 lt .rad.x! 50 health! 1 lt .walkover! 1 lt .nocollide! 1 lt .no_hit! 50 lt .mass! ' provide_light_ceil lt .events! 
1 lt .timer! -20 lt .pos.z! -1 lt .layer! 0 lt .gravity! ;

\ tried this, looked like ass. You can put it back if you like it 


: mansionstatue spawnflip special_objects32_base_id 0x a4 + 0 2 rnd + lt .spriteid! 
	bcircle 9 lt .rad.x! 6weight as-metal 12 health! 
;

} 

