"
value MUSEUMROOMS
MUSEUMROOMS $parse-rooms

\ "spawned loot?" 
0 value spnloot

		: museumloot
			museumtype case
				0 of 6 8 rnd for otaku .scatter next truekatana .drift endof
				1 of
					minigun .drift 
					2 for shotgun .scatter huntcowboy .scatter pistol .scatter next
					dolt .scatter snubnose .scatter 
				endof
				2 of 2 for gauntlet .scatter next 8 10 rnd for hatchet .scatter next medieval .drift endof
				3 of 16 22 rnd sfood endof
			endcase
			1 to spnloot
		;

locdef{

0 value muspri 
3 value museumcountdown

\ STOMACH : ROOMGEN FORCE SCRIPT FOR PRIZE ROOM 
\ "force museum rooms" 
: fmr  

	\ As far as I'm aware, in faulty generations, it will generate 6 rooms. I've not seen it generate less than 6. 
	\ READERS : Please bring to my attention any cases in which 6 rooms did NOT generate.  
	
	\ Rolled bathroom first, then proceeded as normal 
	\ start -> bathroom -> hall -> hall -> longue -> hall 
	rooms-created 6 = doors-unopened 0 = and if 
		\ sfx{ growl } 
		
		4 for 
			muspri 0 = if 
				i 1 - edge-inc i 1 - edge-door "museumprize" only-with-door
				\ sfx{ goodfx 3 scale! } 
				1 to muspri
			then 	
		next 
	then 
	
	\ Rolled hall first, then ignored bathroom 
		museumcountdown 0 = doors-unopened 1 = and if 
		\ start -> hall -> hall -> lounge -> hall  
		\ sfx{ growl } 
		4 for 
			muspri 0 = if 
				i 1 - edge-inc i 1 - edge-door "museumprize" only-with-door
			\ 	sfx{ goodfx 3 scale! } 
				1 to muspri
			then 	
		next 
	then 
; 

\ force museum treasure 
: fmt 
	spnloot 0 = if 
		museumloot
		"MUSEUM LOOT SPAWNED VIA SCRIPT!" print 
	then 
; 

location: museum
		max-rooms: 7
		entry-tags: officstart
		script: set-theme-museum
		pre-script: set-theme-museum
		post-script: 10diff %zombs nad fmr
				
		: museumdown
			' museumcountdown --
			museumcountdown 1 < if
				2 for random-door "museumprize" only-with-door next				
			then;
			random-door "museumhall" only-with-door
			museumcountdown 2 < if
				random-door "emplounge" only-with-door
			then;
		;
		
		: museumstart
			random-door "restroom" only-with-door
			random-door "museumhall" only-with-door
		;
		
		room-choice: officstart
			room-weight: 1
			room-count: 1
			room-post-script: museumstart
			filter-only

		room-choice: emplounge
			room-weight: 10
			room-count: 1
			room-post-script: officefood
			filter-only
			
		room-choice: museumhall
			room-weight: 10
			room-count: 3
			room-post-script: museumdown
			filter-only
			
		room-choice: museumprize
			room-weight: 10
			room-count: 1
			room-post-script: 1 to muspri fmt
			filter-only

		room-choice: restroom
			room-weight: 10
			room-count: 1
			room-script: floor-bath
			filter-only
					
}		

regiondef{			

	region: museum
		script: timeofday o'clock

		inside
					
		loc-choice: museum
			loc-weight: 99
			loc-count: 1

		post-script: 5diff %zombs inspawn
}