dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd"
constant maplayout

: plotmap
	0 -1 maplayout xyplot: pt
;





: keep-colour
	1 weather!
	1 wind_force!

	0 0.3 1 tint_near!
	0 0.3 1 tint_far!
	1 light_mode!
	60 tint_trigger

		0 clr_near_set_r!
		0 clr_near_tile_r!
		0 clr_near_thing_r!

		// 0 clr_near_set_b!
		// 0 clr_near_tile_b!
		// 0 clr_near_thing_b!

		// 0 clr_near_set_g!
		// 0 clr_near_tile_g!
		// 0 clr_near_thing_g!

		timer_retrigger


		generatorpowered 1 = if
		leveron 1 = if

		player 0 = if then;
		player .mapid@ 4 = if
		105 gloom_lighting!
		0 light_mode!

		then
		then
		then;

		generatorpowered 0 = if
		leveron 0 = if

		player 0 = if then;
		player .mapid@ 4 = if
		0.1 gloom_lighting!

		then
		then
		then

;


\ This took 4 hours to figure out. 4 hours!!!!!!!
\ And it's the world's dumbest fix!!!!
\ And it was all so we can have doors that don't glisten!!!!
\ I hope you are happy basement skeleton xDDDDD

: blockeverything
	map{ posx0 16 * posy0 16 * swap pos>tile blocked }
	map{ posx1 16 * posy1 16 * swap pos>tile blocked }
	map{ posx2 16 * posy2 16 * swap pos>tile blocked }
	map{ posx3 16 * posy3 16 * swap pos>tile blocked }
;

: site-setup

	' plotpave to ft

	plotmap

	7 o'clock
	1 no_time!

	1 ' keep-colour timer_add

	// Put char and chars in middle of map
	54 %mv-up 33 %chars-up

	10diff %zombs

	map{ street-junk }

	losthope-music

	3 ' blockeverything timer_add
;

region: specialcamp-3
	w: maplayout layoutw
	h: maplayout layouth

	post-script: site-setup

} }
