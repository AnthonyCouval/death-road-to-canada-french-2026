uses paul/region-layout.df

"../deathforth/events/rareloc/region/arkswaresrooms.txt" $load-rooms
"../deathforth/events/rareloc/region/arkswaresrooms.txt" $add-rooms

uses paul/region-layout.df

locdef{

: tradermallsetup random-door map{ block-last-door } ;


location: nuclearstation
		max-rooms: 1
		entry-tags: mesa2
		pre-script: set-theme-bookstore
		script: set-theme-bookstore
		post-script:

		: control
			n random-edge-door "xboxroom" only-with-door
		;

		: controlcore
			e random-edge-door "core" only-with-door
		;

		: lotsajunk
			30 for
				meleeweapons .scatter
			next
		;

		room-choice: mesa2
			room-weight: 10
			room-count: 1
			room-script: ndx
			room-post-script: lotsajunk
			filter-only


}



map{ roomgen{


	: electricbar
	spawn special_objects48_base_id 98 + lt .spriteid!
	bbox 6 lt .rad.x!
	bbox 6 lt .rad.y!
	immovable as-metal
	150 health! 0 lt .friction!
	;

	: cellsink
	spawn special_objects32_base_id 0x 6b + lt .spriteid! bbox
	25 health! immovable as-metal
	;

	: cellcombine
	spawn special_objects32_base_id 0x 6c + lt .spriteid! bbox
	25 health! immovable as-metal
	;

	: cellbench
	spawn special_objects32_base_id 0x 6d + lt .spriteid! bbox
	25 health! immovable as-metal
	;

	: celltoilet
	spawn special_objects32_base_id 0x 6e + lt .spriteid! bbox
	25 health! immovable as-metal
	;

	: toiletsetup

	celltoilet cellsink

	25 for
		box
		4 lt .mapid!
		379 385 frnd lt .pos.x!
		75 85 frnd lt .pos.y!
	next

	;

	: nuclearloot
	1 5 rnd case
		1 of 2 LOOT_MEDICAL spawnloot drift endof
		2 of 3 LOOT_FOOD spawnloot drift endof
		3 of 10 LOOT_GAS spawnloot drift endof
		4 of 1 LOOT_FOOD spawnloot drift endof
		5 of 2 LOOT_MEDICAL spawnloot drift endof
	endcase
	;

	: pylonloot
	1 5 rnd case
		1 of 5 LOOT_GAS spawnloot drift endof
		2 of 10 LOOT_GAS spawnloot drift endof
		3 of 20 LOOT_GAS spawnloot drift endof
		4 of 40 LOOT_GAS spawnloot drift endof
		5 of 80 LOOT_GAS spawnloot drift endof
	endcase
	;

	: mechanicloot
		1 2 rnd case
		1 of wrench .drift endof
		2 of metal .drift endof
	endcase
	;


cyoa{

cyoa: wirecharge
	"Wireless Recharging!" cyoa-title!
	picon!
	($ cname .. " watches the generator spin and whurr and he flicks a lever to bring it to life. Suddenly, their phone lights up! The electric field is so strong,
	you might even get to CHARGE SOME WEAPONS." $) text!
	choice( "NICE" )choice
;

cyoa: an-alde-time
	"Strange Note" cyoa-title!
	picon!
	($ cname .. " reads the random page they found on the floor. It looks like it was ripped straight out of a journal.
	THEY'RE COMING, it says, the writing scrawly and panicked. SEND HELP is appended at the bottom. What could it mean?" $) text!
	choice( "What have we got ourselves into?" )choice
;

cyoa: an-alde-door
	"Powered Door" cyoa-title!
	picon!
	($ cname .. " comes across a powered metal door. There's no way it'll budge without electricity. Maybe there's a way to power it?
	Is it even worth powering? The growls the other side of the door are most discouraging." $) text!
	choice( "WELP" )choice
;

cyoa: an-alde-gate
	"Locked Gate" cyoa-title!
	picon!
	($ cname .. " voit un generateur derriere la grille. Vous pouvez detruire la grille en l'attaquant avec your weapons!" $) text!
	choice( "DANGNAMIT" )choice
;

}


	: .is-weapon-type?
		depths for
			pops 2 pick = if -1 break then
			i 1 = if 0 then
		next
		-rot 2drop
	;


	: .zombie? .typeid@ THING_ZOMBIE = ;

	: .teammate? dup .character@ args( me chara ) <- me .charid@ 0= if 0 then;
		<- chara .team_status@ TEAM_STATUS_RECRUITED =
	;






} }


map{ regiondef{

trade-camp-reset

: sycatile tile@
	dup LAYER_FLOOR inside_tiles_walls_id 3 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!

	dup LAYER_FLOORTOP inside_tiles_walltops_id 10 + .lspriteid!

	// 10 for regular walltop
	// 9 for right-hand up turn
	// 8 for right-hand end
	// 7 for left-facing-junction
	// 6 for downfacing left turn
	// 5 for straight up
	// 4 for upward end
	// 3 for upward left turn
	// 2 for lefthand end
	// 1 for downward end
	// 0 for tiny square

	dup LAYER_FLOORTOP 0 -16 .tile_layer.off!
	dup LAYER_FLOORTOP 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatileblock tile@

	TILE_BLOCK_FLOOR over .id!
	drop
;

