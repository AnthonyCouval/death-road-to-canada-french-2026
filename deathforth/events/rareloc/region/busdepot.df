uses paul/region-layout.df
uses paul/region-road-layout.df


"events/inner/baseapts.df" $load

"../deathforth/events/rareloc/region/bus-rooms.txt" $load-rooms
"../deathforth/events/rareloc/region/bus-rooms.txt" $add-rooms

locdef{

: tradermallsetup random-door map{ block-last-door } ;	

location: bus-station
		max-rooms: 3
		entry-tags: busstart
		pre-script: set-theme-bunker
		script: set-theme-bunker
		post-script: 
		
		 : controlgarage
		 	e random-edge-door "outgarage" only-with-door
		 ;
		
		 : controlbathroom
		 	n random-edge-door "restroom" only-with-door
		 ;
		
		room-choice: busstart
			room-weight: 10
			room-count: 1
			room-script: ndx 
			room-post-script: controlbathroom controlgarage
			filter-only
		
		room-choice: restroom
			room-weight: 10
			room-count: 1
			room-script: ndx 
			room-post-script:
			filter-only
			
		room-choice: outgarage
			room-weight: 10
			room-count: 1
			room-script: ndx 
			room-post-script:
			filter-only
			
}



map{ roomgen{

	: nuclearloot
	1 5 rnd case
		1 of 2 LOOT_MEDICAL spawnloot drift endof
		2 of 3 LOOT_FOOD spawnloot drift endof
		3 of 10 LOOT_GAS spawnloot drift endof
		4 of 1 LOOT_FOOD spawnloot drift endof
		5 of 2 LOOT_MEDICAL spawnloot drift endof
	endcase
	;
	
	: pylonloot
	1 5 rnd case
		1 of 5 LOOT_GAS spawnloot drift endof
		2 of 10 LOOT_GAS spawnloot drift endof
		3 of 20 LOOT_GAS spawnloot drift endof
		4 of 40 LOOT_GAS spawnloot drift endof
		5 of 80 LOOT_GAS spawnloot drift endof
	endcase
	;
	
	: generatorbus
	spawn special_objects64_base_id 6 + lt .spriteid!
	bbox 6 lt .rad.x!
	bbox 6 lt .rad.y!
	immovable as-wood
	;
	
	
	: rustingbus 
	spawn car_wrecks_base_id 17 + lt .spriteid! lt-as-wreck
	0 lt .cyoa!
	lt .rusty
	50 %chance if
		100 lt .flammability! 1 lt .burning!
	then
	
	3000 lt .hitpoints!
	;
	
	: buskeys keychain 0 lt .clr.r! mission{ cyoa{ ' carkeyz cyoa! } } delete-covering ;
	
	
} }


map{ regiondef{


: bldg3 tanchor!
	// "tradermall" $picklocid addloc 
	 "bus-station" $picklocid addloc 
				prefab{
		WHITE "DINK DEPOT OFFICE" .. sign-text!
		0 0 0 sign-bg!
		0 0 0 sign-border!
		0 0 0 sign-fg!
		1 sign-glow!
		0 3 rnd 15 4 shop }
	
;

: postify
	lt .sprh 2 / 8 - lt .anim.off.y!
	4 lt .rad.x!
;

: treeify
	immovable 100 %flammability!

	postify

	// Specifically for colliding with tiles, overrides other methods
	24 lt .wallbox.x!
	24 lt .wallbox.y!

	rnd5050 lt .flip!
	1 lt .wind!
	0.5 1 frnd lt .clr.r!
	0.5 1 frnd lt .clr.b!
	0.5 1 frnd lt .clr.g!
;


: tree spawn
	trees_base_id road_theme@ 5 * + 0 4 rnd + lt .spriteid! treeify
//	1 lt .no_hit! 
;

: streetlight-flicker args( me eventid )	
	<- eventid THING_EVENT_TIMER = if
			1 <- me .timer!		
			
		gameticks 200 360 frnd % if			
			1 1 0.4 150 <- me .pos d-light
				else
				30 <- me .timer!
				then
			then
	
;


\ : streetlamp spawn special_objects96_base_id 4 + lt .spriteid! 4000 lt .mass! 40 lt .hitpoints! 20 lt .timer! ' streetlight-flicker lt .events! -1 lt .layer! 54 lt .rad.y! 6 lt .rad.x! 1 lt .walkover! 1 lt .tileflags! -4 lt .vel.y! -1 lt .vel.x! 1 lt .nocollide! ;


: somepine spawn special_objects48_base_id 2 + lt .spriteid! treeify 0 475 rnd lt .pos.x! 0 250 rnd lt .pos.y! ;


	: assgas
	spawn special_objects64_base_id 21 + lt .spriteid!
	20 lt .rad.x! 
	6 lt .rad.y!
	immovable as-cloth
	2000 health! 0 lt .friction! 
	40 50 rnd pumpgas
	;


: sycatile tile@
	dup LAYER_FLOOR inside_tiles_walls_id 3 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!
	
	dup LAYER_FLOORTOP inside_tiles_walltops_id 10 + .lspriteid!
	
	// 10 for regular walltop
	// 9 for right-hand up turn
	// 8 for right-hand end
	// 7 for left-facing-junction
	// 6 for downfacing left turn
	// 5 for straight up
	// 4 for upward end
	// 3 for upward left turn
	// 2 for lefthand end
	// 1 for downward end
	// 0 for tiny square
	
	dup LAYER_FLOORTOP 0 -16 .tile_layer.off!
	dup LAYER_FLOORTOP 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatileblock tile@

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatilewall tile@
	dup LAYER_FLOOR inside_tiles_walls_id 198 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatilewalltop tile@
	dup LAYER_FLOOR inside_tiles_walls_id 12 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatilewalltopend tile@
	dup LAYER_FLOOR inside_tiles_walls_id 12 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!

	TILE_BLOCK_FLOOR over .id!
	drop
;

: sycatilestreet tile@ // main
	dup LAYER_FLOOR street_tiles_base_id 17 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!


	drop
;

: sycatilestreet1 tile@ // side
	dup LAYER_FLOOR street_tiles_base_id 33 + .lspriteid!
	dup LAYER_FLOOR 0 0 .tile_layer.off!
	dup LAYER_FLOOR 0 .tile_layer.flipx!


	drop
;

: sycatilestreet2 tile@ // corner
