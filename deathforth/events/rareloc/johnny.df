
cyoa{
cyoa-bridge: johnny-recruit
	cchar to recruitee
	"Nouveau Combat" cyoa-title! ricon goodfx
	"Bien sur, j'aime trainer avec des TOCARDS. Voyons jusqu'ou on peut aller !" pbold cyoa-text! clear-cyoa
	0.25 cchar .ai.wander_chance! 0 nearest .unseen!
	2 cchar .morale!
	team-full? if
		"Virer quelqu'un du groupe :" +crtext recruit-replace? // ' recruit-replace? cyoa-team-choice
	else
		recruited
	then
;

cyoa: johnny-talk
	interactee .character@ choosechar cicon
	"Gars de l'Armee" cyoa-title!
	"... Qu'est-ce que TU REGARDES comme ca, hein ?" pbold cyoa-text!
	choice( "Le laisser tranquille" )choice
	choice( "Essayer de le recruter" )choice: johnny-recruit
;
}

