" $parse-rooms

map{ roomgen{

: spawn-johnny
	new-npc@ 0 over .ai.wander_chance! .johnnyfy
	cyoa{ ' johnny-talk cyoa! }
;

: johnny-furniture
	bed 50 movey
	officedesk -1 movey
	officechair
;
: johnny-table
	chair -1 movex 1.5 movey
	table 1.5 movey
	toilet -2 movey 0 lt .flies!
;
: johnnystart-script s edge-inc s random-edge-door "johnnystairs" only-with-door ;
: johnnystairs-script s edge-inc s random-edge-door "johnnyend" only-with-door ;

locdef{
location: johnny-house
	max-rooms: 3
	entry-tags: johnnystart
	script: set-theme-bunker 
	pre-script: set-theme-bunker
	post-script: nad
	
	room-choice: johnnystart
		room-weight: 300
		room-count: 1
		room-script:
		room-post-script: johnnystart-script
		filter-only
	
	room-choice: johnnystairs
		room-weight: 300
		room-count: 1
		room-script: gcloset-theme
		room-post-script: johnnystairs-script
		filter-only
	
	room-choice: johnnyend
		room-weight: 300
		room-count: 1
		room-script: gcloset-theme
		room-post-script:
		filter-only
} } }